---
import '@fontsource-variable/inter/index.css';
import '@/styles/senavia.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Seo from '@/components/Seo.astro';
import JsonLd from '@/components/JsonLd.astro';
import { CALENDLY_URL } from '@/data/site';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLdType?: 'home' | 'about' | 'service' | 'portfolio' | 'blog' | 'localbusiness' | 'pricing';
  jsonLdData?: Record<string, unknown>;
  noindex?: boolean;
  bodyClass?: string;
  screenLabel?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  jsonLdType = 'home',
  jsonLdData = {},
  noindex = false,
  bodyClass = '',
  screenLabel,
} = Astro.props;

// Absolute URL for hreflang. The site serves both languages from one URL via a
// client-side toggle, so we emit a single absolute x-default (per-language
// hreflang pointing at the same URL is contradictory and errors in Search Console).
const canonicalPath = canonical ?? Astro.url.pathname;
const absoluteUrl = new URL(canonicalPath, Astro.site ?? Astro.url.origin).href;
---
<!DOCTYPE html>
<html lang="en" class="no-js lang-en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" hreflang="x-default" href={absoluteUrl} />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <JsonLd type={jsonLdType} data={jsonLdData} />

    <script is:inline>
      (function () {
        var d = document.documentElement;
        d.classList.replace('no-js', 'js');
        var saved = null;
        try { saved = localStorage.getItem('senavia.lang'); } catch (e) {}
        if (saved === 'es') {
          d.classList.remove('lang-en');
          d.classList.add('lang-es');
          d.setAttribute('lang', 'es');
        }
      })();
    </script>

    <!-- Calendly is loaded lazily (on first interaction / on demand) by the
         loader at the end of <body>, so it sets no third-party cookies on the
         initial page load. Preconnect keeps the on-demand load fast. -->
    <link rel="preconnect" href="https://assets.calendly.com" />

    <!-- Plausible — production only (keeps local/preview traffic out of analytics) -->
    {import.meta.env.PROD && (
      <script
        defer
        data-domain="new.senaviacorp.com"
        src="https://plausible.io/js/script.tagged-events.outbound-links.js"
      ></script>
    )}
    <script is:inline>
      window.plausible = window.plausible || function () {
        (window.plausible.q = window.plausible.q || []).push(arguments);
      };
    </script>
  </head>
  <body class={bodyClass} data-screen-label={screenLabel}>
    <div class="site-bg" aria-hidden="true"></div>
    <Nav />

    <slot />

    <Footer />

    <!-- Global language switcher logic -->
    <script>
      (function () {
        var d = document.documentElement;
        function setLang(lang) {
          if (lang !== 'en' && lang !== 'es') return;
          d.classList.toggle('lang-es', lang === 'es');
          d.classList.toggle('lang-en', lang === 'en');
          d.setAttribute('lang', lang);
          try { localStorage.setItem('senavia.lang', lang); } catch (e) {}
          window.dispatchEvent(new CustomEvent('languagechange', { detail: { lang: lang } }));
          if (typeof window.plausible === 'function') window.plausible('lang_switch', { props: { lang: lang } });
        }
        document.addEventListener('click', function (e) {
          var target = e.target as HTMLElement | null;
          var opt = target ? target.closest('.nav-lang-option') : null;
          if (!opt) return;
          e.preventDefault();
          var lang = opt.getAttribute('data-lang');
          if (lang) setLang(lang);
          if (document.activeElement && (document.activeElement as HTMLElement).blur) {
            (document.activeElement as HTMLElement).blur();
          }
        });
      })();
    </script>

    <!-- Lazy Calendly loader: injects the widget only on first user intent
         (scroll / pointer / key) or when a [data-calendly-trigger] is clicked.
         Keeps Calendly's third-party cookies off the initial page load while
         staying instant for real visitors. -->
    <script is:inline define:vars={{ CALENDLY_URL }}>
      (function () {
        var loading;
        function ensure() {
          if (loading) return loading;
          loading = new Promise(function (resolve) {
            var l = document.createElement('link');
            l.rel = 'stylesheet';
            l.href = 'https://assets.calendly.com/assets/external/widget.css';
            document.head.appendChild(l);
            var s = document.createElement('script');
            s.src = 'https://assets.calendly.com/assets/external/widget.js';
            s.async = true;
            s.onload = function () {
              window.__calendlyReady = true;
              window.dispatchEvent(new Event('calendly:ready'));
              resolve(window.Calendly);
            };
            document.head.appendChild(s);
          });
          return loading;
        }
        window.ensureCalendly = ensure;
        window.openCalendly = function (url) {
          ensure().then(function (C) { if (C) C.initPopupWidget({ url: url || CALENDLY_URL }); });
        };
        // Warm up on first intent so the popup feels instant. Each fires once.
        ['scroll', 'pointerdown', 'touchstart', 'keydown'].forEach(function (ev) {
          window.addEventListener(ev, ensure, { once: true, passive: true });
        });
        // Delegate clicks on any Calendly trigger.
        document.addEventListener('click', function (e) {
          var t = e.target.closest && e.target.closest('[data-calendly-trigger]');
          if (!t) return;
          e.preventDefault();
          window.openCalendly(t.getAttribute('data-calendly-url'));
        });
      })();
    </script>

    <!-- Home/global interactions: carousels, reveals, video autoplay -->
    <script src="/scripts/home.js" defer></script>
  </body>
</html>
