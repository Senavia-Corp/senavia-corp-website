---
import '@fontsource-variable/inter/index.css';
import '@/styles/senavia.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Seo from '@/components/Seo.astro';
import JsonLd from '@/components/JsonLd.astro';
import SenaviaChat from '@/components/SenaviaChat.astro';
import { CAL_LINK, CAL_NS, SITE } from '@/data/site';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLdType?: 'home' | 'about' | 'service' | 'portfolio' | 'blog' | 'localbusiness' | 'pricing';
  jsonLdData?: Record<string, unknown>;
  noindex?: boolean;
  bodyClass?: string;
  screenLabel?: string;
  /** Absolute or root-relative URL of the page's LCP image — emitted as
      <link rel="preload" as="image" fetchpriority="high">. */
  preloadImage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  jsonLdType = 'home',
  jsonLdData = {},
  noindex = false,
  bodyClass = '',
  screenLabel,
  preloadImage,
} = Astro.props;

// Absolute URL for hreflang. The site serves both languages from one URL via a
// client-side toggle, so we emit a single absolute x-default (per-language
// hreflang pointing at the same URL is contradictory and errors in Search Console).
const canonicalPath = canonical ?? Astro.url.pathname;
const absoluteUrl = new URL(canonicalPath, Astro.site ?? Astro.url.origin).href;
---
<!DOCTYPE html>
<html lang="en" class="no-js lang-en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" hreflang="x-default" href={absoluteUrl} />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <JsonLd type={jsonLdType} data={jsonLdData} />

    <script is:inline>
      (function () {
        var d = document.documentElement;
        d.classList.replace('no-js', 'js');
        var saved = null;
        try { saved = localStorage.getItem('senavia.lang'); } catch (e) {}
        if (saved === 'es') {
          d.classList.remove('lang-en');
          d.classList.add('lang-es');
          d.setAttribute('lang', 'es');
        }
      })();
    </script>

    <!-- Cal.com is loaded lazily (on first interaction / on demand) by the
         loader at the end of <body>, so it sets no third-party cookies on the
         initial page load. Preconnect keeps the on-demand load fast. -->
    <link rel="preconnect" href="https://app.cal.com" />

    <!-- LCP hint: preload the hero asset when the page declares it. -->
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <!-- background-video gating: detach <source> before the fetch
         starts (poster-on-mobile everywhere; cta/intro lazy on desktop too).
         home.js re-attaches them near the viewport on >=768px screens. -->
    <script is:inline>
      (function () {
        var desktop = window.matchMedia('(min-width: 768px)').matches;
        function strip(v) {
          var cls = v.className || '';
          if (!/(^|\s)(hero-video|cta-video|intro-video)(\s|$)/.test(cls)) return;
          if (desktop && /(^|\s)hero-video(\s|$)/.test(cls)) return;
          var sources = v.querySelectorAll('source[src]');
          if (!sources.length) return;
          for (var i = 0; i < sources.length; i++) {
            sources[i].setAttribute('data-src', sources[i].getAttribute('src'));
            sources[i].removeAttribute('src');
          }
          v.removeAttribute('autoplay');
          v.setAttribute('data-lazy-video', '');
          try { v.load(); } catch (e) {}
        }
        var mo = new MutationObserver(function (muts) {
          for (var i = 0; i < muts.length; i++) {
            var nodes = muts[i].addedNodes;
            for (var j = 0; j < nodes.length; j++) {
              var n = nodes[j];
              if (n.nodeType !== 1) continue;
              if (n.tagName === 'VIDEO') strip(n);
              else if (n.tagName === 'SOURCE' && n.parentElement && n.parentElement.tagName === 'VIDEO') strip(n.parentElement);
              else if (n.querySelectorAll) {
                var vs = n.querySelectorAll('video');
                for (var k = 0; k < vs.length; k++) strip(vs[k]);
              }
            }
          }
        });
        mo.observe(document.documentElement, { childList: true, subtree: true });
        document.addEventListener('DOMContentLoaded', function () {
          var vs = document.querySelectorAll('video');
          for (var i = 0; i < vs.length; i++) strip(vs[i]);
          mo.disconnect();
        });
      })();
    </script>

    <!-- Plausible — production only (keeps local/preview traffic out of analytics) -->
    {import.meta.env.PROD && (
      <script
        defer
        data-domain={SITE.domain}
        src="https://plausible.io/js/script.tagged-events.outbound-links.js"
      ></script>
    )}
    <script is:inline>
      window.plausible = window.plausible || function () {
        (window.plausible.q = window.plausible.q || []).push(arguments);
      };
    </script>
  </head>
  <body class={bodyClass} data-screen-label={screenLabel}>
    <a class="skip-link" href="#main">
      <span class="lang-only-en">Skip to content</span>
      <span class="lang-only-es">Saltar al contenido</span>
    </a>
    <div class="site-bg" aria-hidden="true"></div>
    <Nav />

    <slot />

    <Footer />

    <!-- AI sales chat: lazy-loaded, self-hosted @n8n/chat. PROD/preview only
         (kept out of local dev, same as Plausible). Nothing loads until the
         visitor opens it. -->
    {import.meta.env.PROD && <SenaviaChat />}

    <!-- Global language switcher logic -->
    <script>
      (function () {
        var d = document.documentElement;
        // WL-024 — skip-link target: pages render their own <main>
        var main = document.querySelector('main');
        if (main && !main.id) {
          main.id = 'main';
          main.setAttribute('tabindex', '-1');
        }
        function closeLangMenus(except?: Element | null) {
          document.querySelectorAll('.nav-lang.is-open').forEach(function (l) {
            if (l === except) return;
            l.classList.remove('is-open');
            var t = l.querySelector('.nav-lang-trigger');
            if (t) t.setAttribute('aria-expanded', 'false');
          });
        }
        function setLang(lang) {
          if (lang !== 'en' && lang !== 'es') return;
          d.classList.toggle('lang-es', lang === 'es');
          d.classList.toggle('lang-en', lang === 'en');
          d.setAttribute('lang', lang);
          try { localStorage.setItem('senavia.lang', lang); } catch (e) {}
          window.dispatchEvent(new CustomEvent('languagechange', { detail: { lang: lang } }));
          if (typeof window.plausible === 'function') window.plausible('lang_switch', { props: { lang: lang } });
        }
        document.addEventListener('click', function (e) {
          var target = e.target as HTMLElement | null;
          // WL-026 — click-driven dropdown (iOS Safari can't rely on
          // :hover/:focus-within) with aria-expanded kept in sync.
          var trigger = target ? (target.closest('.nav-lang-trigger') as HTMLElement | null) : null;
          if (trigger) {
            var wrap = trigger.closest('.nav-lang') as HTMLElement;
            closeLangMenus(wrap);
            var open = wrap.classList.toggle('is-open');
            trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
            if (!open) trigger.blur(); // otherwise :focus-within re-opens it
            return;
          }
          var opt = target ? target.closest('.nav-lang-option') : null;
          if (!opt) { closeLangMenus(null); return; }
          e.preventDefault();
          var lang = opt.getAttribute('data-lang');
          if (lang) setLang(lang);
          closeLangMenus(null);
          if (document.activeElement && (document.activeElement as HTMLElement).blur) {
            (document.activeElement as HTMLElement).blur();
          }
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeLangMenus(null);
        });
      })();
    </script>

    <!-- Floating "Book a Free Call" button — a circular FAB that matches the AI
         chat launcher (SenaviaChat.astro) in size/color/icon, placed in the
         opposite (bottom-left) corner. Always visible; opens the modal in-page. -->
    <button id="book-fab" class="book-fab" type="button" aria-label="Book a Free Call">
      <svg viewBox="0 0 24 24" width="27" height="27" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
    </button>

    <!-- Cal.com booking — single init point for the whole site. Loads the
         official embed lazily (first user intent / on demand) so no third-party
         cookies hit the initial page load. The FAB and every existing CTA open
         the SAME in-page modal (never a new tab); inline calendars + an
         Estimator opener share one namespace + calLink + config. -->
    <script is:inline define:vars={{ CAL_LINK, CAL_NS }}>
      (function () {
        var CFG = { layout: 'month_view', useSlotsViewOnSmallScreen: 'true' };
        var CFG_STR = JSON.stringify(CFG);
        var EMBED = 'https://app.cal.com/embed/embed.js';
        function isEs() { return document.documentElement.classList.contains('lang-es'); }

        // Cal queue stub — the official snippet WITHOUT its auto-append, so we
        // load embed.js ourselves and get a real load/error signal.
        function calStub() {
          if (window.Cal) return;
          (function (C, A, L) { var p = function (a, ar) { a.q.push(ar); }; C.Cal = function () { var cal = C.Cal; var ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; cal.loaded = true; } if (ar[0] === L) { var api = function () { p(api, arguments); }; var ns = ar[1]; api.q = api.q || []; if (typeof ns === 'string') { cal.ns[ns] = cal.ns[ns] || api; p(cal.ns[ns], ar); p(cal, ['initNamespace', ns]); } else p(cal, ar); return; } p(cal, ar); }; })(window, EMBED, 'init');
        }

        // Resolve TRUE only when embed.js's OWN load event fires (the real
        // "it executed" signal — NOT the stub's synchronous cal.loaded flag,
        // which is always set even when the script is blocked). FALSE on
        // error/timeout, and re-arm so a later click can retry.
        var readyPromise;
        function ensure() {
          if (readyPromise) return readyPromise;
          readyPromise = new Promise(function (resolve) {
            calStub();
            window.Cal('init', CAL_NS, { origin: 'https://app.cal.com' });
            window.Cal.config = window.Cal.config || {};
            window.Cal.config.forwardQueryParams = true;
            window.Cal.ns[CAL_NS]('ui', {
              cssVarsPerTheme: { light: { 'cal-brand': '#0A0E26' }, dark: { 'cal-brand': '#99CC33' } },
              hideEventTypeDetails: true, layout: 'month_view',
            });
            var settled = false;
            function finish(ok) { if (settled) return; settled = true; clearTimeout(to); if (!ok) readyPromise = null; resolve(!!ok); }
            var to = setTimeout(function () { finish(false); }, 10000);
            var s = document.createElement('script');
            s.src = EMBED; s.async = true;
            s.onload = function () { finish(true); };
            s.onerror = function () { finish(false); };
            document.head.appendChild(s);
          });
          return readyPromise;
        }

        // Hidden <button> (no href → can never navigate) = the element-click
        // trigger for programmatic opens. Clicked only AFTER embed.js is ready,
        // so it always opens the in-page modal, never a new tab.
        var hidden;
        function getHidden() {
          if (hidden) return hidden;
          hidden = document.createElement('button');
          hidden.type = 'button';
          hidden.style.display = 'none';
          hidden.setAttribute('data-cal-link', CAL_LINK);
          hidden.setAttribute('data-cal-namespace', CAL_NS);
          hidden.setAttribute('data-cal-config', CFG_STR);
          document.body.appendChild(hidden);
          return hidden;
        }
        // Open the booking modal in-page. opts.notes prefills the booking form.
        // If the embed is blocked/broken, degrade to the public page in the SAME
        // tab — never a new tab, never a dead button.
        window.openBooking = function (opts) {
          ensure().then(function (ok) {
            if (ok) {
              var h = getHidden();
              h.setAttribute('data-cal-config',
                opts && opts.notes
                  ? JSON.stringify({ layout: CFG.layout, useSlotsViewOnSmallScreen: CFG.useSlotsViewOnSmallScreen, notes: opts.notes })
                  : CFG_STR);
              h.click();
              // Cal creates <cal-modal-box> synchronously when it handles the
              // click; if it's there, the modal is open and we're done.
              if (document.querySelector('cal-modal-box')) return;
            }
            window.location.assign('https://cal.com/' + CAL_LINK);
          });
        };

        // Inline calendar mount (used by /schedule, /contact, service pages).
        window.calInline = function (target) {
          ensure().then(function (ok) {
            if (ok) window.Cal.ns[CAL_NS]('inline', { elementOrSelector: target, calLink: CAL_LINK, config: CFG });
          });
        };

        // Every existing CTA opens the SAME in-page modal — never a new tab.
        // The real href (public page) is only a no-JS fallback; the delegated
        // handler preventDefaults it for JS users. No data-cal-link on the
        // visible CTAs, so Cal never double-handles the click.
        function wireCtas() {
          var els = document.querySelectorAll('[data-calendly-trigger]');
          for (var i = 0; i < els.length; i++) {
            var el = els[i];
            if (el.tagName === 'A') {
              var h = el.getAttribute('href');
              if (!h || h === '#') el.setAttribute('href', 'https://cal.com/' + CAL_LINK);
              el.removeAttribute('target'); // never open a new tab
            }
          }
        }
        if (document.readyState !== 'loading') wireCtas();
        else document.addEventListener('DOMContentLoaded', wireCtas);
        document.addEventListener('click', function (e) {
          var t = e.target.closest && e.target.closest('[data-calendly-trigger]');
          if (!t) return;
          e.preventDefault();
          window.openBooking();
        });

        // Floating button: label per language, click opens the modal.
        function labelFab() {
          var f = document.getElementById('book-fab');
          if (f) f.setAttribute('aria-label', isEs() ? 'Agenda una Llamada' : 'Book a Free Call');
        }
        var fab = document.getElementById('book-fab');
        if (fab) fab.addEventListener('click', function () { window.openBooking(); });
        labelFab();
        window.addEventListener('languagechange', labelFab);

        // Warm up embed.js on first intent so the first open is instant, while
        // keeping third-party cookies off the initial page load. Each once.
        ['scroll', 'pointerdown', 'touchstart', 'keydown'].forEach(function (ev) {
          window.addEventListener(ev, ensure, { once: true, passive: true });
        });
      })();
    </script>

    <!-- Home/global interactions: carousels, reveals, video autoplay.
         /scripts/ ships with immutable 1y cache but no fingerprint:
         bump ?v= on every content change so returning visitors get patches. -->
    <script src="/scripts/home.js?v=20260703" defer></script>
  </body>
</html>
