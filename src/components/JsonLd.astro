---
import { SITE, NAP, SOCIAL, GOOGLE_PARTNER_URL } from '@/data/site';

interface Props {
  type?: 'home' | 'about' | 'service' | 'portfolio' | 'blog' | 'localbusiness' | 'pricing';
  data?: Record<string, unknown>;
}
const { type = 'home', data = {} } = Astro.props;

const organization = {
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  legalName: SITE.legalName,
  url: SITE.url,
  logo: `${SITE.url}/images/Logo-Senavia.svg`,
  description: SITE.description,
  telephone: NAP.phoneE164,
  email: NAP.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: NAP.streetAddress,
    addressLocality: NAP.addressLocality,
    addressRegion: NAP.addressRegion,
    postalCode: NAP.postalCode,
    addressCountry: NAP.addressCountry,
  },
  sameAs: [SOCIAL.instagram, SOCIAL.facebook, SOCIAL.youtube, GOOGLE_PARTNER_URL],
};

const localBusiness = {
  '@type': 'ProfessionalService',
  '@id': `${SITE.url}/#localbusiness`,
  name: SITE.name,
  url: SITE.url,
  image: `${SITE.url}/images/Logo-Senavia.svg`,
  telephone: NAP.phoneE164,
  email: NAP.email,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: NAP.streetAddress,
    addressLocality: NAP.addressLocality,
    addressRegion: NAP.addressRegion,
    postalCode: NAP.postalCode,
    addressCountry: NAP.addressCountry,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: NAP.latitude,
    longitude: NAP.longitude,
  },
  areaServed: NAP.areaServed.map((name) => ({ '@type': 'AdministrativeArea', name })),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
  ],
  sameAs: [SOCIAL.instagram, SOCIAL.facebook, SOCIAL.youtube, GOOGLE_PARTNER_URL],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Digital Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Custom Web Design', url: `${SITE.url}/services/web-design` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Web Development', url: `${SITE.url}/services/web-development` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Traffic Generation', url: `${SITE.url}/services/traffic-generation` } },
    ],
  },
};

const website = {
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: ['en-US', 'es-US'],
};

let graph: Array<Record<string, unknown>> = [organization, localBusiness, website];

if (type === 'service') {
  graph.push({
    '@type': 'Service',
    provider: { '@id': `${SITE.url}/#organization` },
    areaServed: NAP.areaServed.map((name) => ({ '@type': 'AdministrativeArea', name })),
    ...data,
  });
}
if (type === 'blog' && data.headline) {
  graph.push({
    '@type': 'BlogPosting',
    publisher: { '@id': `${SITE.url}/#organization` },
    author: { '@id': `${SITE.url}/#organization` },
    ...data,
  });
}
if (type === 'portfolio' && data.name) {
  graph.push({
    '@type': 'CreativeWork',
    creator: { '@id': `${SITE.url}/#organization` },
    ...data,
  });
}
if (type === 'pricing' && Array.isArray(data.offers)) {
  graph.push({
    '@type': 'OfferCatalog',
    name: 'SENAVIA Pricing',
    itemListElement: data.offers,
  });
}

/* WL-029 — BreadcrumbList generated from the URL for every route >=2 levels
   deep. Excluded: /gqm (private) and the two templates that already emit
   their own breadcrumb inline (service-areas/[slug], services/web-design/[slug]). */
const segments = Astro.url.pathname.replace(/\/+$/, '').split('/').filter(Boolean);
const SEGMENT_LABELS: Record<string, string> = {
  blog: 'Blog',
  portfolio: 'Portfolio',
  services: 'Services',
  'service-areas': 'Service Areas',
  'web-design': 'Custom Web Design',
  'web-development': 'Web Development',
  'traffic-generation': 'Traffic Generation',
};
const skipBreadcrumb =
  segments.length < 2 ||
  segments[0] === 'gqm' ||
  (segments[0] === 'service-areas' && segments.length >= 2) ||
  (segments[0] === 'services' &&
    ['web-design', 'web-development', 'traffic-generation'].includes(segments[1]) &&
    segments.length >= 3);
function crumbLabel(seg: string, isLast: boolean): string {
  if (isLast && type === 'blog' && typeof data.headline === 'string') return data.headline;
  if (isLast && type === 'portfolio' && typeof data.name === 'string') return data.name;
  return (
    SEGMENT_LABELS[seg] ??
    seg.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
  );
}
if (!skipBreadcrumb) {
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
      ...segments.map((seg, i) => ({
        '@type': 'ListItem',
        position: i + 2,
        name: crumbLabel(seg, i === segments.length - 1),
        item: `${SITE.url}/${segments.slice(0, i + 1).join('/')}`,
      })),
    ],
  });
}

const ld = { '@context': 'https://schema.org', '@graph': graph };
---
{/* WL-027 — escape '<' so CMS-sourced strings can never close the script tag */}
<script type="application/ld+json" set:html={JSON.stringify(ld).replace(/</g, '\\u003c')} />
