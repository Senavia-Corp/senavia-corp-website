---
import { getCollection } from 'astro:content';

interface Copy { en: string; es: string }
interface Step {
  label: Copy;  // "1. Explore" / "1. Explorar" (or "Step 01" / "Paso 01")
  title: Copy;
  body: Copy;
  alt?: string; // step photo alt; falls back to the home alt for that slot
}
interface Props {
  /* Per-page copy. Both languages are rendered inline (lang-only-* spans); the
     site's CSS toggle shows the active one. These are the ONLY per-page knobs —
     everything else (step photos, videos, CTAs, layout, spacing) is fixed so
     every instance is identical to the home reference, and Process + Reviews
     always ship together. */
  processTitle?: Copy;
  processIntro?: Copy;          // rendered with set:html so CMS-driven pages can pass rich prose
  steps?: Step[];               // exactly 4; photos are fixed per slot
  testimonialsTitle?: Copy;
  testimonialsIntro?: Copy;     // set:html, same as processIntro
  processEyebrow?: string;      // section number ("03") — service-areas only; absent = home
  testimonialsEyebrow?: string; // section number ("04")
  processScreenLabel?: string;
  testimonialsScreenLabel?: string;
}

/* Fixed step photos — one per slot, same on every page. */
const STEP_IMAGES = [
  '/images/process/explore.avif',
  '/images/process/estimate.avif',
  '/images/process/development.avif',
  '/images/process/delivery.avif',
];

/* Home copy verbatim = the defaults. */
const DEFAULT_STEPS: Required<Step>[] = [
  {
    label: { en: '1. Explore', es: '1. Explorar' },
    title: { en: 'Digital Strategy & Market Discovery', es: 'Estrategia Digital y Descubrimiento de Mercado' },
    body: { en: 'We analyze goals, audience, and market to uncover growth opportunities across South Florida.', es: 'Analizamos metas, audiencia y mercado para descubrir oportunidades de crecimiento en todo el Sur de Florida.' },
    alt: 'Digital strategy and market discovery for South Florida businesses',
  },
  {
    label: { en: '2. Estimate', es: '2. Estimar' },
    title: { en: 'Project Planning & Strategic Roadmap', es: 'Planificación del Proyecto y Hoja de Ruta Estratégica' },
    body: { en: 'We define a clear project plan aligned with your budget, timeline, and objectives.', es: 'Definimos un plan de proyecto claro alineado con tu presupuesto, cronograma y objetivos.' },
    alt: 'Project planning and strategic roadmap for a web project',
  },
  {
    label: { en: '3. Development', es: '3. Desarrollo' },
    title: { en: 'Custom Web Development & SEO', es: 'Desarrollo Web a la Medida y SEO' },
    body: { en: 'We build high-performance websites and platforms optimized for SEO and conversions.', es: 'Construimos sitios web y plataformas de alto rendimiento optimizados para SEO y conversiones.' },
    alt: 'Custom web development and SEO build in progress',
  },
  {
    label: { en: '4. Delivery', es: '4. Entrega' },
    title: { en: 'Website Launch & Ongoing Optimization', es: 'Lanzamiento del Sitio y Optimización Continua' },
    body: { en: 'We launch and optimize your digital presence from Plantation, serving South Florida.', es: 'Lanzamos y optimizamos tu presencia digital desde Plantation, al servicio del Sur de Florida.' },
    alt: 'Website launch and ongoing optimization in Plantation, FL',
  },
];

const {
  processTitle = { en: 'Our Process', es: 'Nuestro Proceso' },
  processIntro = {
    en: 'We understand your goals and challenges, create a tailored plan with clear estimates, and build a custom solution designed for your success.',
    es: 'Entendemos tus metas y desafíos, creamos un plan a la medida con estimados claros y construimos una solución personalizada diseñada para tu éxito.',
  },
  steps = DEFAULT_STEPS,
  testimonialsTitle = { en: 'What Our Clients Say', es: 'Lo Que Dicen Nuestros Clientes' },
  testimonialsIntro = {
    en: 'Based in Plantation, we deliver custom web design and SEO that help South Florida companies grow. Hear what our clients say about working with the SENAVIA team — on camera, in their own words.',
    es: 'Desde Plantation, ofrecemos diseño web a la medida y SEO que ayudan a las empresas del Sur de Florida a crecer. Descubre lo que dicen nuestros clientes sobre trabajar con el equipo de SENAVIA — frente a cámara, en sus propias palabras.',
  },
  processEyebrow,
  testimonialsEyebrow,
  processScreenLabel = '05 Process',
  testimonialsScreenLabel = '06 Client Reviews',
} = Astro.props;

/* Fixed video testimonials — same 3 CMS videos on every page. */
const videos = (await getCollection('videos'))
  .filter((v) => v.data.youtubeId)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---
<div class="green-bg">
  <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
  <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
  <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

  <!-- PROCESS -->
  <section id="process" class="section section-flush" data-screen-label={processScreenLabel}>
    <div class="container">
      <div class="section-head" data-reveal>
        {processEyebrow && <span class="sec-num">{processEyebrow}</span>}
        <h2><span class="lang-only-en">{processTitle.en}</span><span class="lang-only-es">{processTitle.es}</span></h2>
        <p><span class="lang-only-en" set:html={processIntro.en} /><span class="lang-only-es" set:html={processIntro.es} /></p>
      </div>
      <div class="grid-4" data-reveal-children>
        {steps.map((st, i) => (
          <article class="process-block">
            <img class="process-img" src={STEP_IMAGES[i]} alt={st.alt ?? DEFAULT_STEPS[i].alt} loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">{st.label.en}</span><span class="lang-only-es">{st.label.es}</span></h3>
                <h4><span class="lang-only-en">{st.title.en}</span><span class="lang-only-es">{st.title.es}</span></h4>
              </div>
              <p><span class="lang-only-en">{st.body.en}</span><span class="lang-only-es">{st.body.es}</span></p>
            </div>
          </article>
        ))}
      </div>
      <div class="center-cta" style="margin-top: 3rem;" data-reveal>
        <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
      </div>
    </div>
  </section>

  <!-- CLIENT REVIEWS -->
  <section id="reviews" class="section" data-screen-label={testimonialsScreenLabel}>
    <div class="container">
      <div class="reviews-grid">
        <div class="reviews-left" data-reveal>
          {testimonialsEyebrow && <span class="sec-num">{testimonialsEyebrow}</span>}
          <h2><span class="lang-only-en">{testimonialsTitle.en}</span><span class="lang-only-es">{testimonialsTitle.es}</span></h2>
          <p><span class="lang-only-en" set:html={testimonialsIntro.en} /><span class="lang-only-es" set:html={testimonialsIntro.es} /></p>
          <div class="reviews-cta-row">
            <a href="/testimonials" class="btn is-sm"><span class="lang-only-en">Watch Video Testimonials</span><span class="lang-only-es">Ver Testimonios en Video</span></a>
            <a href="https://www.google.com/search?q=senavia+corp+plantation+reviews" target="_blank" rel="noopener" class="btn is-secondary is-sm"><span class="lang-only-en">Find Us on Google</span><span class="lang-only-es">Encuéntranos en Google</span></a>
          </div>
        </div>
        <div class="reviews-card" data-reveal>
          {videos.map((v) => (
            <a class="review-item vt-mini" href="/testimonials#video-testimonials" aria-label={`Watch video testimonial from ${v.data.name} / Ver testimonio en video de ${v.data.name}`}>
              <img class="vt-mini-thumb" src={`https://i.ytimg.com/vi/${v.data.youtubeId}/mqdefault.jpg`} alt="" width="128" height="72" loading="lazy" decoding="async" />
              <span class="vt-mini-body">
                <span class="vt-mini-name">{v.data.name}</span>
                <span class="vt-mini-tag"><span class="lang-only-en">Video testimonial</span><span class="lang-only-es">Testimonio en video</span></span>
              </span>
              <span class="vt-mini-play" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="8 5 19 12 8 19 8 5"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* Layout/spacing comes from the global senavia.css rules (.green-bg, .section,
     .section-flush, .process-*, .reviews-*, #process/#reviews, .center-cta) —
     only the styles that used to be copy-pasted per page live here. */

  /* Real video-testimonial rows inside the reviews card */
  a.review-item.vt-mini {
    flex-direction: row;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    transition: border-color .2s ease, background .2s ease;
  }
  a.review-item.vt-mini:hover {
    border-color: rgba(153,204,51,0.35);
    background: rgba(255,255,255,0.05);
  }
  a.review-item.vt-mini:focus-visible {
    outline: 2px solid var(--primary, #99cc33);
    outline-offset: 3px;
  }
  .vt-mini-thumb {
    width: 128px;
    height: 72px;
    border-radius: 10px;
    object-fit: cover;
    flex: 0 0 auto;
    background: #0a0e26;
  }
  .vt-mini-body { display: flex; flex-direction: column; gap: 4px; min-width: 0; flex: 1; }
  .vt-mini-name { color: var(--white); font-weight: 500; font-size: 15px; }
  .vt-mini-tag { font-size: 12.5px; color: rgba(255,255,255,0.6); }
  .vt-mini-play {
    width: 38px;
    height: 38px;
    flex: 0 0 auto;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(153,204,51,0.14);
    border: 1px solid rgba(153,204,51,0.35);
    color: var(--primary, #99cc33);
  }
  .vt-mini-play svg { width: 16px; height: 16px; }
  @media (max-width: 480px) {
    .vt-mini-thumb { width: 96px; height: 54px; }
  }

  /* Section number eyebrow (service-areas pages pass processEyebrow/testimonialsEyebrow).
     Same declarations as the page-level .sa-sec-num, renamed to avoid coupling. */
  .sec-num {
    display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--primary, #99cc33); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; margin-bottom: 8px;
  }
</style>
