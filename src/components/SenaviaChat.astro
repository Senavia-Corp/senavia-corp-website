---
/*
  SENAVIA AI Sales Chat — floating widget, self-hosted @n8n/chat (v1.28.3).
  Mirrors the site's Calendly loader: the 1.9MB bundle + its CSS load ONLY when
  the visitor opens the chat, so there are zero third-party requests / cookies on
  the initial page load and Lighthouse stays intact. Everything is same-origin
  (/scripts/…), so the only CSP change needed is adding the n8n host to connect-src.

  webhookUrl points straight at the n8n Chat Trigger for now. To harden later,
  swap it for a same-origin Vercel proxy (/api/chat) — one line, no other change.
*/
const WEBHOOK_URL = 'https://senavia.app.n8n.cloud/webhook/95bd1c1b-bdd5-4b05-8541-ce98f915b422/chat';
---

<button
  id="senavia-chat-launcher"
  type="button"
  aria-haspopup="dialog"
  aria-controls="senavia-chat-panel"
  aria-expanded="false"
>
  <span class="lang-only-en visually-hidden">Open chat</span>
  <span class="lang-only-es visually-hidden">Abrir chat</span>
  <svg class="scl-icon-open" viewBox="0 0 24 24" width="26" height="26" fill="none" aria-hidden="true">
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <svg class="scl-icon-close" viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
    <path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
  </svg>
</button>

<div id="senavia-chat-panel" role="dialog" aria-modal="false" aria-label="SENAVIA" hidden>
  <div id="senavia-chat"></div>
</div>

<style is:global>
  /* ---- Brand theming for @n8n/chat (exact var names from the v1.28.3 bundle) ---- */
  :root {
    --chat--color--primary: #99CC33;
    --chat--color--primary-shade-50: #ADE73A;
    --chat--color--primary--shade-100: #7DB022;
    --chat--color--secondary: #282B38;
    --chat--color-dark: #0A0E26;
    --chat--color-typing: #ADE73A;
    --chat--font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --chat--border-radius: 10px;
    --chat--header--background: #0A0E26;
    --chat--header--color: #FFFFFF;
    --chat--message--user--background: #282B38;
    --chat--message--user--color: #FFFFFF;
    --chat--message--bot--background: #FFFFFF;
    --chat--message--bot--color: #0A0E26;
    --chat--input--send--button--background: #99CC33;
    --chat--input--send--button--color: #0A0E26;
  }

  #senavia-chat-launcher {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 40; /* below sticky nav (50); raised to a modal layer when open */
    width: 58px;
    height: 58px;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: var(--grad-button, #99CC33);
    color: #0A0E26;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(153, 204, 51, 0.35);
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  #senavia-chat-launcher:hover { transform: translateY(-2px); }
  #senavia-chat-launcher:focus-visible { outline: 3px solid #ADE73A; outline-offset: 3px; }
  #senavia-chat-launcher .scl-icon-close { display: none; }
  #senavia-chat-launcher[aria-expanded='true'] { z-index: 1001; }
  #senavia-chat-launcher[aria-expanded='true'] .scl-icon-open { display: none; }
  #senavia-chat-launcher[aria-expanded='true'] .scl-icon-close { display: block; }

  #senavia-chat-panel {
    position: fixed;
    right: 1.25rem;
    bottom: 5.5rem;
    z-index: 1000;
    width: 400px;
    max-width: calc(100vw - 2rem);
    height: 620px;
    max-height: calc(100vh - 7.5rem);
    overflow: hidden;
    border-radius: 16px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
    background: #0A0E26;
    animation: sclRise 0.18s ease;
  }
  #senavia-chat-panel[hidden] { display: none; }
  #senavia-chat, #senavia-chat > * { height: 100%; }
  /* Loading state while the bundle streams in */
  #senavia-chat:empty::before {
    content: 'Loading…';
    display: grid;
    place-items: center;
    height: 100%;
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-sans, sans-serif);
    font-size: 0.95rem;
  }
  html.lang-es #senavia-chat:empty::before { content: 'Cargando…'; }

  @keyframes sclRise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) {
    #senavia-chat-panel { animation: none; }
    #senavia-chat-launcher { transition: none; }
  }

  /* Mobile: fill the screen */
  @media (max-width: 560px) {
    #senavia-chat-panel {
      right: 0; left: 0; bottom: 0;
      width: 100%; max-width: 100%;
      height: 86vh; max-height: 86vh;
      border-radius: 16px 16px 0 0;
    }
    #senavia-chat-launcher { right: 1rem; bottom: 1rem; }
  }

  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
</style>

<script is:inline define:vars={{ WEBHOOK_URL }}>
  (function () {
    var launcher = document.getElementById('senavia-chat-launcher');
    var panel = document.getElementById('senavia-chat-panel');
    if (!launcher || !panel) return;

    var VERSION = '20260708';
    var loaded = false;
    var isOpen = false;

    function currentLang() {
      return document.documentElement.classList.contains('lang-es') ? 'es' : 'en';
    }

    function i18nFor(lang) {
      if (lang === 'es') {
        return {
          title: 'SENAVIA · Asistente',
          subtitle: 'Resolvemos tus dudas y agendamos tu asesoría gratis.',
          footer: 'Al chatear aceptas nuestra Política de Privacidad.',
          getStarted: 'Nueva conversación',
          inputPlaceholder: 'Escribe tu mensaje…',
          closeButtonTooltip: 'Cerrar'
        };
      }
      return {
        title: 'SENAVIA · Assistant',
        subtitle: 'Ask us anything and book your free consultation.',
        footer: 'By chatting you agree to our Privacy Policy.',
        getStarted: 'New conversation',
        inputPlaceholder: 'Type your message…',
        closeButtonTooltip: 'Close'
      };
    }

    function greeting(lang) {
      return lang === 'es'
        ? ['¡Hola! 👋 Soy el asistente de SENAVIA. ¿En qué proyecto estás pensando — una web, tienda online o marketing?']
        : ['Hi! 👋 I’m the SENAVIA assistant. What are you working on — a website, online store, or marketing?'];
    }

    function load() {
      if (loaded) return Promise.resolve();
      loaded = true;
      var css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = '/scripts/n8n-chat.css?v=' + VERSION;
      document.head.appendChild(css);
      var lang = currentLang();
      return import('/scripts/n8n-chat.bundle.js?v=' + VERSION)
        .then(function (mod) {
          mod.createChat({
            webhookUrl: WEBHOOK_URL,
            target: '#senavia-chat',
            mode: 'fullscreen',
            showWelcomeScreen: false,
            loadPreviousSession: true,
            defaultLanguage: 'en',
            initialMessages: greeting(lang),
            i18n: { en: i18nFor(lang) },
            metadata: { source_url: location.pathname, site_lang: lang }
          });
        })
        .catch(function () {
          loaded = false; // allow a retry on next open
          var box = document.getElementById('senavia-chat');
          if (box) {
            box.textContent = currentLang() === 'es'
              ? 'No pudimos cargar el chat. Escríbenos a info@senaviacorp.com o al (754) 262-3659.'
              : 'We couldn’t load the chat. Email info@senaviacorp.com or call (754) 262-3659.';
          }
        });
    }

    function open() {
      panel.hidden = false;
      launcher.setAttribute('aria-expanded', 'true');
      isOpen = true;
      load();
      if (typeof window.plausible === 'function') {
        window.plausible('chat_open', { props: { lang: currentLang() } });
      }
    }
    function close() {
      panel.hidden = true;
      launcher.setAttribute('aria-expanded', 'false');
      isOpen = false;
      launcher.focus();
    }

    launcher.addEventListener('click', function () {
      isOpen ? close() : open();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen) close();
    });
  })();
</script>
