---
interface Props {
  size?: 'sm' | 'lg';
  variant: 'en' | 'es';
}
const { size = 'sm', variant } = Astro.props;
const sizeClass = size === 'lg' ? 'lg' : '';
---
{variant === 'en' && (
  <span class={`lang-flag ${sizeClass}`.trim()} aria-hidden="true">
    <svg viewBox="0 0 20 20">
      <rect width="20" height="20" fill="#B22234"/>
      <g fill="#fff">
        <rect y="1.54" width="20" height="1.54"/>
        <rect y="4.62" width="20" height="1.54"/>
        <rect y="7.7" width="20" height="1.54"/>
        <rect y="10.78" width="20" height="1.54"/>
        <rect y="13.86" width="20" height="1.54"/>
        <rect y="16.94" width="20" height="1.54"/>
      </g>
      <rect width="9" height="7.7" fill="#3C3B6E"/>
      <g fill="#fff">
        <circle cx="1.5" cy="1.3" r="0.45"/><circle cx="3" cy="1.3" r="0.45"/><circle cx="4.5" cy="1.3" r="0.45"/><circle cx="6" cy="1.3" r="0.45"/><circle cx="7.5" cy="1.3" r="0.45"/>
        <circle cx="2.25" cy="2.6" r="0.45"/><circle cx="3.75" cy="2.6" r="0.45"/><circle cx="5.25" cy="2.6" r="0.45"/><circle cx="6.75" cy="2.6" r="0.45"/>
        <circle cx="1.5" cy="3.85" r="0.45"/><circle cx="3" cy="3.85" r="0.45"/><circle cx="4.5" cy="3.85" r="0.45"/><circle cx="6" cy="3.85" r="0.45"/><circle cx="7.5" cy="3.85" r="0.45"/>
        <circle cx="2.25" cy="5.1" r="0.45"/><circle cx="3.75" cy="5.1" r="0.45"/><circle cx="5.25" cy="5.1" r="0.45"/><circle cx="6.75" cy="5.1" r="0.45"/>
        <circle cx="1.5" cy="6.35" r="0.45"/><circle cx="3" cy="6.35" r="0.45"/><circle cx="4.5" cy="6.35" r="0.45"/><circle cx="6" cy="6.35" r="0.45"/><circle cx="7.5" cy="6.35" r="0.45"/>
      </g>
    </svg>
  </span>
)}
{variant === 'es' && (
  <span class={`lang-flag ${sizeClass}`.trim()} aria-hidden="true">
    <svg viewBox="0 0 20 20">
      <rect width="20" height="20" fill="#AA151B"/>
      <rect y="5" width="20" height="10" fill="#F1BF00"/>
      <g transform="translate(6.5,8.5)">
        <rect width="3" height="3" rx="0.4" fill="#AA151B"/>
        <rect x="0.6" y="0.55" width="0.7" height="1.9" fill="#F1BF00"/>
        <rect x="1.7" y="0.55" width="0.7" height="1.9" fill="#F1BF00"/>
      </g>
    </svg>
  </span>
)}
