---
import { NAV, NAP } from '@/data/site';
import { SUBSERVICES as WEB_DESIGN_SUBS } from '@/data/subservices';
import { SUBSERVICES_TRAFFIC as TRAFFIC_SUBS } from '@/data/subservices-traffic';
import { SUBSERVICES_WEBDEV as WEBDEV_SUBS } from '@/data/subservices-webdev';
import LangSwitcher from './LangSwitcher.astro';
import { Icon } from 'astro-icon/components';

// Attach each service's subservices as menu sub-links. Data-driven from the
// same source that renders the subservice pages — labels derived from the
// eyebrow ("Business Website Design · Miami" → "Business Website Design").
const SUBS_BY_SERVICE: Record<string, typeof WEB_DESIGN_SUBS> = {
  '/services/web-design': WEB_DESIGN_SUBS,
  '/services/traffic-generation': TRAFFIC_SUBS,
  '/services/web-development': WEBDEV_SUBS,
};
const shortLabel = (eyebrow: string) => eyebrow.split('·')[0].trim();
const servicesNav = NAV.services.map((item) => ({
  ...item,
  key: item.href.split('/').pop() ?? item.href,
  subservices: (SUBS_BY_SERVICE[item.href] ?? []).map((s) => ({
    href: `${item.href}/${s.slug}`,
    label_en: shortLabel(s.eyebrow_en),
    label_es: shortLabel(s.eyebrow_es),
  })),
}));
---
<nav class="nav" data-screen-label="01 Navbar">
  <div class="nav-inner">
    <a href="/" class="nav-brand" aria-label="SENAVIA Corp — Home">
      <img src="/images/Logo-Senavia.svg" alt="SENAVIA Corp" width="180" height="40" />
    </a>

    <div class="nav-links">
      <div class="nav-dropdown">
        <a href="/services" class="nav-link">
          <span class="lang-only-en">Services</span>
          <span class="lang-only-es">Servicios</span>
          <span class="caret"></span>
        </a>
        <div class="nav-panel is-services">
          {servicesNav.map((item) => (
            <div class="nav-panel-col">
              <a class="nav-panel-head" href={item.href}>
                <span class="ic"><img src={item.icon} alt="" /></span>
                <span class="nav-panel-title">
                  <span class="lang-only-en">{item.title_en}</span>
                  <span class="lang-only-es">{item.title_es}</span>
                </span>
                <span class="more">
                  <span class="lang-only-en">View all</span>
                  <span class="lang-only-es">Ver todo</span>
                </span>
              </a>
              <ul class="nav-sublinks">
                {item.subservices.map((s) => (
                  <li>
                    <a href={s.href}>
                      <span class="lang-only-en">{s.label_en}</span>
                      <span class="lang-only-es">{s.label_es}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <a href="/portfolio" class="nav-link">
        <span class="lang-only-en">Portfolio</span>
        <span class="lang-only-es">Portafolio</span>
      </a>

      <div class="nav-dropdown">
        <a href="/about" class="nav-link">
          <span class="lang-only-en">About Us</span>
          <span class="lang-only-es">Nosotros</span>
          <span class="caret"></span>
        </a>
        <div class="nav-panel">
          {NAV.about.map((item) => (
            <a class="nav-panel-item" href={item.href}>
              <span class="ic"><img src={item.icon} alt="" /></span>
              <span class="nav-panel-title">
                <span class="lang-only-en">{item.title_en}</span>
                <span class="lang-only-es">{item.title_es}</span>
              </span>
              <p>
                <span class="lang-only-en">{item.desc_en}</span>
                <span class="lang-only-es">{item.desc_es}</span>
              </p>
              <span class="more">
                <span class="lang-only-en">Learn More</span>
                <span class="lang-only-es">Saber Más</span>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="nav-dropdown">
        <a href="/pricing" class="nav-link">
          <span class="lang-only-en">Resources</span>
          <span class="lang-only-es">Recursos</span>
          <span class="caret"></span>
        </a>
        <div class="nav-panel">
          {NAV.resources.map((item) => (
            <a class="nav-panel-item" href={item.href}>
              <span class="ic"><img src={item.icon} alt="" /></span>
              <span class="nav-panel-title">
                <span class="lang-only-en">{item.title_en}</span>
                <span class="lang-only-es">{item.title_es}</span>
              </span>
              <p>
                <span class="lang-only-en">{item.desc_en}</span>
                <span class="lang-only-es">{item.desc_es}</span>
              </p>
              <span class="more">
                <span class="lang-only-en">Learn More</span>
                <span class="lang-only-es">Saber Más</span>
              </span>
            </a>
          ))}
        </div>
      </div>

      <a href="/contact" class="nav-link">
        <span class="lang-only-en">Contact Us</span>
        <span class="lang-only-es">Contacto</span>
      </a>
    </div>

    <div class="nav-cta">
      <a
        href="#"
        class="btn is-nav-primary"
        data-calendly-trigger
        data-track="book_call_click"
        
      >
        <span class="lang-only-en">Book a Free Call</span>
        <span class="lang-only-es">Agenda una Llamada</span>
      </a>
      <a href={`tel:${NAP.phoneE164}`} class="nav-call">
        <span class="phone-ic"><Icon name="lucide:phone" /></span>
        <span class="text">
          <span class="label">
            <span class="lang-only-en">Call Us Now!</span>
            <span class="lang-only-es">¡Llámanos!</span>
          </span>
          <span class="number">{NAP.phone}</span>
        </span>
      </a>
      <LangSwitcher />
      <button class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="navMobile" id="navBurger">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>
</nav>

<div class="nav-scrim" id="navScrim"></div>
<aside class="nav-mobile" id="navMobile" role="dialog" aria-modal="true" aria-label="Menu / Menú" aria-hidden="true" inert>
  <div class="nav-mobile-head">
    <img src="/images/Logo-Senavia.svg" alt="SENAVIA Corp" />
    <button class="nav-mobile-close" id="navClose" aria-label="Close menu"></button>
  </div>
  <div class="nav-mobile-body">
    <div class="nav-mobile-section">
      <button type="button" class="nav-mobile-link" data-toggle aria-expanded="false" aria-controls="navSubServices">
        <span class="lang-only-en">Services</span>
        <span class="lang-only-es">Servicios</span>
        <span class="caret"></span>
      </button>
      <div class="nav-mobile-sub" id="navSubServices">
        {servicesNav.map((item) => (
          <div class="nav-mobile-subgroup">
            <a class="nav-mobile-subhead" href={item.href}>
              <span class="ic"><img src={item.icon} alt="" /></span>
              <span class="lang-only-en">{item.title_en}</span>
              <span class="lang-only-es">{item.title_es}</span>
            </a>
            <button type="button" class="nav-mobile-subtoggle" data-toggle
              aria-expanded="false" aria-controls={`navSub-${item.key}`}>
              <span class="sr-only lang-only-en">Show {item.title_en} services</span>
              <span class="sr-only lang-only-es">Ver servicios de {item.title_es}</span>
              <span class="caret" aria-hidden="true"></span>
            </button>
            <ul class="nav-mobile-subsub" id={`navSub-${item.key}`}>
              {item.subservices.map((s) => (
                <li>
                  <a href={s.href}>
                    <span class="lang-only-en">{s.label_en}</span>
                    <span class="lang-only-es">{s.label_es}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="nav-mobile-section">
      <a class="nav-mobile-link" href="/portfolio">
        <span class="lang-only-en">Portfolio</span>
        <span class="lang-only-es">Portafolio</span>
      </a>
    </div>
    <div class="nav-mobile-section">
      <button type="button" class="nav-mobile-link" data-toggle aria-expanded="false" aria-controls="navSubAbout">
        <span class="lang-only-en">About Us</span>
        <span class="lang-only-es">Nosotros</span>
        <span class="caret"></span>
      </button>
      <div class="nav-mobile-sub" id="navSubAbout">
        {NAV.about.map((item) => (
          <a href={item.href}>
            <span class="ic"><img src={item.icon} alt="" /></span>
            <span class="lang-only-en">{item.title_en}</span>
            <span class="lang-only-es">{item.title_es}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="nav-mobile-section">
      <button type="button" class="nav-mobile-link" data-toggle aria-expanded="false" aria-controls="navSubResources">
        <span class="lang-only-en">Resources</span>
        <span class="lang-only-es">Recursos</span>
        <span class="caret"></span>
      </button>
      <div class="nav-mobile-sub" id="navSubResources">
        {NAV.resources.map((item) => (
          <a href={item.href}>
            <span class="ic"><img src={item.icon} alt="" /></span>
            <span class="lang-only-en">{item.title_en}</span>
            <span class="lang-only-es">{item.title_es}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="nav-mobile-section">
      <a class="nav-mobile-link" href="/contact">
        <span class="lang-only-en">Contact Us</span>
        <span class="lang-only-es">Contacto</span>
      </a>
    </div>
    <a
      href="#"
      class="btn is-block"
      style="margin-top:8px;"
      data-calendly-trigger
      data-track="book_call_click"
      
    >
      <span class="lang-only-en">Book a Free Call</span>
      <span class="lang-only-es">Agenda una Llamada</span>
    </a>
  </div>
  <div class="nav-mobile-foot">
    <a href={`tel:${NAP.phoneE164}`} class="nav-call">
      <span class="phone-ic"><Icon name="lucide:phone" /></span>
      <span class="text">
        <span class="label">
          <span class="lang-only-en">Call Us Now!</span>
          <span class="lang-only-es">¡Llámanos!</span>
        </span>
        <span class="number">{NAP.phone}</span>
      </span>
    </a>
    <div class="row">
      <LangSwitcher />
      <span class="nav-social">
        <a href={`https://www.instagram.com/senaviacorp`} aria-label="Instagram" target="_blank" rel="noopener"><Icon name="lucide:instagram" /></a>
        <a href={`https://www.facebook.com/senaviacorp`} aria-label="Facebook" target="_blank" rel="noopener"><Icon name="lucide:facebook" /></a>
        <a href={`https://www.youtube.com/@senaviacorp`} aria-label="YouTube" target="_blank" rel="noopener"><Icon name="lucide:youtube" /></a>
      </span>
    </div>
  </div>
</aside>

<script>
  (function () {
    var burger = document.getElementById('navBurger');
    var menu = document.getElementById('navMobile');
    var scrim = document.getElementById('navScrim');
    var close = document.getElementById('navClose');
    if (!burger || !menu || !scrim || !close) return;
    function setBackgroundInert(on: boolean) {
      Array.prototype.forEach.call(document.body.children, function (el: Element) {
        if (el === menu || el === scrim || el.tagName === 'SCRIPT') return;
        if (on) el.setAttribute('inert', '');
        else el.removeAttribute('inert');
      });
    }
    function open() {
      menu!.classList.add('is-open');
      scrim!.classList.add('is-open');
      document.body.classList.add('nav-locked');
      menu!.setAttribute('aria-hidden', 'false');
      menu!.removeAttribute('inert');
      burger!.setAttribute('aria-expanded', 'true');
      setBackgroundInert(true);
      (close as HTMLElement).focus();
    }
    function shut() {
      if (!menu!.classList.contains('is-open')) return;
      menu!.classList.remove('is-open');
      scrim!.classList.remove('is-open');
      document.body.classList.remove('nav-locked');
      menu!.setAttribute('aria-hidden', 'true');
      menu!.setAttribute('inert', '');
      burger!.setAttribute('aria-expanded', 'false');
      setBackgroundInert(false);
      (burger as HTMLElement).focus();
    }
    burger.addEventListener('click', open);
    close.addEventListener('click', shut);
    scrim.addEventListener('click', shut);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') shut();
    });
    var mqDesktop = window.matchMedia('(min-width: 1181px)');
    mqDesktop.addEventListener('change', function (e) {
      if (e.matches) shut();
    });
    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        shut();
      });
    });
    menu.querySelectorAll('[data-toggle]').forEach(function (el) {
      el.addEventListener('click', function () {
        var expanded = el.parentElement?.classList.toggle('is-open');
        el.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      });
    });
  })();
</script>
