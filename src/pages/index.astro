---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "SENAVIA Corp — Web Design & Digital Marketing Agency in South Florida";
const description = "Google Partner-certified digital agency in Plantation, FL. Custom web design, SEO, and digital marketing for South Florida businesses across Miami-Dade, Broward, and Palm Beach.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/"
  jsonLdType="home"
  screenLabel="Home"
>
<main>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" data-screen-label="01 Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <h1>Web Design &amp; Digital Marketing Agency in South Florida</h1>
      <p>We build high-performing websites and SEO-driven marketing systems for businesses across Miami-Dade, Broward, and Palm Beach counties. Based in Plantation, Florida, we help brands rank higher, convert more traffic, and scale faster.</p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">Book a Free Call</a>
    </div>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        <div class="ph-logo">Pergola Plus</div>
        <div class="ph-logo">Lake Scaping</div>
        <div class="ph-logo">AB Aluminum</div>
        <div class="ph-logo">ANGELE GLOW</div>
        <div class="ph-logo">Mr. &amp; Mrs.</div>
        <div class="ph-logo">GQM Inc.</div>
        <div class="ph-logo">Orchid Roofing</div>
        <div class="ph-logo">Sunline Pools</div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO — Premier Web Design & Marketing Agency
       ============================================================ -->
  <section class="intro" data-screen-label="02 Intro">
    <video class="intro-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/bg-video-poster.jpg">
      <source src="/videos/bg-video.mp4" type="video/mp4">
    </video>
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Premier Web Design &amp; Marketing Agency in South Florida</h2>
        <p>We are a web design and digital marketing agency based in Miami, offering responsive websites, e-commerce solutions, and SEO strategies designed to drive growth.</p>
      </div>
      <div class="video-frame" data-reveal>
        <iframe src="https://www.youtube.com/embed/T2MHMFoFvbk?rel=0" title="SENAVIA Corp — Agency reel"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SERVICES
       ============================================================ -->
  <section id="services" class="section" data-screen-label="03 Services">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Digital Services Designed To Grow Your Business In South Florida</h2>
        <p>From custom web design to digital marketing and custom software development — SENAVIA Corp delivers end-to-end digital solutions that help South Florida businesses attract more customers, rank higher on Google, and scale revenue faster.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="card-border is-purple">
          <a class="card-glass service-link" href="/services/web-design">
            <span class="svc-icon"><img src="/images/Web-Design-Icon.svg" alt=""></span>
            <h3 style="margin-top:18px;">Web Design</h3>
            <p style="font-size:14px;color:rgba(255,255,255,0.75);margin:0 0 12px;">Modern, responsive, SEO-optimized websites that convert visitors into customers and strengthen your brand authority across South Florida.</p>
            <span class="more">See More</span>
          </a>
        </article>
        <article class="card-border is-cyan">
          <a class="card-glass service-link" href="/services/digital-marketing">
            <span class="svc-icon is-cyan"><img src="/images/Marketing-Icon.svg" alt=""></span>
            <h3 style="margin-top:18px;">Digital Marketing</h3>
            <p style="font-size:14px;color:rgba(255,255,255,0.75);margin:0 0 12px;">SEO, Google Ads, and data-driven marketing strategies that attract qualified traffic and generate leads for local businesses.</p>
            <span class="more">See More</span>
          </a>
        </article>
        <article class="card-border is-green">
          <a class="card-glass service-link" href="/services/web-development">
            <span class="svc-icon is-green"><img src="/images/Development-Icon.svg" alt=""></span>
            <h3 style="margin-top:18px;">Web Development</h3>
            <p style="font-size:14px;color:rgba(255,255,255,0.75);margin:0 0 12px;">Scalable web solutions in Webflow, Shopify, and custom systems — engineered for performance, conversion, and growth.</p>
            <span class="more">See More</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO carousel
       ============================================================ -->
  <section id="portfolio" class="section" data-screen-label="04 Portfolio">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Web Design, Development &amp; Marketing Projects</h2>
        <p>Explore our web design projects across South Florida — custom digital experiences built to elevate UX, boost conversions, and increase visibility.</p>
      </div>

      <div class="carousel" data-carousel="portfolio">
        <div class="carousel-arrows">
          <button class="carousel-arrow prev" aria-label="Previous projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
          </button>
          <button class="carousel-arrow next" aria-label="Next projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
        <div class="carousel-viewport">
          <div class="carousel-track" role="list">
          <article class="project-card" role="listitem">
            <a href="/portfolio/pergola-plus-florida" class="project-cover ph-1" aria-label="Pergola Plus Florida — Outdoor Living">
              <span class="project-name">Pergola Plus Florida</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Outdoor Living · Service Site</p>
              <p>Outdoor living brand site with quote request flow, gallery, and local SEO — built to capture pergola buyers across South Florida.</p>
              <a href="/portfolio/pergola-plus-florida" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/portfolio/lake-scaping" class="project-cover ph-2" aria-label="Lake Scaping LLC">
              <span class="project-name">Lake Scaping LLC</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Landscaping · Lead Generation</p>
              <p>Landscaping company website with service area pages, before/after gallery, and an automated lead-to-CRM workflow.</p>
              <a href="/portfolio/lake-scaping" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/portfolio/ab-aluminum" class="project-cover ph-3" aria-label="AB Aluminum & Screens">
              <span class="project-name">AB Aluminum &amp; Screens</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Home Improvement · Webflow</p>
              <p>Home improvement contractor site with screen-enclosure product showcase, financing CTA, and Google Ads landing pages.</p>
              <a href="/portfolio/ab-aluminum" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/portfolio/angele-glow" class="project-cover ph-4" aria-label="ANGELE GLOW Skincare">
              <span class="project-name">ANGELE GLOW</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Skincare · Shopify E-commerce</p>
              <p>Skincare e-commerce on Shopify with custom UI, subscription bundles, and a wholesale portal for spa partners.</p>
              <a href="/portfolio/angele-glow" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/portfolio/mr-mrs-outdoor" class="project-cover ph-5" aria-label="Mr. & Mrs. Outdoor Living">
              <span class="project-name">Mr. &amp; Mrs. Outdoor Living</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Outdoor · Service & Booking</p>
              <p>Service-area website with itemized quote tool, project map across Broward, and integrated booking calendar.</p>
              <a href="/portfolio/mr-mrs-outdoor" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/portfolio/gqm-inc" class="project-cover ph-6" aria-label="GQM Inc. Custom Admin Panel">
              <span class="project-name">GQM Inc.</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Internal Tool · Custom Admin Panel</p>
              <p>Custom admin panel for internal operations: project tracking, client billing, and reporting dashboards.</p>
              <a href="/portfolio/gqm-inc" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
        </div>
        </div>
        <div class="carousel-scrollbar" role="presentation">
          <div class="carousel-scrollbar-thumb"></div>
        </div>
      </div>

      <div class="center-cta">
        <a href="/portfolio" class="btn">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROCESS + REVIEWS (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <!-- PROCESS -->
    <section id="process" class="section section-flush" data-screen-label="05 Process">
      <div class="container">
        <div class="section-head" data-reveal>
          <h2>Our Process</h2>
          <p>We understand your goals and challenges, create a tailored plan with clear estimates, and build a custom solution designed for your success.</p>
        </div>
        <div class="grid-4" data-reveal-children>
          <article class="process-block">
            <img class="process-img" src="/images/process/explore.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>1. Explore</h3>
                <h4>Digital Strategy &amp; Market Discovery</h4>
              </div>
              <p>We analyze goals, audience, and market to uncover growth opportunities across South Florida.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/estimate.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>2. Estimate</h3>
                <h4>Project Planning &amp; Strategic Roadmap</h4>
              </div>
              <p>We define a clear project plan aligned with your budget, timeline, and objectives.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/development.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>3. Development</h3>
                <h4>Custom Web Development &amp; SEO</h4>
              </div>
              <p>We build high-performance websites and platforms optimized for SEO and conversions.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/delivery.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>4. Delivery</h3>
                <h4>Website Launch &amp; Ongoing Optimization</h4>
              </div>
              <p>We launch and optimize your digital presence from Plantation, serving South Florida.</p>
            </div>
          </article>
        </div>
        <div class="center-cta" style="margin-top: 3rem;" data-reveal>
          <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">Book a Free Call</a>
        </div>
      </div>
    </section>

    <!-- GOOGLE REVIEWS -->
    <section id="reviews" class="section" data-screen-label="06 Google Reviews">
      <div class="container">
        <div class="reviews-grid">
          <div class="reviews-left" data-reveal>
            <h2>Google Reviews</h2>
            <p>Based in Plantation, we deliver custom web design and SEO that help South Florida companies grow. Hear what our clients say about working with the SENAVIA team.</p>
            <div class="reviews-rating">
              <span class="score">
                5.0
                <span class="score-stars" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </span>
              </span>
              <span class="score-meta">From <strong>47 verified reviews</strong> on Google</span>
            </div>
            <div class="reviews-cta-row">
              <a href="https://www.google.com/search?q=senavia+corp+plantation+reviews" target="_blank" rel="noopener" class="btn is-sm">Read All Reviews</a>
            </div>
          </div>
          <div class="reviews-card" data-reveal data-elfsight-app-id="d2ce1169-e2c8-43d7-873d-f9e6f7bc1e07">
            <div class="review-item">
              <div class="review-stars" role="img" aria-label="5 out of 5 stars">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div class="review-head">
                <span class="review-name">Carlos Rivera</span>
                <span class="review-date">2 weeks ago</span>
              </div>
              <p class="review-text">Senavia rebuilt our roofing company website and within two months we doubled our qualified leads. The team is detail-oriented, communicative, and clearly knows local SEO inside out.</p>
            </div>
            <div class="review-item">
              <div class="review-stars" role="img" aria-label="5 out of 5 stars">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div class="review-head">
                <span class="review-name">Maria Gonzalez</span>
                <span class="review-date">1 month ago</span>
              </div>
              <p class="review-text">Their design work elevated our brand instantly — modern, fast, and converting. We've climbed three Google ranking positions for our main keywords since launch. Highly recommend.</p>
            </div>
            <div class="review-item">
              <div class="review-stars" role="img" aria-label="5 out of 5 stars">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div class="review-head">
                <span class="review-name">James Patterson</span>
                <span class="review-date">3 months ago</span>
              </div>
              <p class="review-text">Best agency decision we've made. Communication is fast, the SEO strategy actually drives traffic, and the website performs in Core Web Vitals. Real partners, not just vendors.</p>
            </div>
            <div class="google-badge">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.5 12.27c0-.79-.07-1.55-.2-2.27H12v4.3h5.92c-.25 1.37-1.03 2.53-2.2 3.31v2.75h3.56c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.75c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.12A6.6 6.6 0 0 1 5.5 12c0-.74.13-1.45.34-2.12V7.04H2.18A10.97 10.97 0 0 0 1 12c0 1.78.43 3.47 1.18 4.96l3.66-2.84z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.65l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.04l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
              </svg>
              <span>Powered by Google · 5.0 ★ from 47 reviews</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================================
       BLOG carousel
       ============================================================ -->
  <section id="blog" class="section" data-screen-label="07 Blog">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Blog &amp; Tips</h2>
        <p>Expert insights on web development, SEO, digital marketing, and automation to grow traffic and stay competitive in South Florida.</p>
      </div>

      <div class="carousel" data-carousel="blog">
        <div class="carousel-arrows">
          <button class="carousel-arrow prev" aria-label="Previous posts" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
          </button>
          <button class="carousel-arrow next" aria-label="Next posts" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
        <div class="carousel-viewport">
          <div class="carousel-track" role="list">
          <article class="blog-card" role="listitem">
            <h3>How to Choose a Web Design Agency in Miami (2026 Guide)</h3>
            <p class="excerpt">Vetting an agency goes beyond portfolio screenshots. Here's the framework we use with new South Florida clients to make sure design, SEO, and growth all align.</p>
            <div class="cover"></div>
            <div class="meta">
              <span>Aug 14, 2025</span><span class="dot"></span><span>5 min read</span>
            </div>
          </article>
          <article class="blog-card" role="listitem">
            <h3>Local SEO Strategy for South Florida Contractors</h3>
            <p class="excerpt">From service-area pages to Google Business Profile optimization — the tactics that move contractors into the local 3-pack for high-intent queries.</p>
            <div class="cover"></div>
            <div class="meta">
              <span>Jul 30, 2025</span><span class="dot"></span><span>7 min read</span>
            </div>
          </article>
          <article class="blog-card" role="listitem">
            <h3>Google Ads vs Meta Ads: Which Drives More Leads in 2026?</h3>
            <p class="excerpt">We pulled twelve months of campaign data across our clients to find the real winner per industry — and where you should split your spend.</p>
            <div class="cover"></div>
            <div class="meta">
              <span>Jul 18, 2025</span><span class="dot"></span><span>6 min read</span>
            </div>
          </article>
          <article class="blog-card" role="listitem">
            <h3>Core Web Vitals: What Every Business Owner Should Know</h3>
            <p class="excerpt">A non-technical breakdown of LCP, INP, and CLS — what they measure, why Google ranks on them, and how to fix the most common issues.</p>
            <div class="cover"></div>
            <div class="meta">
              <span>Jun 28, 2025</span><span class="dot"></span><span>4 min read</span>
            </div>
          </article>
          <article class="blog-card" role="listitem">
            <h3>AEO &amp; GEO — Ranking in AI Search Engines</h3>
