---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = "SENAVIA Corp — Web Design & Digital Marketing Agency in South Florida";
const description = "Google Partner-certified digital agency in Plantation, FL. Custom web design, SEO, and digital marketing for South Florida businesses across Miami-Dade, Broward, and Palm Beach.";

/* Tool / integration logos for the hero marquee */
const logos = (await getCollection('logos')).sort((a, b) => a.data.order - b.data.order);

/* First 3 projects: featured first, then CMS order */
const projects = (await getCollection('portfolio'))
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order,
  )
  .slice(0, 3);

/* 2 most recent blog posts by publish date */
const posts = (await getCollection('blog'))
  .sort((a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0))
  .slice(0, 2);

const fmtEn = (d?: Date) =>
  d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
const fmtEs = (d?: Date) =>
  d ? d.toLocaleDateString('es-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
---
<BaseLayout
  title={title}
  description={description}
  canonical="/"
  jsonLdType="home"
  screenLabel="Home"
>
<main>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" data-screen-label="01 Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <h1><span class="lang-only-en">Web Design &amp; Digital Marketing Agency in South Florida</span><span class="lang-only-es">Agencia de Diseño Web y Marketing Digital en el Sur de Florida</span></h1>
      <p><span class="lang-only-en">We build high-performing websites and SEO-driven marketing systems for businesses across Miami-Dade, Broward, and Palm Beach counties. Based in Plantation, Florida, we help brands rank higher, convert more traffic, and scale faster.</span><span class="lang-only-es">Creamos sitios web de alto rendimiento y sistemas de marketing impulsados por SEO para empresas en los condados de Miami-Dade, Broward y Palm Beach. Desde Plantation, Florida, ayudamos a las marcas a posicionarse mejor, convertir más tráfico y crecer más rápido.</span></p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;"><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
    </div>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {logos.map((l) => (
          <img class="marquee-logo" src={l.data.logo} alt={l.data.name} loading="lazy" decoding="async" />
        ))}
        {logos.map((l) => (
          <img class="marquee-logo" src={l.data.logo} alt={l.data.name} loading="lazy" decoding="async" />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO — Premier Web Design & Marketing Agency
       ============================================================ -->
  <section class="intro" data-screen-label="02 Intro">
    <video class="intro-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/bg-video-poster.jpg">
      <source src="/videos/bg-video.mp4" type="video/mp4">
    </video>
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Premier Web Design &amp; Marketing Agency in South Florida</span><span class="lang-only-es">Agencia Líder de Diseño Web y Marketing en el Sur de Florida</span></h2>
        <p><span class="lang-only-en">We are a web design and digital marketing agency based in Miami, offering responsive websites, e-commerce solutions, and SEO strategies designed to drive growth.</span><span class="lang-only-es">Somos una agencia de diseño web y marketing digital con base en Miami, que ofrece sitios web responsivos, soluciones de e-commerce y estrategias de SEO diseñadas para impulsar el crecimiento.</span></p>
      </div>
      <div class="video-frame" data-reveal>
        <iframe src="https://www.youtube.com/embed/T2MHMFoFvbk?rel=0" title="SENAVIA Corp — Agency reel"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SERVICES
       ============================================================ -->
  <section id="services" class="section" data-screen-label="03 Services">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Digital Services Designed To Grow Your Business In South Florida</span><span class="lang-only-es">Servicios Digitales Diseñados Para Hacer Crecer tu Negocio en el Sur de Florida</span></h2>
