---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PortfolioCarousel from '@/components/PortfolioCarousel.astro';
import BlogCarousel from '@/components/BlogCarousel.astro';
import ProcessTestimonials from '@/components/ProcessTestimonials.astro';
import TrustBadges from '@/components/TrustBadges.astro';

const title = "SENAVIA Corp — Custom Web Design & Web Development Agency in South Florida";
const description = "Bilingual digital agency in Plantation, FL. Custom web design, web development, and traffic generation (SEO, SEM & GEO) for South Florida businesses across Miami-Dade, Broward, and Palm Beach.";

/* Tool / integration logos for the hero marquee */
const logos = (await getCollection('logos')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title={title}
  description={description}
  canonical="/"
  jsonLdType="home"
  screenLabel="Home"
>
<main>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" data-screen-label="01 Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <TrustBadges />
      <h1><span class="lang-only-en">Custom Web Design &amp; Web Development Agency in South Florida</span><span class="lang-only-es">Agencia de Diseño Web Personalizado y Desarrollo Web en el Sur de Florida</span></h1>
      <p><span class="lang-only-en">We design high-performing websites, build custom systems, and generate the traffic that grows businesses across Miami-Dade, Broward, and Palm Beach counties. Based in Plantation, Florida, we help brands rank higher, convert more traffic, and scale faster.</span><span class="lang-only-es">Diseñamos sitios web de alto rendimiento, construimos sistemas personalizados y generamos el tráfico que hace crecer a las empresas en los condados de Miami-Dade, Broward y Palm Beach. Desde Plantation, Florida, ayudamos a las marcas a posicionarse mejor, convertir más tráfico y crecer más rápido.</span></p>
      <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
    </div>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {logos.map((l) => (
          <img class="marquee-logo" src={l.data.logo} alt={l.data.name} width="140" height="40" decoding="async" />
        ))}
        {logos.map((l) => (
          <img class="marquee-logo" src={l.data.logo} alt={l.data.name} width="140" height="40" loading="lazy" decoding="async" />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO — Premier Web Design & Marketing Agency
       ============================================================ -->
  <section class="intro" data-screen-label="02 Intro">
    <video class="intro-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/bg-video-poster.jpg">
      <source src="/videos/bg-video.mp4" type="video/mp4">
    </video>
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Premier Custom Web Design &amp; Development Agency in South Florida</span><span class="lang-only-es">Agencia Líder de Diseño Web Personalizado y Desarrollo en el Sur de Florida</span></h2>
        <p><span class="lang-only-en">We are a custom web design and development agency based in South Florida, delivering conversion-focused websites, custom systems, and traffic generation (SEO, SEM &amp; GEO) designed to drive growth.</span><span class="lang-only-es">Somos una agencia de diseño web personalizado y desarrollo con base en el Sur de Florida, que ofrece sitios web enfocados en conversión, sistemas personalizados y generación de tráfico (SEO, SEM y GEO) diseñados para impulsar el crecimiento.</span></p>
      </div>
      <div class="video-frame" data-reveal>
        <button class="yt-lite" type="button" data-yt-facade="T2MHMFoFvbk"
                aria-label="Play video — SENAVIA Corp agency reel"
                style="background-image:url('/images/agency-reel-poster.jpg')">
          <span class="yt-lite-play" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SERVICES
       ============================================================ -->
  <section id="services" class="section" data-screen-label="03 Services">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Digital Services Designed To Grow Your Business In South Florida</span><span class="lang-only-es">Servicios Digitales Diseñados Para Hacer Crecer tu Negocio en el Sur de Florida</span></h2>
        <p><span class="lang-only-en">From custom web design to web development and traffic generation — SENAVIA Corp delivers end-to-end digital solutions that help South Florida businesses attract more customers, rank higher on Google, and scale revenue faster.</span><span class="lang-only-es">Desde diseño web personalizado hasta desarrollo web y generación de tráfico — SENAVIA Corp ofrece soluciones digitales integrales que ayudan a las empresas del Sur de Florida a atraer más clientes, posicionarse mejor en Google y aumentar sus ingresos más rápido.</span></p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="card-border is-purple">
          <a class="card-glass service-link" href="/services/web-design">
            <span class="svc-icon"><img src="/images/Web-Design-Icon.svg" alt=""></span>
            <h3 style="margin-top:18px;"><span class="lang-only-en">Custom Web Design</span><span class="lang-only-es">Diseño Web Personalizado</span></h3>
            <p style="font-size:14px;color:rgba(255,255,255,0.75);margin:0 0 12px;"><span class="lang-only-en">Conversion-focused custom sites, CMS &amp; e-commerce that turn visitors into customers and strengthen your brand authority across South Florida.</span><span class="lang-only-es">Sitios personalizados enfocados en conversión, CMS y e-commerce que convierten visitantes en clientes y fortalecen la autoridad de tu marca en todo el Sur de Florida.</span></p>
            <span class="more"><span class="lang-only-en">See More</span><span class="lang-only-es">Ver Más</span></span>
          </a>
        </article>
        <article class="card-border is-cyan">
          <a class="card-glass service-link" href="/services/traffic-generation">
            <span class="svc-icon is-cyan"><img src="/images/Marketing-Icon.svg" alt=""></span>
            <h3 style="margin-top:18px;"><span class="lang-only-en">Traffic Generation</span><span class="lang-only-es">Generación de Tráfico</span></h3>
            <p style="font-size:14px;color:rgba(255,255,255,0.75);margin:0 0 12px;"><span class="lang-only-en">SEO, SEM &amp; GEO to capture organic, paid &amp; AI traffic — data-driven strategies that attract qualified visitors and generate leads.</span><span class="lang-only-es">SEO, SEM y GEO para captar tráfico orgánico, pago y de IA — estrategias basadas en datos que atraen visitantes calificados y generan clientes potenciales.</span></p>
            <span class="more"><span class="lang-only-en">See More</span><span class="lang-only-es">Ver Más</span></span>
          </a>
        </article>
        <article class="card-border is-green">
          <a class="card-glass service-link" href="/services/web-development">
            <span class="svc-icon is-green"><img src="/images/Development-Icon.svg" alt=""></span>
            <h3 style="margin-top:18px;"><span class="lang-only-en">Web Development</span><span class="lang-only-es">Desarrollo Web</span></h3>
            <p style="font-size:14px;color:rgba(255,255,255,0.75);margin:0 0 12px;"><span class="lang-only-en">Admin panels, CRM/ERP portals &amp; workflow automation — scalable systems engineered for performance, conversion, and growth.</span><span class="lang-only-es">Paneles administrativos, portales CRM/ERP y automatización de flujos de trabajo — sistemas escalables diseñados para el rendimiento, la conversión y el crecimiento.</span></p>
            <span class="more"><span class="lang-only-en">See More</span><span class="lang-only-es">Ver Más</span></span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO carousel
       ============================================================ -->
  <PortfolioCarousel />

  <!-- ============================================================
       PROCESS + REVIEWS (inside .green-bg)
       ============================================================ -->
  <ProcessTestimonials />

  <!-- ============================================================
       BLOG carousel
       ============================================================ -->
  <BlogCarousel />

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="08 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Let's Build Your Next Digital Success Story</span><span class="lang-only-es">Construyamos tu Próxima Historia de Éxito Digital</span></h2>
      <p><span class="lang-only-en">Schedule your free web design &amp; SEO consultation and get a custom strategy to increase traffic, leads, and conversions.</span><span class="lang-only-es">Agenda tu consulta gratuita de diseño web y SEO, y obtén una estrategia a la medida para aumentar el tráfico, los prospectos y las conversiones.</span></p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>

<style is:global>
  /* ---- Hero marquee: real colored tool logos on a full-width white band ---- */
  .marquee .marquee-track { gap: 4rem; }
  .marquee-track img.marquee-logo {
    height: 40px;
    width: 140px;                 /* fixed slot: zero CLS while logos load */
    flex: 0 0 auto;
    opacity: 1;
    filter: none;                 /* keep brand color of the logos */
    object-fit: contain;
  }
  @media (max-width: 700px) {
    .marquee .marquee-track { gap: 2.5rem; }
    .marquee-track img.marquee-logo { height: 32px; width: 112px; }
  }

  /* ---- Project card cover: real CMS image fills the frame ---- */
  .project-cover.has-img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Readability scrim so the project name stays legible over photos */
  .project-cover.has-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,14,38,0.05) 0%, rgba(10,14,38,0.55) 100%);
    z-index: 1;
  }
  .project-cover.has-img .project-name { z-index: 2; }

  /* ---- Blog card rendered as a link ---- */
  a.blog-card { text-decoration: none; color: inherit; }
  a.blog-card:hover { text-decoration: none; }
</style>

<script>
  // Click-to-load the agency reel: swap the facade for the real YouTube iframe
  // only when the visitor presses play.
  document.querySelectorAll('[data-yt-facade]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-yt-facade');
      var f = document.createElement('iframe');
      f.src = 'https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0';
      f.title = 'SENAVIA Corp — Agency reel';
      f.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      f.setAttribute('allowfullscreen', '');
      btn.replaceWith(f);
    });
  });
</script>
</BaseLayout>
