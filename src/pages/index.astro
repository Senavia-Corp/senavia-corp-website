            <div class="google-badge">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.5 12.27c0-.79-.07-1.55-.2-2.27H12v4.3h5.92c-.25 1.37-1.03 2.53-2.2 3.31v2.75h3.56c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.75c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.12A6.6 6.6 0 0 1 5.5 12c0-.74.13-1.45.34-2.12V7.04H2.18A10.97 10.97 0 0 0 1 12c0 1.78.43 3.47 1.18 4.96l3.66-2.84z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.65l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.04l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
              </svg>
              <span><span class="lang-only-en">Powered by Google · 5.0 ★ from 47 reviews</span><span class="lang-only-es">Con tecnología de Google · 5.0 ★ de 47 reseñas</span></span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================================
       BLOG carousel
       ============================================================ -->
  <section id="blog" class="section section--band" data-screen-label="07 Blog">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Blog &amp; Tips</span><span class="lang-only-es">Blog y Consejos</span></h2>
        <p><span class="lang-only-en">Expert insights on web development, SEO, digital marketing, and automation to grow traffic and stay competitive in South Florida.</span><span class="lang-only-es">Perspectivas de expertos sobre desarrollo web, SEO, marketing digital y automatización para aumentar el tráfico y mantenerte competitivo en el Sur de Florida.</span></p>
      </div>

      <div class="carousel" data-carousel="blog">
        <div class="carousel-arrows">
          <button class="carousel-arrow prev" aria-label="Previous posts" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
          </button>
          <button class="carousel-arrow next" aria-label="Next posts" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
        <div class="carousel-viewport">
          <div class="carousel-track" role="list">
          {posts.map((post) => (
            <a class="blog-card" role="listitem" href={`/blog/${post.id}`}>
              <div class="cover">
                {post.data.thumbnail && (
                  <img src={post.data.thumbnail} alt={post.data.altImage} loading="lazy" decoding="async" />
                )}
              </div>
              <h3>{post.data.title}</h3>
              <p class="excerpt">{post.data.summary}</p>
              <div class="meta">
                <span><span class="lang-only-en">{fmtEn(post.data.pubDate)}</span><span class="lang-only-es">{fmtEs(post.data.pubDate)}</span></span>
                {post.data.category && (<><span class="dot"></span><span>{post.data.category}</span></>)}
              </div>
            </a>
          ))}
        </div>
        </div>
        <div class="carousel-scrollbar" role="presentation">
          <div class="carousel-scrollbar-thumb"></div>
        </div>
      </div>

      <div class="center-cta">
        <a href="/blog" class="btn is-secondary"><span class="lang-only-en">View All Blogs</span><span class="lang-only-es">Ver Todos los Artículos</span></a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="08 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Let's Build Your Next Digital Success Story</span><span class="lang-only-es">Construyamos tu Próxima Historia de Éxito Digital</span></h2>
      <p><span class="lang-only-en">Schedule your free web design &amp; SEO consultation and get a custom strategy to increase traffic, leads, and conversions.</span><span class="lang-only-es">Agenda tu consulta gratuita de diseño web y SEO, y obtén una estrategia a la medida para aumentar el tráfico, los prospectos y las conversiones.</span></p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>

<style is:global>
  /* ---- Hero marquee: real colored tool logos on navy ---- */
  .marquee-track img.marquee-logo {
    height: 30px;
    width: auto;
    flex: 0 0 auto;
    opacity: 0.85;
    filter: none;                 /* keep brand color of SVG logos */
    object-fit: contain;
  }
  @media (max-width: 700px) {
    .marquee-track img.marquee-logo { height: 26px; }
  }

  /* ---- Project card cover: real CMS image fills the frame ---- */
  .project-cover.has-img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Readability scrim so the project name stays legible over photos */
  .project-cover.has-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,14,38,0.05) 0%, rgba(10,14,38,0.55) 100%);
    z-index: 1;
  }
  .project-cover.has-img .project-name { z-index: 2; }

  /* ---- Blog card rendered as a link ---- */
  a.blog-card { text-decoration: none; color: inherit; }
  a.blog-card:hover { text-decoration: none; }
</style>
</BaseLayout>
