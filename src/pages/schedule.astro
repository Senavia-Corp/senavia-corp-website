---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Schedule a Consultation — SENAVIA Corp · Book a Free 30-Minute Call";
const description = "Book a free 30-minute consultation with the SENAVIA team. Pick a time from the live Calendly calendar — no back-and-forth required.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/schedule"
  jsonLdType="home"
  screenLabel="Schedule"
>
<style is:global data-recovered>
.hero.is-compact + .section { padding-top: 4rem; }
  .sch-wrap { max-width: 980px; margin: 0 auto; }
  .sch-frame {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(13,18,53,0.7), rgba(11,15,35,0.55)) padding-box,
      linear-gradient(160deg, rgba(153,204,51,0.3), rgba(255,255,255,0.04) 50%, rgba(51,204,204,0.18)) border-box;
    border: 1px solid transparent;
    backdrop-filter: blur(12px);
    min-height: 780px;
    padding: 0;
  }
  #calendlyInline { min-height: 780px; }
  #calendlyInline iframe { width: 100%; min-height: inherit; border: 0; }
  .sch-fallback {
    position: absolute; inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: rgba(255,255,255,0.6);
    font-size: 14px;
    text-align: center;
    padding: 2rem;
    z-index: 1;
    pointer-events: none;
  }
  .sch-fallback .ic {
    width: 56px; height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(153,204,51,0.18), rgba(51,204,204,0.1));
    border: 1px solid rgba(153,204,51,0.3);
    color: var(--primary, #99cc33);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .sch-fallback .ic svg { width: 26px; height: 26px; }
  .sch-fallback strong { color: #fff; font-weight: 500; font-size: 16px; }
  .sch-fallback p { margin: 0; max-width: 380px; line-height: 1.55; color: rgba(255,255,255,0.55); }

  /* Benefits row under embed */
  .sch-perks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 2rem;
  }
  @media (max-width: 720px) { .sch-perks { grid-template-columns: 1fr; } }
  .sch-perk {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
  }
  .sch-perk .ic {
    width: 32px; height: 32px;
    flex: 0 0 32px;
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(153,204,51,0.16), rgba(51,204,204,0.1));
    border: 1px solid rgba(153,204,51,0.3);
    color: var(--primary, #99cc33);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .sch-perk .ic svg { width: 16px; height: 16px; }
  .sch-perk h3 {
    margin: 0 0 4px;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    text-transform: none;
    letter-spacing: -0.005em;
  }
  .sch-perk p {
    margin: 0;
    font-size: 12.5px;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
    max-width: none;
  }
</style>

<main>
  <section class="hero is-compact" data-screen-label="01 Schedule Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">30 minutes · No commitment</span><span class="lang-only-es">30 minutos · Sin compromiso</span></div>
      <h1><span class="lang-only-en">Schedule a Free Consultation</span><span class="lang-only-es">Agenda una Consulta Gratis</span></h1>
      <p><span class="lang-only-en">Pick a 30-minute slot from the live calendar below. We'll review your project, identify the biggest wins, and outline what's possible.</span><span class="lang-only-es">Elige un espacio de 30 minutos en el calendario en vivo. Revisaremos tu proyecto, identificaremos las mayores oportunidades y delinearemos lo que es posible.</span></p>
    </div>
  </section>

  <section class="section section--band" data-screen-label="02 Calendar">
    <div class="container">
      <div class="sch-wrap">
        <div class="sch-frame">
          <div id="calendlyInline" role="region" aria-label="Schedule a meeting"></div>
          <div class="sch-fallback" id="calendlyFallback">
            <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg></span>
            <strong><span class="lang-only-en">Loading availability…</span><span class="lang-only-es">Cargando disponibilidad…</span></strong>
            <p><span class="lang-only-en">Pick a 30-minute slot from the Calendly grid once it loads. If it doesn't appear, refresh or call us directly.</span><span class="lang-only-es">Elige un espacio de 30 minutos en el calendario de Calendly una vez que cargue. Si no aparece, actualiza la página o llámanos directamente.</span></p>
          </div>
        </div>

        <div class="sch-perks">
          <div class="sch-perk">
            <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
            <div>
              <h3><span class="lang-only-en">Quick site &amp; SEO audit</span><span class="lang-only-es">Auditoría rápida de sitio y SEO</span></h3>
              <p><span class="lang-only-en">We'll review your current funnel and flag the highest-impact fixes — yours to keep either way.</span><span class="lang-only-es">Revisaremos tu embudo actual y señalaremos las mejoras de mayor impacto — tuyas para conservar en cualquier caso.</span></p>
            </div>
          </div>
          <div class="sch-perk">
            <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
            <div>
              <h3><span class="lang-only-en">Actionable next steps</span><span class="lang-only-es">Próximos pasos accionables</span></h3>
              <p><span class="lang-only-en">Tailored recommendations you can implement whether we work together or not.</span><span class="lang-only-es">Recomendaciones a tu medida que puedes implementar, trabajemos juntos o no.</span></p>
            </div>
          </div>
          <div class="sch-perk">
            <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
            <div>
              <h3><span class="lang-only-en">Zero sales pitch</span><span class="lang-only-es">Cero discurso de ventas</span></h3>
              <p><span class="lang-only-en">Expert eyes on your project — focused on what's best for your business, not ours.</span><span class="lang-only-es">Ojos expertos en tu proyecto — enfocados en lo mejor para tu negocio, no para el nuestro.</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta" data-screen-label="03 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Calendar Not Working for You?</span><span class="lang-only-es">¿El Calendario No Te Funciona?</span></h2>
      <p><span class="lang-only-en">Call us directly and we'll find a time live.</span><span class="lang-only-es">Llámanos directamente y encontramos una hora en vivo.</span></p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>
</main>

<script>
  // Hide fallback once Calendly mounts
  (function(){
    var el = document.getElementById('calendlyInline');
    var ph = document.getElementById('calendlyFallback');
    if (!el || !ph) return;
    var obs = new MutationObserver(function(){
      if (el.children.length > 0) {
        ph.style.display = 'none';
        obs.disconnect();
      }
    });
    obs.observe(el, { childList: true });
    setTimeout(function(){ obs.disconnect(); }, 8000);
  })();
</script>

<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el) return;
    function init() {
      if (!window.Calendly) { setTimeout(init, 200); return; }
      window.Calendly.initInlineWidget({
        url: 'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon?hide_landing_page_details=1&hide_gdpr_banner=1&background_color=0a0e26&text_color=ffffff&primary_color=99cc33',
        parentElement: el,
        prefill: {}, utm: {}
      });
      // Mark loaded after a beat
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    init();
  })();
</script>

<!-- Language switcher -->
</BaseLayout>
