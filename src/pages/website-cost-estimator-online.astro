---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Estimator from '@/components/Estimator';
const title = "Website Cost Estimator — SENAVIA Corp · Get an Instant Project Quote";
const description = "Get a custom estimate for your website project in under 2 minutes. Free, no commitment — pick your project type, features, and timeline.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/website-cost-estimator-online"
  jsonLdType="home"
  screenLabel="Cost Estimator"
>
<style is:global data-recovered>
/* ============================================================
     ESTIMATOR PAGE
     ============================================================ */
  .hero.is-compact + .section { padding-top: 3rem; }

  .est-wrap { max-width: 920px; margin: 0 auto; }

  /* ===== PROGRESS BAR ===== */
  .est-progress { margin-bottom: 2.5rem; }
  .est-progress-track {
    position: relative;
    height: 4px;
    background: rgba(255,255,255,0.06);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }
  .est-progress-fill {
    position: absolute;
    inset: 0 auto 0 0;
    background: linear-gradient(90deg, #99CC33 0%, #33CCCC 100%);
    box-shadow: 0 0 12px rgba(153,204,51,0.5);
    border-radius: 999px;
    transition: width .4s cubic-bezier(.2,.6,.2,1);
  }
  .est-progress-steps {
    display: flex;
    justify-content: space-between;
    gap: 4px;
  }
  .est-step-dot {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 4px 6px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;
    min-width: 0;
    transition: opacity .2s ease;
  }
  .est-step-dot:disabled { cursor: not-allowed; opacity: 0.5; }
  .est-step-num {
    width: 24px; height: 24px;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.55);
    font-size: 12px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    border: 1px solid rgba(255,255,255,0.1);
    transition: all .25s ease;
  }
  .est-step-dot.is-active .est-step-num {
    background: var(--primary, #99cc33);
    color: #0a0e26;
    border-color: var(--primary, #99cc33);
    box-shadow: 0 0 0 4px rgba(153,204,51,0.18);
  }
  .est-step-dot.is-done .est-step-num {
    background: rgba(153,204,51,0.18);
    color: var(--primary, #99cc33);
    border-color: rgba(153,204,51,0.45);
  }
  .est-step-label {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
    white-space: nowrap;
  }
  .est-step-dot.is-active .est-step-label { color: #fff; font-weight: 600; }
  @media (max-width: 580px) {
    .est-step-label { display: none; }
  }

  /* ===== CARD ===== */
  .est-card {
    padding: 3rem 2.5rem;
    background:
      linear-gradient(180deg, rgba(13,18,53,0.7), rgba(11,15,35,0.55)) padding-box,
      linear-gradient(160deg, rgba(153,204,51,0.32), rgba(255,255,255,0.04) 50%, rgba(51,204,204,0.16)) border-box;
    border: 1px solid transparent;
    border-radius: 22px;
    backdrop-filter: blur(12px);
    animation: estIn .35s cubic-bezier(.2,.6,.2,1);
  }
  @keyframes estIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 640px) { .est-card { padding: 2rem 1.5rem; } }

  .est-card .est-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(153,204,51,0.12);
    border: 1px solid rgba(153,204,51,0.32);
    margin-bottom: 18px;
  }
  .est-card h2 {
    margin: 0 0 12px;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.2;
  }
  .est-card .est-lede {
    margin: 0 0 2rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    font-size: 15px;
    max-width: 580px;
  }

  /* ===== STEP 1 — TYPE TILES ===== */
  .est-grid-4 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media (min-width: 800px) { .est-grid-4 { grid-template-columns: repeat(4, 1fr); } }

  .est-tile {
    appearance: none;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    color: inherit;
    padding: 1.5rem 1.25rem 1.25rem;
    border-radius: 14px;
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: all .25s cubic-bezier(.2,.6,.2,1);
  }
  .est-tile:hover {
    border-color: rgba(153,204,51,0.4);
    background: rgba(20,28,60,0.6);
    transform: translateY(-3px);
  }
  .est-tile.is-active {
    border-color: var(--primary, #99cc33);
    background:
      linear-gradient(180deg, rgba(20,38,30,0.7), rgba(11,28,22,0.5));
    box-shadow: 0 0 0 1px rgba(153,204,51,0.25), 0 12px 30px rgba(0,0,0,0.32);
  }
  .est-tile-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(153,204,51,0.18), rgba(51,204,204,0.1));
    border: 1px solid rgba(153,204,51,0.32);
    color: var(--primary, #99cc33);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .est-tile-icon svg { width: 22px; height: 22px; }
  .est-tile-label {
    font-size: 1.0625rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.005em;
  }
  .est-tile-sub {
    font-size: 12.5px;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
    flex: 1;
  }
  .est-tile-price {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    color: var(--primary, #99cc33);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* ===== STEP 2 — PAGES SLIDER ===== */
  .est-pages-display {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 12px;
    margin: 2.5rem 0 2rem;
  }
  .est-pages-num {
    font-size: clamp(4rem, 12vw, 6rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    color: #fff;
    background: linear-gradient(135deg, #fff 0%, #99CC33 80%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .est-pages-unit {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.5);
    font-weight: 400;
  }

  .est-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 999px;
    outline: none;
    margin: 0;
    cursor: pointer;
    background-image: linear-gradient(90deg, #99CC33 0%, #33CCCC 100%);
    background-size: 0% 100%;
    background-repeat: no-repeat;
  }
  .est-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px; height: 22px;
    border-radius: 999px;
    background: #fff;
    border: 4px solid #99CC33;
    cursor: grab;
    box-shadow: 0 4px 14px rgba(153,204,51,0.4);
    transition: transform .15s ease;
  }
  .est-slider::-webkit-slider-thumb:hover { transform: scale(1.15); }
  .est-slider::-moz-range-thumb {
    width: 22px; height: 22px;
    border-radius: 999px;
    background: #fff;
    border: 4px solid #99CC33;
    cursor: grab;
    box-shadow: 0 4px 14px rgba(153,204,51,0.4);
  }
  .est-slider-scale {
    display: flex;
    justify-content: space-between;
    margin-top: 12px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.08em;
  }
  .est-page-meta {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 13.5px;
    color: rgba(255,255,255,0.7);
    flex-wrap: wrap;
  }
  .est-page-meta .accent { color: var(--primary, #99cc33); font-weight: 600; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .est-page-meta .muted  { color: rgba(255,255,255,0.45); font-style: italic; }

  /* ===== STEP 3 — FEATURES ===== */
  .est-feat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  @media (min-width: 720px) { .est-feat-grid { grid-template-columns: repeat(2, 1fr); } }

  .est-feat {
    appearance: none;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    color: inherit;
    padding: 14px 16px;
    border-radius: 12px;
    cursor: pointer;
    text-align: left;
    display: grid;
    grid-template-columns: 22px 1fr auto;
    gap: 12px;
    align-items: start;
    transition: all .2s ease;
  }
  .est-feat:hover {
    background: rgba(20,28,60,0.55);
    border-color: rgba(153,204,51,0.32);
  }
  .est-feat.is-on {
    background: rgba(153,204,51,0.06);
    border-color: rgba(153,204,51,0.5);
  }
  .est-feat-check {
    width: 22px; height: 22px;
    margin-top: 2px;
    border-radius: 6px;
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(255,255,255,0.18);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    transition: all .2s ease;
  }
  .est-feat.is-on .est-feat-check {
    background: var(--primary, #99cc33);
    border-color: var(--primary, #99cc33);
    color: #0a0e26;
  }
  .est-feat-check svg { width: 13px; height: 13px; }
  .est-feat-body { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .est-feat-label { color: #fff; font-size: 14.5px; font-weight: 500; letter-spacing: -0.005em; }
  .est-feat-desc  { color: rgba(255,255,255,0.55); font-size: 12.5px; line-height: 1.4; }
  .est-feat-price {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    font-weight: 600;
    color: var(--primary, #99cc33);
    white-space: nowrap;
    align-self: center;
  }

  /* ===== STEP 4 — TIMELINE ===== */
  .est-tl-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 720px) { .est-tl-grid { grid-template-columns: repeat(2, 1fr); } }

  .est-tl {
    appearance: none;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    color: inherit;
    padding: 1.25rem 1.25rem 1.1rem;
    border-radius: 14px;
    cursor: pointer;
    text-align: left;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    gap: 4px 12px;
    align-items: start;
    transition: all .2s ease;
    position: relative;
  }
  .est-tl:hover { transform: translateY(-2px); border-color: rgba(153,204,51,0.4); background: rgba(20,28,60,0.55); }
  .est-tl.is-active {
    border-color: var(--primary, #99cc33);
    background: linear-gradient(180deg, rgba(20,38,30,0.6), rgba(11,28,22,0.4));
    box-shadow: 0 0 0 1px rgba(153,204,51,0.25);
  }
  .est-tl-badge {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: start;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 999px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .est-tl-badge.tone-warn { background: rgba(240,160,80,0.18); color: #f6b56e; border: 1px solid rgba(240,160,80,0.36); }
  .est-tl-badge.tone-mid  { background: rgba(45,125,184,0.18); color: #79c1ee; border: 1px solid rgba(45,125,184,0.36); }
  .est-tl-badge.tone-good { background: rgba(153,204,51,0.18); color: var(--primary,#99cc33); border: 1px solid rgba(153,204,51,0.42); }
  .est-tl-badge.tone-ok   { background: rgba(123,63,228,0.16); color: #b89bf2; border: 1px solid rgba(123,63,228,0.36); }
  .est-tl-label {
    grid-column: 1;
    grid-row: 1;
    font-size: 1.0625rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.005em;
  }
  .est-tl-sub {
    grid-column: 1;
    grid-row: 2;
    font-size: 13px;
    color: rgba(255,255,255,0.55);
  }
  .est-tl-radio {
    grid-column: 2;
    grid-row: 3;
    align-self: end;
    width: 18px; height: 18px;
    border-radius: 999px;
    border: 1.5px solid rgba(255,255,255,0.2);
    margin-top: 8px;
    position: relative;
  }
  .est-tl.is-active .est-tl-radio { border-color: var(--primary,#99cc33); }
  .est-tl-radio span {
    position: absolute;
    inset: 3px;
    border-radius: 999px;
    background: var(--primary, #99cc33);
  }

  /* ===== STEP 5 — CONTACT FORM ===== */
  .est-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  @media (max-width: 580px) { .est-form { grid-template-columns: 1fr; } }
  .est-field { display: flex; flex-direction: column; gap: 6px; }
  .est-field.full { grid-column: 1 / -1; }
  .est-field label {
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.72);
  }
  .est-field .req { color: var(--primary,#99cc33); margin-left: 2px; }
  .est-field .muted-label { color: rgba(255,255,255,0.4); font-weight: 500; letter-spacing: 0.04em; text-transform: none; margin-left: 4px; }
  .est-field input {
    appearance: none;
    background: rgba(10,14,38,0.55);
    border: 1px solid rgba(255,255,255,0.1);
    color: #fff;
    font: inherit;
    font-size: 14.5px;
    padding: 12px 14px;
    border-radius: 10px;
    transition: border-color .2s ease, background .2s ease;
  }
  .est-field input::placeholder { color: rgba(255,255,255,0.35); }
  .est-field input:focus {
    outline: none;
    border-color: var(--primary,#99cc33);
    background: rgba(10,14,38,0.75);
  }
  .est-err {
    color: #f48cb6;
    font-size: 12px;
    font-weight: 500;
  }

  /* ===== STEP 6 — RESULT ===== */
  .est-result h2 {
    background: linear-gradient(135deg, #fff 0%, #99CC33 80%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .est-result-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 24px;
    align-items: stretch;
  }
  @media (max-width: 820px) { .est-result-grid { grid-template-columns: 1fr; } }

  .est-bd {
    padding: 1.5rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
  }
  .est-bd h3 {
    margin: 0 0 14px;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.6);
    font-weight: 600;
  }
  .est-bd-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .est-bd-list li {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
    font-size: 13.5px;
    color: rgba(255,255,255,0.78);
  }
  .est-bd-list .amt {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
  }
  .est-bd-list .subtotal {
    padding-top: 10px;
    margin-top: 6px;
    border-top: 1px dashed rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.92);
    font-weight: 500;
  }
  .est-bd-list .rush { color: #f6b56e; }
  .est-bd-list .rush .amt { color: #f6b56e; }
  .est-bd-list .tag {
    margin-left: 6px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10.5px;
    padding: 2px 7px;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.55);
  }

  .est-total {
    padding: 1.75rem 1.5rem;
    background:
      linear-gradient(180deg, rgba(20,38,30,0.8), rgba(11,28,22,0.6)) padding-box,
      linear-gradient(160deg, #99cc33, rgba(51,204,204,0.5) 50%, rgba(153,204,51,0.4)) border-box;
    border: 1px solid transparent;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .est-total::before {
    content: '';
    position: absolute;
    top: -50px; right: -50px;
    width: 160px; height: 160px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(153,204,51,0.32) 0%, transparent 65%);
    pointer-events: none;
  }
  .est-total-label {
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--primary,#99cc33);
    font-weight: 600;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    position: relative;
    z-index: 1;
  }
  .est-total-amount {
    font-size: clamp(2.5rem, 7vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #fff;
    margin: 4px 0 4px;
    position: relative;
    z-index: 1;
  }
  .est-total-note {
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    line-height: 1.5;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }
  .est-send {
    appearance: none;
    border: 0;
    background: linear-gradient(135deg, #99cc33 0%, #c1e15a 100%);
    color: #0a0e26;
    font-weight: 600;
    font-size: 14.5px;
    padding: 14px 22px;
    border-radius: 999px;
    cursor: pointer;
    transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    position: relative;
    z-index: 1;
  }
  .est-send:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 30px rgba(153,204,51,0.36);
    filter: brightness(1.05);
  }
  .est-send svg { width: 16px; height: 16px; }
  .est-call {
    color: rgba(255,255,255,0.6);
    font-size: 12.5px;
    text-decoration: none;
    margin-top: 6px;
    padding-top: 12px;
    border-top: 1px dashed rgba(255,255,255,0.1);
    position: relative;
    z-index: 1;
  }
  .est-call:hover { color: #fff; }

  .est-sent {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 1rem 0 0;
    color: rgba(255,255,255,0.85);
    font-size: 13.5px;
    position: relative;
    z-index: 1;
  }
  .est-sent strong { color: #fff; font-weight: 500; font-size: 14.5px; }
  .est-sent-icon {
    width: 44px; height: 44px;
    border-radius: 999px;
    background: rgba(153,204,51,0.2);
    border: 2px solid var(--primary,#99cc33);
    color: var(--primary,#99cc33);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }
  .est-sent-icon svg { width: 22px; height: 22px; }

  /* ===== NAVIGATION ===== */
  .est-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 2rem;
    padding-top: 1.5rem;
  }
  .est-back, .est-next {
    appearance: none;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.78);
    font: inherit;
    font-size: 14px;
    font-weight: 500;
    padding: 12px 22px;
    border-radius: 999px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all .2s ease;
  }
