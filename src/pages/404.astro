---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
const title = "404 — Page not found · SENAVIA Corp";
const description = "404 — Page not found. The page you're looking for has either moved, been renamed, or never existed. Let's get you somewhere useful.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/404"
  jsonLdType="home"
  noindex
  screenLabel="404 Error"
>
<style is:global data-recovered>
/* ERROR PAGES (404 / 401) */
  main.err-main {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7rem 1.5rem 4.5rem;
    min-height: 62vh;
    position: relative;
    overflow: hidden;
  }
  /* Decorative gradient orbs */
  main.err-main::before, main.err-main::after {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(80px);
    opacity: 0.3;
    z-index: 0;
  }
  main.err-main::before {
    top: -200px; left: -200px;
    background: radial-gradient(circle, rgba(153,204,51,0.5) 0%, transparent 70%);
  }
  main.err-main::after {
    bottom: -200px; right: -200px;
    background: radial-gradient(circle, rgba(51,204,204,0.35) 0%, transparent 70%);
  }
  .err-card {
    position: relative;
    z-index: 1;
    max-width: 640px;
    text-align: center;
    padding: 3rem;
  }
  @media (max-width: 600px) { .err-card { padding: 2rem 1rem; } }
  .err-code {
    font-size: clamp(8rem, 22vw, 12rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.05em;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, #99CC33 0%, #c1e15a 50%, #33CCCC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 60px rgba(153,204,51,0.4);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    animation: errPulse 4s ease-in-out infinite;
  }
  @keyframes errPulse {
    0%, 100% { filter: brightness(1) drop-shadow(0 0 30px rgba(153,204,51,0.3)); }
    50%      { filter: brightness(1.15) drop-shadow(0 0 50px rgba(153,204,51,0.6)); }
  }
  .err-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(153,204,51,0.1);
    border: 1px solid rgba(153,204,51,0.3);
    margin-bottom: 1.25rem;
  }
  .err-title {
    margin: 0 0 1rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.2;
  }
  .err-desc {
    margin: 0 0 2.25rem;
    color: rgba(255,255,255,0.65);
    font-size: 16px;
    line-height: 1.6;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .err-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  .err-actions .btn-secondary {
    appearance: none;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.85);
    font: inherit;
    font-size: 14px;
    font-weight: 500;
    padding: 13px 24px;
    border-radius: 999px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all .2s ease;
  }
  .err-actions .btn-secondary:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.08);
  }
  .err-actions .btn-secondary svg { width: 14px; height: 14px; }

  /* Quick links */
  .err-links {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px 18px;
    font-size: 14px;
  }
  .err-links-label { color: rgba(255,255,255,0.5); letter-spacing: 0.02em; }
  .err-links a { color: rgba(255,255,255,0.8); text-decoration: none; border-bottom: 1px solid transparent; transition: color .2s ease, border-color .2s ease; }
  .err-links a:hover { color: var(--primary, #99cc33); border-bottom-color: rgba(153,204,51,0.5); }

  /* Footer mini */
  .err-foot {
    position: relative;
    z-index: 1;
    padding: 1.5rem 1rem;
    text-align: center;
    font-size: 12px;
    color: rgba(255,255,255,0.72);
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .err-foot a { color: rgba(255,255,255,0.85); text-decoration: none; }
  .err-foot a:hover { color: var(--primary, #99cc33); }
</style>

<main class="err-main" data-screen-label="01 404 Error">
    <div class="err-card">
      <h1 class="err-code">404</h1>
      <span class="err-eyebrow"><span class="lang-only-en">Lost in South Florida</span><span class="lang-only-es">Perdido en el Sur de Florida</span></span>
      <h2 class="err-title"><span class="lang-only-en">Page not found</span><span class="lang-only-es">Página no encontrada</span></h2>
      <p class="err-desc"><span class="lang-only-en">The page you're looking for has either moved, been renamed, or never existed. Let's get you somewhere useful.</span><span class="lang-only-es">La página que buscas se movió, cambió de nombre o nunca existió. Te llevamos a un lugar útil.</span></p>
      <div class="err-actions">
        <a href="/" class="btn">
          <Icon name="lucide:house" width="14" height="14" style="margin-right: 6px;" />
          <span class="lang-only-en">Back to Home</span><span class="lang-only-es">Volver al Inicio</span>
        </a>
        <a href="/contact" class="btn-secondary">
          <span class="lang-only-en">Contact Us</span><span class="lang-only-es">Contáctanos</span>
          <Icon name="lucide:arrow-right" />
        </a>
      </div>
      <nav class="err-links" aria-label="Helpful links">
        <span class="err-links-label"><span class="lang-only-en">Or jump to:</span><span class="lang-only-es">O ve a:</span></span>
        <a href="/services"><span class="lang-only-en">Services</span><span class="lang-only-es">Servicios</span></a>
        <a href="/portfolio"><span class="lang-only-en">Portfolio</span><span class="lang-only-es">Portafolio</span></a>
        <a href="/pricing"><span class="lang-only-en">Pricing</span><span class="lang-only-es">Precios</span></a>
        <a href="/blog"><span class="lang-only-en">Blog</span><span class="lang-only-es">Blog</span></a>
        <a href="/service-areas"><span class="lang-only-en">Service Areas</span><span class="lang-only-es">Áreas de Servicio</span></a>
      </nav>
    </div>
  </main>
</BaseLayout>
