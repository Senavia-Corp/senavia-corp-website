---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "About SENAVIA Corp — South Florida Web Design & Marketing Agency";
const description = "Meet SENAVIA Corp — a Google Partner-certified digital agency in Plantation, FL. Bilingual EN/ES team helping South Florida businesses grow online.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/about"
  jsonLdType="about"
  screenLabel="About"
>
<main>

  <!-- ============================================================
       HERO (compact, ~60vh)
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 About Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-about-poster.jpg">
      <source src="/videos/hero-about.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">About SENAVIA Corp</span><span class="lang-only-es">Sobre SENAVIA Corp</span></div>
      <h1><span class="lang-only-en">A Digital Agency You Can Trust — Based in Plantation, FL</span><span class="lang-only-es">Una Agencia Digital en la Que Puedes Confiar — Desde Plantation, FL</span></h1>
      <p><span class="lang-only-en">SENAVIA Corp is a Google Partner-certified digital agency with a proven track record of helping South Florida businesses establish and grow their digital presence. Meet the team behind the results.</span><span class="lang-only-es">SENAVIA Corp es una agencia digital certificada como Google Partner, con un historial comprobado ayudando a empresas del Sur de Florida a establecer y hacer crecer su presencia digital. Conoce al equipo detrás de los resultados.</span></p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;"><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
    </div>
  </section>

  <!-- ============================================================
       SPLIT — Your Miami Digital Growth Partner
       ============================================================ -->
  <section class="section section--band" data-screen-label="02 Growth Partner">
    <div class="container">
      <div class="split" data-reveal>
        <div class="split-copy">
          <div class="eyebrow"><span class="lang-only-en">Your South Florida partner</span><span class="lang-only-es">Tu socio en el Sur de Florida</span></div>
          <h2><span class="lang-only-en">Your Miami Digital Growth Partner</span><span class="lang-only-es">Tu Socio de Crecimiento Digital en Miami</span></h2>
          <p><span class="lang-only-en">SENAVIA Corp is a results-driven web design and digital marketing agency headquartered in Plantation, FL. We work shoulder-to-shoulder with contractors, service businesses, and SMBs across Miami-Dade, Broward, and Palm Beach — translating brand vision into websites and marketing systems that compound traffic, leads, and revenue.</span><span class="lang-only-es">SENAVIA Corp es una agencia de diseño web y marketing digital orientada a resultados, con sede en Plantation, FL. Trabajamos codo a codo con contratistas, empresas de servicios y pymes en Miami-Dade, Broward y Palm Beach — convirtiendo la visión de marca en sitios web y sistemas de marketing que multiplican el tráfico, los prospectos y los ingresos.</span></p>
          <p><span class="lang-only-en">Every engagement starts with the same question: <em style="color: var(--white); font-style: normal;">what does growth actually look like for this business?</em> From there we build the strategy, the site, and the SEO infrastructure to deliver it — measured in rankings, conversions, and pipeline.</span><span class="lang-only-es">Cada proyecto comienza con la misma pregunta: <em style="color: var(--white); font-style: normal;">¿cómo se ve realmente el crecimiento para este negocio?</em> A partir de ahí construimos la estrategia, el sitio y la infraestructura de SEO para lograrlo — medido en posicionamiento, conversiones y oportunidades de venta.</span></p>
          <div class="chip-row" aria-label="Capabilities">
            <span class="chip"><span class="dot"></span><span class="lang-only-en">Web Design</span><span class="lang-only-es">Diseño Web</span></span>
            <span class="chip"><span class="dot"></span><span class="lang-only-en">Local SEO</span><span class="lang-only-es">SEO Local</span></span>
            <span class="chip"><span class="dot"></span>Google Ads</span>
            <span class="chip"><span class="dot"></span><span class="lang-only-en">Webflow Development</span><span class="lang-only-es">Desarrollo en Webflow</span></span>
            <span class="chip"><span class="dot"></span><span class="lang-only-en">Shopify E-commerce</span><span class="lang-only-es">E-commerce en Shopify</span></span>
            <span class="chip"><span class="dot"></span><span class="lang-only-en">Conversion Optimization</span><span class="lang-only-es">Optimización de Conversión</span></span>
          </div>
        </div>
        <div class="split-media">
          <img src="/images/about/office.webp" alt="SENAVIA Corp headquarters office building in Plantation, Florida" loading="lazy">
          <span class="badge-overlay"><span class="lang-only-en">Plantation, FL · Est. 2019</span><span class="lang-only-es">Plantation, FL · Desde 2019</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       MISSION — value props (3 glass cards)
       ============================================================ -->
  <section class="section" data-screen-label="03 Mission Values">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Our mission</span><span class="lang-only-es">Nuestra misión</span></div>
        <h2><span class="lang-only-en">The Standards Behind Every Project</span><span class="lang-only-es">Los Estándares Detrás de Cada Proyecto</span></h2>
        <p><span class="lang-only-en">We hold every site, campaign, and integration to the same three commitments — non-negotiables that distinguish a SENAVIA build from a templated agency deliverable.</span><span class="lang-only-es">Sometemos cada sitio, campaña e integración a los mismos tres compromisos — innegociables que distinguen un proyecto de SENAVIA de un entregable de agencia hecho con plantillas.</span></p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="value-card">
          <span class="step"><span class="lang-only-en">01 · Performance</span><span class="lang-only-es">01 · Rendimiento</span></span>
          <h3><span class="lang-only-en">Performance-first</span><span class="lang-only-es">El rendimiento primero</span></h3>
          <p><span class="lang-only-en">Every site we build is optimized for Core Web Vitals and conversion — fast LCP, low CLS, instant interaction, and architectures designed to stay fast as content scales.</span><span class="lang-only-es">Cada sitio que creamos está optimizado para Core Web Vitals y conversión — LCP rápido, CLS bajo, interacción instantánea y arquitecturas diseñadas para mantenerse veloces a medida que el contenido crece.</span></p>
        </article>
        <article class="value-card">
          <span class="step"><span class="lang-only-en">02 · Discoverability</span><span class="lang-only-es">02 · Visibilidad</span></span>
          <h3><span class="lang-only-en">SEO baked in</span><span class="lang-only-es">SEO desde la base</span></h3>
          <p><span class="lang-only-en">Technical SEO, schema markup, and Answer Engine Optimization are part of the build, not a paid add-on. Your site ships ready to rank — in Google, AI Overviews, and the local 3-pack.</span><span class="lang-only-es">El SEO técnico, el marcado schema y la Optimización para Motores de Respuesta forman parte del proyecto, no son un extra de pago. Tu sitio se entrega listo para posicionarse — en Google, en las Vistas Generales de IA y en el 3-pack local.</span></p>
        </article>
        <article class="value-card">
          <span class="step"><span class="lang-only-en">03 · Local fluency</span><span class="lang-only-es">03 · Dominio local</span></span>
          <h3><span class="lang-only-en">Bilingual &amp; local</span><span class="lang-only-es">Bilingüe y local</span></h3>
          <p><span class="lang-only-en">An EN/ES team serving South Florida with deep market knowledge — copy that resonates with both audiences, schema that captures bilingual searches, and partners who actually know the territory.</span><span class="lang-only-es">Un equipo EN/ES al servicio del Sur de Florida con profundo conocimiento del mercado — textos que conectan con ambas audiencias, schema que capta búsquedas bilingües y socios que de verdad conocen el territorio.</span></p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PHILOSOPHY — pull-quote inside green-bg wrapper
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <section class="section" data-screen-label="04 Philosophy">
      <div class="container">
        <div class="philosophy" data-reveal>
          <span class="quote-mark" aria-hidden="true">"</span>
          <blockquote>
            <span class="lang-only-en">We don't build websites to look good in case studies — we build them to <em>show up in search</em>, <em>convert traffic</em>, and <em>compound revenue</em> for the South Florida businesses that trust us with their growth.</span><span class="lang-only-es">No creamos sitios web para que luzcan bien en casos de estudio — los creamos para <em>aparecer en las búsquedas</em>, <em>convertir tráfico</em> y <em>multiplicar los ingresos</em> de las empresas del Sur de Florida que nos confían su crecimiento.</span>
          </blockquote>
          <div class="attribution">
            <span class="avatar" aria-hidden="true">JF</span>
            <span class="who">
              <strong>Juan Fonseca</strong>
              <span><span class="lang-only-en">Founder &amp; CEO · SENAVIA Corp</span><span class="lang-only-es">Fundador y CEO · SENAVIA Corp</span></span>
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- KPI row -->
    <section class="section" data-screen-label="05 Quick Facts" style="padding-top: 2rem;">
      <div class="container">
        <div class="section-head" data-reveal>
          <div class="eyebrow"><span class="lang-only-en">By the numbers</span><span class="lang-only-es">En cifras</span></div>
          <h2><span class="lang-only-en">Built for South Florida, Trusted to Deliver</span><span class="lang-only-es">Hecho para el Sur de Florida, con Resultados que Cumplen</span></h2>
        </div>
        <div class="stat-grid" data-reveal-children>
          <article class="stat-card">
            <span class="stat-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </span>
            <span class="stat-value">100+</span>
            <span class="stat-label"><span class="lang-only-en">Websites launched across South Florida since 2019</span><span class="lang-only-es">Sitios web lanzados en el Sur de Florida desde 2019</span></span>
          </article>
          <article class="stat-card">
            <span class="stat-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15c2.21 0 4-1.79 4-4V5a4 4 0 0 0-8 0v6c0 2.21 1.79 4 4 4z"/><path d="M19 11a7 7 0 0 1-14 0"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="8" y1="22" x2="16" y2="22"/></svg>
            </span>
            <span class="stat-value"><span class="lang-only-en">Certified</span><span class="lang-only-es">Certificada</span></span>
            <span class="stat-label"><span class="lang-only-en">Google Partner agency — verified track record &amp; spend</span><span class="lang-only-es">Agencia Google Partner — historial e inversión verificados</span></span>
          </article>
          <article class="stat-card">
            <span class="stat-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </span>
            <span class="stat-value">EN / ES</span>
            <span class="stat-label"><span class="lang-only-en">Bilingual team — fluent service for both audiences</span><span class="lang-only-es">Equipo bilingüe — atención fluida para ambas audiencias</span></span>
          </article>
          <article class="stat-card">
            <span class="stat-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span class="stat-value"><span class="lang-only-en">3 Counties</span><span class="lang-only-es">3 Condados</span></span>
            <span class="stat-label"><span class="lang-only-en">Miami-Dade · Broward · Palm Beach — local-first focus</span><span class="lang-only-es">Miami-Dade · Broward · Palm Beach — enfoque local primero</span></span>
          </article>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="06 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Let's Build Your Next Digital Success Story</span><span class="lang-only-es">Construyamos tu Próxima Historia de Éxito Digital</span></h2>
      <p><span class="lang-only-en">Schedule your free web design &amp; SEO consultation and get a custom strategy to increase traffic, leads, and conversions.</span><span class="lang-only-es">Agenda tu consulta gratuita de diseño web y SEO, y obtén una estrategia a la medida para aumentar el tráfico, los prospectos y las conversiones.</span></p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>

<!-- Shared page interactions (reveals + autoplay + marquee) -->
</BaseLayout>
