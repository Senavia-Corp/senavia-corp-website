<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el || !window.calInline) return;
    var mounted = false;
    function mount(){
      if (mounted) return; mounted = true;
      window.calInline(el);
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    // Mount when the calendar nears the viewport — instant for visitors,
    // never triggered during a no-scroll Lighthouse navigation pass.
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(ents){
        ents.forEach(function(e){ if (e.isIntersecting) { mount(); io.disconnect(); } });
      }, { rootMargin: '300px 0px' });
      io.observe(el);
    } else { mount(); }
  })();
</script>

<!-- Language switcher -->

<!-- Defer the Google Maps embed until it nears the viewport (keeps its
     third-party cookies off the initial page load). -->
<script>
  (function(){
    var f = document.querySelector('iframe[data-map-src]');
    if (!f) return;
    function load(){ f.src = f.getAttribute('data-map-src'); }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(ents){
        ents.forEach(function(e){ if (e.isIntersecting) { load(); io.disconnect(); } });
      }, { rootMargin: '300px 0px' });
      io.observe(f);
    } else { load(); }
  })();
</script>

<!-- Calendly placeholder hide on load -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    var ph = document.getElementById('calendlyFallback');
    if (!el || !ph) return;
    var obs = new MutationObserver(function(){
      if (el.children.length > 0) {
        ph.style.display = 'none';
        obs.disconnect();
      }
    });
    obs.observe(el, { childList: true });
    setTimeout(function(){ obs.disconnect(); }, 8000);
  })();
</script>
