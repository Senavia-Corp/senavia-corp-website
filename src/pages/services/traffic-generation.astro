---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProjectCarousel from '@/components/ProjectCarousel.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import { Icon } from 'astro-icon/components';

const videoTestimonials = (await getCollection('videos'))
  .filter((v) => v.data.youtubeId)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const title = "Traffic Generation in Miami — SENAVIA Corp · SEO, SEM & GEO";
const description = "Traffic generation agency in Miami. We combine SEO, paid SEM, and Generative Engine Optimization (GEO) to send qualified visitors to your site across South Florida.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/services/traffic-generation"
  jsonLdType="service"
  jsonLdData={{
    name: 'Traffic Generation',
    serviceType: 'Traffic Generation',
    description: 'Integral traffic generation combining SEO, paid SEM, and Generative Engine Optimization (GEO) to drive qualified visitors for South Florida businesses.',
  }}
  screenLabel="Traffic Generation Service"
>
<main>

  <!-- ============================================================
       HERO — Full viewport
       ============================================================ -->
  <section class="hero" data-screen-label="01 Traffic Generation Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-digital-marketing-poster.jpg">
      <source src="/videos/hero-digital-marketing.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <TrustBadges />
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">Traffic Generation · Miami</span><span class="lang-only-es">Generación de Tráfico · Miami</span></div>
      <h1><span class="lang-only-en">A Great Website Means Nothing Without the Right Visitors.</span><span class="lang-only-es">Un Gran Sitio Web No Sirve de Nada Sin los Visitantes Correctos.</span></h1>
      <p class="lang-only-en">An advanced ecosystem that captures customers by combining organic, paid, and AI-driven channels — SEO, SEM, and GEO working as one engine.</p>
      <p class="lang-only-es">Un ecosistema avanzado que captura clientes combinando canales orgánicos, pagados y de inteligencia artificial — SEO, SEM y GEO funcionando como un solo motor.</p>
      <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
      <div class="metric-strip" aria-label="Key metrics">
        <div class="metric"><span class="metric-value">SEO</span><span class="metric-label"><span class="lang-only-en">Organic search traffic</span><span class="lang-only-es">Tráfico orgánico de búsqueda</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">SEM</span><span class="metric-label"><span class="lang-only-en">Paid campaigns</span><span class="lang-only-es">Campañas de pago</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">GEO</span><span class="metric-label"><span class="lang-only-en">AI search visibility</span><span class="lang-only-es">Visibilidad en buscadores de IA</span></span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO SPLIT — Premier Traffic Generation Agency + video
       ============================================================ -->
  <section class="section section--band" data-screen-label="02 Premier Agency">
    <div class="container">
      <div class="split is-reversed" data-reveal>
        <div class="split-copy">
          <div class="eyebrow"><span class="lang-only-en">Why Miami trusts us</span><span class="lang-only-es">Por qué Miami confía en nosotros</span></div>
          <h2><span class="lang-only-en">Premier Traffic Generation Agency in South Florida</span><span class="lang-only-es">Agencia Líder en Generación de Tráfico en el Sur de Florida</span></h2>
          <p class="lang-only-en">A beautiful website is only the first step — without the right visitors, it generates no results. SENAVIA Corp builds an advanced traffic ecosystem for contractors, e-commerce brands, and service businesses across Miami-Dade, Broward, and Palm Beach, capturing customers across every channel that matters today.</p>
          <p class="lang-only-es">Un sitio web atractivo es solo el primer paso — sin los visitantes correctos, no genera resultados. SENAVIA Corp construye un ecosistema avanzado de tráfico para contratistas, marcas de e-commerce y negocios de servicios en Miami-Dade, Broward y Palm Beach, capturando clientes en cada canal que hoy importa.</p>
          <p class="lang-only-en">We combine organic, paid, and AI channels into a single revenue engine: durable SEO authority, high-intent paid campaigns, and content engineered so AI assistants recommend your brand. Our bilingual EN/ES team gives you a partner that speaks your market — and the platforms that serve it.</p>
          <p class="lang-only-es">Combinamos canales orgánicos, pagados y de IA en un solo motor de ingresos: autoridad SEO duradera, campañas pagadas de alta intención y contenido diseñado para que los asistentes de IA recomienden tu marca. Nuestro equipo bilingüe EN/ES te brinda un socio que habla el idioma de tu mercado y de las plataformas que lo atienden.</p>
          <a href="#consultation" class="btn"><span class="lang-only-en">Schedule a Free Consultation</span><span class="lang-only-es">Agenda una Consulta Gratis</span></a>
        </div>
        <div class="split-media">
          <div class="video-embed">
            <iframe
              src="https://www.youtube-nocookie.com/embed/Le_xjWf1JMM?rel=0"
              title="SENAVIA Corp — Traffic Generation overview / Generación de Tráfico"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen></iframe>
          </div>
          <span class="badge-overlay"><span class="lang-only-en">SEO · SEM · GEO — One Engine</span><span class="lang-only-es">SEO · SEM · GEO — Un Solo Motor</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SUB-PILLARS — SEO · SEM · GEO (Strategy · Purpose · Impact)
       ============================================================ -->
  <section class="section" data-screen-label="03 Traffic Pillars">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">The traffic ecosystem</span><span class="lang-only-es">El ecosistema de tráfico</span></div>
        <h2><span class="lang-only-en">Three Engines: SEO, SEM &amp; GEO</span><span class="lang-only-es">Tres Motores: SEO, SEM y GEO</span></h2>
        <p class="lang-only-en">Each channel plays a distinct role across strategy, purpose, and impact — combined, they capture demand from search engines, paid platforms, and AI assistants alike.</p>
        <p class="lang-only-es">Cada canal cumple un rol distinto en estrategia, propósito e impacto — combinados, capturan demanda de los motores de búsqueda, las plataformas pagadas y los asistentes de IA por igual.</p>
      </div>
      <div class="grid-3 pillars-grid" data-reveal-children>
        <article class="pillar-card">
          <span class="pillar-tag">SEO</span>
          <h3><span class="lang-only-en">Search Engine Optimization</span><span class="lang-only-es">Optimización para Motores de Búsqueda</span></h3>
          <div class="pillar-rows">
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Strategy</span><span class="lang-only-es">Estrategia</span></span>
              <p class="lang-only-en">Organic channel — long-term semantic optimization.</p>
              <p class="lang-only-es">Canal orgánico — optimización semántica a largo plazo.</p>
            </div>
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Purpose</span><span class="lang-only-es">Propósito</span></span>
              <p class="lang-only-en">Build digital authority and durable, long-term semantic optimization across your site.</p>
              <p class="lang-only-es">Construir autoridad digital y una optimización semántica duradera y a largo plazo en todo tu sitio.</p>
            </div>
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Impact</span><span class="lang-only-es">Impacto</span></span>
              <p class="lang-only-en">Steady, sustainable qualified organic traffic that lowers customer acquisition cost over time.</p>
              <p class="lang-only-es">Tráfico orgánico calificado, constante y sostenible que reduce el costo de adquisición de clientes con el tiempo.</p>
            </div>
          </div>
        </article>
        <article class="pillar-card">
          <span class="pillar-tag">SEM</span>
          <h3><span class="lang-only-en">Search Engine Marketing</span><span class="lang-only-es">Marketing en Motores de Búsqueda</span></h3>
          <div class="pillar-rows">
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Strategy</span><span class="lang-only-es">Estrategia</span></span>
              <p class="lang-only-en">Paid channel — high-intent PPC campaigns.</p>
              <p class="lang-only-es">Canal pagado — campañas PPC de alta intención.</p>
            </div>
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Purpose</span><span class="lang-only-es">Propósito</span></span>
              <p class="lang-only-en">Run high-intent paid PPC campaigns on Google Ads and Meta Ads.</p>
              <p class="lang-only-es">Ejecutar campañas PPC pagadas de alta intención en Google Ads y Meta Ads.</p>
            </div>
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Impact</span><span class="lang-only-es">Impacto</span></span>
              <p class="lang-only-en">Instant traffic and revenue while organic consolidates, plus fast keyword validation.</p>
              <p class="lang-only-es">Tráfico e ingresos inmediatos mientras lo orgánico se consolida, además de validación rápida de palabras clave.</p>
            </div>
          </div>
        </article>
        <article class="pillar-card">
          <span class="pillar-tag">GEO</span>
          <h3><span class="lang-only-en">Generative Engine Optimization</span><span class="lang-only-es">Optimización para Motores Generativos</span></h3>
          <div class="pillar-rows">
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Strategy</span><span class="lang-only-es">Estrategia</span></span>
              <p class="lang-only-en">AI channel — content and data prepared for LLMs.</p>
              <p class="lang-only-es">Canal de IA — contenido y datos preparados para LLMs.</p>
            </div>
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Purpose</span><span class="lang-only-es">Propósito</span></span>
              <p class="lang-only-en">Prepare content and structured data so large language models understand your brand.</p>
              <p class="lang-only-es">Preparar el contenido y los datos estructurados para que los modelos de lenguaje entiendan tu marca.</p>
            </div>
            <div class="pillar-row">
              <span class="pillar-label"><span class="lang-only-en">Impact</span><span class="lang-only-es">Impacto</span></span>
              <p class="lang-only-en">Your brand gets recommended as a direct answer in ChatGPT, Gemini, and Perplexity.</p>
              <p class="lang-only-es">Tu marca es recomendada como respuesta directa en ChatGPT, Gemini y Perplexity.</p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CAPABILITIES — 3 cards
       ============================================================ -->
  <section class="section section--band" data-screen-label="04 Traffic Capabilities">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">What we deliver</span><span class="lang-only-es">Qué entregamos</span></div>
        <h2><span class="lang-only-en">Send the Right Visitors To Your Website, Every Day</span><span class="lang-only-es">Lleva los Visitantes Correctos a tu Sitio Web, Todos los Días</span></h2>
        <p class="lang-only-en">Six core capabilities cover the full funnel — high-intent paid search and social, durable local and organic SEO, and AI search visibility — all feeding one traffic engine.</p>
        <p class="lang-only-es">Seis capacidades clave que cubren todo el embudo: búsqueda y redes pagadas de alta intención, SEO local y orgánico duradero, y visibilidad en búsqueda con IA — todas alimentando un solo motor de tráfico.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="cap-card is-purple">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:target" /></span>
          <span class="cap-num">01 · <span class="lang-only-en">Paid Search</span><span class="lang-only-es">Búsqueda Pagada</span></span>
          <h3><span class="lang-only-en">Google Ads Management</span><span class="lang-only-es">Gestión de Google Ads</span></h3>
          <p class="lang-only-en">As a Google Ads agency in Miami, we run high-intent search campaigns engineered to lower CPA and lift ROAS — keyword strategy, ad copy, and conversion tracking managed by Google-certified specialists.</p>
          <p class="lang-only-es">Como agencia de Google Ads en Miami, gestionamos campañas de búsqueda de alta intención diseñadas para reducir el CPA y aumentar el ROAS — estrategia de palabras clave, redacción de anuncios y seguimiento de conversiones a cargo de especialistas certificados por Google.</p>
        </article>
        <article class="cap-card is-cyan">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:search" /></span>
          <span class="cap-num">02 · <span class="lang-only-en">Organic Search</span><span class="lang-only-es">Búsqueda Orgánica</span></span>
          <h3><span class="lang-only-en">SEO Services</span><span class="lang-only-es">Servicios de SEO</span></h3>
          <p class="lang-only-en">Full-funnel SEO services for South Florida businesses — technical SEO, on-page optimization, and content that earns durable rankings and compounding organic traffic month after month.</p>
          <p class="lang-only-es">Servicios de SEO de embudo completo para negocios del Sur de Florida — SEO técnico, optimización on-page y contenido que gana posiciones duraderas y tráfico orgánico creciente mes tras mes.</p>
        </article>
        <article class="cap-card is-green">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:map-pin" /></span>
          <span class="cap-num">03 · <span class="lang-only-en">Local SEO</span><span class="lang-only-es">SEO Local</span></span>
          <h3><span class="lang-only-en">Local SEO Services</span><span class="lang-only-es">Servicios de SEO Local</span></h3>
          <p class="lang-only-en">Local SEO that puts you on the map across Miami-Dade, Broward, and Palm Beach — map pack visibility, service-area pages, citations, and review strategy that turn nearby searches into calls.</p>
          <p class="lang-only-es">SEO local que te posiciona en el mapa en Miami-Dade, Broward y Palm Beach — visibilidad en el paquete de mapas, páginas de áreas de servicio, citaciones y estrategia de reseñas que convierten búsquedas cercanas en llamadas.</p>
        </article>
        <article class="cap-card is-purple">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:megaphone" /></span>
          <span class="cap-num">04 · <span class="lang-only-en">Paid Social</span><span class="lang-only-es">Redes Pagadas</span></span>
          <h3><span class="lang-only-en">Facebook &amp; Instagram Ads</span><span class="lang-only-es">Facebook e Instagram Ads</span></h3>
          <p class="lang-only-en">A Facebook Ads agency in Miami building Instagram &amp; Facebook funnels that drive qualified leads — audience research, creative, retargeting flows, and pixel/CAPI setup built for measurable pipeline.</p>
          <p class="lang-only-es">Una agencia de Facebook Ads en Miami que construye embudos de Instagram y Facebook para generar prospectos calificados — investigación de audiencias, creatividades, retargeting y configuración de píxel/CAPI para un flujo de ventas medible.</p>
        </article>
        <article class="cap-card is-cyan">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:map-pinned" /></span>
          <span class="cap-num">05 · <span class="lang-only-en">Google Maps</span><span class="lang-only-es">Google Maps</span></span>
          <h3><span class="lang-only-en">Google Business Profile Optimization</span><span class="lang-only-es">Optimización del Perfil de Empresa en Google</span></h3>
          <p class="lang-only-en">Google Business Profile optimization and Google Maps SEO that win the local map pack — complete profile setup, category and post strategy, photos, and review management that build trust.</p>
          <p class="lang-only-es">Optimización del Perfil de Empresa en Google y SEO de Google Maps para ganar el paquete de mapas local — configuración completa del perfil, estrategia de categorías y publicaciones, fotos y gestión de reseñas que generan confianza.</p>
        </article>
        <article class="cap-card is-green">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:sparkles" /></span>
          <span class="cap-num">06 · <span class="lang-only-en">GEO / AI Search</span><span class="lang-only-es">GEO / Búsqueda IA</span></span>
          <h3><span class="lang-only-en">AI Search Optimization</span><span class="lang-only-es">Optimización para Búsqueda con IA</span></h3>
          <p class="lang-only-en">GEO optimization that gets you cited in AI search — so ChatGPT, Perplexity, and Google's AI answers recommend your business. Structured content and entity signals built for AI search visibility.</p>
          <p class="lang-only-es">Optimización GEO para que te citen en la búsqueda con IA — para que ChatGPT, Perplexity y las respuestas de IA de Google recomienden tu negocio. Contenido estructurado y señales de entidad diseñados para visibilidad en búsqueda con IA.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       REASONS — 6-up grid with check icons
       ============================================================ -->
  <section class="section" data-screen-label="05 Why Choose Senavia">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Why SENAVIA</span><span class="lang-only-es">Por Qué SENAVIA</span></div>
        <h2><span class="lang-only-en">Why Choose SENAVIA for Traffic Generation in Miami</span><span class="lang-only-es">Por Qué Elegir a SENAVIA Para Generar Tráfico en Miami</span></h2>
        <p class="lang-only-en">Six concrete reasons South Florida businesses pick us over the freelancer down the street and the out-of-state agency upstairs.</p>
        <p class="lang-only-es">Seis razones concretas por las que los negocios del Sur de Florida nos eligen por encima del freelancer de la esquina y de la agencia de otro estado.</p>
      </div>
      <div class="reasons-grid" data-reveal-children>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:badge-check" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Full-funnel channel strategy</span><span class="lang-only-es">Estrategia de canales de embudo completo</span></h3>
            <p class="lang-only-en">SEO, SEM, and GEO planned as one engine — organic authority, high-intent paid campaigns, and AI-assistant visibility working together.</p>
            <p class="lang-only-es">SEO, SEM y GEO planificados como un solo motor: autoridad orgánica, campañas pagadas de alta intención y visibilidad en asistentes de IA trabajando en conjunto.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:languages" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Bilingual EN / ES service</span><span class="lang-only-es">Servicio bilingüe EN / ES</span></h3>
