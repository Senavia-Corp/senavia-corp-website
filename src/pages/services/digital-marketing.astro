---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Digital Marketing Agency in Miami — SENAVIA Corp · SEO, Google Ads &amp; Meta Ads";
const description = "Digital marketing agency in Miami. SEO, Google Ads, and data-driven campaigns to grow traffic, leads, and revenue across South Florida.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/services/digital-marketing"
  jsonLdType="service"
  screenLabel="Digital Marketing Service"
>
<main>

  <!-- ============================================================
       HERO — Full viewport
       ============================================================ -->
  <section class="hero" data-screen-label="01 Digital Marketing Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-digital-marketing-poster.jpg">
      <source src="/videos/hero-digital-marketing.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">Digital Marketing · Miami</span><span class="lang-only-es">Marketing Digital · Miami</span></div>
      <h1><span class="lang-only-en">Digital Marketing Agency in Miami</span><span class="lang-only-es">Agencia de Marketing Digital en Miami</span></h1>
      <p class="lang-only-en">SEO, Google Ads, and data-driven campaigns to grow your traffic, leads, and revenue across South Florida.</p>
      <p class="lang-only-es">SEO, Google Ads y campañas basadas en datos para aumentar tu tráfico, prospectos e ingresos en todo el Sur de Florida.</p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;"><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
      <div class="metric-strip" aria-label="Key metrics">
        <div class="metric"><span class="metric-value">$12M+</span><span class="metric-label"><span class="lang-only-en">Ad spend managed</span><span class="lang-only-es">Inversión publicitaria gestionada</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">3.8×</span><span class="metric-label"><span class="lang-only-en">Avg. ROAS lift</span><span class="lang-only-es">Aumento promedio de ROAS</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">5.0 ★</span><span class="metric-label"><span class="lang-only-en">Google reviews</span><span class="lang-only-es">Reseñas en Google</span></span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO SPLIT — Miami's Leading Web Design Agency
       ============================================================ -->
  <section class="section section--band" data-screen-label="02 Premier Agency">
    <div class="container">
      <div class="split is-reversed" data-reveal>
        <div class="split-copy">
          <div class="eyebrow"><span class="lang-only-en">Why Miami trusts us</span><span class="lang-only-es">Por qué Miami confía en nosotros</span></div>
          <h2><span class="lang-only-en">Premier Digital Marketing Agency in South Florida</span><span class="lang-only-es">Agencia Líder de Marketing Digital en el Sur de Florida</span></h2>
          <p class="lang-only-en">SENAVIA Corp is a Google Partner-certified team running performance marketing for contractors, e-commerce brands, and service businesses across Miami-Dade, Broward, and Palm Beach. Every campaign starts with a strategy session and ends with measurable pipeline — not vanity metrics.</p>
          <p class="lang-only-es">SENAVIA Corp es un equipo certificado como Google Partner que ejecuta marketing de rendimiento para contratistas, marcas de e-commerce y negocios de servicios en Miami-Dade, Broward y Palm Beach. Cada campaña comienza con una sesión de estrategia y termina con un flujo de ventas medible, no con métricas de vanidad.</p>
          <p class="lang-only-en">We blend paid search, paid social, and technical SEO into a single revenue engine: budgets allocated by intent, creative built around offers, and reporting tied directly to leads and sales in your CRM. Our bilingual EN/ES team gives you a partner that speaks your market — and the ad platforms that serve it.</p>
          <p class="lang-only-es">Combinamos búsqueda pagada, redes sociales pagadas y SEO técnico en un solo motor de ingresos: presupuestos asignados por intención, creatividades construidas en torno a ofertas y reportes vinculados directamente a los prospectos y ventas en tu CRM. Nuestro equipo bilingüe EN/ES te brinda un socio que habla el idioma de tu mercado y de las plataformas publicitarias que lo atienden.</p>
          <a href="#consultation" class="btn"><span class="lang-only-en">Schedule a Free Consultation</span><span class="lang-only-es">Agenda una Consulta Gratis</span></a>
        </div>
        <div class="split-media">
          <img src="/images/services/digital-marketing-showcase.png" alt="Google Ads, Meta Ads, and analytics dashboards managed by SENAVIA Corp" loading="lazy">
          <span class="badge-overlay"><span class="lang-only-en">Google Partner Certified</span><span class="lang-only-es">Certificado Google Partner</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CAPABILITIES — 3 cards
       ============================================================ -->
  <section class="section" data-screen-label="03 Marketing Capabilities">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">What we deliver</span><span class="lang-only-es">Qué entregamos</span></div>
        <h2><span class="lang-only-en">Take Your Business To The Next Level With High Marketing</span><span class="lang-only-es">Lleva tu Negocio al Siguiente Nivel con Marketing de Alto Impacto</span></h2>
        <p class="lang-only-en">Three core capabilities cover the full funnel — from high-intent paid search to social demand capture and durable organic visibility.</p>
        <p class="lang-only-es">Tres capacidades clave que cubren todo el embudo: desde la búsqueda pagada de alta intención hasta la captación de demanda en redes sociales y una visibilidad orgánica duradera.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="cap-card">
          <span class="cap-num">01 · Paid Search</span>
          <h3><span class="lang-only-en">Google Ads &amp; Paid Search</span><span class="lang-only-es">Google Ads y Búsqueda Pagada</span></h3>
          <p class="lang-only-en">Performance campaigns engineered to lower CPA and increase ROAS. Keyword strategy, ad copy, landing-page alignment, and conversion tracking — managed by Google-certified specialists.</p>
          <p class="lang-only-es">Campañas de rendimiento diseñadas para reducir el CPA y aumentar el ROAS. Estrategia de palabras clave, redacción de anuncios, alineación de la página de destino y seguimiento de conversiones, gestionado por especialistas certificados por Google.</p>
        </article>
        <article class="cap-card">
          <span class="cap-num">02 · Paid Social</span>
          <h3><span class="lang-only-en">Meta Ads &amp; Paid Advertising</span><span class="lang-only-es">Meta Ads y Publicidad Pagada</span></h3>
          <p class="lang-only-en">Facebook &amp; Instagram funnels that drive qualified leads. Audience research, creative production, retargeting flows, and pixel/CAPI setup — built for measurable pipeline.</p>
          <p class="lang-only-es">Embudos de Facebook e Instagram que generan prospectos calificados. Investigación de audiencias, producción creativa, flujos de retargeting y configuración de píxel/CAPI, construidos para un flujo de ventas medible.</p>
        </article>
        <article class="cap-card">
          <span class="cap-num">03 · SEO</span>
          <h3><span class="lang-only-en">SEO &amp; Local Business Positioning</span><span class="lang-only-es">SEO y Posicionamiento Local de Negocios</span></h3>
          <p class="lang-only-en">Local SEO, technical SEO, and Google Business Profile optimization. Map pack visibility, service-area schema, and content that earns rankings for the searches your buyers actually make.</p>
          <p class="lang-only-es">SEO local, SEO técnico y optimización del Perfil de Empresa en Google. Visibilidad en el paquete de mapas, schema de áreas de servicio y contenido que gana posiciones para las búsquedas que realmente hacen tus clientes.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       REASONS — 6-up grid with check icons
       ============================================================ -->
  <section class="section section--band" data-screen-label="04 Why Choose Senavia">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Why SENAVIA</span><span class="lang-only-es">Por Qué SENAVIA</span></div>
        <h2><span class="lang-only-en">Why Choose SENAVIA As Your Digital Marketing Agency In Miami</span><span class="lang-only-es">Por Qué Elegir a SENAVIA Como Tu Agencia de Marketing Digital en Miami</span></h2>
        <p class="lang-only-en">Six concrete reasons South Florida businesses pick us over the freelancer down the street and the out-of-state agency upstairs.</p>
        <p class="lang-only-es">Seis razones concretas por las que los negocios del Sur de Florida nos eligen por encima del freelancer de la esquina y de la agencia de otro estado.</p>
      </div>
      <div class="reasons-grid" data-reveal-children>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Google Partner-certified team</span><span class="lang-only-es">Equipo certificado como Google Partner</span></h3>
            <p class="lang-only-en">Verified agency status — vetted spend track record and ongoing training on the latest Google products.</p>
            <p class="lang-only-es">Estatus de agencia verificada: historial de inversión comprobado y capacitación continua en los últimos productos de Google.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Bilingual EN / ES service</span><span class="lang-only-es">Servicio bilingüe EN / ES</span></h3>
            <p class="lang-only-en">Project management, copy, and SEO strategy delivered fluently in both languages — for both audiences.</p>
            <p class="lang-only-es">Gestión de proyectos, redacción y estrategia de SEO con dominio fluido de ambos idiomas, para ambas audiencias.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Local South Florida expertise</span><span class="lang-only-es">Experiencia local en el Sur de Florida</span></h3>
            <p class="lang-only-en">Deep market knowledge across Miami-Dade, Broward, and Palm Beach — service-area schema, geo-targeted content, the works.</p>
            <p class="lang-only-es">Profundo conocimiento del mercado en Miami-Dade, Broward y Palm Beach: schema de áreas de servicio, contenido geolocalizado y todo lo necesario.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Transparent reporting &amp; KPIs</span><span class="lang-only-es">Reportes transparentes y KPIs</span></h3>
            <p class="lang-only-en">Live dashboards tied to leads and revenue — not just clicks. You always know what each dollar of ad spend is returning.</p>
            <p class="lang-only-es">Paneles en vivo vinculados a prospectos e ingresos, no solo a clics. Siempre sabes qué retorno genera cada dólar invertido en publicidad.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Full-funnel campaign strategy</span><span class="lang-only-es">Estrategia de campañas de embudo completo</span></h3>
            <p class="lang-only-en">Search, social, and SEO orchestrated together — capturing demand at every stage from cold awareness to bottom-of-funnel intent.</p>
            <p class="lang-only-es">Búsqueda, redes sociales y SEO orquestados en conjunto, captando la demanda en cada etapa, desde el reconocimiento inicial hasta la intención de compra al final del embudo.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Ongoing optimization &amp; testing</span><span class="lang-only-es">Optimización y pruebas continuas</span></h3>
            <p class="lang-only-en">Weekly creative refreshes, A/B tests, and bid adjustments — we stay accountable to performance, not just running ads.</p>
            <p class="lang-only-es">Renovaciones creativas semanales, pruebas A/B y ajustes de pujas: somos responsables del rendimiento, no solo de mantener los anuncios activos.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONSULTATION — Calendly inline embed
       ============================================================ -->
  <section id="consultation" class="section" data-screen-label="05 Consultation">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Free consultation</span><span class="lang-only-es">Consulta gratuita</span></div>
        <h2><span class="lang-only-en">Schedule Your Free Web Design Consultation</span><span class="lang-only-es">Agenda tu Consulta Gratuita de Marketing Digital</span></h2>
        <p class="lang-only-en">30 minutes, no commitment. We'll review your current marketing, identify the biggest wins, and outline what a SENAVIA-managed campaign would look like for your business.</p>
        <p class="lang-only-es">30 minutos, sin compromiso. Revisaremos tu marketing actual, identificaremos las mayores oportunidades y trazaremos cómo se vería una campaña gestionada por SENAVIA para tu negocio.</p>
      </div>
      <div class="calendly-block" data-reveal>
        <div class="calendly-copy">
          <h3><span class="lang-only-en">What you'll walk away with</span><span class="lang-only-es">Con qué te quedarás</span></h3>
          <p class="lang-only-en">A focused conversation tailored to your business goals — actionable next steps you can use whether we work together or not.</p>
          <p class="lang-only-es">Una conversación enfocada y adaptada a los objetivos de tu negocio: pasos prácticos que puedes aplicar, trabajemos juntos o no.</p>
          <ul class="calendly-perks">
            <li><span class="lang-only-en">Quick audit of your current ad accounts &amp; SEO</span><span class="lang-only-es">Auditoría rápida de tus cuentas publicitarias actuales y SEO</span></li>
            <li><span class="lang-only-en">Specific recommendations to lift ROAS and lead quality</span><span class="lang-only-es">Recomendaciones específicas para mejorar el ROAS y la calidad de los prospectos</span></li>
            <li><span class="lang-only-en">Ballpark budget &amp; channel mix if you'd like to move forward</span><span class="lang-only-es">Presupuesto aproximado y combinación de canales si decides avanzar</span></li>
            <li><span class="lang-only-en">No sales pitch — just expert eyes on your funnel</span><span class="lang-only-es">Sin discurso de ventas: solo ojos expertos en tu embudo</span></li>
          </ul>
        </div>
        <div class="calendly-inline" id="calendlyInline" role="region" aria-label="Schedule a meeting"></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO carousel (reuse)
       ============================================================ -->
<!-- ============================================================
       PORTFOLIO carousel
       ============================================================ -->
  <section id="portfolio" class="section section--band" data-screen-label="04 Portfolio">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Portfolio &amp; Success Cases</span><span class="lang-only-es">Portafolio y Casos de Éxito</span></h2>
        <p class="lang-only-en">Explore campaigns and digital projects across South Florida — paid media, SEO, and full-funnel strategies built to deliver measurable growth.</p>
        <p class="lang-only-es">Explora campañas y proyectos digitales en todo el Sur de Florida: medios pagados, SEO y estrategias de embudo completo diseñadas para generar un crecimiento medible.</p>
      </div>

      <div class="carousel" data-carousel="portfolio">
        <div class="carousel-arrows">
          <button class="carousel-arrow prev" aria-label="Previous projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
          </button>
          <button class="carousel-arrow next" aria-label="Next projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
        <div class="carousel-viewport">
          <div class="carousel-track" role="list">
          <article class="project-card" role="listitem">
            <a href="/../portfolio/pergola-plus-florida" class="project-cover ph-1" aria-label="Pergola Plus Florida — Outdoor Living">
              <span class="project-name">Pergola Plus Florida</span>
            </a>
            <div class="project-body">
              <p class="project-sector"><span class="lang-only-en">Outdoor Living · Service Site</span><span class="lang-only-es">Vida al Aire Libre · Sitio de Servicios</span></p>
              <p class="lang-only-en">Outdoor living brand site with quote request flow, gallery, and local SEO — built to capture pergola buyers across South Florida.</p>
              <p class="lang-only-es">Sitio de marca de vida al aire libre con flujo de solicitud de cotización, galería y SEO local, diseñado para captar compradores de pérgolas en todo el Sur de Florida.</p>
              <a href="/../portfolio/pergola-plus-florida" class="btn is-secondary is-sm"><span class="lang-only-en">Preview Website</span><span class="lang-only-es">Ver Sitio Web</span></a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/lake-scaping" class="project-cover ph-2" aria-label="Lake Scaping LLC">
              <span class="project-name">Lake Scaping LLC</span>
            </a>
            <div class="project-body">
              <p class="project-sector"><span class="lang-only-en">Landscaping · Lead Generation</span><span class="lang-only-es">Paisajismo · Generación de Prospectos</span></p>
              <p class="lang-only-en">Landscaping company website with service area pages, before/after gallery, and an automated lead-to-CRM workflow.</p>
              <p class="lang-only-es">Sitio web de empresa de paisajismo con páginas de áreas de servicio, galería de antes y después y un flujo automatizado de prospectos al CRM.</p>
              <a href="/../portfolio/lake-scaping" class="btn is-secondary is-sm"><span class="lang-only-en">Preview Website</span><span class="lang-only-es">Ver Sitio Web</span></a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/ab-aluminum" class="project-cover ph-3" aria-label="AB Aluminum & Screens">
              <span class="project-name">AB Aluminum &amp; Screens</span>
            </a>
            <div class="project-body">
              <p class="project-sector"><span class="lang-only-en">Home Improvement · Webflow</span><span class="lang-only-es">Mejoras del Hogar · Webflow</span></p>
              <p class="lang-only-en">Home improvement contractor site with screen-enclosure product showcase, financing CTA, and Google Ads landing pages.</p>
              <p class="lang-only-es">Sitio para contratista de mejoras del hogar con vitrina de productos de cerramientos de mallas, llamada a la acción de financiamiento y páginas de destino para Google Ads.</p>
              <a href="/../portfolio/ab-aluminum" class="btn is-secondary is-sm"><span class="lang-only-en">Preview Website</span><span class="lang-only-es">Ver Sitio Web</span></a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/angele-glow" class="project-cover ph-4" aria-label="ANGELE GLOW Skincare">
              <span class="project-name">ANGELE GLOW</span>
            </a>
            <div class="project-body">
              <p class="project-sector"><span class="lang-only-en">Skincare · Shopify E-commerce</span><span class="lang-only-es">Cuidado de la Piel · E-commerce en Shopify</span></p>
              <p class="lang-only-en">Skincare e-commerce on Shopify with custom UI, subscription bundles, and a wholesale portal for spa partners.</p>
              <p class="lang-only-es">E-commerce de cuidado de la piel en Shopify con interfaz personalizada, paquetes de suscripción y un portal mayorista para socios de spa.</p>
              <a href="/../portfolio/angele-glow" class="btn is-secondary is-sm"><span class="lang-only-en">Preview Website</span><span class="lang-only-es">Ver Sitio Web</span></a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/mr-mrs-outdoor" class="project-cover ph-5" aria-label="Mr. & Mrs. Outdoor Living">
              <span class="project-name">Mr. &amp; Mrs. Outdoor Living</span>
            </a>
            <div class="project-body">
              <p class="project-sector"><span class="lang-only-en">Outdoor · Service & Booking</span><span class="lang-only-es">Aire Libre · Servicios y Reservas</span></p>
              <p class="lang-only-en">Service-area website with itemized quote tool, project map across Broward, and integrated booking calendar.</p>
              <p class="lang-only-es">Sitio web de áreas de servicio con herramienta de cotización detallada, mapa de proyectos en todo Broward y calendario de reservas integrado.</p>
              <a href="/../portfolio/mr-mrs-outdoor" class="btn is-secondary is-sm"><span class="lang-only-en">Preview Website</span><span class="lang-only-es">Ver Sitio Web</span></a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/gqm-inc" class="project-cover ph-6" aria-label="GQM Inc. Custom Admin Panel">
              <span class="project-name">GQM Inc.</span>
            </a>
            <div class="project-body">
              <p class="project-sector"><span class="lang-only-en">Internal Tool · Custom Admin Panel</span><span class="lang-only-es">Herramienta Interna · Panel de Administración a Medida</span></p>
              <p class="lang-only-en">Custom admin panel for internal operations: project tracking, client billing, and reporting dashboards.</p>
              <p class="lang-only-es">Panel de administración a medida para operaciones internas: seguimiento de proyectos, facturación de clientes y paneles de reportes.</p>
              <a href="/../portfolio/gqm-inc" class="btn is-secondary is-sm"><span class="lang-only-en">Preview Website</span><span class="lang-only-es">Ver Sitio Web</span></a>
            </div>
          </article>
        </div>
        </div>
        <div class="carousel-scrollbar" role="presentation">
          <div class="carousel-scrollbar-thumb"></div>
        </div>
      </div>

      <div class="center-cta">
        <a href="/../portfolio" class="btn"><span class="lang-only-en">View All Projects</span><span class="lang-only-es">Ver Todos los Proyectos</span></a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROCESS + REVIEWS (reuse)
       ============================================================ -->
<!-- ============================================================
       PROCESS + REVIEWS (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <!-- PROCESS -->
    <section id="process" class="section section-flush" data-screen-label="05 Process">
      <div class="container">
        <div class="section-head" data-reveal>
