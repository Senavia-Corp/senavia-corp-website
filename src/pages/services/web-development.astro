---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProjectCarousel from '@/components/ProjectCarousel.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import { Icon } from 'astro-icon/components';

const videoTestimonials = (await getCollection('videos'))
  .filter((v) => v.data.youtubeId)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const title = "Web Development in Miami — SENAVIA Corp · Apps, CRM & ERP";
const description = "Web development agency in Miami. Custom admin panels, CRM/ERP systems, and workflow automation built to scale your operations across South Florida.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/services/web-development"
  jsonLdType="service"
  jsonLdData={{
    name: 'Web Development',
    serviceType: 'Web Development',
    description: 'Custom admin panels, dashboards, CRM/ERP portals, and workflow automation engineered for South Florida businesses.',
  }}
  screenLabel="Web Development Service"
>
<main>

  <!-- ============================================================
       HERO — Full viewport
       ============================================================ -->
  <section class="hero" data-screen-label="01 Web Development Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-web-development-poster.jpg">
      <source src="/videos/hero-web-development.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <TrustBadges />
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">Web Development · Miami</span><span class="lang-only-es">Desarrollo Web · Miami</span></div>
      <h1><span class="lang-only-en">Your Business Needs a Platform That Works as Hard as You Do.</span><span class="lang-only-es">Su Negocio Necesita una Plataforma Que Trabaje Tan Duro Como Usted.</span></h1>
      <p class="lang-only-en">Custom admin panels, CRM/ERP systems, and workflow automation built to scale your operations.</p>
      <p class="lang-only-es">Paneles administrativos a la medida, sistemas CRM/ERP y automatización de flujos de trabajo creados para escalar sus operaciones.</p>
      <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
      <div class="metric-strip" aria-label="Key metrics">
        <div class="metric"><span class="metric-value">100%</span><span class="metric-label"><span class="lang-only-en">Custom-built systems</span><span class="lang-only-es">Sistemas a la medida</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">CRM · ERP</span><span class="metric-label"><span class="lang-only-en">Portals &amp; admin panels</span><span class="lang-only-es">Portales y paneles administrativos</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">EN / ES</span><span class="metric-label"><span class="lang-only-en">Bilingual team</span><span class="lang-only-es">Equipo bilingüe</span></span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO SPLIT — Miami's Leading Web Design Agency
       ============================================================ -->
  <section class="section" data-screen-label="02 Premier Dev Agency">
    <div class="container">
      <div class="split is-reversed" data-reveal>
        <div class="split-copy">
          <div class="eyebrow"><span class="lang-only-en">Why Miami trusts us</span><span class="lang-only-es">Por qué Miami confía en nosotros</span></div>
          <h2><span class="lang-only-en">Premier Web Development Agency in South Florida</span><span class="lang-only-es">La Mejor Agencia de Desarrollo Web en el Sur de Florida</span></h2>
          <p class="lang-only-en">SENAVIA Corp builds the systems that run South Florida businesses behind the scenes. We engineer custom admin panels, CRM/ERP platforms, and integration workflows for contractors, service operators, and e-commerce teams — the tools that take operations from spreadsheets and email threads to a single source of truth.</p>
          <p class="lang-only-es">SENAVIA Corp construye los sistemas que hacen funcionar a los negocios del Sur de Florida tras bambalinas. Desarrollamos paneles administrativos a la medida, plataformas CRM/ERP y flujos de integración para contratistas, operadores de servicios y equipos de e-commerce — las herramientas que llevan las operaciones de las hojas de cálculo y los correos a una sola fuente de verdad.</p>
          <p class="lang-only-en">We turn complex designs into robust, fast, secure platforms — the infrastructure and business logic your team needs to operate efficiently. Every engagement starts with how your team actually works — jobs, quotes, billing, dispatch, reporting — and ends with a platform engineered around it. Modern stacks, clean APIs, and integrations with the tools you already use: QuickBooks, Salesforce, HubSpot, Buildertrend, Notion, and more.</p>
          <p class="lang-only-es">Convertimos diseños complejos en plataformas robustas, rápidas y seguras — la infraestructura y la lógica de negocio que su equipo necesita para operar con eficiencia. Cada proyecto comienza con la forma en que su equipo realmente trabaja — trabajos, cotizaciones, facturación, despacho, reportes — y termina con una plataforma diseñada en torno a ello. Stacks modernos, APIs limpias e integraciones con las herramientas que ya usa: QuickBooks, Salesforce, HubSpot, Buildertrend, Notion y más.</p>
          <a href="#consultation" class="btn"><span class="lang-only-en">Schedule a Free Consultation</span><span class="lang-only-es">Agenda una Consulta Gratis</span></a>
        </div>
        <div class="split-media">
          <div class="video-embed">
            <iframe
              src="https://www.youtube-nocookie.com/embed/QDpIO4MqW1U?rel=0"
              title="SENAVIA Corp web development — custom platforms, dashboards &amp; automation"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen></iframe>
          </div>
          <span class="badge-overlay"><span class="lang-only-en">Custom Systems · Built In-House</span><span class="lang-only-es">Sistemas a la Medida · Desarrollo Propio</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SUB-PILLARS — 3 cards (Web Development)
       ============================================================ -->
  <section class="section section--band" data-screen-label="03 Web Development Sub-Pillars">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">What we build</span><span class="lang-only-es">Qué construimos</span></div>
        <h2><span class="lang-only-en">Web Development Built Around Your Business Logic</span><span class="lang-only-es">Desarrollo Web Construido en Torno a su Lógica de Negocio</span></h2>
        <p class="lang-only-en">Six capabilities cover the systems behind the business — the web apps, dashboards, and CRMs your team runs on, plus the integrations, automation, and ERP that tie everything together.</p>
        <p class="lang-only-es">Seis capacidades cubren los sistemas detrás del negocio — las aplicaciones web, los tableros y los CRM sobre los que opera su equipo, más las integraciones, la automatización y el ERP que lo conectan todo.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="cap-card is-purple">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:app-window" /></span>
          <span class="cap-num">01 · <span class="lang-only-en">Web Apps</span><span class="lang-only-es">Aplicaciones</span></span>
          <h3><span class="lang-only-en">Custom Web Application Development</span><span class="lang-only-es">Desarrollo de Aplicaciones Web a Medida</span></h3>
          <p class="lang-only-en">Custom web application development for businesses that have outgrown off-the-shelf software — a web app developer in Miami building secure, scalable tools around your exact business logic.</p>
          <p class="lang-only-es">Desarrollo de aplicaciones web a medida para empresas que ya superaron el software genérico — un desarrollador de aplicaciones web en Miami que construye herramientas seguras y escalables en torno a la lógica exacta de su negocio.</p>
        </article>
        <article class="cap-card is-cyan">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:layout-dashboard" /></span>
          <span class="cap-num">02 · <span class="lang-only-en">Dashboards</span><span class="lang-only-es">Tableros</span></span>
          <h3><span class="lang-only-en">Admin Panel Development</span><span class="lang-only-es">Desarrollo de Paneles Administrativos</span></h3>
          <p class="lang-only-en">Custom dashboard and admin panel development — manage users, finances, inventory, and KPIs in real time from one unified panel built by a business dashboard developer who knows your data.</p>
          <p class="lang-only-es">Desarrollo de paneles administrativos y dashboards a medida — gestione usuarios, finanzas, inventario y KPIs en tiempo real desde un panel unificado construido por un desarrollador que entiende sus datos.</p>
        </article>
        <article class="cap-card is-green">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:users" /></span>
          <span class="cap-num">03 · CRM</span>
          <h3><span class="lang-only-en">CRM Development</span><span class="lang-only-es">Desarrollo de CRM</span></h3>
          <p class="lang-only-en">Custom CRM development that fits how you actually sell — a CRM system developer building pipelines, client portals, and follow-up automation, with no per-seat fees or rigid templates.</p>
          <p class="lang-only-es">Desarrollo de CRM a medida que se ajusta a cómo realmente vende — un desarrollador de sistemas CRM que construye embudos, portales de clientes y automatización de seguimiento, sin tarifas por usuario ni plantillas rígidas.</p>
        </article>
        <article class="cap-card is-purple">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:webhook" /></span>
          <span class="cap-num">04 · <span class="lang-only-en">Integrations</span><span class="lang-only-es">Integraciones</span></span>
          <h3><span class="lang-only-en">API Integration Services</span><span class="lang-only-es">Servicios de Integración de API</span></h3>
          <p class="lang-only-en">API integration services that connect the tools you already use — a QuickBooks integration developer and software integration company syncing your data so nothing is entered twice.</p>
          <p class="lang-only-es">Servicios de integración de API que conectan las herramientas que ya usa — desarrollador de integraciones con QuickBooks y empresa de integración de software que sincroniza sus datos para no capturar nada dos veces.</p>
        </article>
        <article class="cap-card is-cyan">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:workflow" /></span>
          <span class="cap-num">05 · <span class="lang-only-en">Automation</span><span class="lang-only-es">Automatización</span></span>
          <h3><span class="lang-only-en">Workflow Automation</span><span class="lang-only-es">Automatización de Flujos de Trabajo</span></h3>
          <p class="lang-only-en">Business workflow automation that eliminates manual busywork — a process automation developer turning repetitive tasks into automated business systems that run while your team focuses on growth.</p>
          <p class="lang-only-es">Automatización de flujos de trabajo que elimina el trabajo manual repetitivo — un desarrollador de automatización de procesos que convierte tareas repetitivas en sistemas de negocio automatizados que operan mientras su equipo se enfoca en crecer.</p>
        </article>
        <article class="cap-card is-green">
          <span class="cap-icon" aria-hidden="true"><Icon name="lucide:boxes" /></span>
          <span class="cap-num">06 · ERP</span>
          <h3><span class="lang-only-en">ERP System Development</span><span class="lang-only-es">Desarrollo de Sistemas ERP</span></h3>
          <p class="lang-only-en">ERP system development for operations that have outgrown spreadsheets — a custom ERP developer building one business management system that unifies finance, inventory, and operations.</p>
          <p class="lang-only-es">Desarrollo de sistemas ERP para operaciones que ya superaron las hojas de cálculo — un desarrollador de ERP a medida que construye un sistema de gestión empresarial que unifica finanzas, inventario y operaciones.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       REASONS — 6-up grid with check icons
       ============================================================ -->
  <section class="section" data-screen-label="04 Why Choose Senavia">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Why SENAVIA</span><span class="lang-only-es">Por qué SENAVIA</span></div>
        <h2><span class="lang-only-en">Why Choose SENAVIA as Your Web Development Company in Miami</span><span class="lang-only-es">Por Qué Elegir a SENAVIA Como su Empresa de Desarrollo Web en Miami</span></h2>
        <p class="lang-only-en">Six concrete reasons South Florida businesses pick us over the freelancer down the street and the out-of-state agency upstairs.</p>
        <p class="lang-only-es">Seis razones concretas por las que los negocios del Sur de Florida nos eligen por encima del freelancer de la esquina y de la agencia de fuera del estado.</p>
      </div>
      <div class="reasons-grid" data-reveal-children>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:badge-check" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">In-house engineering team</span><span class="lang-only-es">Equipo de ingeniería propio</span></h3>
            <p class="lang-only-en">Architecture, build, and support handled by one accountable team — the people you meet are the people who write the code.</p>
            <p class="lang-only-es">Arquitectura, desarrollo y soporte a cargo de un solo equipo responsable — las personas que conoces son las que escriben el código.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:languages" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Bilingual EN / ES service</span><span class="lang-only-es">Servicio bilingüe EN / ES</span></h3>
            <p class="lang-only-en">Project management, copy, and SEO strategy delivered fluently in both languages — for both audiences.</p>
            <p class="lang-only-es">Gestión de proyectos, redacción y estrategia SEO con fluidez en ambos idiomas — para ambas audiencias.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:map-pin" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Local South Florida expertise</span><span class="lang-only-es">Experiencia local en el Sur de Florida</span></h3>
            <p class="lang-only-en">Deep market knowledge across Miami-Dade, Broward, and Palm Beach — service-area schema, geo-targeted content, the works.</p>
            <p class="lang-only-es">Profundo conocimiento del mercado en Miami-Dade, Broward y Palm Beach — schema de áreas de servicio, contenido geolocalizado y mucho más.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:route" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Built around your real workflow</span><span class="lang-only-es">Construido en torno a su flujo de trabajo real</span></h3>
            <p class="lang-only-en">We map operations first — quotes, jobs, billing, reporting — then engineer the system around it, not the other way around.</p>
            <p class="lang-only-es">Primero mapeamos las operaciones — cotizaciones, trabajos, facturación, reportes — y luego diseñamos el sistema en torno a ellas, no al revés.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:blocks" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Integration-first engineering</span><span class="lang-only-es">Ingeniería centrada en la integración</span></h3>
            <p class="lang-only-en">Podio, QuickBooks, Buildertrend, Zapier, and custom APIs — your existing tools connect cleanly instead of being replaced wholesale.</p>
            <p class="lang-only-es">Podio, QuickBooks, Buildertrend, Zapier y APIs a la medida — sus herramientas actuales se conectan de forma limpia en lugar de ser reemplazadas por completo.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <Icon name="lucide:wrench" />
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Ongoing maintenance &amp; support</span><span class="lang-only-es">Mantenimiento &amp; soporte continuo</span></h3>
            <p class="lang-only-en">SLAs, monitoring, and a roadmap for new features — we stay on as your engineering partner long after launch day.</p>
            <p class="lang-only-es">SLAs, monitoreo y una hoja de ruta para nuevas funciones — seguimos siendo su socio de ingeniería mucho después del día del lanzamiento.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONSULTATION — Calendly inline embed
       ============================================================ -->
  <section id="consultation" class="section section--band" data-screen-label="05 Consultation">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Free consultation</span><span class="lang-only-es">Consulta gratuita</span></div>
        <h2><span class="lang-only-en">Schedule Your Free Web Development Consultation</span><span class="lang-only-es">Agende su Consulta Gratuita de Desarrollo Web</span></h2>
        <p class="lang-only-en">30 minutes, no commitment. We'll review your current site, identify the biggest wins, and outline what a redesigned SENAVIA build would look like for your business.</p>
        <p class="lang-only-es">30 minutos, sin compromiso. Revisaremos su sitio actual, identificaremos las mayores oportunidades y le mostraremos cómo se vería un rediseño de SENAVIA para su negocio.</p>
      </div>
      <div class="calendly-block" data-reveal>
        <div class="calendly-copy">
          <h3><span class="lang-only-en">What you'll walk away with</span><span class="lang-only-es">Con qué se quedará</span></h3>
          <p class="lang-only-en">A focused conversation tailored to your business goals — actionable next steps you can use whether we work together or not.</p>
          <p class="lang-only-es">Una conversación enfocada y adaptada a los objetivos de su negocio — pasos accionables que podrá usar trabajemos juntos o no.</p>
          <ul class="calendly-perks lang-only-en">
            <li>Quick audit of your current systems &amp; workflows</li>
            <li>Specific recommendations to automate manual work</li>
            <li>Ballpark scope &amp; timeline if you'd like to move forward</li>
            <li>No sales pitch — just expert eyes on your funnel</li>
          </ul>
          <ul class="calendly-perks lang-only-es">
            <li>Auditoría rápida de sus sistemas &amp; flujos de trabajo actuales</li>
            <li>Recomendaciones específicas para automatizar el trabajo manual</li>
            <li>Alcance &amp; cronograma aproximados si desea avanzar</li>
            <li>Sin discurso de ventas — solo ojos expertos sobre su embudo</li>
          </ul>
        </div>
        <div class="calendly-inline" id="calendlyInline" role="region" aria-label="Schedule a meeting"></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO carousel (reuse)
       ============================================================ -->
<!-- ============================================================
       PORTFOLIO carousel
       ============================================================ -->
  <section id="portfolio" class="section" data-screen-label="04 Portfolio">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Portfolio &amp; Success Cases</span><span class="lang-only-es">Portafolio &amp; Casos de Éxito</span></h2>
        <p class="lang-only-en">Explore custom platforms and internal tools we've shipped across South Florida — admin panels, client portals, and integrations engineered for real operational scale.</p>
        <p class="lang-only-es">Explore plataformas a la medida y herramientas internas que hemos entregado en todo el Sur de Florida — paneles administrativos, portales de clientes e integraciones diseñadas para una escala operativa real.</p>
      </div>

      <ProjectCarousel />

      <div class="center-cta">
        <a href="/portfolio" class="btn"><span class="lang-only-en">View All Projects</span><span class="lang-only-es">Ver Todos los Proyectos</span></a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROCESS + REVIEWS (reuse)
       ============================================================ -->
<!-- ============================================================
       PROCESS + REVIEWS (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <!-- PROCESS -->
    <section id="process" class="section section-flush" data-screen-label="05 Process">
      <div class="container">
        <div class="section-head" data-reveal>
          <h2><span class="lang-only-en">Our Process</span><span class="lang-only-es">Nuestro Proceso</span></h2>
          <p class="lang-only-en">We understand your goals and challenges, create a tailored plan with clear estimates, and build a custom solution designed for your success.</p>
          <p class="lang-only-es">Entendemos sus objetivos y desafíos, creamos un plan a la medida con estimaciones claras y construimos una solución personalizada diseñada para su éxito.</p>
        </div>
        <div class="grid-4" data-reveal-children>
          <article class="process-block">
            <img class="process-img" src="/images/process/explore.avif" alt="Digital strategy and market discovery for South Florida businesses" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">1. Explore</span><span class="lang-only-es">1. Explorar</span></h3>
                <h4><span class="lang-only-en">Digital Strategy &amp; Market Discovery</span><span class="lang-only-es">Estrategia Digital &amp; Descubrimiento de Mercado</span></h4>
              </div>
              <p class="lang-only-en">We analyze goals, audience, and market to uncover growth opportunities across South Florida.</p>
              <p class="lang-only-es">Analizamos objetivos, audiencia y mercado para descubrir oportunidades de crecimiento en todo el Sur de Florida.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/estimate.avif" alt="Project planning and strategic roadmap for a web project" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">2. Estimate</span><span class="lang-only-es">2. Estimar</span></h3>
                <h4><span class="lang-only-en">Project Planning &amp; Strategic Roadmap</span><span class="lang-only-es">Planificación del Proyecto &amp; Hoja de Ruta Estratégica</span></h4>
              </div>
              <p class="lang-only-en">We define a clear project plan aligned with your budget, timeline, and objectives.</p>
              <p class="lang-only-es">Definimos un plan de proyecto claro alineado con su presupuesto, cronograma y objetivos.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/development.avif" alt="Custom web development and SEO build in progress" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">3. Development</span><span class="lang-only-es">3. Desarrollo</span></h3>
                <h4><span class="lang-only-en">Custom Web Development &amp; SEO</span><span class="lang-only-es">Desarrollo Web a la Medida &amp; SEO</span></h4>
              </div>
              <p class="lang-only-en">We build high-performance websites and platforms optimized for SEO and conversions.</p>
              <p class="lang-only-es">Construimos sitios web y plataformas de alto rendimiento optimizados para SEO y conversiones.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/delivery.avif" alt="Website launch and ongoing optimization in Plantation, FL" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">4. Delivery</span><span class="lang-only-es">4. Entrega</span></h3>
                <h4><span class="lang-only-en">Website Launch &amp; Ongoing Optimization</span><span class="lang-only-es">Lanzamiento del Sitio &amp; Optimización Continua</span></h4>
              </div>
              <p class="lang-only-en">We launch and optimize your digital presence from Plantation, serving South Florida.</p>
              <p class="lang-only-es">Lanzamos y optimizamos su presencia digital desde Plantation, sirviendo a todo el Sur de Florida.</p>
            </div>
          </article>
