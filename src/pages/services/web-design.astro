<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el) return;
    function init() {
      if (!window.Calendly) { setTimeout(init, 200); return; }
      window.Calendly.initInlineWidget({
        url: 'https://calendly.com/leads-senaviacorp/30-minute-meeting-senavia?hide_landing_page_details=1&hide_gdpr_banner=1&background_color=0a0e26&text_color=ffffff&primary_color=99cc33',
        parentElement: el,
        prefill: {}, utm: {}
      });
      // Mark loaded after a beat
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    init();
  })();
</script>

