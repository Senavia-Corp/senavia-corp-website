---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const title = "Web Design Agency in Miami — SENAVIA Corp · Conversion-Focused Websites";
const description = "Web design agency in Miami building modern, conversion-focused websites. Webflow, custom design, SEO-ready, mobile-first — for South Florida businesses.";

/* First 3 projects: featured first, then CMS order */
const projects = (await getCollection('portfolio'))
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order,
  )
  .slice(0, 3);
---
<BaseLayout
  title={title}
  description={description}
  canonical="/services/web-design"
  jsonLdType="service"
  screenLabel="Web Design Service"
>
<main>

  <!-- ============================================================
       HERO — Full viewport
       ============================================================ -->
  <section class="hero" data-screen-label="01 Web Design Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-web-design-poster.jpg">
      <source src="/videos/hero-web-design.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">Web Design · Miami</span><span class="lang-only-es">Diseño Web · Miami</span></div>
      <h1><span class="lang-only-en">Web Design Agency in Miami That Converts</span><span class="lang-only-es">Agencia de Diseño Web en Miami Que Convierte</span></h1>
      <p class="lang-only-en">SENAVIA builds modern, conversion-focused websites for South Florida businesses. Webflow development, custom design, SEO-ready, mobile-first.</p>
      <p class="lang-only-es">SENAVIA crea sitios web modernos y enfocados en la conversión para negocios del Sur de Florida. Desarrollo en Webflow, diseño a la medida, listo para SEO y mobile-first.</p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;"><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
      <div class="metric-strip" aria-label="Key metrics / Métricas clave">
        <div class="metric"><span class="metric-value">100+</span><span class="metric-label"><span class="lang-only-en">Sites launched</span><span class="lang-only-es">Sitios lanzados</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">95+</span><span class="metric-label"><span class="lang-only-en">Avg. PageSpeed</span><span class="lang-only-es">PageSpeed prom.</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">5.0 ★</span><span class="metric-label"><span class="lang-only-en">Google reviews</span><span class="lang-only-es">Reseñas de Google</span></span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO SPLIT — Miami's Leading Web Design Agency
       ============================================================ -->
  <section class="section" data-screen-label="02 Miami Leading">
    <div class="container">
      <div class="split is-reversed" data-reveal>
        <div class="split-copy">
          <div class="eyebrow"><span class="lang-only-en">Why Miami trusts us</span><span class="lang-only-es">Por qué Miami confía en nosotros</span></div>
          <h2><span class="lang-only-en">Miami's Leading Web Design &amp; Digital Marketing Agency</span><span class="lang-only-es">La Agencia Líder de Diseño Web &amp; Marketing Digital en Miami</span></h2>
          <p class="lang-only-en">SENAVIA Corp is a Google Partner-certified team building high-performance websites for contractors, e-commerce brands, and service businesses across South Florida. Every project starts with strategy and ends with measurable growth — not just a launch.</p>
          <p class="lang-only-es">SENAVIA Corp es un equipo certificado como Google Partner que construye sitios web de alto rendimiento para contratistas, marcas de e-commerce y negocios de servicios en todo el Sur de Florida. Cada proyecto comienza con estrategia y termina con crecimiento medible — no solo con un lanzamiento.</p>
          <p class="lang-only-en">We design and build in Webflow, Shopify, and custom stacks — combining bold UI, technical SEO, and conversion architecture into sites that load fast, rank well, and turn traffic into pipeline. Our bilingual EN/ES team gives you a partner that speaks your market, not a vendor with a template.</p>
          <p class="lang-only-es">Diseñamos y construimos en Webflow, Shopify y stacks personalizados — combinando una UI llamativa, SEO técnico y arquitectura de conversión en sitios que cargan rápido, posicionan bien y convierten el tráfico en oportunidades. Nuestro equipo bilingüe EN/ES le ofrece un socio que habla el idioma de su mercado, no un proveedor con una plantilla.</p>
          <a href="#consultation" class="btn"><span class="lang-only-en">Schedule a Free Consultation</span><span class="lang-only-es">Agenda una Consulta Gratis</span></a>
        </div>
        <div class="split-media">
          <img src="/images/services/web-design-showcase.png" alt="Collage of modern, responsive websites SENAVIA Corp has designed for South Florida businesses" loading="lazy">
          <span class="badge-overlay"><span class="lang-only-en">Google Partner Certified</span><span class="lang-only-es">Certificado Google Partner</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CAPABILITIES — 3 cards
       ============================================================ -->
  <section class="section section--band" data-screen-label="03 Web Design Capabilities">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">What we deliver</span><span class="lang-only-es">Qué entregamos</span></div>
        <h2><span class="lang-only-en">Professional Web Design &amp; Development Services in Miami</span><span class="lang-only-es">Servicios Profesionales de Diseño Web &amp; Desarrollo en Miami</span></h2>
        <p class="lang-only-en">Three core capabilities cover the full spectrum — from branded marketing sites to revenue-driving storefronts and CMS-backed content engines.</p>
        <p class="lang-only-es">Tres capacidades centrales cubren todo el espectro — desde sitios de marketing de marca hasta tiendas que generan ingresos y motores de contenido respaldados por CMS.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="cap-card">
          <span class="cap-num">01 · <span class="lang-only-en">Design</span><span class="lang-only-es">Diseño</span></span>
          <h3><span class="lang-only-en">Custom Website Design</span><span class="lang-only-es">Diseño de Sitios Web a la Medida</span></h3>
          <p class="lang-only-en">Tailored designs, brand-aligned, conversion-focused. Information architecture, UX flows, and high-fidelity UI — built around how your buyers actually decide.</p>
          <p class="lang-only-es">Diseños a la medida, alineados con la marca y enfocados en la conversión. Arquitectura de información, flujos UX y UI de alta fidelidad — construidos en torno a cómo deciden realmente sus compradores.</p>
        </article>
        <article class="cap-card">
          <span class="cap-num">02 · CMS</span>
          <h3><span class="lang-only-en">CMS Web Development</span><span class="lang-only-es">Desarrollo Web con CMS</span></h3>
          <p class="lang-only-en">Webflow, WordPress, and headless CMS expertise. Your team gets a content engine they can ship from — without breaking the design or losing performance.</p>
          <p class="lang-only-es">Experiencia en Webflow, WordPress y CMS headless. Su equipo obtiene un motor de contenido desde el cual publicar — sin romper el diseño ni perder rendimiento.</p>
        </article>
        <article class="cap-card">
          <span class="cap-num">03 · E-commerce</span>
          <h3><span class="lang-only-en">E-commerce Website Design</span><span class="lang-only-es">Diseño de Sitios E-commerce</span></h3>
          <p class="lang-only-en">Shopify and custom storefronts that sell. Product UX, checkout optimization, integrations, and subscription models — engineered for conversion at every step.</p>
          <p class="lang-only-es">Tiendas en Shopify y personalizadas que venden. UX de producto, optimización del checkout, integraciones y modelos de suscripción — diseñados para la conversión en cada paso.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
