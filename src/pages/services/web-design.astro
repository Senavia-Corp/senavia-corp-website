<style is:global>
  /* ---- Responsive 16:9 YouTube embed (custom web design showcase) ---- */
  .video-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 18px;
    overflow: hidden;
    background: #0a0e26;
    box-shadow: 0 24px 60px rgba(10, 14, 38, 0.35);
  }
  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  /* ---- Project card cover: real CMS image fills the frame ---- */
  .project-cover.has-img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .project-cover.has-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,14,38,0.05) 0%, rgba(10,14,38,0.55) 100%);
    z-index: 1;
  }
  .project-cover.has-img .project-name { z-index: 2; }

</style>

<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el || !window.calInline) return;
    var mounted = false;
    function mount(){
      if (mounted) return; mounted = true;
      window.calInline(el);
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(ents){
        ents.forEach(function(e){ if (e.isIntersecting) { mount(); io.disconnect(); } });
      }, { rootMargin: '300px 0px' });
      io.observe(el);
    } else { mount(); }
  })();
</script>

<!-- Language switcher -->
</BaseLayout>
