---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Web Design Agency in Miami — SENAVIA Corp · Conversion-Focused Websites";
const description = "Web design agency in Miami building modern, conversion-focused websites. Webflow, custom design, SEO-ready, mobile-first — for South Florida businesses.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/services/web-design"
  jsonLdType="service"
  screenLabel="Web Design Service"
>
<main>

  <!-- ============================================================
       HERO — Full viewport
       ============================================================ -->
  <section class="hero" data-screen-label="01 Web Design Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="../assets/videos/hero-home-poster.jpg">
      <source src="../assets/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;">Web Design · Miami</div>
      <h1>Web Design Agency in Miami That Converts</h1>
      <p>SENAVIA builds modern, conversion-focused websites for South Florida businesses. Webflow development, custom design, SEO-ready, mobile-first.</p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">Book a Free Call</a>
      <div class="metric-strip" aria-label="Key metrics">
        <div class="metric"><span class="metric-value">100+</span><span class="metric-label">Sites launched</span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">95+</span><span class="metric-label">Avg. PageSpeed</span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">5.0 ★</span><span class="metric-label">Google reviews</span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO SPLIT — Miami's Leading Web Design Agency
       ============================================================ -->
  <section class="section" data-screen-label="02 Miami Leading">
    <div class="container">
      <div class="split is-reversed" data-reveal>
        <div class="split-copy">
          <div class="eyebrow">Why Miami trusts us</div>
          <h2>Miami's Leading Web Design &amp; Digital Marketing Agency</h2>
          <p>SENAVIA Corp is a Google Partner-certified team building high-performance websites for contractors, e-commerce brands, and service businesses across South Florida. Every project starts with strategy and ends with measurable growth — not just a launch.</p>
          <p>We design and build in Webflow, Shopify, and custom stacks — combining bold UI, technical SEO, and conversion architecture into sites that load fast, rank well, and turn traffic into pipeline. Our bilingual EN/ES team gives you a partner that speaks your market, not a vendor with a template.</p>
          <a href="#consultation" class="btn">Schedule a Free Consultation</a>
        </div>
        <div class="split-media">
          <img src="../assets/images/services/web-design-miami.avif" alt="Web designer working on a SENAVIA Corp client project in Miami" loading="lazy">
          <span class="badge-overlay">Google Partner Certified</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CAPABILITIES — 3 cards
       ============================================================ -->
  <section class="section" data-screen-label="03 Web Design Capabilities">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">What we deliver</div>
        <h2>Professional Web Design &amp; Development Services in Miami</h2>
        <p>Three core capabilities cover the full spectrum — from branded marketing sites to revenue-driving storefronts and CMS-backed content engines.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="cap-card">
          <span class="cap-num">01 · Design</span>
          <h3>Custom Website Design</h3>
          <p>Tailored designs, brand-aligned, conversion-focused. Information architecture, UX flows, and high-fidelity UI — built around how your buyers actually decide.</p>
        </article>
        <article class="cap-card">
          <span class="cap-num">02 · CMS</span>
          <h3>CMS Web Development</h3>
          <p>Webflow, WordPress, and headless CMS expertise. Your team gets a content engine they can ship from — without breaking the design or losing performance.</p>
        </article>
        <article class="cap-card">
          <span class="cap-num">03 · E-commerce</span>
          <h3>E-commerce Website Design</h3>
          <p>Shopify and custom storefronts that sell. Product UX, checkout optimization, integrations, and subscription models — engineered for conversion at every step.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       REASONS — 6-up grid with check icons
       ============================================================ -->
  <section class="section" data-screen-label="04 Why Choose Senavia">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Why SENAVIA</div>
        <h2>Why Choose SENAVIA as Your Web Design Company in Miami</h2>
        <p>Six concrete reasons South Florida businesses pick us over the freelancer down the street and the out-of-state agency upstairs.</p>
      </div>
      <div class="reasons-grid" data-reveal-children>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3>Google Partner-certified team</h3>
            <p>Verified agency status — vetted spend track record and ongoing training on the latest Google products.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3>Bilingual EN / ES service</h3>
            <p>Project management, copy, and SEO strategy delivered fluently in both languages — for both audiences.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3>Local South Florida expertise</h3>
            <p>Deep market knowledge across Miami-Dade, Broward, and Palm Beach — service-area schema, geo-targeted content, the works.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3>Conversion-optimized design</h3>
            <p>Every page architecture is built around the action you want users to take — and measured against it after launch.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3>Technical SEO included</h3>
            <p>Schema markup, Core Web Vitals tuning, sitemap and robots, AEO structure — part of the build, not an upsell.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3>Ongoing optimization support</h3>
            <p>Post-launch retainers for SEO, CRO, content, and performance — we stay accountable to results, not just shipping.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONSULTATION — Calendly inline embed
       ============================================================ -->
  <section id="consultation" class="section" data-screen-label="05 Consultation">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Free consultation</div>
        <h2>Schedule Your Free Web Design Consultation</h2>
        <p>30 minutes, no commitment. We'll review your current site, identify the biggest wins, and outline what a redesigned SENAVIA build would look like for your business.</p>
      </div>
      <div class="calendly-block" data-reveal>
        <div class="calendly-copy">
          <h3>What you'll walk away with</h3>
          <p>A focused conversation tailored to your business goals — actionable next steps you can use whether we work together or not.</p>
          <ul class="calendly-perks">
            <li>Quick audit of your current website &amp; SEO</li>
            <li>Specific recommendations to lift conversions</li>
            <li>Ballpark scope &amp; timeline if you'd like to move forward</li>
            <li>No sales pitch — just expert eyes on your funnel</li>
          </ul>
        </div>
        <div class="calendly-inline" id="calendlyInline" role="region" aria-label="Schedule a meeting"></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO carousel (reuse)
       ============================================================ -->
<!-- ============================================================
       PORTFOLIO carousel
       ============================================================ -->
  <section id="portfolio" class="section" data-screen-label="04 Portfolio">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Web Design, Development &amp; Marketing Projects</h2>
        <p>Explore our web design projects across South Florida — custom digital experiences built to elevate UX, boost conversions, and increase visibility.</p>
      </div>

      <div class="carousel" data-carousel="portfolio">
        <div class="carousel-arrows">
          <button class="carousel-arrow prev" aria-label="Previous projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
          </button>
          <button class="carousel-arrow next" aria-label="Next projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
        <div class="carousel-viewport">
          <div class="carousel-track" role="list">
          <article class="project-card" role="listitem">
            <a href="/../portfolio/pergola-plus-florida" class="project-cover ph-1" aria-label="Pergola Plus Florida — Outdoor Living">
              <span class="project-name">Pergola Plus Florida</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Outdoor Living · Service Site</p>
              <p>Outdoor living brand site with quote request flow, gallery, and local SEO — built to capture pergola buyers across South Florida.</p>
              <a href="/../portfolio/pergola-plus-florida" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/lake-scaping" class="project-cover ph-2" aria-label="Lake Scaping LLC">
              <span class="project-name">Lake Scaping LLC</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Landscaping · Lead Generation</p>
              <p>Landscaping company website with service area pages, before/after gallery, and an automated lead-to-CRM workflow.</p>
              <a href="/../portfolio/lake-scaping" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/ab-aluminum" class="project-cover ph-3" aria-label="AB Aluminum & Screens">
              <span class="project-name">AB Aluminum &amp; Screens</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Home Improvement · Webflow</p>
              <p>Home improvement contractor site with screen-enclosure product showcase, financing CTA, and Google Ads landing pages.</p>
              <a href="/../portfolio/ab-aluminum" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/angele-glow" class="project-cover ph-4" aria-label="ANGELE GLOW Skincare">
              <span class="project-name">ANGELE GLOW</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Skincare · Shopify E-commerce</p>
              <p>Skincare e-commerce on Shopify with custom UI, subscription bundles, and a wholesale portal for spa partners.</p>
              <a href="/../portfolio/angele-glow" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/mr-mrs-outdoor" class="project-cover ph-5" aria-label="Mr. & Mrs. Outdoor Living">
              <span class="project-name">Mr. &amp; Mrs. Outdoor Living</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Outdoor · Service & Booking</p>
              <p>Service-area website with itemized quote tool, project map across Broward, and integrated booking calendar.</p>
              <a href="/../portfolio/mr-mrs-outdoor" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
          <article class="project-card" role="listitem">
            <a href="/../portfolio/gqm-inc" class="project-cover ph-6" aria-label="GQM Inc. Custom Admin Panel">
              <span class="project-name">GQM Inc.</span>
            </a>
            <div class="project-body">
              <p class="project-sector">Internal Tool · Custom Admin Panel</p>
              <p>Custom admin panel for internal operations: project tracking, client billing, and reporting dashboards.</p>
              <a href="/../portfolio/gqm-inc" class="btn is-secondary is-sm">Preview Website</a>
            </div>
          </article>
        </div>
        </div>
        <div class="carousel-scrollbar" role="presentation">
          <div class="carousel-scrollbar-thumb"></div>
        </div>
      </div>

      <div class="center-cta">
        <a href="/../portfolio" class="btn">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROCESS + REVIEWS (reuse)
       ============================================================ -->
<!-- ============================================================
       PROCESS + REVIEWS (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="../assets/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="../assets/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="../assets/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <!-- PROCESS -->
    <section id="process" class="section section-flush" data-screen-label="05 Process">
      <div class="container">
        <div class="section-head" data-reveal>
          <h2>Our Process</h2>
          <p>We understand your goals and challenges, create a tailored plan with clear estimates, and build a custom solution designed for your success.</p>
        </div>
        <div class="grid-4" data-reveal-children>
          <article class="process-block">
            <img class="process-img" src="../assets/images/process/explore.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>1. Explore</h3>
                <h4>Digital Strategy &amp; Market Discovery</h4>
              </div>
              <p>We analyze goals, audience, and market to uncover growth opportunities across South Florida.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="../assets/images/process/estimate.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>2. Estimate</h3>
                <h4>Project Planning &amp; Strategic Roadmap</h4>
              </div>
              <p>We define a clear project plan aligned with your budget, timeline, and objectives.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="../assets/images/process/development.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>3. Development</h3>
                <h4>Custom Web Development &amp; SEO</h4>
              </div>
              <p>We build high-performance websites and platforms optimized for SEO and conversions.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="../assets/images/process/delivery.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>4. Delivery</h3>
                <h4>Website Launch &amp; Ongoing Optimization</h4>
              </div>
              <p>We launch and optimize your digital presence from Plantation, serving South Florida.</p>
            </div>
          </article>
        </div>
        <div class="center-cta" style="margin-top: 3rem;" data-reveal>
          <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">Book a Free Call</a>
        </div>
      </div>
    </section>

    <!-- GOOGLE REVIEWS -->
    <section id="reviews" class="section" data-screen-label="06 Google Reviews">
      <div class="container">
        <div class="reviews-grid">
          <div class="reviews-left" data-reveal>
            <h2>Google Reviews</h2>
            <p>Based in Plantation, we deliver custom web design and SEO that help South Florida companies grow. Hear what our clients say about working with the SENAVIA team.</p>
            <div class="reviews-rating">
              <span class="score">
                5.0
                <span class="score-stars" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </span>
              </span>
              <span class="score-meta">From <strong>47 verified reviews</strong> on Google</span>
            </div>
            <div class="reviews-cta-row">
              <a href="https://www.google.com/search?q=senavia+corp+plantation+reviews" target="_blank" rel="noopener" class="btn is-sm">Read All Reviews</a>
            </div>
          </div>
          <div class="reviews-card" data-reveal data-elfsight-app-id="d2ce1169-e2c8-43d7-873d-f9e6f7bc1e07">
            <div class="review-item">
              <div class="review-stars" aria-label="5 out of 5 stars">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div class="review-head">
                <span class="review-name">Carlos Rivera</span>
                <span class="review-date">2 weeks ago</span>
              </div>
              <p class="review-text">Senavia rebuilt our roofing company website and within two months we doubled our qualified leads. The team is detail-oriented, communicative, and clearly knows local SEO inside out.</p>
            </div>
            <div class="review-item">
              <div class="review-stars" aria-label="5 out of 5 stars">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div class="review-head">
                <span class="review-name">Maria Gonzalez</span>
                <span class="review-date">1 month ago</span>
              </div>
              <p class="review-text">Their design work elevated our brand instantly — modern, fast, and converting. We've climbed three Google ranking positions for our main keywords since launch. Highly recommend.</p>
            </div>
            <div class="review-item">
              <div class="review-stars" aria-label="5 out of 5 stars">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div class="review-head">
                <span class="review-name">James Patterson</span>
