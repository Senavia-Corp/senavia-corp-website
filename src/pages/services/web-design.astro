---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCarousel from '@/components/ProjectCarousel.astro';
import TrustBadges from '@/components/TrustBadges.astro';
const title = "Custom Web Design in Miami — SENAVIA Corp";
const description = "Custom web design in Miami & South Florida. 100% custom, conversion-focused websites with advanced UX/UI, mobile-first design, and SEO architecture — never prebuilt templates.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/services/web-design"
  jsonLdType="service"
  jsonLdData={{
    name: 'Custom Web Design',
    serviceType: 'Custom Web Design',
    description: '100% custom, conversion-focused websites with advanced UX/UI, mobile-first design, and SEO architecture for Miami and South Florida businesses.',
  }}
  screenLabel="Custom Web Design Service"
>
<main>

  <!-- ============================================================
       HERO — Full viewport
       ============================================================ -->
  <section class="hero" data-screen-label="01 Custom Web Design Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-web-design-poster.jpg">
      <source src="/videos/hero-web-design.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <TrustBadges />
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">Custom Web Design · Miami</span><span class="lang-only-es">Diseño Web Personalizado · Miami</span></div>
      <h1><span class="lang-only-en">Custom Web Design That Captures Your Brand &amp; Converts</span><span class="lang-only-es">Diseño Web Personalizado que Captura su Marca y Convierte</span></h1>
      <p class="lang-only-en">SENAVIA designs 100% custom, conversion-focused visual experiences for South Florida businesses — never prebuilt templates. Advanced UX/UI, mobile-first, and SEO architecture that guide visitors to convert.</p>
      <p class="lang-only-es">SENAVIA diseña experiencias visuales 100% personalizadas y enfocadas en la conversión para negocios del Sur de Florida — nunca plantillas prediseñadas. UX/UI avanzado, mobile-first y arquitectura SEO que guían al visitante a convertir.</p>
      <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
      <div class="metric-strip" aria-label="Key metrics / Métricas clave">
        <div class="metric"><span class="metric-value">100+</span><span class="metric-label"><span class="lang-only-en">Sites launched</span><span class="lang-only-es">Sitios lanzados</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">95+</span><span class="metric-label"><span class="lang-only-en">Avg. PageSpeed</span><span class="lang-only-es">PageSpeed prom.</span></span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">5.0 ★</span><span class="metric-label"><span class="lang-only-en">Google reviews</span><span class="lang-only-es">Reseñas de Google</span></span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTRO SPLIT — Miami's Leading Web Design Agency
       ============================================================ -->
  <section class="section" data-screen-label="02 Custom By Design">
    <div class="container">
      <div class="split is-reversed" data-reveal>
        <div class="split-copy">
          <div class="eyebrow"><span class="lang-only-en">Custom by design</span><span class="lang-only-es">Personalizado por diseño</span></div>
          <h2><span class="lang-only-en">Custom Web Design Built Around Your Brand &amp; Your Buyers</span><span class="lang-only-es">Diseño Web Personalizado Construido en Torno a su Marca y sus Compradores</span></h2>
          <p class="lang-only-en">SENAVIA Corp is a Google Partner-certified team that designs 100% custom websites for contractors, e-commerce brands, and service businesses across South Florida. No prebuilt themes, no recycled layouts — every screen is crafted around how your customers actually decide and convert.</p>
          <p class="lang-only-es">SENAVIA Corp es un equipo certificado como Google Partner que diseña sitios web 100% personalizados para contratistas, marcas de e-commerce y negocios de servicios en todo el Sur de Florida. Sin temas prediseñados ni plantillas recicladas — cada pantalla se crea en torno a cómo deciden y convierten realmente sus clientes.</p>
          <p class="lang-only-en">We combine advanced UX/UI, mobile-first design, and SEO architecture into visual experiences that capture your brand at a premium level and guide visitors toward action. Our bilingual EN/ES team gives you a design partner that speaks your market — not a vendor handing you a template.</p>
          <p class="lang-only-es">Combinamos UX/UI avanzado, diseño mobile-first y arquitectura SEO en experiencias visuales que capturan su marca a un nivel premium y guían al visitante hacia la acción. Nuestro equipo bilingüe EN/ES le ofrece un socio de diseño que habla el idioma de su mercado — no un proveedor que le entrega una plantilla.</p>
          <a href="#consultation" class="btn"><span class="lang-only-en">Schedule a Free Consultation</span><span class="lang-only-es">Agenda una Consulta Gratis</span></a>
        </div>
        <div class="split-media">
          <div class="video-embed">
            <iframe
              src="https://www.youtube-nocookie.com/embed/qOOyCUcOKfM?rel=0"
              title="SENAVIA Corp custom web design showcase / Muestra de diseño web personalizado de SENAVIA Corp"
              loading="lazy"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen></iframe>
          </div>
          <span class="badge-overlay"><span class="lang-only-en">100% Custom · No Templates</span><span class="lang-only-es">100% Personalizado · Sin Plantillas</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SUB-PILLARS — 3 cards (Custom Web Design)
       ============================================================ -->
  <section class="section section--band" data-screen-label="03 Web Design Sub-Pillars">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">What's inside custom web design</span><span class="lang-only-es">Qué incluye el diseño web personalizado</span></div>
        <h2><span class="lang-only-en">Six Types of Websites We Design &amp; Build</span><span class="lang-only-es">Seis Tipos de Sitios Web que Diseñamos y Construimos</span></h2>
        <p class="lang-only-en">From business sites and corporate platforms to Shopify stores, custom builds, landing pages, and redesigns — every project is 100% custom and engineered to convert.</p>
        <p class="lang-only-es">Desde sitios de negocio y plataformas corporativas hasta tiendas Shopify, desarrollos a medida, landing pages y rediseños — cada proyecto es 100% personalizado y diseñado para convertir.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <article class="cap-card is-purple">
          <span class="cap-num">01 · <span class="lang-only-en">Business</span><span class="lang-only-es">Negocio</span></span>
          <h3><span class="lang-only-en">Business Website Design</span><span class="lang-only-es">Diseño de Sitios Web de Negocio</span></h3>
          <p class="lang-only-en">Conversion-focused websites for local and growing businesses — clean design, mobile-first, and built on SEO architecture that turns South Florida searches into booked leads.</p>
          <p class="lang-only-es">Sitios web enfocados en la conversión para negocios locales y en crecimiento — diseño limpio, mobile-first y arquitectura SEO que convierte las búsquedas del Sur de Florida en clientes potenciales.</p>
        </article>
        <article class="cap-card is-cyan">
          <span class="cap-num">02 · <span class="lang-only-en">Corporate</span><span class="lang-only-es">Corporativo</span></span>
          <h3><span class="lang-only-en">Corporate Website Design</span><span class="lang-only-es">Diseño de Sitios Web Corporativos</span></h3>
          <p class="lang-only-en">Premium, multi-page websites for established companies — structured information architecture, brand-level polish, and the scalability larger organizations demand.</p>
          <p class="lang-only-es">Sitios web premium de varias páginas para empresas consolidadas — arquitectura de información estructurada, acabado a nivel de marca y la escalabilidad que exigen las grandes organizaciones.</p>
        </article>
        <article class="cap-card is-green">
          <span class="cap-num">03 · Shopify</span>
          <h3><span class="lang-only-en">Shopify Store Design</span><span class="lang-only-es">Diseño de Tiendas Shopify</span></h3>
          <p class="lang-only-en">High-converting Shopify storefronts — fast, mobile-optimized, with secure checkout and product pages designed to sell from day one.</p>
          <p class="lang-only-es">Tiendas Shopify de alta conversión — rápidas, optimizadas para móvil, con checkout seguro y páginas de producto diseñadas para vender desde el primer día.</p>
        </article>
        <article class="cap-card is-purple">
          <span class="cap-num">04 · <span class="lang-only-en">Custom Dev</span><span class="lang-only-es">Desarrollo</span></span>
          <h3><span class="lang-only-en">Custom Website Development</span><span class="lang-only-es">Desarrollo Web a Medida</span></h3>
          <p class="lang-only-en">High-ticket builds for complex needs — custom functionality, integrations, and the infrastructure to power portals, dashboards, and automation your business runs on.</p>
          <p class="lang-only-es">Desarrollos de alto nivel para necesidades complejas — funcionalidad a medida, integraciones y la infraestructura para impulsar portales, paneles y automatización sobre los que opera su negocio.</p>
        </article>
        <article class="cap-card is-cyan">
          <span class="cap-num">05 · <span class="lang-only-en">Landing Page</span><span class="lang-only-es">Landing Page</span></span>
          <h3><span class="lang-only-en">Landing Page Design</span><span class="lang-only-es">Diseño de Landing Pages</span></h3>
          <p class="lang-only-en">High-intent landing pages built for Google Ads and campaigns — single-focus, fast-loading, and engineered to maximize conversions and lower your cost per lead.</p>
          <p class="lang-only-es">Landing pages de alta intención para Google Ads y campañas — enfocadas en un solo objetivo, de carga rápida y diseñadas para maximizar conversiones y reducir tu costo por lead.</p>
        </article>
        <article class="cap-card is-green">
          <span class="cap-num">06 · <span class="lang-only-en">Redesign</span><span class="lang-only-es">Rediseño</span></span>
          <h3><span class="lang-only-en">Website Redesign</span><span class="lang-only-es">Rediseño de Sitios Web</span></h3>
          <p class="lang-only-en">Already have a site that underperforms? We rebuild it for modern UX, speed, and SEO — keeping what works and fixing what costs you conversions.</p>
          <p class="lang-only-es">¿Ya tienes un sitio que rinde por debajo de su potencial? Lo reconstruimos con UX moderno, velocidad y SEO — conservando lo que funciona y corrigiendo lo que te cuesta conversiones.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       REASONS — 6-up grid with check icons
       ============================================================ -->
  <section class="section" data-screen-label="04 Why Choose Senavia">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Why SENAVIA</span><span class="lang-only-es">Por qué SENAVIA</span></div>
        <h2><span class="lang-only-en">Why Choose SENAVIA as Your Web Design Company in Miami</span><span class="lang-only-es">Por Qué Elegir a SENAVIA Como su Empresa de Diseño Web en Miami</span></h2>
        <p class="lang-only-en">Six concrete reasons South Florida businesses pick us over the freelancer down the street and the out-of-state agency upstairs.</p>
        <p class="lang-only-es">Seis razones concretas por las que los negocios del Sur de Florida nos eligen por encima del freelancer de la esquina y de la agencia de fuera del estado.</p>
      </div>
      <div class="reasons-grid" data-reveal-children>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Google Partner-certified team</span><span class="lang-only-es">Equipo certificado como Google Partner</span></h3>
            <p class="lang-only-en">Verified agency status — vetted spend track record and ongoing training on the latest Google products.</p>
            <p class="lang-only-es">Estatus de agencia verificada — historial de inversión comprobado y formación continua en los últimos productos de Google.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Bilingual EN / ES service</span><span class="lang-only-es">Servicio bilingüe EN / ES</span></h3>
            <p class="lang-only-en">Project management, copy, and SEO strategy delivered fluently in both languages — for both audiences.</p>
            <p class="lang-only-es">Gestión de proyectos, redacción y estrategia SEO con fluidez en ambos idiomas — para ambas audiencias.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Local South Florida expertise</span><span class="lang-only-es">Experiencia local en el Sur de Florida</span></h3>
            <p class="lang-only-en">Deep market knowledge across Miami-Dade, Broward, and Palm Beach — service-area schema, geo-targeted content, the works.</p>
            <p class="lang-only-es">Profundo conocimiento del mercado en Miami-Dade, Broward y Palm Beach — schema de áreas de servicio, contenido geolocalizado y mucho más.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Conversion-optimized design</span><span class="lang-only-es">Diseño optimizado para la conversión</span></h3>
            <p class="lang-only-en">Every page architecture is built around the action you want users to take — and measured against it after launch.</p>
            <p class="lang-only-es">La arquitectura de cada página se construye en torno a la acción que desea que tomen los usuarios — y se mide en función de ella después del lanzamiento.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Technical SEO included</span><span class="lang-only-es">SEO técnico incluido</span></h3>
            <p class="lang-only-en">Schema markup, Core Web Vitals tuning, sitemap and robots, AEO structure — part of the build, not an upsell.</p>
            <p class="lang-only-es">Marcado schema, optimización de Core Web Vitals, sitemap y robots, estructura AEO — parte del desarrollo, no un costo adicional.</p>
          </div>
        </article>
        <article class="reason-item">
          <span class="check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <div class="reason-body">
            <h3><span class="lang-only-en">Ongoing optimization support</span><span class="lang-only-es">Soporte de optimización continua</span></h3>
            <p class="lang-only-en">Post-launch retainers for SEO, CRO, content, and performance — we stay accountable to results, not just shipping.</p>
            <p class="lang-only-es">Planes post-lanzamiento para SEO, CRO, contenido y rendimiento — respondemos por los resultados, no solo por entregar.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONSULTATION — Calendly inline embed
       ============================================================ -->
  <section id="consultation" class="section section--band" data-screen-label="05 Consultation">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Free consultation</span><span class="lang-only-es">Consulta gratuita</span></div>
        <h2><span class="lang-only-en">Schedule Your Free Web Design Consultation</span><span class="lang-only-es">Agende su Consulta Gratuita de Diseño Web</span></h2>
        <p class="lang-only-en">30 minutes, no commitment. We'll review your current site, identify the biggest wins, and outline what a redesigned SENAVIA build would look like for your business.</p>
        <p class="lang-only-es">30 minutos, sin compromiso. Revisaremos su sitio actual, identificaremos las mayores oportunidades y le mostraremos cómo se vería un rediseño de SENAVIA para su negocio.</p>
      </div>
      <div class="calendly-block" data-reveal>
        <div class="calendly-copy">
          <h3><span class="lang-only-en">What you'll walk away with</span><span class="lang-only-es">Con qué se quedará</span></h3>
          <p class="lang-only-en">A focused conversation tailored to your business goals — actionable next steps you can use whether we work together or not.</p>
          <p class="lang-only-es">Una conversación enfocada y adaptada a los objetivos de su negocio — pasos accionables que podrá usar trabajemos juntos o no.</p>
          <ul class="calendly-perks lang-only-en">
            <li>Quick audit of your current website &amp; SEO</li>
            <li>Specific recommendations to lift conversions</li>
            <li>Ballpark scope &amp; timeline if you'd like to move forward</li>
            <li>No sales pitch — just expert eyes on your funnel</li>
          </ul>
          <ul class="calendly-perks lang-only-es">
            <li>Auditoría rápida de su sitio web &amp; SEO actuales</li>
            <li>Recomendaciones específicas para aumentar las conversiones</li>
            <li>Alcance &amp; cronograma aproximados si desea avanzar</li>
            <li>Sin discurso de ventas — solo ojos expertos sobre su embudo</li>
          </ul>
        </div>
        <div class="calendly-inline" id="calendlyInline" role="region" aria-label="Schedule a meeting / Agenda una reunión"></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO carousel (reuse)
       ============================================================ -->
<!-- ============================================================
       PORTFOLIO carousel
       ============================================================ -->
  <section id="portfolio" class="section" data-screen-label="06 Portfolio">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Custom Web Design Projects</span><span class="lang-only-es">Proyectos de Diseño Web Personalizado</span></h2>
        <p class="lang-only-en">Explore our custom web design work across South Florida — 100% bespoke digital experiences built to elevate UX, capture each brand, and turn visitors into customers.</p>
        <p class="lang-only-es">Explore nuestro trabajo de diseño web personalizado en todo el Sur de Florida — experiencias digitales 100% a la medida creadas para elevar la UX, capturar cada marca y convertir visitantes en clientes.</p>
      </div>

      <ProjectCarousel />

      <div class="center-cta">
        <a href="/portfolio" class="btn"><span class="lang-only-en">View All Projects</span><span class="lang-only-es">Ver Todos los Proyectos</span></a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROCESS + REVIEWS (reuse)
       ============================================================ -->
<!-- ============================================================
       PROCESS + REVIEWS (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <!-- PROCESS -->
    <section id="process" class="section section-flush" data-screen-label="05 Process">
      <div class="container">
        <div class="section-head" data-reveal>
          <h2><span class="lang-only-en">Our Process</span><span class="lang-only-es">Nuestro Proceso</span></h2>
          <p class="lang-only-en">We understand your goals and challenges, create a tailored plan with clear estimates, and build a custom solution designed for your success.</p>
          <p class="lang-only-es">Entendemos sus objetivos y desafíos, creamos un plan a la medida con estimaciones claras y construimos una solución personalizada diseñada para su éxito.</p>
        </div>
        <div class="grid-4" data-reveal-children>
          <article class="process-block">
            <img class="process-img" src="/images/process/explore.avif" alt="Digital strategy and market discovery for South Florida businesses" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">1. Explore</span><span class="lang-only-es">1. Explorar</span></h3>
                <h4><span class="lang-only-en">Digital Strategy &amp; Market Discovery</span><span class="lang-only-es">Estrategia Digital &amp; Descubrimiento de Mercado</span></h4>
              </div>
              <p class="lang-only-en">We analyze goals, audience, and market to uncover growth opportunities across South Florida.</p>
              <p class="lang-only-es">Analizamos objetivos, audiencia y mercado para descubrir oportunidades de crecimiento en todo el Sur de Florida.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/estimate.avif" alt="Project planning and strategic roadmap for a web project" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">2. Estimate</span><span class="lang-only-es">2. Estimar</span></h3>
                <h4><span class="lang-only-en">Project Planning &amp; Strategic Roadmap</span><span class="lang-only-es">Planificación del Proyecto &amp; Hoja de Ruta Estratégica</span></h4>
              </div>
              <p class="lang-only-en">We define a clear project plan aligned with your budget, timeline, and objectives.</p>
              <p class="lang-only-es">Definimos un plan de proyecto claro alineado con su presupuesto, cronograma y objetivos.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/development.avif" alt="Custom web development and SEO build in progress" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">3. Development</span><span class="lang-only-es">3. Desarrollo</span></h3>
                <h4><span class="lang-only-en">Custom Web Development &amp; SEO</span><span class="lang-only-es">Desarrollo Web a la Medida &amp; SEO</span></h4>
              </div>
              <p class="lang-only-en">We build high-performance websites and platforms optimized for SEO and conversions.</p>
              <p class="lang-only-es">Construimos sitios web y plataformas de alto rendimiento optimizados para SEO y conversiones.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/delivery.avif" alt="Website launch and ongoing optimization in Plantation, FL" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">4. Delivery</span><span class="lang-only-es">4. Entrega</span></h3>
                <h4><span class="lang-only-en">Website Launch &amp; Ongoing Optimization</span><span class="lang-only-es">Lanzamiento del Sitio &amp; Optimización Continua</span></h4>
              </div>
              <p class="lang-only-en">We launch and optimize your digital presence from Plantation, serving South Florida.</p>
              <p class="lang-only-es">Lanzamos y optimizamos su presencia digital desde Plantation, sirviendo a todo el Sur de Florida.</p>
            </div>
          </article>
        </div>
        <div class="center-cta" style="margin-top: 3rem;" data-reveal>
          <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
        </div>
      </div>
    </section>

    <!-- GOOGLE REVIEWS -->
    <section id="reviews" class="section" data-screen-label="06 Google Reviews">
      <div class="container">
