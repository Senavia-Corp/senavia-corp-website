---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCarousel from '@/components/ProjectCarousel.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '@/data/site';
import { SUBSERVICES_WEBDEV as SUBSERVICES, getWebdevSubservice as getSubservice } from '@/data/subservices-webdev';

export function getStaticPaths() {
  return SUBSERVICES.map((sub) => ({ params: { slug: sub.slug }, props: { sub } }));
}

const { sub } = Astro.props;
const base = `/services/web-development/${sub.slug}`;
const heroImg = `/images/subservices/${sub.slug}-hero.avif`;
const introImg = `/images/subservices/${sub.slug}-intro.avif`;

// Breadcrumb JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Web Development', item: `${SITE.url}/services/web-development` },
    { '@type': 'ListItem', position: 3, name: sub.h1_en, item: `${SITE.url}${base}` },
  ],
};

// FAQ JSON-LD (English — primary indexed language)
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: sub.faq.map((f) => ({
    '@type': 'Question',
    name: f.q_en,
    acceptedAnswer: { '@type': 'Answer', text: f.a_en },
  })),
};

const related = sub.related.map((s) => getSubservice(s)).filter(Boolean);
---
<BaseLayout
  title={sub.metaTitle}
  description={sub.metaDescription}
  canonical={base}
  jsonLdType="service"
  jsonLdData={{
    name: sub.h1_en,
    serviceType: sub.eyebrow_en.split(' · ')[0],
    description: sub.metaDescription,
    url: `${SITE.url}${base}`,
  }}
  screenLabel={`Subservice — ${sub.h1_en}`}
>
<main>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />

  <!-- ===================== HERO (split) ===================== -->
  <section class="subhero" data-screen-label="01 Hero">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span aria-hidden="true">/</span>
        <a href="/services/web-development"><span class="lang-only-en">Web Development</span><span class="lang-only-es">Desarrollo Web</span></a><span aria-hidden="true">/</span>
        <span class="crumbs-current"><span class="lang-only-en">{sub.eyebrow_en.split(' · ')[0]}</span><span class="lang-only-es">{sub.eyebrow_es.split(' · ')[0]}</span></span>
      </nav>
      <div class="subhero-grid">
        <div class="subhero-copy" data-reveal>
          <div class="eyebrow"><span class="lang-only-en">{sub.eyebrow_en}</span><span class="lang-only-es">{sub.eyebrow_es}</span></div>
          <h1><span class="lang-only-en">{sub.h1_en}</span><span class="lang-only-es">{sub.h1_es}</span></h1>
          <p><span class="lang-only-en">{sub.heroSub_en}</span><span class="lang-only-es">{sub.heroSub_es}</span></p>
          <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
          <div class="metric-strip" aria-label="Key metrics / Métricas clave">
            <div class="metric"><span class="metric-value">100+</span><span class="metric-label"><span class="lang-only-en">Sites launched</span><span class="lang-only-es">Sitios lanzados</span></span></div>
            <span class="divider"></span>
            <div class="metric"><span class="metric-value">95+</span><span class="metric-label"><span class="lang-only-en">Avg. PageSpeed</span><span class="lang-only-es">PageSpeed prom.</span></span></div>
            <span class="divider"></span>
            <div class="metric"><span class="metric-value">5.0 ★</span><span class="metric-label"><span class="lang-only-en">Google reviews</span><span class="lang-only-es">Reseñas de Google</span></span></div>
          </div>
        </div>
        <div class="subhero-media" data-reveal>
          <img src={heroImg} width="1200" height="1200" alt={sub.h1_en} fetchpriority="high" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== INTRO split ===================== -->
  <section class="section" data-screen-label="02 Intro">
    <div class="container">
      <div class="split is-reversed" data-reveal>
        <div class="split-copy">
          <div class="eyebrow"><Icon name={sub.icon} /> <span class="lang-only-en">What this is</span><span class="lang-only-es">Qué es esto</span></div>
          <h2><span class="lang-only-en">{sub.introH2_en}</span><span class="lang-only-es">{sub.introH2_es}</span></h2>
          {sub.introBody_en.map((p) => <p class="lang-only-en">{p}</p>)}
          {sub.introBody_es.map((p) => <p class="lang-only-es">{p}</p>)}
          <a href="#consultation" class="btn"><span class="lang-only-en">Schedule a Free Consultation</span><span class="lang-only-es">Agenda una Consulta Gratis</span></a>
        </div>
        <div class="split-media">
          <img class="intro-img" src={introImg} width="1200" height="1200" alt={sub.introH2_en} loading="lazy" decoding="async" />
          <span class="badge-overlay"><span class="lang-only-en">{sub.introBadge_en}</span><span class="lang-only-es">{sub.introBadge_es}</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== DELIVERABLES ===================== -->
  <section class="section section--band" data-screen-label="03 What's Included">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">What's included</span><span class="lang-only-es">Qué incluye</span></div>
        <h2><span class="lang-only-en">What You Get</span><span class="lang-only-es">Lo que Recibe</span></h2>
      </div>
      <div class="grid-3" data-reveal-children>
        {sub.deliverables.map((d) => (
          <article class={`cap-card is-${sub.accent}`}>
            <span class="cap-icon" aria-hidden="true"><Icon name={d.icon} /></span>
            <h3><span class="lang-only-en">{d.title_en}</span><span class="lang-only-es">{d.title_es}</span></h3>
            <p class="lang-only-en">{d.body_en}</p>
            <p class="lang-only-es">{d.body_es}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== WHY SENAVIA (benefits) ===================== -->
  <section class="section" data-screen-label="04 Why SENAVIA">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Why SENAVIA</span><span class="lang-only-es">Por qué SENAVIA</span></div>
        <h2><span class="lang-only-en">Why Choose Us For This</span><span class="lang-only-es">Por Qué Elegirnos para Esto</span></h2>
      </div>
      <div class="reasons-grid" data-reveal-children>
        {sub.benefits.map((b) => (
          <article class="reason-item">
            <span class="check" aria-hidden="true"><Icon name={b.icon} /></span>
            <div class="reason-body">
              <h3><span class="lang-only-en">{b.title_en}</span><span class="lang-only-es">{b.title_es}</span></h3>
              <p class="lang-only-en">{b.body_en}</p>
              <p class="lang-only-es">{b.body_es}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== IDEAL FOR ===================== -->
  <section class="section section--band" data-screen-label="05 Ideal For">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Ideal for</span><span class="lang-only-es">Ideal para</span></div>
        <h2><span class="lang-only-en">Who This Is Built For</span><span class="lang-only-es">Para Quién Está Hecho</span></h2>
      </div>
      <ul class="ideal-grid lang-only-en" data-reveal-children>
        {sub.idealFor_en.map((i) => <li class="ideal-chip"><Icon name="lucide:check" />{i}</li>)}
      </ul>
      <ul class="ideal-grid lang-only-es" data-reveal-children>
        {sub.idealFor_es.map((i) => <li class="ideal-chip"><Icon name="lucide:check" />{i}</li>)}
      </ul>
    </div>
  </section>

  <!-- ===================== PROCESS + figures (reused) ===================== -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">
    <section id="process" class="section section-flush" data-screen-label="06 Process">
      <div class="container">
        <div class="section-head" data-reveal>
          <h2><span class="lang-only-en">Our Process</span><span class="lang-only-es">Nuestro Proceso</span></h2>
          <p class="lang-only-en">We understand your goals, create a tailored plan with clear estimates, and build a custom solution designed for your success.</p>
          <p class="lang-only-es">Entendemos sus objetivos, creamos un plan a la medida con estimaciones claras y construimos una solución personalizada diseñada para su éxito.</p>
        </div>
        <div class="grid-4" data-reveal-children>
          <article class="process-block">
            <img class="process-img" src="/images/process/explore.avif" alt="Digital strategy and market discovery for South Florida businesses" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">1. Explore</span><span class="lang-only-es">1. Explorar</span></h3>
                <h4><span class="lang-only-en">Digital Strategy &amp; Market Discovery</span><span class="lang-only-es">Estrategia Digital &amp; Descubrimiento de Mercado</span></h4>
              </div>
              <p class="lang-only-en">We analyze goals, audience, and market to uncover growth opportunities across South Florida.</p>
              <p class="lang-only-es">Analizamos objetivos, audiencia y mercado para descubrir oportunidades de crecimiento en todo el Sur de Florida.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/estimate.avif" alt="Project planning and strategic roadmap for a web project" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">2. Estimate</span><span class="lang-only-es">2. Estimar</span></h3>
                <h4><span class="lang-only-en">Project Planning &amp; Strategic Roadmap</span><span class="lang-only-es">Planificación del Proyecto &amp; Hoja de Ruta Estratégica</span></h4>
              </div>
              <p class="lang-only-en">We define a clear project plan aligned with your budget, timeline, and objectives.</p>
              <p class="lang-only-es">Definimos un plan de proyecto claro alineado con su presupuesto, cronograma y objetivos.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/development.avif" alt="Custom web development and SEO build in progress" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">3. Development</span><span class="lang-only-es">3. Desarrollo</span></h3>
                <h4><span class="lang-only-en">Custom Web Development &amp; SEO</span><span class="lang-only-es">Desarrollo Web a la Medida &amp; SEO</span></h4>
              </div>
              <p class="lang-only-en">We build high-performance websites and platforms optimized for SEO and conversions.</p>
              <p class="lang-only-es">Construimos sitios web y plataformas de alto rendimiento optimizados para SEO y conversiones.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/delivery.avif" alt="Website launch and ongoing optimization in Plantation, FL" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3><span class="lang-only-en">4. Delivery</span><span class="lang-only-es">4. Entrega</span></h3>
                <h4><span class="lang-only-en">Website Launch &amp; Ongoing Optimization</span><span class="lang-only-es">Lanzamiento del Sitio &amp; Optimización Continua</span></h4>
              </div>
              <p class="lang-only-en">We launch and optimize your digital presence from Plantation, serving South Florida.</p>
              <p class="lang-only-es">Lanzamos y optimizamos su presencia digital desde Plantation, sirviendo a todo el Sur de Florida.</p>
            </div>
          </article>
        </div>
        <div class="center-cta" style="margin-top: 3rem;" data-reveal>
          <a href="#" class="btn" data-calendly-trigger><span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span></a>
        </div>
      </div>
    </section>
  </div>

  <!-- ===================== PORTFOLIO ===================== -->
  <section id="portfolio" class="section" data-screen-label="07 Portfolio">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2><span class="lang-only-en">Recent Work</span><span class="lang-only-es">Trabajo Reciente</span></h2>
        <p class="lang-only-en">Explore our custom web design work across South Florida — built to elevate UX, capture each brand, and convert.</p>
        <p class="lang-only-es">Explore nuestro trabajo de diseño web personalizado en el Sur de Florida — creado para elevar la UX, capturar cada marca y convertir.</p>
      </div>
      <ProjectCarousel />
      <div class="center-cta">
        <a href="/portfolio" class="btn"><span class="lang-only-en">View All Projects</span><span class="lang-only-es">Ver Todos los Proyectos</span></a>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="section section--band" data-screen-label="08 FAQ">
    <div class="container container--narrow">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">FAQ</span><span class="lang-only-es">Preguntas Frecuentes</span></div>
        <h2><span class="lang-only-en">Frequently Asked Questions</span><span class="lang-only-es">Preguntas Frecuentes</span></h2>
      </div>
      <div class="faq-list" data-reveal-children>
        {sub.faq.map((f) => (
          <details class="faq-item">
            <summary>
              <span class="faq-q"><span class="lang-only-en">{f.q_en}</span><span class="lang-only-es">{f.q_es}</span></span>
              <span class="faq-mark" aria-hidden="true"><Icon name="lucide:plus" /></span>
            </summary>
            <div class="faq-a">
              <p class="lang-only-en">{f.a_en}</p>
              <p class="lang-only-es">{f.a_es}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== RELATED ===================== -->
  {related.length > 0 && (
    <section class="section" data-screen-label="09 Related">
      <div class="container">
        <div class="section-head" data-reveal>
          <div class="eyebrow"><span class="lang-only-en">Explore more</span><span class="lang-only-es">Explore más</span></div>
          <h2><span class="lang-only-en">Related Web Development Services</span><span class="lang-only-es">Servicios de Desarrollo Web Relacionados</span></h2>
        </div>
        <div class="grid-3" data-reveal-children>
          {related.map((r) => (
            <a class={`cap-card is-${r.accent} cap-card--link`} href={`/services/web-development/${r.slug}`}>
              <span class="cap-icon" aria-hidden="true"><Icon name={r.icon} /></span>
              <h3><span class="lang-only-en">{r.h1_en.split(' That ')[0].split(' for ')[0]}</span><span class="lang-only-es">{r.eyebrow_es.split(' · ')[0]}</span></h3>
              <p class="lang-only-en">{r.metaDescription}</p>
              <p class="lang-only-es">{r.heroSub_es}</p>
              <span class="cap-link"><span class="lang-only-en">Learn more →</span><span class="lang-only-es">Saber más →</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===================== CONSULTATION (Calendly) ===================== -->
  <section id="consultation" class="section section--band" data-screen-label="10 Consultation">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">Free consultation</span><span class="lang-only-es">Consulta gratuita</span></div>
        <h2><span class="lang-only-en">Book Your Free Consultation</span><span class="lang-only-es">Agende su Consulta Gratuita</span></h2>
        <p class="lang-only-en">30 minutes, no commitment. We'll review your goals and outline what a SENAVIA build looks like for your business.</p>
        <p class="lang-only-es">30 minutos, sin compromiso. Revisaremos sus objetivos y le mostraremos cómo se vería un proyecto de SENAVIA para su negocio.</p>
      </div>
      <div class="calendly-block" data-reveal>
        <div class="calendly-copy">
          <h3><span class="lang-only-en">What you'll walk away with</span><span class="lang-only-es">Con qué se quedará</span></h3>
          <ul class="calendly-perks lang-only-en">
            <li>A quick audit of your current site &amp; SEO</li>
            <li>Specific recommendations to lift conversions</li>
            <li>Ballpark scope &amp; timeline if you'd like to move forward</li>
            <li>No sales pitch — just expert eyes on your funnel</li>
          </ul>
          <ul class="calendly-perks lang-only-es">
            <li>Una auditoría rápida de su sitio &amp; SEO actuales</li>
            <li>Recomendaciones específicas para aumentar conversiones</li>
            <li>Alcance &amp; cronograma aproximados si desea avanzar</li>
            <li>Sin discurso de ventas — solo ojos expertos sobre su embudo</li>
          </ul>
        </div>
        <div class="calendly-inline" id="calendlyInline" role="region" aria-label="Schedule a meeting / Agenda una reunión"></div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="cta" data-screen-label="11 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Let's Build Something Built to Convert</span><span class="lang-only-es">Construyamos Algo Hecho para Convertir</span></h2>
      <p class="lang-only-en">Schedule your free consultation and get a tailored plan to capture your brand and turn visitors into customers.</p>
      <p class="lang-only-es">Agende su consulta gratuita y obtenga un plan a la medida para capturar su marca y convertir visitantes en clientes.</p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>
</main>

<style is:global>
  /* ---- Subservice hero (split: copy + square device image) ---- */
  .subhero { position: relative; padding: 2.5rem 0 clamp(3rem, 6vw, 5rem); overflow: hidden; }
  .crumbs { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.55); margin-bottom: 1.75rem; }
  .crumbs a { color: rgba(255,255,255,0.7); text-decoration: none; }
  .crumbs a:hover { color: var(--primary); }
  .crumbs-current { color: var(--white); }
  .subhero-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .subhero-copy { text-align: left; }
  .subhero-copy .eyebrow { justify-content: flex-start; }
  .subhero-copy h1 { font-size: clamp(2rem, 4vw, 3.1rem); margin-bottom: 18px; }
  .subhero-copy p { margin-bottom: 26px; max-width: 38ch; }
  .subhero-copy .metric-strip { justify-content: flex-start; gap: 1.75rem; }
  .subhero-media img { width: 100%; height: auto; display: block; border-radius: var(--radius-app); }
  @media (max-width: 900px) {
    .subhero-grid { grid-template-columns: 1fr; gap: 2rem; }
    .subhero-copy { text-align: center; }
    .subhero-copy .eyebrow, .subhero-copy .metric-strip { justify-content: center; }
    .subhero-copy p { margin-left: auto; margin-right: auto; }
  }

  /* intro media image fills the frame like other split media */
  .intro-img { width: 100%; height: auto; display: block; border-radius: 18px; }

  /* ---- Ideal-for chips ---- */
  .ideal-grid { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .ideal-chip { display: inline-flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 999px; background: var(--navy-card); border: var(--border-faint); font-size: 15px; }
  .ideal-chip svg { width: 16px; height: 16px; color: var(--primary); flex: none; }

  /* ---- Related cards as links ---- */
  .cap-card--link { text-decoration: none; color: inherit; display: flex; flex-direction: column; }
  .cap-card--link .cap-link { margin-top: auto; padding-top: 12px; color: var(--primary); font-weight: 500; font-size: 15px; }

  /* ---- FAQ accordion (native <details>, no JS) ---- */
  .container--narrow { max-width: 820px; }
  .faq-list { display: flex; flex-direction: column; gap: 12px; }
  .faq-item { background: var(--navy-card); border: var(--border-faint); border-radius: 12px; overflow: hidden; }
  .faq-item summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 18px 22px; font-weight: 500; font-size: 1.05rem; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-mark { flex: none; color: var(--primary); display: inline-flex; transition: transform .2s ease; }
  .faq-mark svg { width: 20px; height: 20px; }
  .faq-item[open] .faq-mark { transform: rotate(45deg); }
  .faq-a { padding: 0 22px 20px; color: rgba(255,255,255,0.78); font-size: 1rem; line-height: 1.5; }
  .faq-a p { margin: 0; }
</style>

<!-- Calendly inline init (same as parent web-design page) -->
<script>
  (function () {
    var el = document.getElementById('calendlyInline');
    if (!el || !window.calInline) return;
    var mounted = false;
    function mount(){
      if (mounted) return; mounted = true;
      window.calInline(el);
      setTimeout(function () { el.classList.add('is-loaded'); }, 1200);
    }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(ents){
        ents.forEach(function(e){ if (e.isIntersecting) { mount(); io.disconnect(); } });
      }, { rootMargin: '300px 0px' });
      io.observe(el);
    } else { mount(); }
  })();
</script>
</BaseLayout>
