---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Web Design Services in Miami, FL — SENAVIA Corp · Google Partner-Certified";
const description = "Expert web design and digital marketing services for businesses in Miami, FL — Google Partner-certified. Conversion-focused websites, local SEO, and development for Miami-Dade.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/service-areas/miami"
  jsonLdType="localbusiness"
  screenLabel="Service Area · Miami"
>
<style is:global data-recovered>
/* ============================================================
     SERVICE AREA DETAIL — page-specific components
     ============================================================ */

  /* Hero breadcrumb */
  .sa-crumb {
    display: inline-flex; align-items: center; gap: 8px;
    margin-bottom: 18px;
    font-size: 13px; font-weight: 500;
    color: rgba(255,255,255,0.6);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: 0.04em;
  }
  .sa-crumb a { color: rgba(255,255,255,0.6); transition: color .15s ease; }
  .sa-crumb a:hover { color: var(--primary); }
  .sa-crumb .sep { opacity: .45; }
  .sa-crumb .here { color: var(--primary); }

  /* --- Local services grid --- */
  .loc-svc {
    display: flex; flex-direction: column; gap: 14px;
    text-decoration: none; color: inherit;
    height: 100%;
  }
  .loc-svc .svc-head { display: flex; align-items: center; gap: 14px; }
  .loc-svc h3 {
    margin: 0;
    font-size: 1.25rem; font-weight: 500;
    letter-spacing: -0.005em;
  }
  .loc-svc p {
    margin: 0;
    font-size: 14.5px;
    color: rgba(255,255,255,0.72);
    line-height: 1.55;
  }
  .loc-svc .more {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: auto; padding-top: 6px;
    color: var(--primary); font-size: 14px; font-weight: 600;
    transition: color .2s ease;
  }
  .loc-svc .more::after {
    content:''; width: 15px; height: 11px;
    background-color: currentColor;
    -webkit-mask: url('/images/Arrow.svg') center/contain no-repeat;
            mask: url('/images/Arrow.svg') center/contain no-repeat;
    transition: transform .2s ease;
  }
  .loc-svc:hover .more::after { transform: translateX(3px); }
  .loc-svc:hover .more { color: var(--white); }

  /* --- Map + stats block --- */
  .sa-mapstats {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: 40px;
    align-items: stretch;
  }
  @media (max-width: 980px) { .sa-mapstats { grid-template-columns: 1fr; gap: 32px; } }

  .map-embed {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    min-height: 460px;
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow: var(--shadow-soft);
    background:
      radial-gradient(ellipse at 64% 42%, rgba(45,125,184,0.22) 0%, transparent 55%),
      linear-gradient(160deg, #12173f 0%, #0c1030 100%);
  }
  /* map grid + faux roads */
  .map-embed::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.045) 1px, transparent 1px);
    background-size: 46px 46px;
  }
  .map-roads { position: absolute; inset: 0; z-index: 1; opacity: .55; }
  .map-water {
    position: absolute; top: 0; right: 0; bottom: 0; width: 34%;
    background: linear-gradient(90deg, transparent, rgba(45,125,184,0.28));
    z-index: 1;
  }
  .map-water-label {
    position: absolute; right: 26px; top: 50%;
    transform: translateY(-50%) rotate(90deg);
    transform-origin: right center;
    font-size: 11px; font-style: italic; letter-spacing: 0.24em;
    color: rgba(150,200,235,0.6);
    z-index: 2;
  }
  /* the pin */
  .map-pin {
    position: absolute; left: 46%; top: 44%;
    transform: translate(-50%, -100%);
    z-index: 3;
    width: 38px; height: 38px;
    filter: drop-shadow(0 8px 14px rgba(0,0,0,0.45));
  }
  .map-pin svg { width: 100%; height: 100%; display: block; }
  .map-pin::after {
    content: '';
    position: absolute; left: 50%; bottom: -7px;
    transform: translateX(-50%);
    width: 26px; height: 9px; border-radius: 50%;
    background: radial-gradient(ellipse, rgba(0,0,0,0.4), transparent 70%);
  }
  .map-ping {
    position: absolute; left: 46%; top: 44%;
    transform: translate(-50%, -50%);
    width: 16px; height: 16px; border-radius: 50%;
    border: 2px solid var(--primary);
    z-index: 2;
    animation: mapPing 2.6s cubic-bezier(.2,.6,.2,1) infinite;
  }
  @keyframes mapPing {
    0%   { opacity: .7; transform: translate(-50%,-50%) scale(.4); }
    80%  { opacity: 0;  transform: translate(-50%,-50%) scale(3.6); }
    100% { opacity: 0; }
  }
  /* business card lower-left, like a real maps pin popup */
  .map-card {
    position: absolute; left: 22px; bottom: 22px; right: 22px;
    max-width: 320px; z-index: 4;
    background: rgba(13,18,53,0.86);
    -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    padding: 16px 18px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .map-card .name { font-size: 15px; font-weight: 600; color: #fff; }
  .map-card .addr { font-size: 13px; color: rgba(255,255,255,0.66); line-height: 1.4; }
  .map-card .rating {
    display: inline-flex; align-items: center; gap: 7px;
    margin-top: 6px; font-size: 13px; color: rgba(255,255,255,0.82);
  }
  .map-card .rating .stars { display: inline-flex; gap: 1px; color: #FFC83D; }
  .map-card .rating .stars svg { width: 13px; height: 13px; }
  /* placeholder ribbon */
  .map-tag {
    position: absolute; top: 16px; left: 16px; z-index: 4;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 6px 10px; border-radius: 8px;
  }

  .sa-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  @media (max-width: 540px) { .sa-stats { grid-template-columns: 1fr; } }
  .sa-stats .stat-card { padding: 1.75rem 1.5rem; }

  /* neighborhood chips under the stats */
  .sa-hoods { margin-top: 1.5rem; }
  .sa-hoods .lbl {
    font-size: 12px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgba(255,255,255,0.5);
    margin: 0 0 12px;
  }
</style>

<main>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" data-screen-label="01 Miami Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="sa-crumb">
        <a href="/../service-areas">Service Areas</a>
        <span class="sep">/</span>
        <span>Miami-Dade County</span>
        <span class="sep">/</span>
        <span class="here">Miami</span>
      </div>
      <h1>Web Design Services in Miami, FL</h1>
      <p>Expert web design and digital marketing services for businesses in Miami, FL — Google Partner-certified.</p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">Book a Free Call</a>
      <div class="metric-strip" aria-label="Key metrics">
        <div class="metric"><span class="metric-value">2.7M</span><span class="metric-label">Miami-Dade residents</span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">100+</span><span class="metric-label">Sites launched</span></div>
        <span class="divider"></span>
        <div class="metric"><span class="metric-value">5.0 ★</span><span class="metric-label">Google reviews</span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHY MIAMI BUSINESSES CHOOSE SENAVIA
       ============================================================ -->
  <section class="section" data-screen-label="02 Why Miami">
    <div class="container">
      <div class="split" data-reveal>
        <div class="split-copy">
          <div class="eyebrow">Why Miami chooses us</div>
          <h2>Why Miami Businesses Choose SENAVIA</h2>
          <p>Miami is the most competitive small-business market in Florida — bilingual buyers, fast-moving verticals, and customers who judge your brand in seconds. SENAVIA builds conversion-focused websites tuned to exactly that pressure, with local SEO that wins the Miami-Dade map pack.</p>
          <p>As a Google Partner-certified agency serving Brickell to Doral, we pair bold, mobile-first design with technical SEO and a fully bilingual EN/ES team — so you get a partner that speaks your market, not a vendor with a template.</p>
          <div class="chip-row">
            <span class="chip"><span class="dot"></span>Google Partner Certified</span>
            <span class="chip"><span class="dot"></span>Bilingual EN / ES</span>
            <span class="chip"><span class="dot"></span>Local Miami-Dade SEO</span>
            <span class="chip"><span class="dot"></span>Webflow &amp; Shopify</span>
          </div>
          <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">Book a Free Call</a>
        </div>
        <div class="split-media">
          <img src="/images/services/web-design-miami.avif" alt="SENAVIA Corp web design team working on a Miami client project" loading="lazy">
          <span class="badge-overlay">Serving Miami-Dade County</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       LOCAL SERVICES GRID
       ============================================================ -->
  <section class="section" data-screen-label="03 Miami Services">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">What we do in Miami</div>
        <h2>Digital Services Built for Miami Businesses</h2>
        <p>Three core capabilities, each tuned to how Miami buyers search, scroll, and decide — from Brickell storefronts to Doral service companies.</p>
      </div>
      <div class="grid-3" data-reveal-children>
        <a href="/../services/web-design" class="card-solid loc-svc">
          <div class="svc-head">
            <span class="svc-icon"><img src="/images/Web-Design-Icon.svg" alt=""></span>
            <h3>Web Design</h3>
          </div>
          <p>Conversion-focused websites that match Miami's pace — bold, mobile-first, and bilingual-ready. We design for the Brickell professional and the Hialeah family business alike, with brand polish Miami buyers expect on first scroll.</p>
          <span class="more">Explore Web Design</span>
        </a>
        <a href="/../services/digital-marketing" class="card-solid loc-svc">
          <div class="svc-head">
            <span class="svc-icon is-cyan"><img src="/images/Marketing-Icon.svg" alt=""></span>
            <h3>Digital Marketing</h3>
          </div>
          <p>Local SEO and paid campaigns engineered for the Miami-Dade map pack. Geo-targeted content, Google Business Profile optimization, and EN/ES ad copy that reaches both of Miami's audiences where they actually search.</p>
          <span class="more">Explore Marketing</span>
        </a>
        <a href="/../services/web-development" class="card-solid loc-svc">
          <div class="svc-head">
            <span class="svc-icon is-green"><img src="/images/Development-Icon.svg" alt=""></span>
            <h3>Web Development</h3>
          </div>
          <p>Fast, scalable builds on Webflow, Shopify, and custom stacks. From Miami e-commerce storefronts to booking systems and CRM integrations — engineered for Core Web Vitals and ready to grow with your business.</p>
          <span class="more">Explore Development</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       MAP + LOCAL STATS
       ============================================================ -->
  <section class="section" data-screen-label="04 Map & Stats">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">On the ground in Miami</div>
        <h2>Serving Every Corner of Miami-Dade</h2>
        <p>Headquartered in Plantation and active across Miami-Dade — here's what our local footprint looks like.</p>
      </div>

      <div class="sa-mapstats" data-reveal>
        <!-- Map embed placeholder -->
        <div class="map-embed" role="img" aria-label="Map of Miami service area">
          <span class="map-tag">Google Maps embed</span>
          <svg class="map-roads" viewBox="0 0 600 460" preserveAspectRatio="none" aria-hidden="true">
            <g stroke="rgba(255,255,255,0.16)" fill="none" stroke-width="3">
              <path d="M-20 120 L380 90 L640 140"/>
              <path d="M-20 260 L300 240 L640 300"/>
              <path d="M60 -20 L120 200 L90 480"/>
              <path d="M320 -20 L300 220 L360 480"/>
            </g>
            <g stroke="rgba(153,204,51,0.45)" fill="none" stroke-width="4">
              <path d="M-20 360 L260 330 L420 380 L640 360"/>
            </g>
          </svg>
          <div class="map-water"></div>
          <span class="map-water-label">ATLANTIC OCEAN</span>
          <span class="map-ping"></span>
          <span class="map-pin">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 22s7-7.16 7-12A7 7 0 1 0 5 10c0 4.84 7 12 7 12z" fill="#99CC33" stroke="#0A0E26" stroke-width="1.3"/>
              <circle cx="12" cy="10" r="2.6" fill="#0A0E26"/>
            </svg>
          </span>
          <div class="map-card">
            <span class="name">SENAVIA Corp — Miami</span>
            <span class="addr">Serving Miami &amp; greater Miami-Dade · HQ in Plantation, FL</span>
            <span class="rating">
              <span class="stars" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </span>
              5.0 · 47 Google reviews
            </span>
          </div>
        </div>

        <!-- Local stats -->
        <div>
          <div class="sa-stats">
            <article class="stat-card">
              <span class="stat-value">2.7M</span>
              <span class="stat-label">Residents across Miami-Dade County — the largest market in South Florida.</span>
            </article>
            <article class="stat-card">
              <span class="stat-value">34</span>
              <span class="stat-label">Municipalities covered, from Miami Beach to Homestead.</span>
            </article>
            <article class="stat-card">
              <span class="stat-value">~25 min</span>
              <span class="stat-label">From our Plantation HQ to Downtown Miami — local, not outsourced.</span>
            </article>
            <article class="stat-card">
              <span class="stat-value">68%</span>
              <span class="stat-label">Of Miami-Dade residents speak Spanish — our team is fully bilingual.</span>
            </article>
          </div>
          <div class="sa-hoods">
            <p class="lbl">Neighborhoods &amp; areas we serve</p>
            <div class="chip-row" style="margin-top:0;">
              <span class="chip"><span class="dot"></span>Brickell</span>
              <span class="chip"><span class="dot"></span>Wynwood</span>
              <span class="chip"><span class="dot"></span>Coral Gables</span>
              <span class="chip"><span class="dot"></span>Doral</span>
              <span class="chip"><span class="dot"></span>Miami Beach</span>
              <span class="chip"><span class="dot"></span>Hialeah</span>
              <span class="chip"><span class="dot"></span>Kendall</span>
              <span class="chip"><span class="dot"></span>Aventura</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       LOCAL CASE STUDIES — carousel
       ============================================================ -->
  <section class="section" data-screen-label="05 Miami Case Studies">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Local case studies</div>
        <h2>Miami Projects We're Proud Of</h2>
        <p>A look at recent web design, development, and marketing work for businesses across Miami-Dade.</p>
      </div>

      <div class="carousel" data-carousel="miami-projects">
        <div class="carousel-arrows">
          <button class="carousel-arrow prev" aria-label="Previous projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
          </button>
          <button class="carousel-arrow next" aria-label="Next projects" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
        <div class="carousel-viewport">
          <div class="carousel-track" role="list">
            <article class="project-card" role="listitem">
              <a href="/../portfolio/angele-glow" class="project-cover ph-1" aria-label="ANGELE GLOW Skincare — Brickell">
                <span class="project-name">ANGELE GLOW</span>
              </a>
              <div class="project-body">
                <p class="project-sector">Brickell · Shopify E-commerce</p>
                <p>Skincare e-commerce on Shopify with custom UI, subscription bundles, and a bilingual storefront for a Brickell beauty brand.</p>
                <a href="/../portfolio/angele-glow" class="btn is-secondary is-sm">Preview Website</a>
              </div>
            </article>
            <article class="project-card" role="listitem">
              <a href="/../portfolio/pergola-plus-florida" class="project-cover ph-3" aria-label="Pergola Plus Florida — Doral">
                <span class="project-name">Pergola Plus Florida</span>
              </a>
              <div class="project-body">
                <p class="project-sector">Doral · Service Site &amp; Local SEO</p>
                <p>Outdoor living brand site with quote-request flow, project gallery, and Miami-Dade local SEO that owns the map pack.</p>
                <a href="/../portfolio/pergola-plus-florida" class="btn is-secondary is-sm">Preview Website</a>
              </div>
            </article>
            <article class="project-card" role="listitem">
              <a href="/../portfolio/ab-aluminum" class="project-cover ph-4" aria-label="AB Aluminum & Screens — Kendall">
                <span class="project-name">AB Aluminum &amp; Screens</span>
              </a>
              <div class="project-body">
                <p class="project-sector">Kendall · Webflow &amp; Google Ads</p>
                <p>Home-improvement contractor site with a screen-enclosure showcase, financing CTA, and conversion-tuned Google Ads landing pages.</p>
                <a href="/../portfolio/ab-aluminum" class="btn is-secondary is-sm">Preview Website</a>
              </div>
            </article>
            <article class="project-card" role="listitem">
              <a href="/../portfolio/lake-scaping" class="project-cover ph-2" aria-label="Lake Scaping LLC — Homestead">
                <span class="project-name">Lake Scaping LLC</span>
              </a>
              <div class="project-body">
                <p class="project-sector">Homestead · Lead Generation</p>
                <p>Landscaping company website with service-area pages, before/after gallery, and an automated lead-to-CRM workflow.</p>
                <a href="/../portfolio/lake-scaping" class="btn is-secondary is-sm">Preview Website</a>
              </div>
            </article>
          </div>
        </div>
        <div class="carousel-scrollbar" role="presentation">
          <div class="carousel-scrollbar-thumb"></div>
        </div>
      </div>

      <div class="center-cta">
        <a href="/../portfolio" class="btn">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROCESS + REVIEWS (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <!-- PROCESS -->
    <section id="process" class="section section-flush" data-screen-label="06 Process">
      <div class="container">
        <div class="section-head" data-reveal>
          <h2>Our Process</h2>
          <p>We understand your goals and challenges, create a tailored plan with clear estimates, and build a custom solution designed for your success in Miami.</p>
        </div>
        <div class="grid-4" data-reveal-children>
          <article class="process-block">
            <img class="process-img" src="/images/process/explore.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>1. Explore</h3>
                <h4>Digital Strategy &amp; Market Discovery</h4>
              </div>
              <p>We analyze your goals, audience, and the Miami-Dade market to uncover real growth opportunities.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/estimate.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>2. Estimate</h3>
                <h4>Project Planning &amp; Strategic Roadmap</h4>
              </div>
              <p>We define a clear project plan aligned with your budget, timeline, and objectives.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/development.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>3. Development</h3>
                <h4>Custom Web Development &amp; SEO</h4>
              </div>
              <p>We build high-performance websites and platforms optimized for SEO and conversions.</p>
            </div>
          </article>
          <article class="process-block">
            <img class="process-img" src="/images/process/delivery.avif" alt="" loading="lazy">
            <div class="process-glass"></div>
            <div class="process-content">
              <div class="process-header">
                <h3>4. Delivery</h3>
                <h4>Website Launch &amp; Ongoing Optimization</h4>
              </div>
              <p>We launch and optimize your digital presence from Plantation, serving all of Miami.</p>
            </div>
          </article>
        </div>
        <div class="center-cta" style="margin-top: 3rem;" data-reveal>
          <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">Book a Free Call</a>
        </div>
      </div>
