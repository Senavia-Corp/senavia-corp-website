---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE, NAP, NAV, CALENDLY_URL } from '@/data/site';

export async function getStaticPaths() {
  const all = (await getCollection('serviceAreas')).sort((a, b) => a.data.order - b.data.order);
  return all.map((entry) => ({ params: { slug: entry.id }, props: { entry, all } }));
}

const { entry, all } = Astro.props;
const d = entry.data;
const cityShort = d.city.replace(/,\s*FL$/i, '');

// Real Google Maps embed centered on the city.
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(`${d.city}, FL`)}&output=embed`;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent('150 S Pine Island Rd Suite 377, Plantation FL 33324')}`;

// The 3 services (canonical pillars) from site nav data.
const services = NAV.services;

// Real CMS data for the strips.
const projects = (await getCollection('portfolio'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order)
  .slice(0, 3);
const posts = (await getCollection('blog'))
  .sort((a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0))
  .slice(0, 3);
const reviews = (await getCollection('testimonials'))
  .sort((a, b) => Number(b.data.rating) - Number(a.data.rating))
  .slice(0, 3);

// Nearby cities in the same county (internal linking for local SEO).
const nearby = all
  .filter((a) => a.data.county === d.county && a.id !== entry.id)
  .slice(0, 9);

const fmtEn = (x?: Date) => (x ? x.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '');
const fmtEs = (x?: Date) => (x ? x.toLocaleDateString('es-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '');
const catLabelEn: Record<string, string> = { 'web-design': 'Web Design', 'web-development': 'Web Development', 'digital-marketing': 'Traffic Generation' };
const catLabelEs: Record<string, string> = { 'web-design': 'Diseño Web', 'web-development': 'Desarrollo Web', 'digital-marketing': 'Generación de Tráfico' };

const STAR = `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:inline-block"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;

// Bilingual fallbacks for section heads when a CMS field is empty.
const t = {
  servicesHead: { en: `Web Design, Development & Traffic Generation in ${cityShort}`, es: `Diseño Web, Desarrollo y Generación de Tráfico en ${cityShort}` },
  portfolioHead: { en: `Our Work Across ${cityShort} & South Florida`, es: `Nuestro Trabajo en ${cityShort} y el Sur de Florida` },
  processHead: { en: `How We Work With ${cityShort} Businesses`, es: `Cómo Trabajamos con Negocios de ${cityShort}` },
  reviewsHead: { en: `What ${cityShort} Business Owners Say`, es: `Lo Que Dicen los Negocios de ${cityShort}` },
  blogHead: { en: `Insights for ${cityShort} Business Owners`, es: `Recursos para Negocios de ${cityShort}` },
};

const steps = [
  { n: '01', en: 'Discovery & local research', es: 'Descubrimiento e investigación local', den: `We map your ${cityShort} market, competitors, and the searches your customers actually use.`, des: `Mapeamos tu mercado en ${cityShort}, la competencia y las búsquedas que tus clientes realmente usan.` },
  { n: '02', en: 'Strategy & estimate', es: 'Estrategia y estimado', den: 'A clear plan, scope, and quote aligned to your goals — no surprises.', des: 'Un plan claro, alcance y cotización alineados a tus objetivos — sin sorpresas.' },
  { n: '03', en: 'Design & build', es: 'Diseño y desarrollo', den: 'A fast, conversion-focused site built around local SEO and your brand.', des: 'Un sitio rápido y enfocado en conversión, construido sobre SEO local y tu marca.' },
  { n: '04', en: 'Launch & grow', es: 'Lanzamiento y crecimiento', den: 'We launch, track conversions, and keep optimizing for more local leads.', des: 'Lanzamos, medimos conversiones y seguimos optimizando para más prospectos locales.' },
];

// City-specific structured data (Service + Breadcrumb) for local SEO.
const cityLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: `Web Design & Digital Marketing in ${cityShort}, FL`,
      serviceType: 'Web Design, Web Development & Traffic Generation',
      provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
      areaServed: { '@type': 'City', name: cityShort, containedInPlace: { '@type': 'AdministrativeArea', name: `${d.county} County, FL` } },
      url: `${SITE.url}/service-areas/${entry.id}`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Service Areas', item: `${SITE.url}/service-areas` },
        { '@type': 'ListItem', position: 2, name: `${d.county} County`, item: `${SITE.url}/service-areas` },
        { '@type': 'ListItem', position: 3, name: cityShort, item: `${SITE.url}/service-areas/${entry.id}` },
      ],
    },
  ],
};
---
<BaseLayout
  title={d.seoTitle}
  description={d.seoDescription}
  canonical={`/service-areas/${entry.id}`}
  jsonLdType="localbusiness"
  screenLabel={`Service Area · ${cityShort}`}
>
<style is:global data-recovered>
  /* ============================================================
     SERVICE AREA DETAIL — local SEO landing
     ============================================================ */
  .sa-crumb {
    display: inline-flex; align-items: center; gap: 8px; margin-bottom: 18px;
    font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.65);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace; letter-spacing: 0.04em; flex-wrap: wrap;
  }
  .sa-crumb a { color: rgba(255,255,255,0.65); transition: color .15s ease; }
  .sa-crumb a:hover { color: var(--primary); }
  .sa-crumb .sep { opacity: .45; }
  .sa-crumb .here { color: var(--primary); }

  .sa-pill {
    display: inline-flex; align-items: center; gap: 8px; margin-top: 22px;
    padding: 8px 16px; border-radius: 999px; font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
    color: var(--primary, #99cc33); background: rgba(153,204,51,0.12); border: 1px solid rgba(153,204,51,0.34);
  }
  .sa-pill .dot { width: 8px; height: 8px; border-radius: 999px; background: var(--primary, #99cc33); box-shadow: 0 0 10px rgba(153,204,51,0.8); }

  .sa-sec-num {
    display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--primary, #99cc33); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; margin-bottom: 8px;
  }
  .cms-prose { color: rgba(255,255,255,0.74); line-height: 1.7; font-size: 1.0625rem; }
  .cms-prose p { margin: 0 0 1rem; } .cms-prose p:last-child { margin-bottom: 0; }
  .cms-prose a { color: var(--primary); text-decoration: underline; text-underline-offset: 2px; }
  .cms-prose strong { color: #fff; }

  /* INTRO 2-col: copy + trust panel */
  .sa-intro-grid { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(0,1fr); gap: 48px; align-items: center; }
  @media (max-width: 900px) { .sa-intro-grid { grid-template-columns: 1fr; gap: 32px; } }
  .sa-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 420px) { .sa-stats { grid-template-columns: 1fr; } }

  /* generic premium card grid for services/process */
  .sa-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 2.5rem; }
  .sa-cards.cols-4 { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 900px) { .sa-cards, .sa-cards.cols-4 { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .sa-cards, .sa-cards.cols-4 { grid-template-columns: 1fr; } }
  .sa-card {
    display: flex; flex-direction: column; gap: 10px; padding: 1.6rem 1.5rem; border-radius: 16px;
    background: rgba(13,18,53,0.55); border: 1px solid rgba(255,255,255,0.08);
    text-decoration: none; color: inherit; transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  a.sa-card:hover { transform: translateY(-4px); border-color: rgba(153,204,51,0.4); box-shadow: 0 20px 50px rgba(0,0,0,0.35); }
  .sa-card .ic { width: 46px; height: 46px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, rgba(153,204,51,0.18), rgba(51,204,204,0.12)); border: 1px solid rgba(153,204,51,0.28); }
  .sa-card .ic img { width: 24px; height: 24px; }
  .sa-card h3 { font-size: 1.15rem; margin: 0; color: #fff; }
  .sa-card p { font-size: 14px; line-height: 1.55; color: rgba(255,255,255,0.7); margin: 0; }
  .sa-card .more { margin-top: auto; font-size: 13px; font-weight: 600; color: var(--primary); }
  .sa-card .step-n { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; color: var(--primary); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }

  /* project cards with real images */
  .sa-proj { position: relative; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08);
    text-decoration: none; color: inherit; display: block; transition: transform .25s ease, box-shadow .25s ease; }
  .sa-proj:hover { transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
  .sa-proj .ph { position: relative; aspect-ratio: 16/10; overflow: hidden; background: #0c1030; }
  .sa-proj .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .sa-proj .bd { padding: 1.1rem 1.25rem 1.3rem; }
  .sa-proj h3 { font-size: 1.05rem; margin: 0 0 .35rem; color: #fff; }
  .sa-proj p { font-size: 13px; line-height: 1.5; color: rgba(255,255,255,0.65); margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  /* review cards */
  .sa-rev { padding: 1.6rem 1.5rem; border-radius: 16px; background: rgba(13,18,53,0.55); border: 1px solid rgba(255,255,255,0.08); }
  .sa-rev .stars { display: inline-flex; gap: 2px; color: #FFC83D; margin-bottom: .7rem; }
  .sa-rev .stars svg { width: 16px; height: 16px; }
  .sa-rev p { font-size: 14.5px; line-height: 1.6; color: rgba(255,255,255,0.82); margin: 0 0 1rem; }
  .sa-rev .who { display: flex; align-items: center; gap: 10px; }
  .sa-rev .av { width: 38px; height: 38px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: #0a0e26; background: linear-gradient(135deg, #99CC33, #33CCCC); }
  .sa-rev .nm { font-size: 14px; font-weight: 600; color: #fff; } .sa-rev .co { font-size: 12.5px; color: rgba(255,255,255,0.6); }

  /* map + nearby cities */
  .sa-mapgrid { display: grid; grid-template-columns: minmax(0,1.3fr) minmax(0,1fr); gap: 40px; align-items: stretch; }
  @media (max-width: 980px) { .sa-mapgrid { grid-template-columns: 1fr; gap: 28px; } }
  .map-embed { position: relative; border-radius: 20px; overflow: hidden; min-height: 460px;
    border: 1px solid rgba(255,255,255,0.10); box-shadow: var(--shadow-soft); background: linear-gradient(160deg, #12173f, #0c1030); }
  .map-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; display: block; filter: saturate(0.9) contrast(1.02); }
  .map-card { position: absolute; left: 22px; bottom: 22px; right: 22px; max-width: 320px; z-index: 4;
    background: rgba(13,18,53,0.86); -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 16px 18px; display: flex; flex-direction: column; gap: 4px; }
  .map-card .name { font-size: 15px; font-weight: 600; color: #fff; }
  .map-card .addr { font-size: 13px; color: rgba(255,255,255,0.66); line-height: 1.4; }
  .map-card .map-card-link { margin-top: 10px; font-size: 13px; font-weight: 600; color: var(--primary); display: inline-flex; align-items: center; gap: 6px; }
  .sa-aside { display: flex; flex-direction: column; gap: 16px; }
  .sa-aside .sa-stats { grid-template-columns: 1fr 1fr; }
  .sa-nearby { padding: 1.6rem 1.5rem; border-radius: 16px; background: rgba(13,18,53,0.55); border: 1px solid rgba(255,255,255,0.08); }
  .sa-nearby h3 { font-size: 1.05rem; margin: 0 0 .9rem; color: #fff; }
  .sa-nearby .chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .sa-nearby a { font-size: 13px; padding: 7px 13px; border-radius: 999px; color: rgba(255,255,255,0.8);
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); text-decoration: none; transition: all .18s ease; }
  .sa-nearby a:hover { color: var(--primary); border-color: rgba(153,204,51,0.45); background: rgba(153,204,51,0.08); }

  .sa-strip-cta { text-align: center; margin-top: 2.25rem; }
</style>

<script type="application/ld+json" set:html={JSON.stringify(cityLd)} is:inline></script>

<main>

  <!-- HERO -->
  <section class="hero" data-screen-label="01 Local Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback" poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="sa-crumb">
        <a href="/service-areas"><span class="lang-only-en">Service Areas</span><span class="lang-only-es">Áreas de Servicio</span></a>
        <span class="sep">/</span><span>{d.county}</span><span class="sep">/</span><span class="here">{cityShort}</span>
      </div>
      <h1>{d.titlePage}</h1>
      {d.summaryPage && <p>{d.summaryPage}</p>}
      <span class="sa-pill"><span class="dot"></span>
        <span class="lang-only-en">Serving {cityShort} &amp; {d.county} County</span>
        <span class="lang-only-es">Atendiendo {cityShort} y el Condado de {d.county}</span>
      </span>
      <div style="margin-top: 28px; display:flex; gap:12px; flex-wrap:wrap;">
        <a href="#" class="btn" onclick={`if(window.Calendly){Calendly.initPopupWidget({url:'${CALENDLY_URL}'});}return false;`}>
          <span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span>
        </a>
        <a href="tel:+17542623659" class="btn is-secondary is-call">(754) 262-3659</a>
      </div>
    </div>
  </section>

  <!-- INTRO + trust stats -->
  <section class="section section--band" data-screen-label="02 Intro">
    <div class="container">
      <div class="sa-intro-grid">
        <div data-reveal>
          <span class="sa-sec-num">01</span>
          <div class="eyebrow"><span class="lang-only-en">Local web design</span><span class="lang-only-es">Diseño web local</span></div>
          <h2>{d.headingIntro || `Web Design Agency Serving ${cityShort}, FL`}</h2>
          {d.paragraphIntro && <div class="cms-prose" set:html={d.paragraphIntro} />}
          <div style="margin-top:1.6rem;">
            <a href="#" class="btn is-sm" onclick={`if(window.Calendly){Calendly.initPopupWidget({url:'${CALENDLY_URL}'});}return false;`}>
              <span class="lang-only-en">Get a Free Quote</span><span class="lang-only-es">Solicita una Cotización</span>
            </a>
          </div>
        </div>
        <div class="sa-stats" data-reveal-children>
          <article class="stat-card"><span class="stat-value">100+</span><span class="stat-label"><span class="lang-only-en">Websites launched for South Florida businesses</span><span class="lang-only-es">Sitios lanzados para negocios del Sur de Florida</span></span></article>
          <article class="stat-card"><span class="stat-value">5.0 ★</span><span class="stat-label"><span class="lang-only-en">Average verified Google review rating</span><span class="lang-only-es">Promedio de reseñas verificadas en Google</span></span></article>
          <article class="stat-card"><span class="stat-value">EN / ES</span><span class="stat-label"><span class="lang-only-en">Fully bilingual team for your market</span><span class="lang-only-es">Equipo totalmente bilingüe para tu mercado</span></span></article>
          <article class="stat-card"><span class="stat-value">Google</span><span class="stat-label"><span class="lang-only-en">Partner-certified for Ads &amp; local search</span><span class="lang-only-es">Certificados como Partner para Ads y búsqueda local</span></span></article>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section" data-screen-label="03 Services">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="sa-sec-num">02</span>
        <div class="eyebrow"><span class="lang-only-en">What we do</span><span class="lang-only-es">Lo que hacemos</span></div>
        <h2>{d.headingServices || t.servicesHead.en}</h2>
        {d.paragraphServices
          ? <div class="cms-prose" style="margin:0 auto; max-width:760px;" set:html={d.paragraphServices} />
          : <p><span class="lang-only-en">Three services that grow {cityShort} businesses — built to attract, convert, and scale.</span><span class="lang-only-es">Tres servicios que hacen crecer a los negocios de {cityShort} — para atraer, convertir y escalar.</span></p>}
      </div>
      <div class="sa-cards" data-reveal-children>
        {services.map((s) => (
          <a class="sa-card" href={s.href}>
            <span class="ic"><img src={s.icon} alt="" /></span>
            <h3><span class="lang-only-en">{s.title_en}</span><span class="lang-only-es">{s.title_es}</span></h3>
            <p><span class="lang-only-en">{s.desc_en}</span><span class="lang-only-es">{s.desc_es}</span></p>
            <span class="more"><span class="lang-only-en">Learn more →</span><span class="lang-only-es">Conoce más →</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section class="section section--band" data-screen-label="04 Portfolio">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="sa-sec-num">03</span>
        <div class="eyebrow"><span class="lang-only-en">Our work</span><span class="lang-only-es">Nuestro trabajo</span></div>
        <h2>{d.headingPortfolio || t.portfolioHead.en}</h2>
        {d.paragraphPortfolio && <div class="cms-prose" style="margin:0 auto; max-width:760px;" set:html={d.paragraphPortfolio} />}
      </div>
      <div class="sa-cards" data-reveal-children>
        {projects.map((p) => (
          <a class="sa-proj" href={`/portfolio/${p.id}`}>
            <span class="ph">{p.data.mainImage && <img src={p.data.mainImage} alt={p.data.imageAlt} loading="lazy" decoding="async" />}</span>
            <span class="bd"><h3>{p.data.title}</h3><p>{p.data.summary}</p></span>
          </a>
        ))}
      </div>
      <div class="sa-strip-cta">
        <a href="/portfolio" class="btn is-secondary"><span class="lang-only-en">View All Projects</span><span class="lang-only-es">Ver Todos los Proyectos</span></a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section" data-screen-label="05 Process">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="sa-sec-num">04</span>
        <div class="eyebrow"><span class="lang-only-en">How we work</span><span class="lang-only-es">Cómo trabajamos</span></div>
        <h2>{d.headingProcess || t.processHead.en}</h2>
        {d.paragraphProcess && <div class="cms-prose" style="margin:0 auto; max-width:760px;" set:html={d.paragraphProcess} />}
      </div>
      <div class="sa-cards cols-4" data-reveal-children>
        {steps.map((st) => (
          <article class="sa-card">
            <span class="step-n">{st.n}</span>
            <h3><span class="lang-only-en">{st.en}</span><span class="lang-only-es">{st.es}</span></h3>
            <p><span class="lang-only-en">{st.den}</span><span class="lang-only-es">{st.des}</span></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section section--band" data-screen-label="06 Reviews">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="sa-sec-num">05</span>
        <div class="eyebrow"><span class="lang-only-en">Client reviews</span><span class="lang-only-es">Reseñas de clientes</span></div>
        <h2>{d.headingReviews || t.reviewsHead.en}</h2>
        {d.paragraphReviews && <div class="cms-prose" style="margin:0 auto; max-width:760px;" set:html={d.paragraphReviews} />}
      </div>
      <div class="sa-cards" data-reveal-children>
        {reviews.map((r) => (
          <article class="sa-rev">
            <span class="stars" aria-hidden="true" set:html={STAR.repeat(Number(r.data.rating) || 5)}></span>
            <p class="lang-only-en">“{r.data.quote_en}”</p>
            <p class="lang-only-es">“{r.data.quote_es}”</p>
            <div class="who">
              <span class="av">{r.data.name.split(' ').map((w) => w[0]).slice(0, 2).join('')}</span>
              <span><span class="nm" style="display:block;">{r.data.name}</span><span class="co">{r.data.company}</span></span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="section" data-screen-label="07 Blog">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="sa-sec-num">06</span>
        <div class="eyebrow"><span class="lang-only-en">Insights</span><span class="lang-only-es">Recursos</span></div>
        <h2>{d.headingBlog || t.blogHead.en}</h2>
        {d.paragraphBlog && <div class="cms-prose" style="margin:0 auto; max-width:760px;" set:html={d.paragraphBlog} />}
      </div>
      <div class="sa-cards" data-reveal-children>
        {posts.map((p) => (
          <a class="sa-proj" href={`/blog/${p.id}`}>
            <span class="ph">{(p.data.thumbnail || p.data.mainImage) && <img src={p.data.thumbnail || p.data.mainImage} alt={p.data.altImage} loading="lazy" decoding="async" />}</span>
            <span class="bd">
              <span class="step-n">{p.data.category && (<><span class="lang-only-en">{catLabelEn[p.data.category] ?? p.data.category}</span><span class="lang-only-es">{catLabelEs[p.data.category] ?? p.data.category}</span></>)}</span>
              <h3 style="margin-top:.4rem;">{p.data.title}</h3>
              <p>{p.data.summary}</p>
            </span>
          </a>
        ))}
      </div>
      <div class="sa-strip-cta">
        <a href="/blog" class="btn is-secondary"><span class="lang-only-en">View All Articles</span><span class="lang-only-es">Ver Todos los Artículos</span></a>
      </div>
    </div>
  </section>

  <!-- MAP + NEARBY CITIES -->
  <section class="section section--band" data-screen-label="08 Map & Area">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">On the ground in {cityShort}</span><span class="lang-only-es">Presentes en {cityShort}</span></div>
        <h2><span class="lang-only-en">Serving {cityShort} &amp; {d.county} County</span><span class="lang-only-es">Atendiendo {cityShort} y el Condado de {d.county}</span></h2>
        <p><span class="lang-only-en">Headquartered in Plantation and active across {d.county} County — here's our local footprint.</span><span class="lang-only-es">Con sede en Plantation y activos en el Condado de {d.county} — esta es nuestra presencia local.</span></p>
      </div>
      <div class="sa-mapgrid" data-reveal>
        <div class="map-embed">
          <iframe src={mapSrc} title={`Map of ${d.city} service area`} loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
          <div class="map-card">
            <span class="name">SENAVIA Corp — {cityShort}</span>
            <span class="addr"><span class="lang-only-en">Serving {cityShort} &amp; greater {d.county} · HQ in Plantation, FL</span><span class="lang-only-es">Atendiendo {cityShort} y el área de {d.county} · Sede en Plantation, FL</span></span>
            <a class="map-card-link" href={directionsUrl} target="_blank" rel="noopener"><span class="lang-only-en">Get Directions →</span><span class="lang-only-es">Cómo Llegar →</span></a>
          </div>
        </div>
        <div class="sa-aside">
          <div class="sa-stats">
            <article class="stat-card"><span class="stat-value">{d.county}</span><span class="stat-label"><span class="lang-only-en">County we proudly serve</span><span class="lang-only-es">Condado que atendemos</span></span></article>
            <article class="stat-card"><span class="stat-value">24h</span><span class="stat-label"><span class="lang-only-en">Typical response time</span><span class="lang-only-es">Tiempo de respuesta típico</span></span></article>
          </div>
          {nearby.length > 0 && (
            <div class="sa-nearby">
              <h3><span class="lang-only-en">We also serve nearby cities</span><span class="lang-only-es">También atendemos ciudades cercanas</span></h3>
              <div class="chips">
                {nearby.map((c) => (<a href={`/service-areas/${c.id}`}>{c.data.city.replace(/,\s*FL$/i, '')}</a>))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta cta--glow" data-screen-label="09 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback" poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Ready to Grow Your {cityShort} Business Online?</span><span class="lang-only-es">¿Listo para Hacer Crecer tu Negocio de {cityShort} en Línea?</span></h2>
      <p><span class="lang-only-en">Schedule your free web design &amp; SEO consultation and get a custom strategy to increase traffic, leads, and conversions across {d.county} County.</span><span class="lang-only-es">Agenda tu consulta gratuita de diseño web y SEO, y obtén una estrategia a medida para aumentar tráfico, prospectos y conversiones en el Condado de {d.county}.</span></p>
      <a href="#" class="btn" onclick={`if(window.Calendly){Calendly.initPopupWidget({url:'${CALENDLY_URL}'});}return false;`}>
        <span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span>
      </a>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>
</BaseLayout>
