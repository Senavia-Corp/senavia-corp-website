---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = (await getCollection('serviceAreas'))
    .sort((a, b) => a.data.order - b.data.order);

  return all.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;

// Real Google Maps embed centered on the city (city already includes ", FL").
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(`${d.city}, FL`)}&output=embed`;

// Section registry — render only the heading/paragraph pairs that exist.
// Paragraphs go through set:html (CMS values may carry inline HTML).
const sections = [
  { key: 'intro',     heading: d.headingIntro,     paragraph: d.paragraphIntro },
  { key: 'services',  heading: d.headingServices,  paragraph: d.paragraphServices },
  { key: 'portfolio', heading: d.headingPortfolio, paragraph: d.paragraphPortfolio },
  { key: 'process',   heading: d.headingProcess,   paragraph: d.paragraphProcess },
  { key: 'reviews',   heading: d.headingReviews,   paragraph: d.paragraphReviews },
  { key: 'blog',      heading: d.headingBlog,      paragraph: d.paragraphBlog },
].filter((s) => (s.heading && s.heading.trim()) || (s.paragraph && s.paragraph.trim()));

// Bilingual eyebrow chrome per section (page chrome, NOT CMS data).
const eyebrows: Record<string, { en: string; es: string }> = {
  intro:     { en: 'Local web design', es: 'Diseño web local' },
  services:  { en: 'What we do',        es: 'Lo que hacemos' },
  portfolio: { en: 'Our work',          es: 'Nuestro trabajo' },
  process:   { en: 'How we work',       es: 'Cómo trabajamos' },
  reviews:   { en: 'Client reviews',    es: 'Reseñas de clientes' },
  blog:      { en: 'Insights',          es: 'Recursos' },
};

const STAR = `<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
---
<BaseLayout
  title={d.seoTitle}
  description={d.seoDescription}
  canonical={`/service-areas/${entry.id}`}
  jsonLdType="localbusiness"
  screenLabel={`Service Area · ${d.city}`}
>
<style is:global data-recovered>
/* ============================================================
     SERVICE AREA DETAIL — page-specific components
     ============================================================ */

  /* Hero breadcrumb */
  .sa-crumb {
    display: inline-flex; align-items: center; gap: 8px;
    margin-bottom: 18px;
    font-size: 13px; font-weight: 500;
    color: rgba(255,255,255,0.6);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: 0.04em;
    flex-wrap: wrap;
  }
  .sa-crumb a { color: rgba(255,255,255,0.6); transition: color .15s ease; }
  .sa-crumb a:hover { color: var(--primary); }
  .sa-crumb .sep { opacity: .45; }
  .sa-crumb .here { color: var(--primary); }

  /* "Serving {county}" pill */
  .sa-pill {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 22px;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 13px; font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--primary, #99cc33);
    background: rgba(153,204,51,0.12);
    border: 1px solid rgba(153,204,51,0.34);
  }
  .sa-pill .dot {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--primary, #99cc33);
    box-shadow: 0 0 10px rgba(153,204,51,0.8);
  }

  /* CMS rich-text / paragraph rendering */
  .cms-prose {
    color: rgba(255,255,255,0.74);
    line-height: 1.7;
    font-size: 1.0625rem;
    max-width: 760px;
  }
  .cms-prose > :first-child { margin-top: 0; }
  .cms-prose > :last-child { margin-bottom: 0; }
  .cms-prose p { margin: 0 0 1rem; }
  .cms-prose a { color: var(--primary, #99cc33); text-decoration: underline; text-underline-offset: 2px; }
  .cms-prose ul, .cms-prose ol { margin: 0 0 1rem 1.1rem; padding: 0; }
  .cms-prose li { margin: 0 0 0.45rem; }
  .cms-prose h2, .cms-prose h3, .cms-prose h4 { color: #fff; margin: 1.5rem 0 0.6rem; }
  .cms-prose strong { color: #fff; }

  /* numbered section index marker */
  .sa-sec-num {
    display: inline-block;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    margin-bottom: 8px;
  }

  /* --- Map block --- */
  .sa-mapstats {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: 40px;
    align-items: stretch;
  }
  @media (max-width: 980px) { .sa-mapstats { grid-template-columns: 1fr; gap: 32px; } }

  /* Real Google Maps embed */
  .map-embed {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    min-height: 460px;
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow: var(--shadow-soft);
    background: linear-gradient(160deg, #12173f 0%, #0c1030 100%);
  }
  .map-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    filter: saturate(0.9) contrast(1.02);
  }
  /* business card lower-left, like a real maps pin popup */
  .map-card {
    position: absolute; left: 22px; bottom: 22px; right: 22px;
    max-width: 320px; z-index: 4;
    background: rgba(13,18,53,0.86);
    -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    padding: 16px 18px;
    display: flex; flex-direction: column; gap: 4px;
    pointer-events: none;
  }
  .map-card .name { font-size: 15px; font-weight: 600; color: #fff; }
  .map-card .addr { font-size: 13px; color: rgba(255,255,255,0.66); line-height: 1.4; }
  .map-card .rating {
    display: inline-flex; align-items: center; gap: 7px;
    margin-top: 6px; font-size: 13px; color: rgba(255,255,255,0.82);
  }
  .map-card .rating .stars { display: inline-flex; gap: 1px; color: #FFC83D; }
  .map-card .rating .stars svg { width: 13px; height: 13px; }
  .map-card .map-card-link {
    pointer-events: auto;
    margin-top: 10px;
    font-size: 13px; font-weight: 600;
    color: var(--primary, #99cc33);
    display: inline-flex; align-items: center; gap: 6px;
  }

  /* map-side trust stats */
  .sa-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  @media (max-width: 540px) { .sa-stats { grid-template-columns: 1fr; } }
  .sa-stats .stat-card { padding: 1.75rem 1.5rem; }
</style>

<main>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" data-screen-label="01 Local Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="sa-crumb">
        <a href="/service-areas">
          <span class="lang-only-en">Service Areas</span>
          <span class="lang-only-es">Áreas de Servicio</span>
        </a>
        <span class="sep">/</span>
        <span>{d.county}</span>
        <span class="sep">/</span>
        <span class="here">{d.city}</span>
      </div>
      <h1>{d.titlePage}</h1>
      {d.summaryPage && <p>{d.summaryPage}</p>}
      <span class="sa-pill">
        <span class="dot"></span>
        <span class="lang-only-en">Serving {d.county}</span>
        <span class="lang-only-es">Atendiendo {d.county}</span>
      </span>
      <div style="margin-top: 28px;">
        <a href="#" class="btn cta--glow" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">
          <span class="lang-only-en">Book a Free Call</span>
          <span class="lang-only-es">Agenda tu Llamada Gratis</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONTENT SECTIONS — one per non-empty heading/paragraph pair
       ============================================================ -->
  {sections.map((s, i) => (
    <section class={`section${i % 2 === 0 ? ' section--band' : ''}`} data-screen-label={`Section · ${s.key}`}>
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="sa-sec-num">{String(i + 1).padStart(2, '0')}</span>
          <div class="eyebrow">
            <span class="lang-only-en">{eyebrows[s.key].en}</span>
            <span class="lang-only-es">{eyebrows[s.key].es}</span>
          </div>
          {s.heading && <h2>{s.heading}</h2>}
        </div>
        {s.paragraph && <div class="cms-prose" data-reveal set:html={s.paragraph} />}
      </div>
    </section>
  ))}

  <!-- ============================================================
       MAP + LOCAL TRUST
       ============================================================ -->
  <section class={`section${sections.length % 2 === 0 ? ' section--band' : ''}`} data-screen-label="Map & Area">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">
          <span class="lang-only-en">On the ground in {d.city}</span>
          <span class="lang-only-es">Presentes en {d.city}</span>
        </div>
        <h2>
          <span class="lang-only-en">Serving {d.city} &amp; {d.county} County</span>
          <span class="lang-only-es">Atendiendo {d.city} y el Condado de {d.county}</span>
        </h2>
        <p>
          <span class="lang-only-en">Headquartered in Plantation and active across {d.county} — here's our local footprint.</span>
          <span class="lang-only-es">Con sede en Plantation y activos en {d.county} — esta es nuestra presencia local.</span>
        </p>
      </div>

      <div class="sa-mapstats" data-reveal>
        <!-- Real Google Maps embed -->
        <div class="map-embed">
          <iframe
            src={mapSrc}
            title={`Map of ${d.city}, FL service area`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen></iframe>
          <div class="map-card">
            <span class="name">SENAVIA Corp — {d.city}</span>
            <span class="addr">
              <span class="lang-only-en">Serving {d.city} &amp; greater {d.county} · HQ in Plantation, FL</span>
              <span class="lang-only-es">Atendiendo {d.city} y el área de {d.county} · Sede en Plantation, FL</span>
            </span>
            <span class="rating">
              <span class="stars" aria-hidden="true" set:html={STAR.repeat(5)}></span>
              <span class="lang-only-en">5.0 · Google reviews</span>
              <span class="lang-only-es">5.0 · Reseñas de Google</span>
            </span>
            <a class="map-card-link" href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent('150 S Pine Island Rd Suite 377, Plantation FL 33324')}`} target="_blank" rel="noopener">
              <span class="lang-only-en">Get Directions</span>
              <span class="lang-only-es">Cómo Llegar</span>
            </a>
          </div>
        </div>

        <!-- Local trust stats -->
        <div>
          <div class="sa-stats">
            <article class="stat-card">
              <span class="stat-value">100+</span>
              <span class="stat-label">
                <span class="lang-only-en">Websites launched for South Florida businesses.</span>
                <span class="lang-only-es">Sitios web lanzados para negocios del Sur de Florida.</span>
              </span>
            </article>
            <article class="stat-card">
              <span class="stat-value">EN / ES</span>
              <span class="stat-label">
                <span class="lang-only-en">Fully bilingual team — your market, in both languages.</span>
                <span class="lang-only-es">Equipo totalmente bilingüe — tu mercado, en ambos idiomas.</span>
              </span>
            </article>
            <article class="stat-card">
              <span class="stat-value">5.0 ★</span>
              <span class="stat-label">
                <span class="lang-only-en">Average rating from verified Google reviews.</span>
                <span class="lang-only-es">Calificación promedio de reseñas verificadas en Google.</span>
              </span>
            </article>
            <article class="stat-card">
              <span class="stat-value">Google</span>
              <span class="stat-label">
                <span class="lang-only-en">Partner-certified for Ads &amp; local search.</span>
                <span class="lang-only-es">Certificados como Partner para Ads y búsqueda local.</span>
              </span>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="cta cta--glow" data-screen-label="CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2>
        <span class="lang-only-en">Ready to Grow Your {d.city} Business Online?</span>
        <span class="lang-only-es">¿Listo para Hacer Crecer tu Negocio de {d.city} en Línea?</span>
      </h2>
      <p>
        <span class="lang-only-en">Schedule your free web design &amp; SEO consultation and get a custom strategy to increase traffic, leads, and conversions across {d.county}.</span>
        <span class="lang-only-es">Agenda tu consulta gratuita de diseño web y SEO, y obtén una estrategia a medida para aumentar tráfico, clientes potenciales y conversiones en {d.county}.</span>
      </p>
      <a href="#" class="btn" onclick="if(window.Calendly){Calendly.initPopupWidget({url:'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon'});}return false;">
        <span class="lang-only-en">Book a Free Call</span>
        <span class="lang-only-es">Agenda tu Llamada Gratis</span>
      </a>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>
</BaseLayout>
</content>
</invoke>
