<!-- Map + county sync -->
<script>
  (function(){
    var shapes = document.querySelectorAll('.sa-county-shape');
    var cards  = document.querySelectorAll('.sa-county-card');

    function setActive(id: string | null) {
      shapes.forEach(function(s){ s.classList.toggle('is-active', s.getAttribute('data-county') === id); });
      cards.forEach(function(c){ c.classList.toggle('is-active', c.getAttribute('data-county') === id); });
    }
    function clear() {
      shapes.forEach(function(s){ s.classList.remove('is-active'); });
      cards.forEach(function(c){ c.classList.remove('is-active'); });
    }

    // WL-059 — make the 'tap any region' copy true on touch: tapping a
    // county shape jumps to its section (hover-only before).
    function countySlug(k: string | null) { return (k || '').toLowerCase().replace(/\s+/g, '-'); }

    shapes.forEach(function(s){
      s.addEventListener('mouseenter', function(){ setActive(s.getAttribute('data-county')); });
      s.addEventListener('mouseleave', clear);
      s.addEventListener('click', function(){
        var target = document.getElementById(countySlug(s.getAttribute('data-county')));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
    cards.forEach(function(c){
      c.addEventListener('mouseenter', function(){ setActive(c.getAttribute('data-county')); });
      c.addEventListener('mouseleave', clear);
    });
  })();
</script>
