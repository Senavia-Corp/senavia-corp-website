---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = "Service Areas — SENAVIA Corp · Web Design & Marketing Across South Florida";
const description = "SENAVIA Corp serves businesses across Miami-Dade, Broward, and Palm Beach counties. Web design, development, and marketing for South Florida.";

const areas = (await getCollection('serviceAreas'))
  .sort((a, b) => a.data.order - b.data.order);

// County metadata + grouping. Keys MATCH the CMS `county` values exactly
// ("Miami Dade" | "Broward" | "Palm Beach"). Page chrome stays bilingual.
type CountyKey = 'Miami Dade' | 'Broward' | 'Palm Beach';
const countyMeta: Record<CountyKey, {
  num: string; label_en: string; label_es: string; pop: string; pop_es: string;
  art: string; lead_en: string; lead_es: string;
}> = {
  'Miami Dade': {
    num: 'County · 01',
    label_en: 'Miami-Dade County',
    label_es: 'Condado de Miami-Dade',
    pop: '2.7M residents · 1,946 sq mi',
    pop_es: '2.7M residentes · 1,946 mi²',
    art: 'art-dade',
    lead_en: "From Miami's skyline to Doral's industrial corridor, we build conversion-focused websites for South Florida's most competitive market.",
    lead_es: 'Desde el horizonte de Miami hasta el corredor industrial de Doral, construimos sitios web enfocados en la conversión para el mercado más competitivo del Sur de Florida.',
  },
  'Broward': {
    num: 'County · 02',
    label_en: 'Broward County',
    label_es: 'Condado de Broward',
    pop: '1.95M residents · 1,323 sq mi',
    pop_es: '1.95M residentes · 1,323 mi²',
    art: 'art-broward',
    lead_en: "SENAVIA Corp is headquartered in Plantation. Broward is home — and it's where our retainer client base is strongest.",
    lead_es: 'SENAVIA Corp tiene su sede en Plantation. Broward es nuestra casa, y es donde nuestra base de clientes con contrato es más sólida.',
  },
  'Palm Beach': {
    num: 'County · 03',
    label_en: 'Palm Beach County',
    label_es: 'Condado de Palm Beach',
    pop: '1.5M residents · 1,969 sq mi',
    pop_es: '1.5M residentes · 1,969 mi²',
    art: 'art-palmbeach',
    lead_en: "Palm Beach's premium buyer profile demands premium presentation. We deliver brand-first sites that earn trust on first scroll.",
    lead_es: 'El perfil de comprador premium de Palm Beach exige una presentación premium. Ofrecemos sitios centrados en la marca que ganan confianza al primer scroll.',
  },
};

const countyOrder: CountyKey[] = ['Miami Dade', 'Broward', 'Palm Beach'];
// Anchor-friendly slug for each county (cards jump to the matching section).
const countySlug = (k: string) => k.toLowerCase().replace(/\s+/g, '-');

const grouped = countyOrder
  .map((key) => ({
    key,
    slug: countySlug(key),
    meta: countyMeta[key],
    cities: areas.filter((a) => a.data.county === key),
  }))
  .filter((g) => g.cities.length > 0);

const totalCities = areas.length;
const totalCounties = grouped.length;

const ARROW = `<svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>`;
---
<BaseLayout
  title={title}
  description={description}
  canonical="/service-areas"
  jsonLdType="localbusiness"
  screenLabel="Service Areas"
>
<style is:global data-recovered>
/* ============================================================
     SERVICE AREAS PAGE
     ============================================================ */
  .hero.is-compact + .section { padding-top: 4rem; }

  /* Map + columns section */
  .sa-map-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 980px) {
    .sa-map-wrap { grid-template-columns: 1fr; gap: 32px; }
  }

  .sa-map {
    position: relative;
    aspect-ratio: 4 / 5;
    width: 100%;
    border-radius: 22px;
    background:
      radial-gradient(ellipse at 70% 50%, rgba(45,125,184,0.18) 0%, transparent 55%),
      linear-gradient(135deg, rgba(13,18,53,0.7), rgba(11,15,35,0.9));
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .sa-map::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    background-position: 0 0;
    pointer-events: none;
    z-index: 1;
  }
  .sa-map svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }
  .sa-county-shape {
    fill: rgba(255,255,255,0.04);
    stroke: rgba(255,255,255,0.18);
    stroke-width: 1.5;
    transition: fill .3s ease, stroke .3s ease, filter .3s ease;
    cursor: pointer;
  }
  .sa-county-shape:hover,
  .sa-county-shape.is-active {
    fill: rgba(153,204,51,0.18);
    stroke: rgba(153,204,51,0.7);
    filter: drop-shadow(0 0 20px rgba(153,204,51,0.32));
  }
  .sa-county-label {
    fill: rgba(255,255,255,0.92);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    pointer-events: none;
  }
  .sa-county-sub {
    fill: rgba(255,255,255,0.45);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    pointer-events: none;
    text-transform: uppercase;
  }
  .sa-pin {
    fill: var(--primary, #99cc33);
    transition: transform .25s ease;
    transform-origin: center;
    transform-box: fill-box;
  }
  .sa-pin:hover { transform: scale(1.25); }
  .sa-pin-label {
    fill: rgba(255,255,255,0.85);
    font-size: 10px;
    font-weight: 500;
    pointer-events: none;
  }
  .sa-compass {
    fill: rgba(255,255,255,0.4);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
  }
  .sa-ocean-label {
    fill: rgba(45,125,184,0.5);
    font-size: 11px;
    font-style: italic;
    letter-spacing: 0.2em;
    pointer-events: none;
  }

  /* WL-059 — mobile legibility: the 400x500 viewBox scales down to ~320px
     at 360px viewports, so hide the tiny per-city pin labels and enlarge
     the county labels instead */
  @media (max-width: 640px) {
    .sa-pin-label { display: none; }
    .sa-county-label { font-size: 19px; }
    .sa-county-sub { font-size: 13px; }
  }

  /* WL-059 — pointer-aware microcopy: 'hover' on mouse devices, 'tap' on touch */
  @media (hover: hover) { .only-touch { display: none; } }
  @media (hover: none) { .only-hover { display: none; } }

  /* County columns to the right of map */
  .sa-counties {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sa-county-card {
    padding: 1.5rem 1.5rem 1.25rem;
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    transition: border-color .25s ease, transform .25s ease, background .25s ease;
    text-decoration: none;
    display: block;
  }
  .sa-county-card:hover,
  .sa-county-card.is-active {
    border-color: rgba(153,204,51,0.4);
    background: rgba(20,28,60,0.6);
    transform: translateX(4px);
  }
  .sa-county-card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }
  .sa-county-dot {
    width: 10px; height: 10px;
    border-radius: 999px;
    background: var(--primary, #99cc33);
    box-shadow: 0 0 12px rgba(153,204,51,0.7);
  }
  .sa-county-card h3 {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 500;
    color: #fff;
    text-transform: none;
    letter-spacing: -0.005em;
  }
  .sa-county-meta {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .sa-county-card p {
    margin: 0;
    font-size: 13.5px;
    color: rgba(255,255,255,0.65);
    line-height: 1.55;
    max-width: none;
  }

  /* County full sections */
  .sa-section-head h2 {
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
  }
  .sa-section-head .county-num {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(153,204,51,0.12);
    border: 1px solid rgba(153,204,51,0.32);
    margin-bottom: 16px;
  }

  .sa-split {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
    margin-bottom: 3rem;
  }
  @media (max-width: 900px) { .sa-split { grid-template-columns: 1fr; gap: 28px; } }

  .sa-split .sa-split-copy h3 {
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 12px;
    text-transform: none;
    letter-spacing: -0.01em;
  }
  .sa-split .sa-split-copy p {
    color: rgba(255,255,255,0.7);
    line-height: 1.65;
    max-width: 540px;
  }
  .sa-split-art {
    aspect-ratio: 5 / 4;
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 18px 50px rgba(0,0,0,0.32);
  }
  .sa-split-art.art-dade { background: linear-gradient(135deg, #2D7DB8 0%, #99CC33 100%); }
  .sa-split-art.art-broward { background: linear-gradient(135deg, #1E5A82 0%, #4A3F8E 100%); }
  .sa-split-art.art-palmbeach { background: linear-gradient(135deg, #7B3FE4 0%, #D14F8C 100%); }
  .sa-split-art::after {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 30% 25%, rgba(255,255,255,0.2) 0%, transparent 45%),
      radial-gradient(ellipse at 75% 80%, rgba(0,0,0,0.3) 0%, transparent 50%);
  }
  .sa-split-art .county-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
    color: #fff;
    background: linear-gradient(180deg, transparent 50%, rgba(10,14,38,0.5) 100%);
  }
  .sa-split-art .county-overlay h4 {
    margin: 0;
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    text-transform: none;
  }
  .sa-split-art .county-overlay .county-pop {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    margin-top: 6px;
  }

  /* City chip grid */
  .sa-cities {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  /* WL-059 — 2 columns in the tablet range: with 10/10/8 cities per county,
     3 columns left a 9+1 orphan row */
  @media (max-width: 980px) { .sa-cities { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .sa-cities { grid-template-columns: repeat(2, 1fr); } }

  .sa-city {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 14px 16px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    color: rgba(255,255,255,0.85);
    font-size: 14px;
    text-decoration: none;
    transition: all .2s ease;
  }
  .sa-city:hover {
    background: rgba(153,204,51,0.08);
    border-color: rgba(153,204,51,0.36);
    color: #fff;
    transform: translateY(-1px);
  }
  .sa-city .arrow {
    width: 14px; height: 14px;
    opacity: 0.4;
    transition: opacity .2s ease, transform .2s ease;
  }
  .sa-city:hover .arrow {
    opacity: 1;
    transform: translateX(2px);
    color: var(--primary, #99cc33);
  }
</style>

<main>

  <!-- ============================================================
       HERO — Compact
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 Service Areas Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/bg-video-poster.jpg">
      <source src="/videos/bg-video.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;">
        <span class="lang-only-en">Headquartered in Plantation, FL</span>
        <span class="lang-only-es">Con sede en Plantation, FL</span>
      </div>
      <h1>
        <span class="lang-only-en">Web Design &amp; Marketing Services Across South Florida</span>
        <span class="lang-only-es">Servicios de Diseño Web y Marketing en Todo el Sur de Florida</span>
      </h1>
      <p>
        <span class="lang-only-en">We serve businesses across Miami-Dade, Broward, and Palm Beach counties.</span>
        <span class="lang-only-es">Atendemos a negocios en los condados de Miami-Dade, Broward y Palm Beach.</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       INTERACTIVE MAP + COUNTY COLUMN
       ============================================================ -->
  <section class="section section--band" data-screen-label="02 Coverage Map">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">
          <span class="lang-only-en">Coverage map</span>
          <span class="lang-only-es">Mapa de Cobertura</span>
        </div>
        <h2>
          <span class="lang-only-en">Where We Work in South Florida</span>
          <span class="lang-only-es">Dónde Trabajamos en el Sur de Florida</span>
        </h2>
        <p>
          <span class="lang-only-en">{totalCounties} counties, {totalCities} cities, and a dedicated bilingual team based in Plantation — <span class="only-hover">hover</span><span class="only-touch">tap</span> any region to explore who we serve there.</span>
          <span class="lang-only-es">{totalCounties} condados, {totalCities} ciudades y un equipo bilingüe dedicado en Plantation — <span class="only-hover">pasa el cursor sobre</span><span class="only-touch">toca</span> cualquier región para explorar a quién atendemos allí.</span>
        </p>
      </div>

      <div class="sa-map-wrap" data-reveal>
        <div class="sa-map" id="saMap">
          <svg viewBox="0 0 400 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="South Florida coverage map">
            <defs>
              <linearGradient id="oceanGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="rgba(45,125,184,0)"/>
                <stop offset="100%" stop-color="rgba(45,125,184,0.2)"/>
              </linearGradient>
            </defs>

            <!-- Ocean strip on right -->
            <rect x="320" y="0" width="80" height="500" fill="url(#oceanGrad)"/>
            <text x="362" y="250" class="sa-ocean-label lang-only-en" transform="rotate(90 362 250)" text-anchor="middle">ATLANTIC OCEAN</text>
            <text x="362" y="250" class="sa-ocean-label lang-only-es" transform="rotate(90 362 250)" text-anchor="middle">OCÉANO ATLÁNTICO</text>

            <!-- Palm Beach County (north, top) -->
            <path class="sa-county-shape" data-county="Palm Beach"
                  d="M 50 50 L 320 50 L 320 175 L 270 175 L 220 165 L 170 175 L 120 170 L 80 180 L 50 165 Z"/>
            <text class="sa-county-label" x="180" y="105" text-anchor="middle">PALM BEACH</text>
            <text class="sa-county-sub lang-only-en" x="180" y="125" text-anchor="middle">COUNTY · 01</text>
            <text class="sa-county-sub lang-only-es" x="180" y="125" text-anchor="middle">CONDADO · 01</text>
            <!-- Palm Beach pins -->
            <g>
              <circle class="sa-pin" cx="290" cy="120" r="5"/>
              <text class="sa-pin-label" x="282" y="138" text-anchor="end">West Palm Beach</text>
            </g>
            <g>
              <circle class="sa-pin" cx="285" cy="155" r="4"/>
              <text class="sa-pin-label" x="277" y="158" text-anchor="end">Boca Raton</text>
            </g>

            <!-- Broward County (middle) -->
            <path class="sa-county-shape" data-county="Broward"
                  d="M 50 175 L 80 180 L 120 170 L 170 175 L 220 165 L 270 175 L 320 175 L 320 290 L 280 295 L 230 285 L 180 295 L 130 285 L 80 295 L 50 280 Z"/>
            <text class="sa-county-label" x="180" y="220" text-anchor="middle">BROWARD</text>
            <text class="sa-county-sub lang-only-en" x="180" y="240" text-anchor="middle">COUNTY · 02</text>
            <text class="sa-county-sub lang-only-es" x="180" y="240" text-anchor="middle">CONDADO · 02</text>
            <!-- Broward pins -->
            <g>
              <circle class="sa-pin" cx="295" cy="245" r="5.5"/>
              <text class="sa-pin-label" x="287" y="248" text-anchor="end">Fort Lauderdale</text>
            </g>
            <g>
              <circle class="sa-pin is-hq" cx="250" cy="265" r="6" fill="#fff" stroke="#99cc33" stroke-width="2"/>
              <text class="sa-pin-label" x="242" y="268" text-anchor="end" style="font-weight:600;fill:#fff;">Plantation · HQ</text>
            </g>
            <g>
              <circle class="sa-pin" cx="290" cy="280" r="4"/>
              <text class="sa-pin-label" x="282" y="283" text-anchor="end">Hollywood</text>
            </g>

            <!-- Miami-Dade County (south, bottom) -->
            <path class="sa-county-shape" data-county="Miami Dade"
                  d="M 50 290 L 80 295 L 130 285 L 180 295 L 230 285 L 280 295 L 320 290 L 320 450 L 240 450 L 180 460 L 130 455 L 80 450 L 50 440 Z"/>
            <text class="sa-county-label" x="180" y="345" text-anchor="middle">MIAMI-DADE</text>
            <text class="sa-county-sub lang-only-en" x="180" y="365" text-anchor="middle">COUNTY · 03</text>
            <text class="sa-county-sub lang-only-es" x="180" y="365" text-anchor="middle">CONDADO · 03</text>
            <!-- Miami-Dade pins -->
            <g>
              <circle class="sa-pin" cx="295" cy="385" r="6"/>
              <text class="sa-pin-label" x="287" y="388" text-anchor="end">Miami</text>
            </g>
            <g>
              <circle class="sa-pin" cx="305" cy="400" r="4"/>
              <text class="sa-pin-label" x="297" y="403" text-anchor="end">Miami Beach</text>
            </g>
            <g>
              <circle class="sa-pin" cx="285" cy="415" r="4"/>
              <text class="sa-pin-label" x="277" y="418" text-anchor="end">Coral Gables</text>
            </g>

            <!-- Compass -->
            <g transform="translate(70 70)">
              <line x1="0" y1="-18" x2="0" y2="18" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
              <line x1="-18" y1="0" x2="18" y2="0" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
              <text class="sa-compass" x="0" y="-22" text-anchor="middle">N</text>
              <text class="sa-compass" x="0" y="32" text-anchor="middle">S</text>
              <text class="sa-compass" x="22" y="4">E</text>
              <text class="sa-compass lang-only-en" x="-22" y="4" text-anchor="end">W</text>
              <text class="sa-compass lang-only-es" x="-22" y="4" text-anchor="end">O</text>
            </g>

            <!-- Scale -->
            <g transform="translate(60 470)">
              <line x1="0" y1="0" x2="60" y2="0" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <line x1="0" y1="-4" x2="0" y2="4" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <line x1="30" y1="-3" x2="30" y2="3" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
              <line x1="60" y1="-4" x2="60" y2="4" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <text class="sa-compass" x="30" y="18" text-anchor="middle" style="font-size:9px;">~15 MI</text>
            </g>
          </svg>
        </div>

        <div class="sa-counties">
          {grouped.map((g) => (
            <a class="sa-county-card" href={`#${g.slug}`} data-county={g.key}>
              <div class="sa-county-card-head">
                <span class="sa-county-dot"></span>
                <h3>
                  <span class="lang-only-en">{g.meta.label_en}</span>
                  <span class="lang-only-es">{g.meta.label_es}</span>
                </h3>
              </div>
              <div class="sa-county-meta">
                <span class="lang-only-en">{g.meta.pop}</span>
                <span class="lang-only-es">{g.meta.pop_es}</span>
              </div>
              <p>
                <span class="lang-only-en">{g.cities.length} {g.cities.length === 1 ? 'city' : 'cities'} listed · <span class="only-hover">Hover the map</span><span class="only-touch">Tap the map</span> to explore.</span>
                <span class="lang-only-es">{g.cities.length} {g.cities.length === 1 ? 'ciudad' : 'ciudades'} · <span class="only-hover">Pasa el cursor sobre el mapa</span><span class="only-touch">Toca el mapa</span> para explorar.</span>
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COUNTY SECTIONS
       ============================================================ -->
  {grouped.map((g) => (
    <Fragment>
      <a id={g.slug}></a>
      <section class="section" data-screen-label={`County · ${g.meta.label_en}`}>
        <div class="container">
          <div class="sa-split" data-reveal>
            <div class="sa-split-copy">
              <div class="sa-section-head">
                <span class="county-num">{g.meta.num}</span>
                <h2>
                  <span class="lang-only-en">Web Design Services Across {g.meta.label_en}</span>
