---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Thank You — Appointment Confirmed · SENAVIA Corp';
const description =
  'Your consultation with SENAVIA Corp is confirmed. Check your email for the details — we look forward to meeting you.';

// ──────────────────────────────────────────────────────────────────────────
// ⚠️  REPLACE THESE 3 PLACEHOLDERS with your real Google IDs, then deploy.
//     This page bootstraps gtag.js on its own because the site uses Plausible
//     site-wide (no gtag elsewhere) — so there is nothing to duplicate.
//     The conversion tags fire ONCE on page load, PRODUCTION builds only
//     (see the import.meta.env.PROD guard below — same policy as Plausible,
//     so local/preview visits don't pollute your Ads/GA4 conversion counts).
//     To test before going live: `npm run build && npm run preview`.
// ──────────────────────────────────────────────────────────────────────────
const GA4_MEASUREMENT_ID = 'GA4_MEASUREMENT_ID'; // e.g. 'G-XXXXXXXXXX'
const GOOGLE_ADS_CONVERSION_ID = 'GOOGLE_ADS_CONVERSION_ID'; // e.g. 'AW-XXXXXXXXXX'
const GOOGLE_ADS_CONVERSION_LABEL = 'GOOGLE_ADS_CONVERSION_LABEL'; // e.g. 'abcDEfgHIjkLMnoPQR'
---
<BaseLayout
  title={title}
  description={description}
  canonical="/thank-you"
  jsonLdType="home"
  noindex
  screenLabel="Thank You"
>
  <style>
    .ty-main {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 7rem 1.5rem 4.5rem;
      min-height: 62vh;
      position: relative;
      overflow: hidden;
    }
    /* Decorative gradient orbs — matches the brand error/standalone pages */
    .ty-main::before,
    .ty-main::after {
      content: '';
      position: absolute;
      width: 600px;
      height: 600px;
      border-radius: 999px;
      pointer-events: none;
      filter: blur(80px);
      opacity: 0.3;
      z-index: 0;
    }
    .ty-main::before {
      top: -220px;
      left: -180px;
      background: radial-gradient(circle, rgba(153, 204, 51, 0.5) 0%, transparent 70%);
    }
    .ty-main::after {
      bottom: -220px;
      right: -180px;
      background: radial-gradient(circle, rgba(51, 204, 204, 0.35) 0%, transparent 70%);
    }
    .ty-card {
      position: relative;
      z-index: 1;
      max-width: 620px;
      text-align: center;
      padding: 3rem;
    }
    @media (max-width: 600px) {
      .ty-card { padding: 2rem 1rem; }
    }
    .ty-badge {
      width: 88px;
      height: 88px;
      margin: 0 auto 1.75rem;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0a0e26;
      background: linear-gradient(135deg, #99cc33 0%, #c1e15a 50%, #33cccc 100%);
      box-shadow: 0 0 60px rgba(153, 204, 51, 0.45);
      animation: tyPop 0.5s cubic-bezier(0.2, 0.8, 0.2, 1.2) both;
    }
    .ty-badge svg { width: 44px; height: 44px; }
    @keyframes tyPop {
      0% { transform: scale(0.6); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
      .ty-badge { animation: none; }
    }
    .ty-eyebrow {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--primary, #99cc33);
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      padding: 6px 14px;
      border-radius: 999px;
      background: rgba(153, 204, 51, 0.1);
      border: 1px solid rgba(153, 204, 51, 0.3);
      margin-bottom: 1.25rem;
    }
    .ty-title {
      margin: 0 0 1rem;
      font-size: clamp(1.85rem, 4.4vw, 2.75rem);
      font-weight: 500;
      letter-spacing: -0.02em;
      color: #fff;
      line-height: 1.18;
    }
    .ty-desc {
      margin: 0 auto 2.25rem;
      color: rgba(255, 255, 255, 0.65);
      font-size: 16.5px;
      line-height: 1.65;
      max-width: 500px;
    }
    .ty-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
    }
    .ty-actions .btn-secondary {
      appearance: none;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.85);
      font: inherit;
      font-size: 14px;
      font-weight: 500;
      padding: 13px 24px;
      border-radius: 999px;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s ease;
    }
    .ty-actions .btn-secondary:hover {
      color: #fff;
      border-color: rgba(255, 255, 255, 0.25);
      background: rgba(255, 255, 255, 0.08);
    }
    .ty-actions .btn-secondary svg { width: 14px; height: 14px; }
    .ty-note {
      margin: 2.25rem auto 0;
      max-width: 460px;
      font-size: 13.5px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.45);
    }
    .ty-note a {
      color: rgba(255, 255, 255, 0.8);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .ty-note a:hover { color: var(--primary, #99cc33); }
  </style>

  <main class="ty-main" data-screen-label="01 Thank You">
    <div class="ty-card">
      <div class="ty-badge" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>

      <span class="ty-eyebrow"><span class="lang-only-en">Appointment confirmed</span><span class="lang-only-es">Cita confirmada</span></span>

      <h1 class="ty-title">
        <span class="lang-only-en">Thank you! Your appointment is confirmed</span>
        <span class="lang-only-es">¡Gracias! Tu cita está confirmada</span>
      </h1>

      <p class="ty-desc">
        <span class="lang-only-en">You're all set. A calendar invite and confirmation are on their way to your inbox — keep an eye out for it. One of our strategists will reach out before the call so we can make the most of your time.</span>
        <span class="lang-only-es">Todo listo. La invitación de calendario y la confirmación van en camino a tu correo — mantente atento. Uno de nuestros estrategas te contactará antes de la llamada para aprovechar al máximo tu tiempo.</span>
      </p>

      <div class="ty-actions">
        <a href="/" class="btn">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M3 12l9-9 9 9"></path><path d="M5 10v10h14V10"></path></svg>
          <span class="lang-only-en">Back to Home</span><span class="lang-only-es">Volver al Inicio</span>
        </a>
        <a href="/portfolio" class="btn-secondary">
          <span class="lang-only-en">View Portfolio</span><span class="lang-only-es">Ver Portafolio</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>

      <p class="ty-note">
        <span class="lang-only-en">Didn't get the email? Check your spam folder, or <a href="/contact">contact us</a> and we'll sort it out.</span>
        <span class="lang-only-es">¿No recibiste el correo? Revisa tu carpeta de spam o <a href="/contact">contáctanos</a> y lo resolvemos.</span>
      </p>
    </div>
  </main>

  {/* ── Conversion tracking — production builds only ─────────────────────────
       gtag.js is not loaded site-wide (Plausible is the site analytics), so it
       is bootstrapped here for this conversion page. Replace the 3 IDs in the
       frontmatter above. Both tags fire once, on page load. */}
  {import.meta.env.PROD && (
    <Fragment>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}></script>
      <script is:inline define:vars={{ GA4_MEASUREMENT_ID, GOOGLE_ADS_CONVERSION_ID, GOOGLE_ADS_CONVERSION_LABEL }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA4_MEASUREMENT_ID);
        gtag('config', GOOGLE_ADS_CONVERSION_ID);

        // (a) GA4 conversion event — mark "schedule_appointment" as a Key Event in GA4.
        gtag('event', 'schedule_appointment', {
          event_category: 'engagement',
          event_label: 'calendly_booking',
        });

        // (b) Google Ads conversion snippet.
        gtag('event', 'conversion', {
          send_to: GOOGLE_ADS_CONVERSION_ID + '/' + GOOGLE_ADS_CONVERSION_LABEL,
        });
      </script>
    </Fragment>
  )}
</BaseLayout>
