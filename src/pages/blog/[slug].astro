---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CALENDLY_URL } from '@/data/site';
import { prettyName } from '@/lib/cms';

/* ------------------------------------------------------------------ *
 *  Real Webflow CMS (English only). One path per post (param = slug).
 *  Render CMS values as-is; keep page chrome bilingual.
 * ------------------------------------------------------------------ */
export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((entry) => {
    const related = posts
      .filter((p) => p.id !== entry.id && p.data.category === entry.data.category)
      .sort((a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0))
      .slice(0, 3);

    return { params: { slug: entry.id }, props: { entry, related } };
  });
}

const { entry, related } = Astro.props;
const { data } = entry;

const CAT_ES: Record<string, string> = {
  'web-design': 'Diseño Web',
  'web-development': 'Desarrollo Web',
  'digital-marketing': 'Marketing Digital',
};
const CAT_EN: Record<string, string> = {
  'web-design': 'Web Design',
  'web-development': 'Web Development',
  'digital-marketing': 'Digital Marketing',
};
const catEn = (slug: string) => CAT_EN[slug] ?? slug;
const catEs = (slug: string) => CAT_ES[slug] ?? slug;

const fmtEn = (d?: Date) => (d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '');
const fmtEs = (d?: Date) => (d ? d.toLocaleDateString('es-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '');

const authorName = prettyName(data.author);
const initials = authorName.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();
const avatarPalette = ['av1', 'av2', 'av3', 'av4'];
const avatarClass = avatarPalette[entry.id.length % avatarPalette.length];
---
<BaseLayout
  title={data.seoTitle || data.title}
  description={data.seoDescription || data.summary}
  canonical={`/blog/${entry.id}`}
  ogType="article"
  jsonLdType="blog"
  screenLabel="Blog Article"
>
<style is:global data-blog-article>
  /* ============================================================
     BLOG ARTICLE — editorial detail
     ============================================================ */
  .article-hero {
    position: relative;
    padding: 7.5rem 0 3rem;
    overflow: hidden;
  }
  .article-hero .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.55;
  }
  .article-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, rgba(10,14,38,0.55) 0%, rgba(10,14,38,0.82) 60%, var(--secondary, #0A0E26) 100%);
  }
  .article-hero .container { max-width: 820px; }

  .article-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1.5rem;
    transition: color .2s ease;
    text-decoration: none;
  }
  .article-back:hover { color: var(--primary, #99cc33); }
  .article-back svg { width: 15px; height: 15px; }

  .article-cat {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(153,204,51,0.16);
    color: var(--primary, #99cc33);
    border: 1px solid rgba(153,204,51,0.3);
    margin-bottom: 1.25rem;
  }
  .article-cat[data-cat="web-design"]        { background: rgba(153,204,51,0.16); color: #b6e06a; border-color: rgba(153,204,51,0.32); }
  .article-cat[data-cat="web-development"]   { background: rgba(123,63,228,0.16); color: #b89bf2; border-color: rgba(123,63,228,0.36); }
  .article-cat[data-cat="digital-marketing"] { background: rgba(240,160,80,0.14); color: #f6b56e; border-color: rgba(240,160,80,0.32); }

  .article-hero h1 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }
  .article-hero .article-dek {
    font-size: 1.125rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.78);
    max-width: 680px;
    margin-bottom: 1.75rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,0.6);
  }
  .article-meta .avatar {
    width: 32px; height: 32px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
  }
  .article-meta .avatar.av1 { background: linear-gradient(135deg, #7B3FE4, #C13B8A); }
  .article-meta .avatar.av2 { background: linear-gradient(135deg, #2A7B4F, #99CC33); }
  .article-meta .avatar.av3 { background: linear-gradient(135deg, #2D7DB8, #33CCCC); }
  .article-meta .avatar.av4 { background: linear-gradient(135deg, #D14F8C, #F0A050); }
  .article-meta .author-name { color: rgba(255,255,255,0.85); font-weight: 500; }
  .article-meta .sep { color: rgba(255,255,255,0.28); }

  /* BODY — readable column */
  .article-body-wrap { padding: 3.5rem 0 4rem; }
  .article-body-wrap .container { max-width: 760px; }

  /* ---------- CMS PROSE (rich-text HTML from Webflow) ---------- */
  .cms-prose {
    max-width: 70ch;
    font-size: 1.0625rem;
    line-height: 1.78;
    color: rgba(255,255,255,0.82);
  }
  .cms-prose > :first-child { margin-top: 0; }
  .cms-prose > :last-child { margin-bottom: 0; }
  .cms-prose p {
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.78;
    margin: 0 0 1.4rem;
    max-width: none;
  }
  .cms-prose h2 {
    font-size: 1.6rem;
    font-weight: 600;
    color: #fff;
    margin: 2.6rem 0 1rem;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .cms-prose h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #fff;
    margin: 2rem 0 0.8rem;
    line-height: 1.3;
  }
  .cms-prose h4 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    margin: 1.75rem 0 0.7rem;
  }
  .cms-prose ul, .cms-prose ol { margin: 0 0 1.5rem; padding-left: 1.4rem; }
  .cms-prose li { margin: 0 0 0.65rem; line-height: 1.7; }
  .cms-prose li::marker { color: var(--primary, #99cc33); }
  .cms-prose ul ul, .cms-prose ol ol, .cms-prose ul ol, .cms-prose ol ul { margin: 0.5rem 0 0.5rem; }
  .cms-prose a {
    color: var(--primary, #99cc33);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity .15s ease;
  }
  .cms-prose a:hover { opacity: 0.8; }
  .cms-prose strong, .cms-prose b { color: #fff; font-weight: 600; }
  .cms-prose em, .cms-prose i { font-style: italic; }
  .cms-prose img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.08);
    margin: 2rem 0;
  }
  .cms-prose figure { margin: 2rem 0; }
  .cms-prose figcaption {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    text-align: center;
    margin-top: 0.6rem;
  }
  .cms-prose blockquote {
    margin: 0 0 2rem;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--primary, #99cc33);
    background: rgba(153,204,51,0.06);
    border-radius: 0 12px 12px 0;
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.9);
  }
  .cms-prose blockquote p { margin: 0; }
  .cms-prose blockquote strong { color: var(--primary, #99cc33); }
  .cms-prose hr {
    border: 0;
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin: 2.5rem 0;
  }
  .cms-prose code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.92em;
    background: rgba(255,255,255,0.07);
    padding: 2px 6px;
    border-radius: 6px;
    color: #d6e9b0;
  }
  .cms-prose pre {
    background: rgba(10,14,38,0.7);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }
  .cms-prose pre code { background: none; padding: 0; color: rgba(255,255,255,0.85); }

  /* AUTHOR FOOTER */
  .article-author-card {
    display: flex;
    gap: 16px;
    align-items: center;
    margin: 3rem 0 0;
    padding: 1.5rem;
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
  }
  .article-author-card .avatar {
    width: 52px; height: 52px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    font-weight: 600;
    color: #fff;
    flex: none;
  }
  .article-author-card .avatar.av1 { background: linear-gradient(135deg, #7B3FE4, #C13B8A); }
  .article-author-card .avatar.av2 { background: linear-gradient(135deg, #2A7B4F, #99CC33); }
  .article-author-card .avatar.av3 { background: linear-gradient(135deg, #2D7DB8, #33CCCC); }
  .article-author-card .avatar.av4 { background: linear-gradient(135deg, #D14F8C, #F0A050); }
  .article-author-card .author-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    margin-bottom: 4px;
  }
  .article-author-card .author-name { font-size: 1.05rem; color: #fff; font-weight: 500; margin-bottom: 3px; }
  .article-author-card .author-bio { font-size: 13.5px; color: rgba(255,255,255,0.62); line-height: 1.5; margin: 0; }

  /* RELATED STRIP */
  .related-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }
  .related-head h2 { font-size: 1.5rem; margin: 0; }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 880px) { .related-grid { grid-template-columns: 1fr; gap: 20px; } }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    transition: transform .25s cubic-bezier(.2,.6,.2,1);
  }
  .related-card:hover { transform: translateY(-3px); }
  .related-card .related-cover {
    aspect-ratio: 16 / 10;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 12px 28px rgba(0,0,0,0.28);
    background: rgba(13,18,53,0.55);
    transition: box-shadow .25s ease;
  }
  .related-card:hover .related-cover {
    box-shadow: 0 18px 40px rgba(0,0,0,0.36), 0 0 0 1px rgba(153,204,51,0.32);
  }
  .related-card .related-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .related-card h3 {
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    color: #fff;
  }
  .related-card:hover h3 { color: var(--primary, #99cc33); }
  .related-card .related-date {
    font-size: 11.5px;
    color: rgba(255,255,255,0.5);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: 0.04em;
  }

  /* CTA */
  .article-cta { padding: 4rem 0 5rem; text-align: center; }
  .article-cta .cta-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 2rem;
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(153,204,51,0.18);
    border-radius: 22px;
  }
  .article-cta h2 { font-size: clamp(1.6rem, 3vw, 2.25rem); margin-bottom: 0.85rem; }
  .article-cta p { font-size: 1.05rem; color: rgba(255,255,255,0.78); max-width: 560px; margin: 0 auto 1.75rem; }
</style>

<main>
  <!-- ============================================================
       ARTICLE HERO
       ============================================================ -->
  <header class="article-hero" data-screen-label="01 Article Hero">
    {data.mainImage && (
      <img class="hero-bg" src={data.mainImage} alt={data.altImage} loading="eager" decoding="async" />
    )}
    <div class="container">
      <a href="/blog" class="article-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
        <span class="lang-only-en">Back to Blog</span>
        <span class="lang-only-es">Volver al Blog</span>
      </a>

      {data.category && (
        <span class="article-cat" data-cat={data.category}>
          <span class="lang-only-en">{catEn(data.category)}</span>
          <span class="lang-only-es">{catEs(data.category)}</span>
        </span>
      )}

      <h1>{data.title}</h1>

      {data.summary && <p class="article-dek">{data.summary}</p>}

      <div class="article-meta">
        <span class={`avatar ${avatarClass}`} aria-hidden="true">{initials}</span>
        <span class="author-name">
          <span class="lang-only-en">By {authorName}</span>
          <span class="lang-only-es">Por {authorName}</span>
        </span>
        <span class="sep">·</span>
        <span class="lang-only-en">{fmtEn(data.pubDate)}</span>
        <span class="lang-only-es">{fmtEs(data.pubDate)}</span>
      </div>
    </div>
  </header>

  <!-- ============================================================
       BODY
       ============================================================ -->
  <article class="article-body-wrap section--band" data-screen-label="02 Article Body">
    <div class="container">
      <div class="cms-prose" data-reveal set:html={data.body} />

      <!-- Author footer -->
      <div class="article-author-card" data-reveal>
        <span class={`avatar ${avatarClass}`} aria-hidden="true">{initials}</span>
        <div>
          <div class="author-label">
            <span class="lang-only-en">Written by</span>
            <span class="lang-only-es">Escrito por</span>
          </div>
          <div class="author-name">{authorName}</div>
          <p class="author-bio">
            <span class="lang-only-en">The SENAVIA team writes about web design, SEO, and digital marketing for South Florida businesses.</span>
            <span class="lang-only-es">El equipo de SENAVIA escribe sobre diseño web, SEO y marketing digital para negocios del Sur de Florida.</span>
          </p>
        </div>
      </div>
    </div>
  </article>

  <!-- ============================================================
       RELATED ARTICLES
       ============================================================ -->
  {related.length > 0 && (
    <section class="section" data-screen-label="03 Related Articles">
      <div class="container">
        <div class="related-head" data-reveal>
          <h2>
            <span class="lang-only-en">Related Articles</span>
            <span class="lang-only-es">Artículos Relacionados</span>
          </h2>
        </div>
        <div class="related-grid" data-reveal-children>
          {related.map((post) => (
            <a href={`/blog/${post.id}`} class="related-card">
              <div class="related-cover">
                <img
                  src={post.data.thumbnail || post.data.mainImage}
                  alt={post.data.altImage}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <h3>{post.data.title}</h3>
              <span class="related-date">
                <span class="lang-only-en">{fmtEn(post.data.pubDate)}</span>
                <span class="lang-only-es">{fmtEs(post.data.pubDate)}</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="article-cta cta--glow" data-screen-label="04 CTA">
    <div class="container">
      <div class="cta-inner" data-reveal>
        <h2>
          <span class="lang-only-en">Ready to grow your business online?</span>
          <span class="lang-only-es">¿Listo para hacer crecer tu negocio en línea?</span>
        </h2>
        <p>
          <span class="lang-only-en">Let's design a web and marketing strategy built around real results. Book a free 30-minute call with the SENAVIA team.</span>
          <span class="lang-only-es">Diseñemos una estrategia web y de marketing enfocada en resultados reales. Agenda una llamada gratis de 30 minutos con el equipo de SENAVIA.</span>
        </p>
        <a
          href="#"
          class="btn"
          data-calendly-trigger
          data-track="book_call_click"
          onclick={`if(window.Calendly){Calendly.initPopupWidget({url:'${CALENDLY_URL}'});}return false;`}
        >
          <span class="lang-only-en">Book a Free Call</span>
          <span class="lang-only-es">Agenda tu Llamada Gratis</span>
        </a>
      </div>
    </div>
  </section>
</main>
</BaseLayout>
</content>
</invoke>
