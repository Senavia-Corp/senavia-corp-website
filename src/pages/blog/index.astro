---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { prettyName } from '@/lib/cms';

const title = "Blog &amp; Tips — SENAVIA Corp · Web, SEO &amp; Marketing Insights";
const description = "Expert insights on web development, SEO, digital marketing, and automation — from the SENAVIA Corp team in South Florida.";

/* ------------------------------------------------------------------ *
 *  Data — real Webflow CMS (English only). Render CMS field values
 *  as-is; keep page chrome bilingual via lang-only-* spans.
 * ------------------------------------------------------------------ */
const posts = (await getCollection('blog')).sort(
  (a, b) => (b.data.pubDate?.getTime() ?? 0) - (a.data.pubDate?.getTime() ?? 0),
);

const featured = posts.filter((p) => p.data.featured);

// English category label → Spanish label (chrome localization).
const CAT_ES: Record<string, string> = {
  'web-design': 'Diseño Web',
  'web-development': 'Desarrollo Web',
  'digital-marketing': 'Marketing Digital',
};
// English category slug → English display label.
const CAT_EN: Record<string, string> = {
  'web-design': 'Web Design',
  'web-development': 'Web Development',
  'digital-marketing': 'Digital Marketing',
};
const catEn = (slug: string) => CAT_EN[slug] ?? slug;
const catEs = (slug: string) => CAT_ES[slug] ?? slug;

const fmtEn = (d?: Date) => (d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '');
const fmtEs = (d?: Date) => (d ? d.toLocaleDateString('es-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '');

const initials = (name: string) =>
  name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();
const avatarPalette = ['av1', 'av2', 'av3', 'av4'];
const avatarFor = (slug: string) => avatarPalette[slug.length % avatarPalette.length];

// Real category counts, ordered by count desc.
const catCounts = new Map<string, number>();
for (const p of posts) {
  const c = p.data.category;
  if (!c) continue;
  catCounts.set(c, (catCounts.get(c) ?? 0) + 1);
}
const categories = [...catCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([slug, count]) => ({ slug, count }));

const total = posts.length;
---
<BaseLayout
  title={title}
  description={description}
  canonical="/blog"
  jsonLdType="blog"
  screenLabel="Blog"
>
<style is:global data-blog-index>
/* ============================================================
     BLOG PAGE
     ============================================================ */
  .hero.is-compact + .section { padding-top: 4rem; }

  .blog-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 1080px) {
    .blog-wrap { grid-template-columns: 1fr; gap: 48px; }
  }
  .blog-main { min-width: 0; }

  /* ---------- FEATURED ROW ---------- */
  .featured-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 1.5rem;
  }
  .featured-head .side-eyebrow { margin: 0; }
  .featured-head h2 { margin: 0; font-size: 1.4rem; letter-spacing: -0.01em; }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 3rem;
  }
  @media (max-width: 680px) { .featured-grid { grid-template-columns: 1fr; gap: 22px; } }

  .featured-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 280px;
    padding: 1.5rem;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 14px 34px rgba(0,0,0,0.32);
    transition: transform .25s cubic-bezier(.2,.6,.2,1), box-shadow .25s ease;
  }
  .featured-card:hover { transform: translateY(-3px); box-shadow: 0 20px 46px rgba(0,0,0,0.4), 0 0 0 1px rgba(153,204,51,0.32); }
  .featured-card img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  .featured-card::after {
    content: '';
    position: absolute; inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, rgba(10,14,38,0.15) 0%, rgba(10,14,38,0.55) 50%, rgba(10,14,38,0.92) 100%);
  }
  .featured-card .blog-tag { margin-bottom: 12px; }
  .featured-card h3 {
    margin: 0 0 8px;
    font-size: 1.35rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .featured-card:hover h3 { color: var(--primary, #99cc33); }
  .featured-card .blog-meta { color: rgba(255,255,255,0.7); }

  /* MAIN — blog grid */
  .blog-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px dashed rgba(255,255,255,0.08);
  }
  .blog-count {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .blog-count .accent { color: var(--primary, #99cc33); font-weight: 600; }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 24px;
  }
  @media (max-width: 680px) { .blog-grid { grid-template-columns: 1fr; gap: 22px; } }

  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform .25s cubic-bezier(.2,.6,.2,1);
  }
  .blog-card:hover { transform: translateY(-3px); }
  .blog-card .blog-cover {
    aspect-ratio: 16 / 10;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 12px 28px rgba(0,0,0,0.28);
    background: rgba(13,18,53,0.55);
    transition: box-shadow .25s ease, border-color .25s ease;
  }
  .blog-card:hover .blog-cover {
    box-shadow: 0 18px 40px rgba(0,0,0,0.36), 0 0 0 1px rgba(153,204,51,0.32);
  }
  .blog-card .blog-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .blog-card .blog-cover::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(10,14,38,0.0) 60%, rgba(10,14,38,0.5) 100%);
  }

  .blog-tag {
    align-self: flex-start;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(153,204,51,0.14);
    color: var(--primary, #99cc33);
    border: 1px solid rgba(153,204,51,0.28);
  }
  .blog-tag[data-cat="web-design"]        { background: rgba(153,204,51,0.14); color: #b6e06a; border-color: rgba(153,204,51,0.3); }
  .blog-tag[data-cat="web-development"]   { background: rgba(123,63,228,0.16); color: #b89bf2; border-color: rgba(123,63,228,0.36); }
  .blog-tag[data-cat="digital-marketing"] { background: rgba(240,160,80,0.14); color: #f6b56e; border-color: rgba(240,160,80,0.32); }

  .blog-card h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
    text-transform: none;
    line-height: 1.3;
  }
  .blog-card:hover h3 { color: var(--primary, #99cc33); }
  .blog-card .blog-excerpt {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255,255,255,0.62);
    max-width: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 2px;
    font-size: 12px;
    color: rgba(255,255,255,0.5);
  }
  .blog-meta .blog-author {
    width: 26px; height: 26px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
  }
  .blog-author.av1 { background: linear-gradient(135deg, #7B3FE4, #C13B8A); }
  .blog-author.av2 { background: linear-gradient(135deg, #2A7B4F, #99CC33); }
  .blog-author.av3 { background: linear-gradient(135deg, #2D7DB8, #33CCCC); }
  .blog-author.av4 { background: linear-gradient(135deg, #D14F8C, #F0A050); }
  .blog-meta .blog-author-name { color: rgba(255,255,255,0.78); font-weight: 500; }
  .blog-meta .sep { color: rgba(255,255,255,0.25); }

  /* Empty state */
  .blog-empty {
    grid-column: 1 / -1;
    padding: 3rem 1.5rem;
    text-align: center;
    color: rgba(255,255,255,0.6);
    border: 1px dashed rgba(255,255,255,0.12);
    border-radius: 14px;
  }

  /* SIDEBAR */
  .blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: 22px;
    position: sticky;
    top: 100px;
  }
  @media (max-width: 1080px) { .blog-sidebar { position: static; } }

  .side-card {
    padding: 1.5rem;
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    backdrop-filter: blur(8px);
  }
  .side-card h3 {
    margin: 0 0 14px;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .side-eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    margin-bottom: 8px;
  }

  /* Subscribe */
  .sub-card {
    position: relative;
    padding: 1.75rem 1.5rem;
    background:
      linear-gradient(160deg, rgba(20,38,30,0.7), rgba(11,28,22,0.55)) padding-box,
      linear-gradient(160deg, #99cc33, rgba(51,204,204,0.5) 60%, transparent) border-box;
    border: 1px solid transparent;
    border-radius: 16px;
    overflow: hidden;
  }
  .sub-card::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 180px; height: 180px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(153,204,51,0.25) 0%, transparent 70%);
    pointer-events: none;
  }
  .sub-card h3 {
    font-size: 1.125rem;
    text-transform: none;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }
  .sub-card p {
    margin: 0 0 16px;
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255,255,255,0.7);
    max-width: none;
  }
  .sub-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    z-index: 1;
  }
  .sub-form input {
    appearance: none;
    background: rgba(10,14,38,0.6);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
    font: inherit;
    font-size: 14px;
    padding: 11px 14px;
    border-radius: 10px;
    width: 100%;
    transition: border-color .2s ease, background .2s ease;
  }
  .sub-form input::placeholder { color: rgba(255,255,255,0.4); }
  .sub-form input:focus {
    outline: none;
    border-color: var(--primary, #99cc33);
    background: rgba(10,14,38,0.8);
  }
  .sub-form .btn { width: 100%; justify-content: center; }
  .sub-note {
    margin-top: 12px;
    font-size: 11.5px;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  /* Categories */
  .cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cat-list .cat-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-radius: 8px;
    color: rgba(255,255,255,0.78);
    font-size: 14px;
  }
  .cat-list .count {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    background: rgba(255,255,255,0.05);
    padding: 2px 7px;
    border-radius: 999px;
  }

  /* Featured articles (sidebar) */
  .feat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .feat-item {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 12px;
    align-items: start;
    text-decoration: none;
    color: inherit;
    transition: opacity .2s ease;
  }
  .feat-item:hover { opacity: 0.92; }
  .feat-item .feat-thumb {
    width: 56px; height: 56px;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: rgba(255,255,255,0.06);
  }
  .feat-item .feat-thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .feat-item .feat-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .feat-item .feat-title {
    font-size: 13px;
    color: #fff;
    font-weight: 500;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .feat-item:hover .feat-title { color: var(--primary, #99cc33); }
  .feat-item .feat-date {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: 0.04em;
  }
</style>

<main>

  <!-- ============================================================
       HERO — Compact
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 Blog Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;">
        <span class="lang-only-en">Field notes · Updated regularly</span>
        <span class="lang-only-es">Notas de campo · Actualizado con frecuencia</span>
      </div>
      <h1>
        <span class="lang-only-en">Blog &amp; Tips</span>
        <span class="lang-only-es">Blog y Consejos</span>
      </h1>
      <p>
        <span class="lang-only-en">Expert insights on web development, SEO, digital marketing, and automation.</span>
        <span class="lang-only-es">Perspectivas expertas sobre desarrollo web, SEO, marketing digital y automatización.</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       BLOG GRID + SIDEBAR
       ============================================================ -->
  <section class="section section--band" data-screen-label="02 Blog Grid">
    <div class="container">
      <div class="blog-wrap">

        <!-- MAIN -->
        <div class="blog-main">

          {featured.length > 0 && (
            <div class="blog-featured">
              <div class="featured-head" data-reveal>
                <span class="side-eyebrow">
                  <span class="lang-only-en">Featured</span>
                  <span class="lang-only-es">Destacados</span>
                </span>
                <h2>
                  <span class="lang-only-en">Editor's Picks</span>
                  <span class="lang-only-es">Selección del Editor</span>
                </h2>
              </div>
              <div class="featured-grid" data-reveal-children>
                {featured.map((post) => (
                  <a href={`/blog/${post.id}`} class="featured-card">
                    <img
                      src={post.data.mainImage || post.data.thumbnail}
                      alt={post.data.altImage}
                      loading="lazy"
                      decoding="async"
                    />
                    <span class="blog-tag" data-cat={post.data.category}>
                      <span class="lang-only-en">{catEn(post.data.category)}</span>
                      <span class="lang-only-es">{catEs(post.data.category)}</span>
                    </span>
                    <h3>{post.data.title}</h3>
                    <div class="blog-meta">
                      <span class={`blog-author ${avatarFor(post.data.author)}`} aria-hidden="true">{initials(prettyName(post.data.author))}</span>
                      <span class="blog-author-name">{prettyName(post.data.author)}</span>
                      <span class="sep">·</span>
                      <span class="lang-only-en">{fmtEn(post.data.pubDate)}</span>
                      <span class="lang-only-es">{fmtEs(post.data.pubDate)}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="blog-toolbar" data-reveal>
            <span class="blog-count">
              <span class="lang-only-en">Showing <span class="accent">{total}</span> {total === 1 ? 'article' : 'articles'}</span>
              <span class="lang-only-es">Mostrando <span class="accent">{total}</span> {total === 1 ? 'artículo' : 'artículos'}</span>
            </span>
            <span class="blog-count">
              <span class="lang-only-en">Newest first</span>
              <span class="lang-only-es">Más recientes primero</span>
            </span>
          </div>

          <div class="blog-grid" data-reveal-children>
            {posts.length === 0 && (
              <div class="blog-empty">
                <span class="lang-only-en">No articles published yet. Check back soon.</span>
                <span class="lang-only-es">Aún no hay artículos publicados. Vuelve pronto.</span>
              </div>
            )}

            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="blog-card">
                <div class="blog-cover">
                  <img
                    src={post.data.thumbnail || post.data.mainImage}
                    alt={post.data.altImage}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="blog-tag" data-cat={post.data.category}>
                  <span class="lang-only-en">{catEn(post.data.category)}</span>
                  <span class="lang-only-es">{catEs(post.data.category)}</span>
                </span>
                <h3>{post.data.title}</h3>
                <p class="blog-excerpt">{post.data.summary}</p>
                <div class="blog-meta">
                  <span class={`blog-author ${avatarFor(post.data.author)}`} aria-hidden="true">{initials(prettyName(post.data.author))}</span>
                  <span class="blog-author-name">{prettyName(post.data.author)}</span>
                  <span class="sep">·</span>
                  <span class="lang-only-en">{fmtEn(post.data.pubDate)}</span>
                  <span class="lang-only-es">{fmtEs(post.data.pubDate)}</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- SIDEBAR -->
        <aside class="blog-sidebar" aria-label="Blog sidebar">

          <div class="sub-card" data-reveal>
            <span class="side-eyebrow">
              <span class="lang-only-en">Newsletter</span>
              <span class="lang-only-es">Boletín</span>
            </span>
            <h3>
              <span class="lang-only-en">Get growth tips in your inbox</span>
              <span class="lang-only-es">Recibe consejos de crecimiento en tu correo</span>
            </h3>
            <p>
              <span class="lang-only-en">One email per month with SEO, design, and marketing playbooks from the SENAVIA team. No spam, unsubscribe anytime.</span>
              <span class="lang-only-es">Un correo al mes con estrategias de SEO, diseño y marketing del equipo de SENAVIA. Sin spam, cancela cuando quieras.</span>
            </p>
            <form class="sub-form" onsubmit="event.preventDefault(); this.querySelector('button').textContent='✓';">
              <input type="email" required placeholder="you@business.com" aria-label="Email address">
              <button type="submit" class="btn">
                <span class="lang-only-en">Subscribe</span>
                <span class="lang-only-es">Suscribirme</span>
              </button>
            </form>
            <p class="sub-note">
              <span class="lang-only-en">By subscribing you agree to our privacy policy. Used only for monthly insights.</span>
              <span class="lang-only-es">Al suscribirte aceptas nuestra política de privacidad. Solo para perspectivas mensuales.</span>
            </p>
          </div>

          {categories.length > 0 && (
            <div class="side-card" data-reveal>
              <h3>
                <span class="lang-only-en">Categories</span>
                <span class="lang-only-es">Categorías</span>
              </h3>
              <ul class="cat-list">
                {categories.map((c) => (
                  <li>
                    <div class="cat-row">
                      <span>
                        <span class="lang-only-en">{catEn(c.slug)}</span>
                        <span class="lang-only-es">{catEs(c.slug)}</span>
                      </span>
                      <span class="count">{c.count}</span>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {featured.length > 0 && (
            <div class="side-card" data-reveal>
              <h3>
                <span class="lang-only-en">Featured Articles</span>
                <span class="lang-only-es">Artículos Destacados</span>
              </h3>
              <ul class="feat-list">
                {featured.map((post) => (
                  <li>
                    <a href={`/blog/${post.id}`} class="feat-item">
                      <span class="feat-thumb">
                        <img
                          src={post.data.thumbnail || post.data.mainImage}
                          alt={post.data.altImage}
                          loading="lazy"
                          decoding="async"
                        />
                      </span>
                      <span class="feat-body">
                        <span class="feat-title">{post.data.title}</span>
                        <span class="feat-date">
                          <span class="lang-only-en">{fmtEn(post.data.pubDate)}</span>
                          <span class="lang-only-es">{fmtEs(post.data.pubDate)}</span>
                        </span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta cta--glow" data-screen-label="03 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
