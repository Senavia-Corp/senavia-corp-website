<!-- Blog pagination + interactions -->
<script>
  (function(){
    var pages = document.querySelectorAll('.blog-page:not(.is-arrow)');
    pages.forEach(function(p){
      p.addEventListener('click', function(){
        document.querySelectorAll('.blog-page').forEach(function(x){ x.classList.remove('is-active'); });
        p.classList.add('is-active');
        window.scrollTo({ top: document.querySelector('.blog-main').offsetTop - 100, behavior: 'smooth' });
      });
    });
  })();
</script>
