  <script>
    /* Blog category filter — client-side, SEO-safe (all posts stay in the DOM).
       One handler drives both the chip bar and the sidebar list, syncing
       aria-pressed state, the live "Showing N" count, and the empty state. */
    (function () {
      var controls = Array.prototype.slice.call(document.querySelectorAll('[data-cat]'));
      var cards = Array.prototype.slice.call(document.querySelectorAll('.blog-grid [data-card-cat]'));
      if (!controls.length || !cards.length) return;
      var countAccents = document.querySelectorAll('.blog-count .accent');
      var emptyFilter = document.querySelector('.blog-empty-filter');

      function apply(cat) {
        var shown = 0;
        cards.forEach(function (c) {
          var match = cat === 'all' || c.getAttribute('data-card-cat') === cat;
          c.hidden = !match;
          if (match) shown++;
        });
        controls.forEach(function (b) {
          b.setAttribute('aria-pressed', b.getAttribute('data-cat') === cat ? 'true' : 'false');
        });
        countAccents.forEach(function (el) { el.textContent = String(shown); });
        if (emptyFilter) emptyFilter.hidden = shown !== 0;
      }

      controls.forEach(function (b) {
        b.addEventListener('click', function () { apply(b.getAttribute('data-cat')); });
      });
    })();
  </script>
</main>
