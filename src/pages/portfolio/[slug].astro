---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = (await getCollection('portfolio'))
    .sort((a, b) => a.data.order - b.data.order);

  return all.map((entry, i) => {
    const prev = all[(i - 1 + all.length) % all.length];
    const next = all[(i + 1) % all.length];
    return {
      params: { slug: entry.id },
      props: { entry, prev, next },
    };
  });
}

const { entry, prev, next } = Astro.props;
const d = entry.data;
const seoTitle = `${d.title} — Portfolio · SENAVIA Corp`;

// WL-042 — neutral state: this client's live domain currently fails TLS at
// the apex (and www 301s into it), so the Preview button would dead-end.
// Treat its liveUrl as pending until the owner confirms the client fixed
// their domain (see _qa/DECISIONS-NEEDED.md §14). Nothing changes in Sanity.
const LIVE_URL_OFFLINE = new Set(['mile-high-renovation']);
const liveUrl = LIVE_URL_OFFLINE.has(entry.id) ? '' : d.liveUrl;

// WL-061 — neutral structural pass on the flat CMS prose: split the
// paragraphs into rhythm blocks (lead paragraph + labeled blocks). Subtitles
// derive ONLY from labels already present in the CMS text (today that is
// "Technologies & Services:"); no content is invented. Full challenge/
// solution/results structure needs owner-approved content (DECISIONS §15).
type DetailBlock =
  | { kind: 'lead' | 'p'; html: string }
  | { kind: 'labeled'; label: string; items: string[] };
const LABEL_RE = /^\s*(Technologies\s*&(?:amp;)?\s*Services)\s*:\s*/i;
const detailParas = (d.details.match(/<p[\s\S]*?<\/p>/gi) || [])
  .map((p) => p.replace(/^<p[^>]*>/i, '').replace(/<\/p>$/i, '').trim())
  .filter(Boolean);
const detailBlocks: DetailBlock[] = detailParas.map((html, i) => {
  if (LABEL_RE.test(html)) {
    const items = html
      .replace(LABEL_RE, '')
      .split(/,\s*/)
      .map((s) => s.trim().replace(/\.\s*$/, ''))
      .filter(Boolean);
    return { kind: 'labeled', label: 'Technologies & Services', items };
  }
  return { kind: i === 0 ? 'lead' : 'p', html };
});
---
<BaseLayout
  title={seoTitle}
  description={d.summary}
  canonical={`/portfolio/${entry.id}`}
  jsonLdType="portfolio"
  screenLabel="Project Detail"
>
<style is:global data-recovered>
/* ============================================================
     PORTFOLIO PROJECT DETAIL
     ============================================================ */

  /* ===== HERO ===== */
  .pp-hero {
    position: relative;
    overflow: hidden;
    padding: 9rem 0 0;
    margin-top: -84px;
  }
  .pp-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #2D7DB8 0%, #33CCCC 50%, #99CC33 100%);
    z-index: 0;
  }
  .pp-hero-bg::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 25% 20%, rgba(255,255,255,0.16) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(0,0,0,0.4) 0%, transparent 60%),
      linear-gradient(180deg, rgba(10,14,38,0.35) 0%, rgba(10,14,38,0.92) 100%);
  }
  .pp-hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.4;
    pointer-events: none;
  }
  .pp-hero .container { position: relative; z-index: 2; }
  .pp-hero-cat {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(153,204,51,0.14);
    border: 1px solid rgba(153,204,51,0.4);
    backdrop-filter: blur(8px);
    margin-bottom: 1.5rem;
  }
  .pp-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.75rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1.5rem;
    color: #fff;
    max-width: 16ch;
  }
  .pp-hero-summary {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.6;
    color: rgba(255,255,255,0.85);
    max-width: 60ch;
    margin: 0 0 2.5rem;
  }
  .pp-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 3.5rem;
  }

  /* Showcase image bleeding under the hero */
  .pp-showcase {
    position: relative;
    z-index: 2;
    margin: 0 auto;
    max-width: 1080px;
    border-radius: 18px 18px 0 0;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.12);
    border-bottom: 0;
    box-shadow: 0 -10px 60px rgba(0,0,0,0.4);
    background: linear-gradient(135deg, #1a1f44 0%, #0d1235 100%);
  }
  .pp-showcase img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ===== LIVE BROWSER PREVIEW ===== */
  .pp-browser { background: #0d1235; }
  .pp-browser-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .pp-dots { display: inline-flex; gap: 7px; flex-shrink: 0; }
  .pp-dots i { width: 11px; height: 11px; border-radius: 50%; background: rgba(255,255,255,0.22); }
  .pp-url {
    flex: 1;
    min-width: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12.5px;
    color: rgba(255,255,255,0.55);
    background: rgba(0,0,0,0.25);
    padding: 5px 12px;
    border-radius: 999px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pp-open {
    flex-shrink: 0;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 16px;
    line-height: 1;
    padding: 4px 8px;
    border-radius: 8px;
    transition: all .2s ease;
  }
  .pp-open:hover { color: var(--primary, #99cc33); background: rgba(153,204,51,0.12); }
  .pp-browser-stage {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #0d1235;
  }
  .pp-poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: top center; }
  .pp-launch {
    position: absolute;
    inset: 0;
    margin: auto;
    width: max-content;
    height: max-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    font-size: 15px;
    font-weight: 600;
    color: #0a0e26;
    text-decoration: none;
    background: var(--primary, #99cc33);
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .pp-launch svg { width: 16px; height: 16px; }
  .pp-launch:hover { transform: translateY(-2px); box-shadow: 0 12px 38px rgba(0,0,0,0.5); }
  .pp-launch:focus-visible { outline: 3px solid #fff; outline-offset: 3px; }
  /* Provisional pending state — same shape, muted, non-interactive */
  .pp-launch.is-pending {
    background: rgba(255,255,255,0.16);
    color: rgba(255,255,255,0.78);
    cursor: default;
    box-shadow: none;
    backdrop-filter: blur(6px);
  }
  .pp-launch.is-pending:hover { transform: none; box-shadow: none; }

  /* ===== CONTENT LAYOUT ===== */
  .pp-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 320px);
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 980px) { .pp-layout { grid-template-columns: 1fr; gap: 40px; } }
  /* WL-020 — cases without a CMS services list render single-column
     (the aside simply does not exist for them) */
  .pp-layout.is-solo { grid-template-columns: minmax(0, 1fr); }

  .pp-block-head .eyebrow { margin-bottom: 14px; }
  .pp-block-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    margin: 0 0 1.75rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  /* Services aside card */
  .pp-aside {
    position: sticky;
    top: 110px;
    padding: 2rem 1.75rem;
    background:
      linear-gradient(180deg, rgba(13,18,53,0.7), rgba(11,15,35,0.55)) padding-box,
      linear-gradient(160deg, rgba(153,204,51,0.32), rgba(255,255,255,0.04) 50%, rgba(51,204,204,0.16)) border-box;
    border: 1px solid transparent;
    border-radius: 18px;
    backdrop-filter: blur(10px);
  }
  @media (max-width: 980px) { .pp-aside { position: static; } }
  .pp-aside .eyebrow { margin-bottom: 12px; }
  .pp-aside h2 {
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 1.1rem;
    color: #fff;
    text-transform: none;
  }

  /* ===== CMS PROSE (set:html content) ===== */
  .cms-prose {
    max-width: 70ch;
    font-size: 16.5px;
    line-height: 1.75;
    color: rgba(255,255,255,0.78);
  }
  .cms-prose > :first-child { margin-top: 0; }
  .cms-prose > :last-child { margin-bottom: 0; }
  .cms-prose h2,
  .cms-prose h3,
  .cms-prose h4 {
    color: #fff;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin: 2rem 0 0.85rem;
  }
  .cms-prose h2 { font-size: 1.6rem; }
  .cms-prose h3 { font-size: 1.3rem; }
  .cms-prose h4 { font-size: 1.1rem; }
  .cms-prose p { margin: 0 0 1.15rem; }
  .cms-prose ul,
  .cms-prose ol { margin: 0 0 1.25rem; padding-left: 1.35rem; }
  .cms-prose li { margin: 0 0 0.5rem; }
  .cms-prose li::marker { color: var(--primary, #99cc33); }
  .cms-prose a {
    color: var(--primary, #99cc33);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity .2s ease;
  }
  .cms-prose a:hover { opacity: 0.78; }
  .cms-prose strong { color: #fff; font-weight: 600; }
  .cms-prose img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    margin: 1.5rem 0;
  }
  .cms-prose blockquote {
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    border-left: 3px solid var(--primary, #99cc33);
    color: rgba(255,255,255,0.85);
    font-style: italic;
  }

  /* WL-061 — structural rhythm for the flat CMS paragraphs */
  .cms-prose .pp-lead {
    font-size: 1.16em;
    line-height: 1.7;
    color: rgba(255,255,255,0.88);
  }
  .pp-tech { margin-top: 2rem; }
  .pp-tech h3 { font-size: 1.05rem; letter-spacing: 0.01em; margin-bottom: 0; }
  .pp-tech-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0.9rem 0 0;
    padding: 0;
  }
  .cms-prose .pp-tech-list li {
    margin: 0;
    font-size: 13px;
    padding: 7px 13px;
    border-radius: 999px;
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
  }

  /* WL-037 — discreet ES-only notice (the case-study body is EN-only) */
  .pp-lang-note {
    font-size: 13.5px;
    font-style: italic;
    color: rgba(255,255,255,0.5);
    margin: -0.75rem 0 1.25rem;
  }

  /* Tighter prose for the services aside */
  .pp-aside .cms-prose {
    font-size: 15px;
    line-height: 1.65;
  }
  .pp-aside .cms-prose ul { padding-left: 1.1rem; }
  .pp-aside .cms-prose p { margin-bottom: 0.85rem; }

  /* ===== PREV / NEXT NAV ===== */
  .pp-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media (max-width: 720px) { .pp-nav { grid-template-columns: 1fr; } }
  .pp-nav-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 1.75rem 1.75rem;
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition: all .25s ease;
    position: relative;
    overflow: hidden;
    min-height: 130px;
  }
  .pp-nav-card:hover {
    border-color: rgba(153,204,51,0.4);
    background: rgba(20,28,60,0.65);
    transform: translateY(-3px);
  }
  .pp-nav-card.next { text-align: right; align-items: flex-end; }
  .pp-nav-card .dir {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .pp-nav-card.next .dir { flex-direction: row-reverse; }
  .pp-nav-card .dir svg { width: 14px; height: 14px; transition: transform .2s ease; }
  .pp-nav-card:hover .dir svg { transform: translateX(-3px); color: var(--primary, #99cc33); }
  .pp-nav-card.next:hover .dir svg { transform: translateX(3px); }
  .pp-nav-card h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.005em;
    text-transform: none;
    line-height: 1.2;
  }
  .pp-nav-card:hover h3 { color: var(--primary, #99cc33); }
  .pp-nav-card .sector {
    font-size: 12.5px;
    color: rgba(255,255,255,0.55);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<main>

  <!-- ============================================================
       HERO — Title + summary + showcase image
       ============================================================ -->
  <section class="pp-hero" data-screen-label="01 Project Hero">
    <div class="pp-hero-bg"></div>
    <div class="container">
      <span class="pp-hero-cat"><span class="lang-only-en">Case study</span><span class="lang-only-es">Caso de Estudio</span></span>
      <h1>{d.title}</h1>
      {d.summary && <p class="pp-hero-summary">{d.summary}</p>}
      <div class="pp-hero-actions">
        <a href="#" class="btn cta--glow" data-calendly-trigger>
          <span class="lang-only-en">Start a project like this</span><span class="lang-only-es">Inicia un proyecto así</span>
        </a>
        <a href="/portfolio" class="btn is-secondary">
          <span class="lang-only-en">All projects</span><span class="lang-only-es">Todos los proyectos</span>
        </a>
      </div>
    </div>
    {/* Every case study renders the same browser frame. liveUrl drives the
        Preview button; when it's missing (or the client site is known to be
        offline — WL-042) we show the pending state instead of a dead link.
        ponytail: provisional placeholder, not a hidden section. */}
    <div class="container">
      <figure class="pp-showcase pp-browser">
        <div class="pp-browser-bar">
          <span class="pp-dots"><i></i><i></i><i></i></span>
          <span class="pp-url">{liveUrl ? liveUrl.replace(/^https?:\/\//, '').replace(/\/$/, '') : 'offline'}</span>
          {liveUrl && <a class="pp-open" href={liveUrl} target="_blank" rel="noopener noreferrer" aria-label="Open live site in a new tab">↗</a>}
        </div>
        <div class="pp-browser-stage">
          {d.mainImage && <img class="pp-poster" src={d.mainImage} alt={d.imageAlt} loading="eager" decoding="async" />}
          {liveUrl ? (
            <a class="pp-launch" href={liveUrl} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
              <span class="lang-only-en">Preview Website</span><span class="lang-only-es">Ver sitio web</span>
            </a>
          ) : (
            <span class="pp-launch is-pending" aria-disabled="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 14"></polyline></svg>
              <span class="lang-only-en">Preview unavailable</span><span class="lang-only-es">Vista previa no disponible</span>
            </span>
          )}
        </div>
      </figure>
    </div>
  </section>

  <!-- ============================================================
       PROJECT DETAILS + SERVICES RENDERED
       ============================================================ -->
  <section class="section" data-screen-label="02 Project Details">
    <div class="container">
      <div class={`pp-layout${d.services ? '' : ' is-solo'}`} data-reveal>
        <div class="pp-block-head">
          <div class="eyebrow"><span class="lang-only-en">Project details</span><span class="lang-only-es">Detalles del Proyecto</span></div>
          <h2><span class="lang-only-en">Inside the build</span><span class="lang-only-es">Dentro del Proyecto</span></h2>
          <p class="pp-lang-note lang-only-es">Este caso de estudio está disponible solo en inglés.</p>
          {detailBlocks.length > 0
            ? <div class="cms-prose">
                {detailBlocks.map((b) =>
                  b.kind === 'labeled' ? (
                    <div class="pp-tech">
                      <h3>{b.label}</h3>
                      <ul class="pp-tech-list">
                        {b.items.map((it) => <li set:html={it} />)}
                      </ul>
                    </div>
                  ) : (
                    <p class={b.kind === 'lead' ? 'pp-lead' : undefined} set:html={b.html} />
                  ),
                )}
              </div>
            : d.details
              ? <div class="cms-prose" set:html={d.details} />
              : <p class="cms-prose">{d.summary}</p>}
        </div>

        {d.services && (
          <aside class="pp-aside">
            <div class="eyebrow"><span class="lang-only-en">What we delivered</span><span class="lang-only-es">Lo que Entregamos</span></div>
            <h2><span class="lang-only-en">Services Rendered</span><span class="lang-only-es">Servicios Prestados</span></h2>
            <div class="cms-prose" set:html={d.services} />
          </aside>
        )}
      </div>
    </div>
  </section>

  <!-- ============================================================
       PREV / NEXT NAV
       ============================================================ -->
  <section class="section section--band" data-screen-label="03 Project Nav">
    <div class="container">
      <div class="pp-nav" data-reveal>
        <a href={`/portfolio/${prev.id}`} class="pp-nav-card prev">
          <span class="dir">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
            <span class="lang-only-en">Previous project</span><span class="lang-only-es">Proyecto Anterior</span>
          </span>
          <h3>{prev.data.title}</h3>
          <span class="sector">{prev.data.summary}</span>
        </a>
        <a href={`/portfolio/${next.id}`} class="pp-nav-card next">
          <span class="dir">
            <span class="lang-only-en">Next project</span><span class="lang-only-es">Proyecto Siguiente</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </span>
          <h3>{next.data.title}</h3>
          <span class="sector">{next.data.summary}</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="04 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Like What You See? Let's Talk.</span><span class="lang-only-es">¿Te Gusta lo que Ves? Conversemos.</span></h2>
      <p>
        <span class="lang-only-en">Schedule your free 30-minute consultation and we'll plan a project worth showcasing.</span>
        <span class="lang-only-es">Agenda tu consulta gratuita de 30 minutos y planearemos un proyecto digno de mostrar.</span>
      </p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>
</BaseLayout>
