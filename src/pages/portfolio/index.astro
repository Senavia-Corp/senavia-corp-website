---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const title = "Portfolio — SENAVIA Corp · South Florida Web Projects";
const description = "Explore SENAVIA Corp's portfolio of web design, e-commerce, custom web apps, and digital marketing projects across South Florida.";

const projects = (await getCollection('portfolio'))
  .sort((a, b) =>
    (Number(b.data.featured) - Number(a.data.featured)) || (a.data.order - b.data.order),
  );
---
<BaseLayout
  title={title}
  description={description}
  canonical="/portfolio"
  jsonLdType="portfolio"
  screenLabel="Portfolio"
>
<style is:global data-recovered>
/* ============================================================
     PORTFOLIO PAGE
     ============================================================ */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 1024px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .portfolio-grid { grid-template-columns: 1fr; gap: 18px; }
  }

  /* Project card */
  .pf-card {
    display: flex;
    flex-direction: column;
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .3s cubic-bezier(.2,.6,.2,1), border-color .25s ease, box-shadow .25s ease;
    position: relative;
  }
  .pf-card:hover,
  .pf-card:focus-visible {
    transform: translateY(-5px);
    border-color: rgba(153,204,51,0.4);
    box-shadow: 0 24px 60px rgba(0,0,0,0.45);
    outline: none;
  }

  .pf-cover {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: linear-gradient(135deg, #1a1f44 0%, #0d1235 100%);
  }
  .pf-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .5s cubic-bezier(.2,.6,.2,1);
  }
  .pf-card:hover .pf-cover img,
  .pf-card:focus-within .pf-cover img { transform: scale(1.06); }

  /* Featured ribbon */
  .pf-featured {
    position: absolute;
    top: 14px; left: 14px;
    z-index: 2;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #0a0e26;
    padding: 5px 11px;
    border-radius: 999px;
    background: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    box-shadow: 0 6px 18px rgba(153,204,51,0.35);
  }

  /* Hover overlay CTA */
  .pf-hover {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 18px;
    background: linear-gradient(180deg, rgba(10,14,38,0) 35%, rgba(10,14,38,0.78) 100%);
    opacity: 0;
    transition: opacity .25s ease;
    pointer-events: none;
  }
  .pf-card:hover .pf-hover,
  .pf-card:focus-within .pf-hover { opacity: 1; }
  .pf-hover .pf-hover-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: #fff;
    transform: translateY(8px);
    transition: transform .3s ease;
  }
  .pf-card:hover .pf-hover .pf-hover-btn,
  .pf-card:focus-within .pf-hover .pf-hover-btn { transform: translateY(0); }
  .pf-hover .pf-hover-btn svg { width: 15px; height: 15px; }

  .pf-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 1.5rem 1.5rem 1.65rem;
    flex: 1;
  }
  .pf-body h3 {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: #fff;
    text-transform: none;
  }
  .pf-card:hover .pf-body h3,
  .pf-card:focus-within .pf-body h3 { color: var(--primary, #99cc33); }
  .pf-body p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pf-view {
    margin-top: auto;
    padding-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .pf-view svg { width: 14px; height: 14px; transition: transform .2s ease; }
  .pf-card:hover .pf-view svg,
  .pf-card:focus-within .pf-view svg { transform: translateX(4px); }

  /* WL-060 — closing CTA card: fills the open slot in the last row of the
     3-col grid (17 published cases) and converts instead of leaving a gap */
  .pf-card--cta {
    align-items: flex-start;
    justify-content: center;
    gap: 14px;
    padding: 2rem 1.75rem;
    border: 1px dashed rgba(153,204,51,0.4);
    background:
      radial-gradient(ellipse at 20% 0%, rgba(153,204,51,0.08) 0%, transparent 55%),
      rgba(13,18,53,0.4);
  }
  .pf-card--cta:hover,
  .pf-card--cta:focus-visible {
    border-color: rgba(153,204,51,0.7);
  }
  .pf-card--cta .pf-cta-badge {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--primary, #99cc33);
    background: rgba(153,204,51,0.12);
    border: 1px solid rgba(153,204,51,0.4);
  }
  .pf-card--cta .pf-cta-badge svg { width: 20px; height: 20px; }
  .pf-card--cta h3 {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: #fff;
    text-transform: none;
  }
  .pf-card--cta:hover h3,
  .pf-card--cta:focus-visible h3 { color: var(--primary, #99cc33); }
  .pf-card--cta p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
  }
  .pf-card--cta .pf-view { margin-top: 4px; padding-top: 0; }

  /* Compact hero gets a bit of bottom breathing room */
  .hero.is-compact + .section { padding-top: 4rem; }
</style>

<main>

  <!-- ============================================================
       HERO — Compact
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 Portfolio Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/bg-video-poster.jpg">
      <source src="/videos/bg-video.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;"><span class="lang-only-en">Selected work · 2021 – 2025</span><span class="lang-only-es">Trabajos Seleccionados · 2021 – 2025</span></div>
      <h1><span class="lang-only-en">Web Design Portfolio</span><span class="lang-only-es">Portafolio de Diseño Web</span></h1>
      <p><span class="lang-only-en">Explore our recent projects across South Florida.</span><span class="lang-only-es">Explora nuestros proyectos recientes en todo el Sur de Florida.</span></p>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO GRID
       ============================================================ -->
  <section class="section section--band" data-screen-label="02 Portfolio Grid">
    <div class="container">
      <div class="portfolio-grid" data-reveal-children>

        {projects.map((p) => (
          <a href={`/portfolio/${p.id}`} class="pf-card" aria-label={p.data.title}>
            <span class="pf-cover">
              {p.data.featured && (
                <span class="pf-featured"><span class="lang-only-en">Featured</span><span class="lang-only-es">Destacado</span></span>
              )}
              <img src={p.data.mainImage} alt={p.data.imageAlt} loading="lazy" decoding="async" />
              <span class="pf-hover">
                <span class="pf-hover-btn">
                  <span class="lang-only-en">View project</span><span class="lang-only-es">Ver proyecto</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </span>
              </span>
            </span>
            <div class="pf-body">
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
              <span class="pf-view">
                <span class="lang-only-en">View case study</span><span class="lang-only-es">Ver caso (en inglés)</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
              </span>
            </div>
          </a>
        ))}

        <!-- closing CTA card squares the case grid -->
        <a href="#" class="pf-card pf-card--cta" data-calendly-trigger>
          <span class="pf-cta-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </span>
          <h3><span class="lang-only-en">Your Project Here</span><span class="lang-only-es">Tu Proyecto Aquí</span></h3>
          <p><span class="lang-only-en">The next case study could be yours. Book a free call and let's plan it together.</span><span class="lang-only-es">El próximo caso de estudio puede ser el tuyo. Agenda una llamada gratis y planeémoslo juntos.</span></p>
          <span class="pf-view">
            <span class="lang-only-en">Book a Free Call</span><span class="lang-only-es">Agenda tu Llamada Gratis</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </span>
        </a>

      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="03 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2><span class="lang-only-en">Have a Project In Mind?</span><span class="lang-only-es">¿Tienes un Proyecto en Mente?</span></h2>
      <p>
        <span class="lang-only-en">Schedule your free consultation and let's design, build, or market your next digital success story.</span>
        <span class="lang-only-es">Agenda tu consulta gratuita y diseñemos, construyamos o promocionemos tu próxima historia de éxito digital.</span>
      </p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>
</BaseLayout>
