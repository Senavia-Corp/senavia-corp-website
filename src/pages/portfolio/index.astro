      </div>

      <p class="pf-empty" hidden role="status">No projects match this filter yet — check back soon.</p>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="03 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2>Have a Project In Mind?</h2>
      <p>Schedule your free consultation and let's design, build, or market your next digital success story.</p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>

<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el) return;
    function init() {
      if (!window.Calendly) { setTimeout(init, 200); return; }
      window.Calendly.initInlineWidget({
        url: 'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon?hide_landing_page_details=1&hide_gdpr_banner=1&background_color=0a0e26&text_color=ffffff&primary_color=99cc33',
        parentElement: el,
        prefill: {}, utm: {}
      });
      // Mark loaded after a beat
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    init();
  })();
</script>

<!-- Language switcher -->

<!-- Portfolio filter -->
<script>
  (function(){
    var items = Array.prototype.slice.call(document.querySelectorAll('.pf-item'));
    var chips = Array.prototype.slice.call(document.querySelectorAll('.pf-chip'));
    var empty = document.querySelector('.pf-empty');
    if (!items.length || !chips.length) return;

    // Counts per category
    var counts = { all: items.length };
    items.forEach(function(el){
      var c = el.getAttribute('data-category');
      counts[c] = (counts[c] || 0) + 1;
    });
    document.querySelectorAll('.pf-count').forEach(function(el){
      var k = el.getAttribute('data-count-for');
      el.textContent = counts[k] || 0;
    });

    function applyFilter(filter){
      var visible = 0;
      items.forEach(function(el){
        var match = (filter === 'all') || (el.getAttribute('data-category') === filter);
        if (match) {
          el.hidden = false;
          el.classList.add('is-entering');
          requestAnimationFrame(function(){
            requestAnimationFrame(function(){ el.classList.remove('is-entering'); });
          });
          visible++;
        } else {
          el.hidden = true;
        }
      });
      if (empty) empty.hidden = visible > 0;
    }

    chips.forEach(function(chip){
      chip.addEventListener('click', function(){
        chips.forEach(function(c){
          c.classList.remove('is-active');
          c.setAttribute('aria-selected', 'false');
        });
        chip.classList.add('is-active');
        chip.setAttribute('aria-selected', 'true');
        applyFilter(chip.getAttribute('data-filter'));
      });
    });
  })();
</script>
</BaseLayout>
