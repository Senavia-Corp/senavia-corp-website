---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Portfolio — SENAVIA Corp · Web Design, Apps & Marketing Projects in South Florida";
const description = "Explore SENAVIA Corp's portfolio of web design, e-commerce, custom web apps, and digital marketing projects across South Florida.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/portfolio"
  jsonLdType="portfolio"
  screenLabel="Portfolio"
>
<main>

  <!-- ============================================================
       HERO — Compact
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 Portfolio Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;">Selected work · 2021 – 2025</div>
      <h1>Web Design Portfolio</h1>
      <p>Explore our recent projects across South Florida.</p>
    </div>
  </section>

  <!-- ============================================================
       PORTFOLIO GRID + FILTER
       ============================================================ -->
  <section class="section" data-screen-label="02 Portfolio Grid">
    <div class="container">
      <div class="portfolio-filter" role="tablist" aria-label="Filter projects by category" data-reveal>
        <button class="pf-chip is-active" type="button" role="tab" aria-selected="true" data-filter="all">
          All <span class="pf-count" data-count-for="all"></span>
        </button>
        <button class="pf-chip" type="button" role="tab" aria-selected="false" data-filter="web-design">
          Web Design <span class="pf-count" data-count-for="web-design"></span>
        </button>
        <button class="pf-chip" type="button" role="tab" aria-selected="false" data-filter="ecommerce">
          E-commerce <span class="pf-count" data-count-for="ecommerce"></span>
        </button>
        <button class="pf-chip" type="button" role="tab" aria-selected="false" data-filter="web-app">
          Web App <span class="pf-count" data-count-for="web-app"></span>
        </button>
        <button class="pf-chip" type="button" role="tab" aria-selected="false" data-filter="marketing">
          Marketing <span class="pf-count" data-count-for="marketing"></span>
        </button>
      </div>

      <div class="portfolio-grid" data-reveal-children>

        <article class="project-card pf-item" data-category="web-design">
          <a href="#" class="project-cover ph-1" aria-label="Pergola Plus Florida — Outdoor Living">
            <span class="project-name">Pergola Plus Florida</span>
            <span class="pf-hover">
              <span class="btn is-secondary is-sm">Preview Website</span>
            </span>
          </a>
          <div class="project-body">
            <p class="project-sector"><span class="pf-tag" data-tag="web-design">Web Design</span></p>
            <p>Outdoor living brand site with quote request flow, gallery, and local SEO across South Florida.</p>
          </div>
        </article>

        <article class="project-card pf-item" data-category="web-design">
          <a href="#" class="project-cover ph-2" aria-label="Lake Scaping LLC">
            <span class="project-name">Lake Scaping LLC</span>
            <span class="pf-hover">
              <span class="btn is-secondary is-sm">Preview Website</span>
            </span>
          </a>
          <div class="project-body">
            <p class="project-sector"><span class="pf-tag" data-tag="web-design">Web Design</span></p>
            <p>Landscaping company site with service-area pages, before/after gallery, and CRM-bound lead workflow.</p>
          </div>
        </article>

        <article class="project-card pf-item" data-category="web-design">
          <a href="#" class="project-cover ph-3" aria-label="AB Aluminum & Screens">
            <span class="project-name">AB Aluminum &amp; Screens</span>
            <span class="pf-hover">
              <span class="btn is-secondary is-sm">Preview Website</span>
            </span>
          </a>
          <div class="project-body">
            <p class="project-sector"><span class="pf-tag" data-tag="web-design">Web Design</span></p>
            <p>Home improvement contractor site with product showcase, financing CTA, and Google Ads landing pages.</p>
          </div>
        </article>

        <article class="project-card pf-item" data-category="ecommerce">
