---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Pergola Plus Florida — SENAVIA Corp Portfolio · Outdoor Living Brand Site";
const description = "Case study: how SENAVIA Corp built Pergola Plus Florida's outdoor-living brand site — and lifted organic traffic 340%, conversions 82%, and qualified leads 4.2x in 6 months.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/portfolio/pergola-plus-florida"
  jsonLdType="portfolio"
  screenLabel="Project Detail"
>
<style is:global data-recovered>
/* ============================================================
     PORTFOLIO PROJECT DETAIL
     ============================================================ */

  /* ===== HERO ===== */
  .pp-hero {
    position: relative;
    height: 90vh;
    min-height: 640px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 0 0 4rem;
    margin-top: -84px;
  }
  .pp-hero-bg {
    position: absolute;
    inset: -10% 0 -10% 0;
    background: linear-gradient(135deg, #2D7DB8 0%, #33CCCC 50%, #99CC33 100%);
    will-change: transform;
    z-index: 0;
  }
  .pp-hero-bg::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 25% 30%, rgba(255,255,255,0.18) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(0,0,0,0.4) 0%, transparent 60%),
      linear-gradient(180deg, rgba(10,14,38,0.2) 0%, rgba(10,14,38,0.85) 100%);
  }
  .pp-hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.4;
    pointer-events: none;
  }
  .pp-hero .container { position: relative; z-index: 2; padding-top: 6rem; }
  .pp-hero-cat {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--primary, #99cc33);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(153,204,51,0.14);
    border: 1px solid rgba(153,204,51,0.4);
    backdrop-filter: blur(8px);
    margin-bottom: 1.5rem;
  }
  .pp-hero h1 {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 0.98;
    margin: 0 0 1.5rem;
    color: #fff;
    max-width: 900px;
  }
  .pp-hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 24px;
    margin-bottom: 2rem;
    font-size: 14.5px;
    color: rgba(255,255,255,0.85);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: 0.04em;
  }
  .pp-hero-meta .label { color: rgba(255,255,255,0.5); font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; margin-right: 8px; }
  .pp-hero-meta .item { display: flex; align-items: center; gap: 8px; }
  .pp-hero-meta .sep { color: rgba(255,255,255,0.25); }
  .pp-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 22px;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(255,255,255,0.5);
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
    backdrop-filter: blur(8px);
    transition: all .25s ease;
  }
  .pp-btn-outline:hover {
    background: #fff;
    color: #0a0e26;
    border-color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 12px 30px rgba(255,255,255,0.18);
  }
  .pp-btn-outline svg { width: 16px; height: 16px; }

  /* Scroll cue */
  .pp-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255,255,255,0.5);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .pp-scroll-cue .line {
    width: 1px;
    height: 32px;
    background: linear-gradient(180deg, rgba(255,255,255,0.5), transparent);
    animation: ppScroll 2s ease-in-out infinite;
  }
  @keyframes ppScroll {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; }
    50%      { transform: scaleY(1); transform-origin: top; }
  }

  /* ===== OVERVIEW ===== */
  .pp-overview {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 980px) { .pp-overview { grid-template-columns: 1fr; gap: 32px; } }

  .pp-overview-copy .eyebrow { margin-bottom: 14px; }
  .pp-overview-copy h2 {
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .pp-overview-copy p {
    font-size: 16.5px;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    max-width: 56ch;
    margin: 0 0 1.25rem;
  }

  .pp-kpis {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .pp-kpi {
    padding: 1.5rem 1.25rem;
    background:
      linear-gradient(180deg, rgba(13,18,53,0.7), rgba(11,15,35,0.55)) padding-box,
      linear-gradient(160deg, rgba(153,204,51,0.32), rgba(255,255,255,0.04) 50%, rgba(51,204,204,0.16)) border-box;
    border: 1px solid transparent;
    border-radius: 16px;
    backdrop-filter: blur(10px);
  }
  .pp-kpi .num {
    font-size: clamp(1.875rem, 3.6vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #fff;
    background: linear-gradient(135deg, #fff 0%, #99CC33 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    display: block;
    margin-bottom: 6px;
  }
  .pp-kpi .lbl {
    font-size: 12.5px;
    color: rgba(255,255,255,0.6);
    line-height: 1.45;
  }

  /* ===== CHALLENGE / SOLUTION / RESULT ===== */
  .pp-csr {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .pp-csr-block {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 48px;
    padding: 2.5rem 0;
    border-bottom: 1px dashed rgba(255,255,255,0.08);
  }
  .pp-csr-block:last-child { border-bottom: 0; }
  @media (max-width: 820px) { .pp-csr-block { grid-template-columns: 1fr; gap: 18px; } }

  .pp-csr-tag {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .pp-csr-tag .step {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--primary, #99cc33);
  }
  .pp-csr-tag .name {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pp-csr-body h2 {
    margin: 0 0 1rem;
    font-size: clamp(1.5rem, 2.8vw, 2.125rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .pp-csr-body p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255,255,255,0.72);
    max-width: 64ch;
    margin: 0 0 1rem;
  }
  .pp-csr-body p:last-child { margin-bottom: 0; }

  /* ===== GALLERY ===== */
  .pp-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  @media (max-width: 720px) { .pp-gallery { grid-template-columns: 1fr; } }
  .pp-shot {
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.08);
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
    transition: transform .35s cubic-bezier(.2,.6,.2,1), box-shadow .25s ease;
  }
  .pp-shot:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.4);
  }
  .pp-shot.full { grid-column: 1 / -1; aspect-ratio: 21 / 9; }
  .pp-shot.bg-1 { background: linear-gradient(135deg, #2D7DB8 0%, #33CCCC 100%); }
  .pp-shot.bg-2 { background: linear-gradient(135deg, #2A7B4F 0%, #99CC33 100%); }
  .pp-shot.bg-3 { background: linear-gradient(135deg, #7B3FE4 0%, #C13B8A 100%); }
  .pp-shot.bg-4 { background: linear-gradient(135deg, #D14F8C 0%, #F0A050 100%); }
  .pp-shot.bg-5 { background: linear-gradient(135deg, #1E5A82 0%, #99CC33 100%); }
  .pp-shot.bg-6 { background: linear-gradient(135deg, #4A3F8E 0%, #33CCCC 100%); }
  .pp-shot::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 65%, rgba(10,14,38,0.45) 100%);
  }
  .pp-shot .pp-shot-label {
    position: absolute;
    bottom: 18px; left: 18px;
    z-index: 2;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    padding: 5px 10px;
    border-radius: 6px;
    background: rgba(10,14,38,0.65);
    backdrop-filter: blur(6px);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  /* Phone frame for mobile shots */
  .pp-shot.mobile {
    aspect-ratio: 9 / 16;
    max-width: 280px;
    margin: 0 auto;
    border-radius: 28px;
    padding: 8px;
    background: linear-gradient(180deg, #1a1f44 0%, #0d1235 100%);
    border: 1px solid rgba(255,255,255,0.12);
  }
  .pp-shot.mobile .pp-mobile-screen {
    width: 100%; height: 100%;
    border-radius: 22px;
    overflow: hidden;
    position: relative;
  }
  .pp-shot.mobile .pp-mobile-screen::before {
    content: '';
    position: absolute;
    top: 8px; left: 50%; transform: translateX(-50%);
    width: 80px; height: 20px;
    background: #0a0e26;
    border-radius: 0 0 12px 12px;
    z-index: 3;
  }
  .pp-mobile-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin: 18px 0 0;
  }
  @media (max-width: 720px) { .pp-mobile-row { grid-template-columns: 1fr; } }

  /* ===== TECH STACK ===== */
  .pp-tech-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
    align-items: center;
  }
  @media (max-width: 980px) { .pp-tech-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 580px) { .pp-tech-grid { grid-template-columns: repeat(3, 1fr); } }

  .pp-tech {
    aspect-ratio: 5 / 2;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.55);
    filter: grayscale(1);
    opacity: 0.85;
    transition: all .25s ease;
    padding: 0 1rem;
  }
  .pp-tech:hover {
    filter: grayscale(0);
    opacity: 1;
    color: #fff;
    border-color: rgba(153,204,51,0.32);
    transform: translateY(-2px);
  }
  .pp-tech-mark {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .pp-tech-mark .ic {
    width: 22px; height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .pp-tech-mark .ic svg { width: 100%; height: 100%; }
  .pp-tech-mark .name {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.005em;
    white-space: nowrap;
  }

  /* ===== PREV / NEXT NAV ===== */
  .pp-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media (max-width: 720px) { .pp-nav { grid-template-columns: 1fr; } }
  .pp-nav-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 1.75rem 1.75rem;
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition: all .25s ease;
    position: relative;
    overflow: hidden;
    min-height: 140px;
  }
  .pp-nav-card:hover {
    border-color: rgba(153,204,51,0.4);
    background: rgba(20,28,60,0.65);
    transform: translateY(-3px);
  }
  .pp-nav-card.next { text-align: right; align-items: flex-end; }
  .pp-nav-card .dir {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .pp-nav-card.next .dir { flex-direction: row-reverse; }
  .pp-nav-card .dir svg { width: 14px; height: 14px; transition: transform .2s ease; }
  .pp-nav-card:hover .dir svg { transform: translateX(-3px); color: var(--primary, #99cc33); }
  .pp-nav-card.next:hover .dir svg { transform: translateX(3px); }
  .pp-nav-card h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.005em;
    text-transform: none;
  }
  .pp-nav-card:hover h3 { color: var(--primary, #99cc33); }
  .pp-nav-card .sector {
    font-size: 12.5px;
    color: rgba(255,255,255,0.5);
  }
</style>

<main>

  <!-- ============================================================
       HERO — Full-width with parallax cover
       ============================================================ -->
  <section class="pp-hero" data-screen-label="01 Project Hero">
    <div class="pp-hero-bg" id="ppParallax"></div>
    <div class="container">
      <span class="pp-hero-cat">Web Design · Outdoor Living</span>
      <h1>Pergola Plus Florida</h1>
      <div class="pp-hero-meta">
        <span class="item"><span class="label">Client</span>Pergola Plus Florida LLC</span>
        <span class="sep">·</span>
        <span class="item"><span class="label">Year</span>2025</span>
        <span class="sep">·</span>
        <span class="item"><span class="label">Stack</span>Webflow + GA4</span>
      </div>
      <a href="https://pergolaplusflorida.com" target="_blank" rel="noopener" class="pp-btn-outline">
        Visit live site
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>
    </div>
    <div class="pp-scroll-cue">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- ============================================================
       OVERVIEW — Paragraph + KPI grid
       ============================================================ -->
  <section class="section" data-screen-label="02 Project Overview">
    <div class="container">
      <div class="pp-overview" data-reveal>
        <div class="pp-overview-copy">
          <div class="eyebrow">Project overview</div>
          <h2>Re-platforming an outdoor-living brand for the South Florida boom.</h2>
          <p>Pergola Plus Florida came to SENAVIA with a fragmented WordPress site that ranked nowhere, loaded slowly, and lost most quote requests to friction at the form. They needed a complete rebuild — brand, IA, conversion architecture, and local SEO — engineered to capture the wave of outdoor-living demand sweeping Miami-Dade and Broward in 2024.</p>
          <p>We delivered a Webflow build with a custom CMS for project galleries, a multi-step quote flow tied to their CRM, and a 12-page local SEO structure with service-area schema across every key Broward city. Six months post-launch, the numbers tell the story.</p>
        </div>
        <div class="pp-kpis" data-reveal-children>
          <div class="pp-kpi"><span class="num">+340%</span><span class="lbl">Organic traffic vs prior 6 months</span></div>
          <div class="pp-kpi"><span class="num">+82%</span><span class="lbl">Quote-form conversion rate</span></div>
          <div class="pp-kpi"><span class="num">4.2×</span><span class="lbl">Qualified leads per month</span></div>
          <div class="pp-kpi"><span class="num">98</span><span class="lbl">Mobile PageSpeed score</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHALLENGE / SOLUTION / RESULT
       ============================================================ -->
  <section class="section" data-screen-label="03 Challenge Solution Result">
    <div class="container">
      <div class="pp-csr">

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">01 /</span>
            <span class="name">Challenge</span>
          </div>
          <div class="pp-csr-body">
            <h2>An outdated stack and a leaky funnel.</h2>
            <p>The legacy WordPress site loaded in over 6 seconds on mobile, had no structured data, and routed quote requests through a generic plugin that lost 40% of submissions to spam filters. Worse, the brand was visually indistinguishable from every other pergola installer in the market.</p>
            <p>Their team had no way to publish project case studies without breaking the design, and Google Ads campaigns were burning budget on landing pages that didn't match the ad creative or load fast enough to rank.</p>
          </div>
        </div>

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">02 /</span>
            <span class="name">Solution</span>
          </div>
          <div class="pp-csr-body">
            <h2>A full Webflow rebuild engineered around the buyer.</h2>
            <p>We rebuilt the site from scratch in Webflow with a custom CMS for projects, a multi-step quote flow with conditional logic, and a local SEO architecture: dedicated service-area pages for the top 8 Broward cities, FAQ schema on every page, and review markup pulled live from Google.</p>
            <p>Design-wise we leaned into the outdoor-living moment — large-scale imagery, generous whitespace, and a confident dark palette with citrus accents. Every page was built around a single conversion goal, with copy and imagery tested against control over 8 weeks.</p>
          </div>
        </div>

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">03 /</span>
            <span class="name">Result</span>
          </div>
          <div class="pp-csr-body">
            <h2>Pipeline that moves — and a team that can ship.</h2>
            <p>Six months post-launch, organic traffic is up 340%, the quote-form conversion rate climbed from 1.8% to 3.3%, and qualified monthly leads jumped from ~22 to 92. The Google Ads program now profitably scales because the landing-page experience finally matches the offer.</p>
            <p>Just as importantly, the Pergola Plus team can publish new projects, edit copy, and roll out new service areas without us — the CMS we shipped pays for itself every week they don't need to file a change request.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       GALLERY
       ============================================================ -->
  <section class="section" style="padding-top: 1rem;" data-screen-label="04 Gallery">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Selected screens</div>
        <h2>Inside the build</h2>
        <p>A few moments from the homepage, service-area pages, project gallery, and the quote-flow we shipped.</p>
      </div>

      <div class="pp-gallery" data-reveal-children>
        <div class="pp-shot full bg-1">
          <span class="pp-shot-label">Homepage hero</span>
        </div>
        <div class="pp-shot bg-2">
          <span class="pp-shot-label">Service-area page</span>
        </div>
        <div class="pp-shot bg-3">
          <span class="pp-shot-label">Project gallery</span>
        </div>
        <div class="pp-shot full bg-5">
          <span class="pp-shot-label">Quote flow · step 2</span>
        </div>
        <div class="pp-shot bg-4">
          <span class="pp-shot-label">Materials selector</span>
        </div>
        <div class="pp-shot bg-6">
          <span class="pp-shot-label">CMS — project detail</span>
        </div>
      </div>

      <div class="pp-mobile-row" data-reveal-children>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #2D7DB8, #33CCCC);"></div>
        </div>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #1E5A82, #99CC33);"></div>
        </div>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #7B3FE4, #C13B8A);"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TECH STACK
       ============================================================ -->
  <section class="section" data-screen-label="05 Tech Stack">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Built with</div>
        <h2>Technologies used</h2>
        <p>A focused stack that prioritized speed, editability, and measurable conversion — no over-engineered surprises.</p>
      </div>
      <div class="pp-tech-grid" data-reveal-children>
