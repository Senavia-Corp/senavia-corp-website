---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Pergola Plus Florida — SENAVIA Corp Portfolio · Outdoor Living Brand Site";
const description = "Case study: how SENAVIA Corp built Pergola Plus Florida's outdoor-living brand site — and lifted organic traffic 340%, conversions 82%, and qualified leads 4.2x in 6 months.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/portfolio/pergola-plus-florida"
  jsonLdType="portfolio"
  screenLabel="Project Detail"
>
<main>

  <!-- ============================================================
       HERO — Full-width with parallax cover
       ============================================================ -->
  <section class="pp-hero" data-screen-label="01 Project Hero">
    <div class="pp-hero-bg" id="ppParallax"></div>
    <div class="container">
      <span class="pp-hero-cat">Web Design · Outdoor Living</span>
      <h1>Pergola Plus Florida</h1>
      <div class="pp-hero-meta">
        <span class="item"><span class="label">Client</span>Pergola Plus Florida LLC</span>
        <span class="sep">·</span>
        <span class="item"><span class="label">Year</span>2025</span>
        <span class="sep">·</span>
        <span class="item"><span class="label">Stack</span>Webflow + GA4</span>
      </div>
      <a href="https://pergolaplusflorida.com" target="_blank" rel="noopener" class="pp-btn-outline">
        Visit live site
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>
    </div>
    <div class="pp-scroll-cue">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- ============================================================
       OVERVIEW — Paragraph + KPI grid
       ============================================================ -->
  <section class="section" data-screen-label="02 Project Overview">
    <div class="container">
      <div class="pp-overview" data-reveal>
        <div class="pp-overview-copy">
          <div class="eyebrow">Project overview</div>
          <h2>Re-platforming an outdoor-living brand for the South Florida boom.</h2>
          <p>Pergola Plus Florida came to SENAVIA with a fragmented WordPress site that ranked nowhere, loaded slowly, and lost most quote requests to friction at the form. They needed a complete rebuild — brand, IA, conversion architecture, and local SEO — engineered to capture the wave of outdoor-living demand sweeping Miami-Dade and Broward in 2024.</p>
          <p>We delivered a Webflow build with a custom CMS for project galleries, a multi-step quote flow tied to their CRM, and a 12-page local SEO structure with service-area schema across every key Broward city. Six months post-launch, the numbers tell the story.</p>
        </div>
        <div class="pp-kpis" data-reveal-children>
          <div class="pp-kpi"><span class="num">+340%</span><span class="lbl">Organic traffic vs prior 6 months</span></div>
          <div class="pp-kpi"><span class="num">+82%</span><span class="lbl">Quote-form conversion rate</span></div>
          <div class="pp-kpi"><span class="num">4.2×</span><span class="lbl">Qualified leads per month</span></div>
          <div class="pp-kpi"><span class="num">98</span><span class="lbl">Mobile PageSpeed score</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHALLENGE / SOLUTION / RESULT
       ============================================================ -->
  <section class="section" data-screen-label="03 Challenge Solution Result">
    <div class="container">
      <div class="pp-csr">

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">01 /</span>
            <span class="name">Challenge</span>
          </div>
          <div class="pp-csr-body">
            <h2>An outdated stack and a leaky funnel.</h2>
            <p>The legacy WordPress site loaded in over 6 seconds on mobile, had no structured data, and routed quote requests through a generic plugin that lost 40% of submissions to spam filters. Worse, the brand was visually indistinguishable from every other pergola installer in the market.</p>
            <p>Their team had no way to publish project case studies without breaking the design, and Google Ads campaigns were burning budget on landing pages that didn't match the ad creative or load fast enough to rank.</p>
          </div>
        </div>

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">02 /</span>
            <span class="name">Solution</span>
          </div>
          <div class="pp-csr-body">
            <h2>A full Webflow rebuild engineered around the buyer.</h2>
            <p>We rebuilt the site from scratch in Webflow with a custom CMS for projects, a multi-step quote flow with conditional logic, and a local SEO architecture: dedicated service-area pages for the top 8 Broward cities, FAQ schema on every page, and review markup pulled live from Google.</p>
            <p>Design-wise we leaned into the outdoor-living moment — large-scale imagery, generous whitespace, and a confident dark palette with citrus accents. Every page was built around a single conversion goal, with copy and imagery tested against control over 8 weeks.</p>
          </div>
        </div>

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">03 /</span>
            <span class="name">Result</span>
          </div>
          <div class="pp-csr-body">
            <h2>Pipeline that moves — and a team that can ship.</h2>
            <p>Six months post-launch, organic traffic is up 340%, the quote-form conversion rate climbed from 1.8% to 3.3%, and qualified monthly leads jumped from ~22 to 92. The Google Ads program now profitably scales because the landing-page experience finally matches the offer.</p>
            <p>Just as importantly, the Pergola Plus team can publish new projects, edit copy, and roll out new service areas without us — the CMS we shipped pays for itself every week they don't need to file a change request.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       GALLERY
       ============================================================ -->
  <section class="section" style="padding-top: 1rem;" data-screen-label="04 Gallery">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Selected screens</div>
        <h2>Inside the build</h2>
        <p>A few moments from the homepage, service-area pages, project gallery, and the quote-flow we shipped.</p>
      </div>

      <div class="pp-gallery" data-reveal-children>
        <div class="pp-shot full bg-1">
          <span class="pp-shot-label">Homepage hero</span>
        </div>
        <div class="pp-shot bg-2">
          <span class="pp-shot-label">Service-area page</span>
        </div>
        <div class="pp-shot bg-3">
          <span class="pp-shot-label">Project gallery</span>
        </div>
        <div class="pp-shot full bg-5">
          <span class="pp-shot-label">Quote flow · step 2</span>
        </div>
        <div class="pp-shot bg-4">
          <span class="pp-shot-label">Materials selector</span>
        </div>
        <div class="pp-shot bg-6">
          <span class="pp-shot-label">CMS — project detail</span>
        </div>
      </div>

      <div class="pp-mobile-row" data-reveal-children>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #2D7DB8, #33CCCC);"></div>
        </div>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #1E5A82, #99CC33);"></div>
        </div>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #7B3FE4, #C13B8A);"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TECH STACK
       ============================================================ -->
  <section class="section" data-screen-label="05 Tech Stack">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Built with</div>
        <h2>Technologies used</h2>
        <p>A focused stack that prioritized speed, editability, and measurable conversion — no over-engineered surprises.</p>
      </div>
      <div class="pp-tech-grid" data-reveal-children>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M22 6L18 18l-4-9-3 9-4-12-3 9-2-3H1l3 12 4-9 3 9 3-9 3 9 5-15z" fill="currentColor"/></svg></span><span class="name">Webflow</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" fill="currentColor"/><rect x="14" y="3" width="7" height="7" fill="currentColor"/><rect x="3" y="14" width="7" height="7" fill="currentColor"/><circle cx="17.5" cy="17.5" r="3.5" fill="currentColor"/></svg></span><span class="name">Figma</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 3v18M3 12h18" stroke="currentColor" stroke-width="2"/></svg></span><span class="name">GA4</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M3 17l6-6 4 4 8-8" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 7 21 7 21 14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg></span><span class="name">GTM</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M12 2l3 7h7l-5.5 4.5 2 7.5L12 17l-6.5 4 2-7.5L2 9h7z" fill="currentColor"/></svg></span><span class="name">Cloudflare</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 9h18M8 14h2M8 17h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span><span class="name">HubSpot</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M4 4h16v16H4z" stroke="currentColor" stroke-width="2"/><path d="M9 9l3 3 3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="name">Klaviyo</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span><span class="name">Calendly</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M3 12l4-7h10l4 7-9 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg></span><span class="name">Lottie</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 3a9 9 0 0 0 0 18" stroke="currentColor" stroke-width="2"/></svg></span><span class="name">Hotjar</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="6" width="16" height="12" rx="2" stroke="currentColor" stroke-width="2"/><path d="M4 10h16" stroke="currentColor" stroke-width="2"/></svg></span><span class="name">Stripe</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M4 8l8-5 8 5v8l-8 5-8-5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg></span><span class="name">Sentry</span></span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PREV / NEXT NAV
       ============================================================ -->
  <section class="section" data-screen-label="06 Project Nav">
    <div class="container">
      <div class="pp-nav" data-reveal>
        <a href="/lake-scaping" class="pp-nav-card prev">
          <span class="dir">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
            Previous project
          </span>
          <h3>Lake Scaping LLC</h3>
          <span class="sector">Landscaping · Lead Generation</span>
        </a>
        <a href="/ab-aluminum" class="pp-nav-card next">
          <span class="dir">
            Next project
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </span>
          <h3>AB Aluminum &amp; Screens</h3>
          <span class="sector">Home Improvement · Webflow</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="07 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="../assets/videos/cta-bg-poster.jpg">
      <source src="../assets/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2>Like What You See? Let's Talk.</h2>
      <p>Schedule your free 30-minute consultation and we'll plan a project worth showcasing.</p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>

<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el) return;
    function init() {
      if (!window.Calendly) { setTimeout(init, 200); return; }
      window.Calendly.initInlineWidget({
        url: 'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon?hide_landing_page_details=1&hide_gdpr_banner=1&background_color=0a0e26&text_color=ffffff&primary_color=99cc33',
        parentElement: el,
        prefill: {}, utm: {}
      });
      // Mark loaded after a beat
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    init();
  })();
</script>

<!-- Language switcher -->

<!-- Hero parallax -->
<script>
  (function(){
    var bg = document.getElementById('ppParallax');
    if (!bg) return;
    var ticking = false;
    function update() {
      var y = window.scrollY;
      var rect = bg.parentElement.getBoundingClientRect();
      // only animate while hero is visible-ish
      if (rect.bottom > 0) {
        bg.style.transform = 'translate3d(0,' + (y * 0.35) + 'px, 0) scale(1.05)';
      }
      ticking = false;
    }
    window.addEventListener('scroll', function(){
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
    update();
  })();
</script>
</BaseLayout>
