---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "ANGELE GLOW — SENAVIA Corp Portfolio · Skincare Shopify E-commerce";
const description = "Case study: how SENAVIA Corp built ANGELE GLOW's Shopify storefront in Brickell, Miami — lifting online revenue 218%, average order value 64%, and subscriber retention 3.1x in 6 months.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/portfolio/angele-glow"
  jsonLdType="portfolio"
  screenLabel="Project Detail · ANGELE GLOW"
>
<main>

  <!-- ============================================================
       HERO — Full-width with parallax cover
       ============================================================ -->
  <section class="pp-hero" data-screen-label="01 Project Hero">
    <div class="pp-hero-bg" id="ppParallax" style="background: linear-gradient(135deg, #7B3FE4 0%, #C13B8A 55%, #F0A050 100%);"></div>
    <div class="container">
      <span class="pp-hero-cat">Web Design · Skincare E-commerce</span>
      <h1>ANGELE GLOW</h1>
      <div class="pp-hero-meta">
        <span class="item"><span class="label">Client</span>Angele Glow Skincare Co.</span>
        <span class="sep">·</span>
        <span class="item"><span class="label">Year</span>2025</span>
        <span class="sep">·</span>
        <span class="item"><span class="label">Stack</span>Shopify + Klaviyo</span>
      </div>
      <a href="https://angeleglow.com" target="_blank" rel="noopener" class="pp-btn-outline">
        Visit live site
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>
    </div>
    <div class="pp-scroll-cue">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- ============================================================
       OVERVIEW — Paragraph + KPI grid
       ============================================================ -->
  <section class="section" data-screen-label="02 Project Overview">
    <div class="container">
      <div class="pp-overview" data-reveal>
        <div class="pp-overview-copy">
          <div class="eyebrow">Project overview</div>
          <h2>Turning a beloved Brickell skincare line into a subscription engine.</h2>
          <p>ANGELE GLOW had a cult following at pop-ups and spas across Miami, but their online store was an afterthought — a templated Shopify theme with slow product pages, no subscription option, and a checkout that bled customers on mobile. They needed a storefront that felt as premium as the product and turned one-time buyers into recurring revenue.</p>
          <p>We rebuilt the store on Shopify with a custom theme, a subscription-and-bundle model powered by Klaviyo flows, and a bilingual EN/ES shopping experience tuned for Miami's beauty buyer. Six months post-launch, the storefront finally matches the brand — and the numbers compounded.</p>
        </div>
        <div class="pp-kpis" data-reveal-children>
          <div class="pp-kpi"><span class="num">+218%</span><span class="lbl">Online revenue vs prior 6 months</span></div>
          <div class="pp-kpi"><span class="num">+64%</span><span class="lbl">Average order value</span></div>
          <div class="pp-kpi"><span class="num">3.1×</span><span class="lbl">Subscriber retention rate</span></div>
          <div class="pp-kpi"><span class="num">96</span><span class="lbl">Mobile PageSpeed score</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHALLENGE / SOLUTION / RESULT
       ============================================================ -->
  <section class="section" data-screen-label="03 Challenge Solution Result">
    <div class="container">
      <div class="pp-csr">

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">01 /</span>
            <span class="name">Challenge</span>
          </div>
          <div class="pp-csr-body">
            <h2>A premium product trapped in a templated store.</h2>
            <p>The off-the-shelf Shopify theme loaded product pages in over 5 seconds on mobile, offered no subscribe-and-save option, and forced a clunky three-step checkout that abandoned at nearly 80%. The brand photography was gorgeous, but the storefront flattened it into a generic grid that looked like every other indie skincare shop.</p>
            <p>There was no retention engine either — no post-purchase flows, no win-back emails, and no bundling — so a loyal Miami customer base was buying once and disappearing instead of subscribing.</p>
          </div>
        </div>

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">02 /</span>
            <span class="name">Solution</span>
          </div>
          <div class="pp-csr-body">
            <h2>A custom Shopify storefront built around repeat purchase.</h2>
            <p>We designed and built a custom Shopify theme from scratch — editorial product pages with full-bleed imagery, a one-page accelerated checkout, and a subscribe-and-save model with bundle builders for routines. Klaviyo powers the retention layer: welcome, post-purchase, replenishment, and win-back flows, all in EN and ES.</p>
            <p>Design-wise we leaned into the brand's warm, luminous palette — soft gradients, generous whitespace, and confident typography — so the store feels like the product. Every template was tested against control over an 8-week conversion sprint.</p>
          </div>
        </div>

        <div class="pp-csr-block" data-reveal>
          <div class="pp-csr-tag">
            <span class="step">03 /</span>
            <span class="name">Result</span>
          </div>
          <div class="pp-csr-body">
            <h2>Revenue that recurs — and a brand that finally scales.</h2>
            <p>Six months post-launch, online revenue is up 218%, average order value climbed 64% on the back of bundles, and subscriber retention more than tripled. Mobile checkout abandonment dropped from ~80% to 51%, and the storefront now sustains a profitable paid-social program because the experience finally matches the ad.</p>
            <p>The ANGELE GLOW team manages products, drops, and bundles themselves inside Shopify, while Klaviyo flows quietly compound retention every week — turning a pop-up favorite into a real direct-to-consumer business.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       GALLERY
       ============================================================ -->
  <section class="section" style="padding-top: 1rem;" data-screen-label="04 Gallery">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Selected screens</div>
        <h2>Inside the build</h2>
        <p>A few moments from the homepage, product detail pages, the bundle builder, and the subscribe-and-save checkout we shipped.</p>
      </div>

      <div class="pp-gallery" data-reveal-children>
        <div class="pp-shot full bg-3">
          <span class="pp-shot-label">Homepage hero</span>
        </div>
        <div class="pp-shot bg-4">
          <span class="pp-shot-label">Product detail page</span>
        </div>
        <div class="pp-shot bg-1">
          <span class="pp-shot-label">Bundle builder</span>
        </div>
        <div class="pp-shot full bg-6">
          <span class="pp-shot-label">Subscribe &amp; save · checkout</span>
        </div>
        <div class="pp-shot bg-5">
          <span class="pp-shot-label">Collection grid</span>
        </div>
        <div class="pp-shot bg-2">
          <span class="pp-shot-label">Klaviyo email flow</span>
        </div>
      </div>

      <div class="pp-mobile-row" data-reveal-children>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #7B3FE4, #C13B8A);"></div>
        </div>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #C13B8A, #F0A050);"></div>
        </div>
        <div class="pp-shot mobile">
          <div class="pp-mobile-screen" style="background: linear-gradient(180deg, #4A3F8E, #C13B8A);"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TECH STACK
       ============================================================ -->
  <section class="section" data-screen-label="05 Tech Stack">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">Built with</div>
        <h2>Technologies used</h2>
        <p>A focused commerce stack that prioritized speed, recurring revenue, and editable merchandising — no over-engineered surprises.</p>
      </div>
      <div class="pp-tech-grid" data-reveal-children>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M15.3 4.2c-.2 0-2.6.1-2.6.1s-1.7-1.7-1.9-1.9c-.2-.2-.6-.1-.7-.1l-.9 18.4 7.6-1.6-1.5-14.9zM12 5.6c-.5.1-1 .3-1.5.5 0-.9-.2-1.8-.7-2.4.9.1 1.6 1.1 2 1.9z" fill="currentColor"/><path d="M5.9 6.4l1.3-.1 1.7 12.9-5.4 1.1 2.4-13.9z" fill="currentColor"/></svg></span><span class="name">Shopify</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" fill="currentColor"/><rect x="14" y="3" width="7" height="7" fill="currentColor"/><rect x="3" y="14" width="7" height="7" fill="currentColor"/><circle cx="17.5" cy="17.5" r="3.5" fill="currentColor"/></svg></span><span class="name">Figma</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M4 4h16v16H4z" stroke="currentColor" stroke-width="2"/><path d="M9 9l3 3 3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="name">Klaviyo</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 3v18M3 12h18" stroke="currentColor" stroke-width="2"/></svg></span><span class="name">GA4</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><rect x="4" y="6" width="16" height="12" rx="2" stroke="currentColor" stroke-width="2"/><path d="M4 10h16" stroke="currentColor" stroke-width="2"/></svg></span><span class="name">Stripe</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M3 17l6-6 4 4 8-8" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 7 21 7 21 14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg></span><span class="name">GTM</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M12 2l3 7h7l-5.5 4.5 2 7.5L12 17l-6.5 4 2-7.5L2 9h7z" fill="currentColor"/></svg></span><span class="name">Cloudflare</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 3a9 9 0 0 0 0 18" stroke="currentColor" stroke-width="2"/></svg></span><span class="name">Hotjar</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M3 12l4-7h10l4 7-9 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg></span><span class="name">Lottie</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span><span class="name">Calendly</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 9h18M8 14h2M8 17h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span><span class="name">Gorgias</span></span></div>
        <div class="pp-tech"><span class="pp-tech-mark"><span class="ic"><svg viewBox="0 0 24 24" fill="none"><path d="M4 8l8-5 8 5v8l-8 5-8-5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg></span><span class="name">Sentry</span></span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PREV / NEXT NAV
       ============================================================ -->
  <section class="section" data-screen-label="06 Project Nav">
    <div class="container">
      <div class="pp-nav" data-reveal>
        <a href="/pergola-plus-florida" class="pp-nav-card prev">
          <span class="dir">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg>
            Previous project
          </span>
          <h3>Pergola Plus Florida</h3>
          <span class="sector">Outdoor Living · Webflow</span>
        </a>
        <a href="/lake-scaping" class="pp-nav-card next">
          <span class="dir">
            Next project
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </span>
          <h3>Lake Scaping LLC</h3>
          <span class="sector">Landscaping · Lead Generation</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta" data-screen-label="07 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="../assets/videos/cta-bg-poster.jpg">
      <source src="../assets/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2>Like What You See? Let's Build Your Store.</h2>
      <p>Schedule your free 30-minute consultation and we'll plan a Shopify build worth showcasing.</p>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>

<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el) return;
    function init() {
      if (!window.Calendly) { setTimeout(init, 200); return; }
      window.Calendly.initInlineWidget({
        url: 'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon?hide_landing_page_details=1&hide_gdpr_banner=1&background_color=0a0e26&text_color=ffffff&primary_color=99cc33',
        parentElement: el,
        prefill: {}, utm: {}
      });
      // Mark loaded after a beat
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    init();
  })();
</script>

<!-- Language switcher -->

<!-- Hero parallax -->
<script>
  (function(){
    var bg = document.getElementById('ppParallax');
    if (!bg) return;
    var ticking = false;
    function update() {
      var y = window.scrollY;
      var rect = bg.parentElement.getBoundingClientRect();
      // only animate while hero is visible-ish
      if (rect.bottom > 0) {
        bg.style.transform = 'translate3d(0,' + (y * 0.35) + 'px, 0) scale(1.05)';
      }
      ticking = false;
    }
    window.addEventListener('scroll', function(){
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
    update();
  })();
</script>
</BaseLayout>
