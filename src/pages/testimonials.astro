          <div class="gr-author">
            <span class="gr-avatar a4" aria-hidden="true">SA</span>
            <div class="gr-author-info">
              <span class="gr-author-name">Sofía Alvarez</span>
              <span class="gr-author-date">5 weeks ago</span>
            </div>
          </div>
        </article>

        <article class="gr-card">
          <span class="gr-quote" aria-hidden="true">"</span>
