---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = "Testimonials — SENAVIA Corp · Video Reviews from South Florida Clients";
const description = "Hear directly from South Florida business owners SENAVIA Corp has worked with. Video testimonials and Google Reviews from contractors, e-commerce brands, and service businesses.";
---
<BaseLayout
  title={title}
  description={description}
  canonical="/testimonials"
  jsonLdType="home"
  screenLabel="Testimonials"
>
<main>

  <!-- ============================================================
       HERO — Compact
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 Testimonials Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="auto"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/hero-home-poster.jpg">
      <source src="/videos/hero-home.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;">Real clients · Real results</div>
      <h1>Testimonial Videos</h1>
      <p>Hear directly from South Florida business owners we've worked with.</p>
    </div>
  </section>

  <!-- ============================================================
       VIDEO TESTIMONIAL GRID
       ============================================================ -->
  <section class="section" data-screen-label="02 Video Testimonials">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow">In their words</div>
        <h2>Voices Behind the Projects</h2>
        <p>Eight clients across web design, e-commerce, custom apps, and marketing — sharing what changed after working with SENAVIA.</p>
      </div>
      <div class="vt-grid" data-reveal-children>
        
        <article class="vt-card" tabindex="0" role="button" aria-label="Play video testimonial from Carlos Rivera, Pergola Plus Florida">
          <div class="vt-thumb bg-1">
            <span class="vt-play" aria-hidden="true">
              <span><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg></span>
            </span>
            <span class="vt-duration">2:14</span>
          </div>
          <div class="vt-meta">
            <h3 class="vt-name">Carlos Rivera</h3>
            <span class="vt-business">Pergola Plus Florida</span>
            <span class="vt-tag" data-tag="web-design">Web Design</span>
          </div>
        </article>

        <article class="vt-card" tabindex="0" role="button" aria-label="Play video testimonial from Maria Gonzalez, ANGELE GLOW Skincare">
          <div class="vt-thumb bg-4">
            <span class="vt-play" aria-hidden="true">
              <span><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg></span>
            </span>
            <span class="vt-duration">1:48</span>
          </div>
          <div class="vt-meta">
            <h3 class="vt-name">Maria Gonzalez</h3>
            <span class="vt-business">ANGELE GLOW Skincare</span>
            <span class="vt-tag" data-tag="ecommerce">E-commerce</span>
          </div>
        </article>

        <article class="vt-card" tabindex="0" role="button" aria-label="Play video testimonial from James Patterson, Mariner Marine">
          <div class="vt-thumb bg-3">
            <span class="vt-play" aria-hidden="true">
              <span><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg></span>
            </span>
            <span class="vt-duration">3:02</span>
          </div>
          <div class="vt-meta">
            <h3 class="vt-name">James Patterson</h3>
            <span class="vt-business">Mariner Marine</span>
            <span class="vt-tag" data-tag="webapp">Web App</span>
          </div>
        </article>

        <article class="vt-card" tabindex="0" role="button" aria-label="Play video testimonial from Sofía Alvarez, Casa Lumière Interiors">
          <div class="vt-thumb bg-7">
            <span class="vt-play" aria-hidden="true">
              <span><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg></span>
            </span>
            <span class="vt-duration">2:36</span>
