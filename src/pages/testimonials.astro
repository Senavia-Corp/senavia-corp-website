---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CALENDLY_URL } from '@/data/site';

const title = "Testimonials — SENAVIA Corp · What Our Clients Say in South Florida";
const description = "Hear from South Florida business owners SENAVIA Corp has worked with — web design, e-commerce, custom apps, and marketing clients across Miami-Dade, Broward, and Palm Beach.";

const testimonials = (await getCollection('testimonials'))
  .sort((a, b) => Number(b.data.rating) - Number(a.data.rating));

// Real video testimonials from the CMS (YouTube)
const videos = (await getCollection('videos'))
  .filter((v) => v.data.youtubeId)
  .sort((a, b) => a.data.order - b.data.order);

const count = testimonials.length;
const avgRating = count
  ? (testimonials.reduce((s, t) => s + Number(t.data.rating), 0) / count)
  : 5;
const avgDisplay = avgRating.toFixed(1);

// Bilingual category labels for the card tag
const catLabel: Record<string, { en: string; es: string }> = {
  'web-design': { en: 'Web Design', es: 'Diseño Web' },
  'ecommerce':  { en: 'E-commerce', es: 'E-commerce' },
  'web-app':    { en: 'Web App',    es: 'Aplicación Web' },
  'marketing':  { en: 'Marketing',  es: 'Marketing' },
};
// data-tag attribute the CSS keys off ("ecommerce" / "webapp" / "marketing")
const catTag: Record<string, string> = {
  'web-design': 'web-design',
  'ecommerce':  'ecommerce',
  'web-app':    'webapp',
  'marketing':  'marketing',
};

// initials for the avatar bubble, derived from the company name
function initials(name: string): string {
  const cleaned = name.replace(/[^A-Za-z0-9 &]/g, ' ').trim();
  const parts = cleaned.split(/\s+/).filter((p) => p && p !== '&');
  if (parts.length === 0) return 'SC';
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return (parts[0][0] + parts[1][0]).toUpperCase();
}

const STAR = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`;
---
<BaseLayout
  title={title}
  description={description}
  canonical="/testimonials"
  jsonLdType="localbusiness"
  screenLabel="Testimonials"
>
<style is:global data-recovered>
/* ============================================================
     TESTIMONIALS PAGE
     ============================================================ */
  .hero.is-compact + .section { padding-top: 4rem; }

  /* Testimonials header (rating summary) */
  .gr-header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .gr-header h2 { margin: 0 0 0.5rem; }
  .gr-header p  { margin: 0; max-width: 540px; }
  .gr-rating {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }
  @media (max-width: 700px) {
    .gr-header { flex-direction: column; align-items: flex-start; }
    .gr-rating { align-items: flex-start; }
  }
  .gr-score {
    font-size: 2.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .gr-score-stars {
    display: inline-flex;
    color: #FBBC05;
    gap: 2px;
  }
  .gr-score-stars svg { width: 22px; height: 22px; }
  .gr-meta {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
  }

  /* Testimonial card grid */
  .gr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 1080px) { .gr-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .gr-grid { grid-template-columns: 1fr; } }

  .gr-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 1.75rem 1.5rem 1.5rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    transition: transform .25s ease, border-color .2s ease, background .2s ease;
    position: relative;
  }
  .gr-card:hover {
    transform: translateY(-3px);
    border-color: rgba(153,204,51,0.32);
    background: rgba(20,28,60,0.55);
  }
  .gr-card .gr-quote {
    position: absolute;
    top: 16px;
    right: 18px;
    font-family: Georgia, serif;
    font-size: 4rem;
    line-height: 1;
    color: rgba(153,204,51,0.18);
    font-weight: 700;
    pointer-events: none;
  }
  .gr-cardtop {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .gr-stars {
    display: inline-flex;
    color: #FBBC05;
    gap: 2px;
  }
  .gr-stars svg { width: 16px; height: 16px; }
  .gr-text {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: rgba(255,255,255,0.78);
    flex: 1;
  }
  .gr-author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 14px;
    border-top: 1px dashed rgba(255,255,255,0.08);
  }
  .gr-avatar {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    flex: 0 0 40px;
  }
  .gr-avatar.a1 { background: linear-gradient(135deg, #7B3FE4, #C13B8A); }
  .gr-avatar.a2 { background: linear-gradient(135deg, #2A7B4F, #99CC33); }
  .gr-avatar.a3 { background: linear-gradient(135deg, #2D7DB8, #33CCCC); }
  .gr-avatar.a4 { background: linear-gradient(135deg, #D14F8C, #F0A050); }
  .gr-avatar.a5 { background: linear-gradient(135deg, #1E5A82, #99CC33); }
  .gr-avatar.a6 { background: linear-gradient(135deg, #4A3F8E, #33CCCC); }
  .gr-author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .gr-author-name {
    font-size: 14px;
    font-weight: 500;
    color: #fff;
  }
  .gr-author-date {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
  }
  /* category tag on each card */
  .gr-tag {
    align-self: flex-start;
    display: inline-block;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(153,204,51,0.14);
    color: var(--primary, #99cc33);
    border: 1px solid rgba(153,204,51,0.28);
  }
  .gr-tag[data-tag="ecommerce"] {
    background: rgba(209,79,140,0.14);
    color: #f48cb6;
    border-color: rgba(209,79,140,0.32);
  }
  .gr-tag[data-tag="marketing"] {
    background: rgba(240,160,80,0.14);
    color: #f6b56e;
    border-color: rgba(240,160,80,0.32);
  }
  .gr-tag[data-tag="webapp"] {
    background: rgba(45,125,184,0.16);
    color: #79c1ee;
    border-color: rgba(45,125,184,0.34);
  }
  /* verified badge */
  .gr-verified {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11.5px;
    color: rgba(255,255,255,0.55);
    margin-left: auto;
  }
  .gr-verified svg { width: 14px; height: 14px; color: var(--primary, #99cc33); }

  .gr-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 2.5rem;
    color: rgba(255,255,255,0.55);
    font-size: 13px;
  }
  .gr-footer svg { width: 18px; height: 18px; }

  /* ===== Video testimonials ===== */
  .vt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 2.5rem;
  }
  @media (max-width: 900px) { .vt-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 620px) { .vt-grid { grid-template-columns: 1fr; } }
  .vt-card {
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    overflow: hidden;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .vt-card:hover {
    transform: translateY(-4px);
    border-color: rgba(153,204,51,0.35);
    box-shadow: 0 20px 50px rgba(0,0,0,0.4);
  }
  .vt-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .vt-frame iframe {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    border: 0; display: block;
  }
  .vt-body { padding: 1.1rem 1.25rem 1.4rem; }
  .vt-name {
    margin: 0 0 .4rem;
    font-size: 1.05rem; font-weight: 600; color: #fff; letter-spacing: -0.005em;
  }
  .vt-summary {
    margin: 0;
    font-size: 13.5px; line-height: 1.55; color: rgba(255,255,255,0.65);
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }
</style>

<main>

  <!-- ============================================================
       HERO — Compact
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 Testimonials Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/bg-video-poster.jpg">
      <source src="/videos/bg-video.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;">
        <span class="lang-only-en">Real clients · Real results</span>
        <span class="lang-only-es">Clientes Reales · Resultados Reales</span>
      </div>
      <h1>
        <span class="lang-only-en">What Our Clients Say</span>
        <span class="lang-only-es">Lo Que Dicen Nuestros Clientes</span>
      </h1>
      <p>
        <span class="lang-only-en">Hear directly from South Florida business owners we've worked with.</span>
        <span class="lang-only-es">Escucha directamente a los dueños de negocios del Sur de Florida con quienes hemos trabajado.</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       TESTIMONIALS GRID (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <section class="section section--band" data-screen-label="02 Testimonials">
      <div class="container">
        <div class="gr-header" data-reveal>
          <div>
            <div class="eyebrow">
              <span class="lang-only-en">Testimonials</span>
              <span class="lang-only-es">Testimonios</span>
            </div>
            <h2>
              <span class="lang-only-en">Trusted by Businesses Across South Florida</span>
              <span class="lang-only-es">La Confianza de Negocios en Todo el Sur de Florida</span>
            </h2>
            <p>
              <span class="lang-only-en">From verified reviews by contractors, e-commerce brands, and service operators we've helped grow across Miami-Dade, Broward, and Palm Beach.</span>
              <span class="lang-only-es">De reseñas verificadas de contratistas, marcas de e-commerce y empresas de servicios que hemos ayudado a crecer en Miami-Dade, Broward y Palm Beach.</span>
            </p>
          </div>
          <div class="gr-rating">
            <div class="gr-score">
              {avgDisplay}
              <span class="gr-score-stars" aria-hidden="true" set:html={STAR.repeat(5)}></span>
            </div>
            <span class="gr-meta">
              <span class="lang-only-en">From <strong>{count} verified reviews</strong></span>
              <span class="lang-only-es">De <strong>{count} reseñas verificadas</strong></span>
            </span>
          </div>
        </div>

        <div class="gr-grid" data-reveal-children>
          {testimonials.map((t) => {
            const d = t.data;
            const tag = catTag[d.category] ?? 'web-design';
            const label = catLabel[d.category] ?? { en: d.category, es: d.category };
            const stars = Math.max(1, Math.min(5, Math.round(Number(d.rating))));
            return (
              <article class="gr-card">
                <span class="gr-quote" aria-hidden="true">&#8220;</span>
                <div class="gr-cardtop">
                  <div class="gr-stars" role="img" aria-label={`${stars} out of 5 stars`} set:html={STAR.repeat(stars)}></div>
                  <span class="gr-verified">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span class="lang-only-en">Verified review</span>
                    <span class="lang-only-es">Reseña Verificada</span>
                  </span>
                </div>
                <span class="gr-tag" data-tag={tag}>
                  <span class="lang-only-en">{label.en}</span>
                  <span class="lang-only-es">{label.es}</span>
                </span>
                <p class="gr-text">
                  <span class="lang-only-en">{d.quote_en}</span>
                  <span class="lang-only-es">{d.quote_es}</span>
                </p>
                <div class="gr-author">
                  <span class={`gr-avatar ${d.avatarClass ?? 'a1'}`} aria-hidden="true">{initials(d.company)}</span>
                  <div class="gr-author-info">
                    <span class="gr-author-name">{d.company}</span>
                    <span class="gr-author-date">{d.date}</span>
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        <div class="gr-footer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.5 12.27c0-.79-.07-1.55-.2-2.27H12v4.3h5.92c-.25 1.37-1.03 2.53-2.2 3.31v2.75h3.56c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.75c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.12A6.6 6.6 0 0 1 5.5 12c0-.74.13-1.45.34-2.12V7.04H2.18A10.97 10.97 0 0 0 1 12c0 1.78.43 3.47 1.18 4.96l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.65l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.04l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
          </svg>
          <span class="lang-only-en">Verified reviews from South Florida clients</span>
          <span class="lang-only-es">Reseñas verificadas de clientes del Sur de Florida</span>
          <a href="https://www.google.com/search?q=senavia+corp+plantation+reviews" target="_blank" rel="noopener" class="btn is-secondary is-sm" style="margin-left: 14px;">
            <span class="lang-only-en">Read All Reviews</span>
            <span class="lang-only-es">Leer Todas las Reseñas</span>
          </a>
        </div>
      </div>
    </section>
  </div>

  {videos.length > 0 && (
  <section class="section section--band vt-section" data-screen-label="03 Video Testimonials">
    <div class="container">
      <div class="section-head" data-reveal>
        <div class="eyebrow"><span class="lang-only-en">In their words</span><span class="lang-only-es">En sus palabras</span></div>
        <h2><span class="lang-only-en">Video Testimonials</span><span class="lang-only-es">Testimonios en Video</span></h2>
        <p><span class="lang-only-en">Real South Florida business owners on what it was like to work with SENAVIA.</span><span class="lang-only-es">Dueños de negocios reales del Sur de Florida sobre cómo fue trabajar con SENAVIA.</span></p>
      </div>
      <div class="vt-grid" data-reveal-children>
        {videos.map((v) => (
          <article class="vt-card">
            <div class="vt-frame">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${v.data.youtubeId}?rel=0`}
                title={v.data.name}
                loading="lazy"
                allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
            <div class="vt-body">
              <h3 class="vt-name">{v.data.name}</h3>
              {v.data.summary && <p class="vt-summary">{v.data.summary}</p>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta cta--glow" data-screen-label="04 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2>
        <span class="lang-only-en">Want to Be Our Next Success Story?</span>
        <span class="lang-only-es">¿Quieres Ser Nuestra Próxima Historia de Éxito?</span>
      </h2>
      <p>
        <span class="lang-only-en">Schedule a 30-minute consultation and let's plan a digital strategy worth talking about.</span>
        <span class="lang-only-es">Agenda una consulta de 30 minutos y planeemos una estrategia digital de la que valga la pena hablar.</span>
      </p>
      <a href="#" class="btn" data-calendly-trigger data-track="book_call_click" onclick={`if(window.Calendly){Calendly.initPopupWidget({url:'${CALENDLY_URL}'});}return false;`}>
        <span class="lang-only-en">Book a Free Call</span>
        <span class="lang-only-es">Agenda una Llamada Gratis</span>
      </a>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>
</BaseLayout>
