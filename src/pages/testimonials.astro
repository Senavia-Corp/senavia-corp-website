        </article>

        <article class="vt-card" tabindex="0" role="button" aria-label="Play video testimonial from Luis Hernández, AB Aluminum & Screens">
          <div class="vt-thumb bg-5">
            <span class="vt-play" aria-hidden="true">
              <span><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg></span>
            </span>
            <span class="vt-duration">1:55</span>
          </div>
          <div class="vt-meta">
            <h3 class="vt-name">Luis Hernández</h3>
            <span class="vt-business">AB Aluminum & Screens</span>
            <span class="vt-tag" data-tag="web-design">Web Design</span>
