<!-- Video modal -->
<div class="vt-modal" id="vtModal" aria-hidden="true" role="dialog" aria-label="Video player">
  <div class="vt-modal-frame">
    <button class="vt-modal-close" id="vtModalClose" type="button" aria-label="Close video">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="6" y1="18" x2="18" y2="6"></line></svg>
    </button>
    <div class="vt-modal-placeholder" id="vtModalContent">Video placeholder — embed your testimonial here</div>
  </div>
</div>

<!-- Initialize Calendly inline widget once the script loads -->
<script>
  (function(){
    var el = document.getElementById('calendlyInline');
    if (!el) return;
    function init() {
      if (!window.Calendly) { setTimeout(init, 200); return; }
      window.Calendly.initInlineWidget({
        url: 'https://calendly.com/leads-senaviacorp/30-minute-meeting-clon?hide_landing_page_details=1&hide_gdpr_banner=1&background_color=0a0e26&text_color=ffffff&primary_color=99cc33',
        parentElement: el,
        prefill: {}, utm: {}
      });
      // Mark loaded after a beat
      setTimeout(function(){ el.classList.add('is-loaded'); }, 1200);
    }
    init();
  })();
</script>

<!-- Language switcher -->

<!-- Video testimonial modal -->
<script>
  (function(){
    var modal = document.getElementById('vtModal');
    var closeBtn = document.getElementById('vtModalClose');
    var content = document.getElementById('vtModalContent');
    if (!modal) return;
    var cards = document.querySelectorAll('.vt-card');
    function open(card){
      var label = card.getAttribute('aria-label') || 'Video testimonial';
      content.textContent = label.replace(/^Play video testimonial from /, '') + ' — Video placeholder';
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function close(){
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    cards.forEach(function(c){
      c.addEventListener('click', function(){ open(c); });
      c.addEventListener('keydown', function(e){
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(c); }
      });
    });
    closeBtn.addEventListener('click', close);
    modal.addEventListener('click', function(e){ if (e.target === modal) close(); });
    document.addEventListener('keydown', function(e){ if (e.key === 'Escape') close(); });
  })();
</script>
</BaseLayout>
