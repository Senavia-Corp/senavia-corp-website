---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = "Testimonials — SENAVIA Corp · What Our Clients Say in South Florida";
const description = "Hear from South Florida business owners SENAVIA Corp has worked with — real video testimonials from web design, e-commerce, and custom app clients.";

// Real video testimonials from the CMS (YouTube)
const videos = (await getCollection('videos'))
  .filter((v) => v.data.youtubeId)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title={title}
  description={description}
  canonical="/testimonials"
  jsonLdType="localbusiness"
  screenLabel="Testimonials"
>
<style is:global data-recovered>
/* ============================================================
     TESTIMONIALS PAGE
     ============================================================ */
  .hero.is-compact + .section { padding-top: 4rem; }

  /* ===== Video testimonials ===== */
  .vt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 2.5rem;
  }
  @media (max-width: 900px) {
    .vt-grid { grid-template-columns: 1fr 1fr; }
    /* odd counts: let the last card span the row instead of orphaning */
    .vt-grid > :last-child:nth-child(odd) { grid-column: 1 / -1; }
  }
  @media (max-width: 620px) { .vt-grid { grid-template-columns: 1fr; } }
  .vt-card {
    background: rgba(13,18,53,0.55);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    overflow: hidden;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .vt-card:hover {
    transform: translateY(-4px);
    border-color: rgba(153,204,51,0.35);
    box-shadow: 0 20px 50px rgba(0,0,0,0.4);
  }
  .vt-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .vt-frame iframe {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    border: 0; display: block;
  }
  .vt-body { padding: 1.1rem 1.25rem 1.4rem; }
  .vt-name {
    margin: 0 0 .4rem;
    font-size: 1.05rem; font-weight: 600; color: #fff; letter-spacing: -0.005em;
  }
  .vt-summary {
    margin: 0;
    font-size: 13.5px; line-height: 1.55; color: rgba(255,255,255,0.65);
  }
  .vt-summary .lang-only-en {
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* ===== Google profile band ===== */
  .gr-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 2.5rem;
    color: rgba(255,255,255,0.55);
    font-size: 13px;
  }
</style>

<main>

  <!-- ============================================================
       HERO — Compact
       ============================================================ -->
  <section class="hero is-compact" data-screen-label="01 Testimonials Hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/bg-video-poster.jpg">
      <source src="/videos/bg-video.mp4" type="video/mp4">
    </video>
    <div class="hero-inner">
      <div class="eyebrow" style="margin-bottom: 18px;">
        <span class="lang-only-en">Real clients · Real results</span>
        <span class="lang-only-es">Clientes Reales · Resultados Reales</span>
      </div>
      <h1>
        <span class="lang-only-en">What Our Clients Say</span>
        <span class="lang-only-es">Lo Que Dicen Nuestros Clientes</span>
      </h1>
      <p>
        <span class="lang-only-en">Hear directly from South Florida business owners we've worked with — on camera, in their own words.</span>
        <span class="lang-only-es">Escucha directamente a los dueños de negocios del Sur de Florida con quienes hemos trabajado — frente a cámara, en sus propias palabras.</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       VIDEO TESTIMONIALS (inside .green-bg)
       ============================================================ -->
  <div class="green-bg">
    <img class="figure f1" src="/images/figure-bg-3.svg" alt="" aria-hidden="true">
    <img class="figure f2" src="/images/figure-bg-2.svg" alt="" aria-hidden="true">
    <img class="figure f3" src="/images/figure-bg-1.svg" alt="" aria-hidden="true">

    <section id="video-testimonials" class="section section--band vt-section" data-screen-label="02 Video Testimonials">
      <div class="container">
        <div class="section-head" data-reveal>
          <div class="eyebrow"><span class="lang-only-en">In their words</span><span class="lang-only-es">En sus palabras</span></div>
          <h2><span class="lang-only-en">Trusted by Businesses Across South Florida</span><span class="lang-only-es">La Confianza de Negocios en Todo el Sur de Florida</span></h2>
          <p><span class="lang-only-en">Real South Florida business owners on what it was like to work with SENAVIA — web design, e-commerce, and custom app clients across Miami-Dade, Broward, and Palm Beach.</span><span class="lang-only-es">Dueños de negocios reales del Sur de Florida sobre cómo fue trabajar con SENAVIA — clientes de diseño web, e-commerce y aplicaciones a la medida en Miami-Dade, Broward y Palm Beach.</span></p>
        </div>

        {videos.length > 0 ? (
        <div class="vt-grid" data-reveal-children>
          {videos.map((v) => (
            <article class="vt-card">
              <div class="vt-frame">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${v.data.youtubeId}?rel=0`}
                  title={v.data.name}
                  loading="lazy"
                  allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
              <div class="vt-body">
                <h3 class="vt-name">{v.data.name}</h3>
                {v.data.summary && (
                  <p class="vt-summary">
                    <span class="lang-only-en">{v.data.summary}</span>
                    <span class="lang-only-es">Testimonio en video (en inglés).</span>
                  </p>
                )}
              </div>
            </article>
          ))}
        </div>
        ) : (
        <p data-reveal>
          <span class="lang-only-en">New client stories are on the way — in the meantime, explore our work in the <a href="/portfolio">portfolio</a>.</span>
          <span class="lang-only-es">Pronto publicaremos nuevas historias de clientes — mientras tanto, explora nuestro trabajo en el <a href="/portfolio">portafolio</a>.</span>
        </p>
        )}

        <div class="gr-footer" data-reveal>
          <span class="lang-only-en">You can also find SENAVIA Corp on Google.</span>
          <span class="lang-only-es">También puedes encontrar a SENAVIA Corp en Google.</span>
          <a href="https://www.google.com/search?q=senavia+corp+plantation+reviews" target="_blank" rel="noopener" class="btn is-secondary is-sm" style="margin-left: 14px;">
            <span class="lang-only-en">Find Us on Google</span>
            <span class="lang-only-es">Encuéntranos en Google</span>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta cta--glow" data-screen-label="03 CTA">
    <video class="cta-video" autoplay muted loop playsinline preload="metadata"
           disablepictureinpicture disableremoteplayback
           controlslist="nodownload nofullscreen noremoteplayback"
           poster="/videos/cta-bg-poster.jpg">
      <source src="/videos/cta-bg.mp4" type="video/mp4">
    </video>
    <div class="container">
      <h2>
        <span class="lang-only-en">Want to Be Our Next Success Story?</span>
        <span class="lang-only-es">¿Quieres Ser Nuestra Próxima Historia de Éxito?</span>
      </h2>
      <p>
        <span class="lang-only-en">Schedule a 30-minute consultation and let's plan a digital strategy worth talking about.</span>
        <span class="lang-only-es">Agenda una consulta de 30 minutos y planeemos una estrategia digital de la que valga la pena hablar.</span>
      </p>
      <a href="#" class="btn" data-calendly-trigger data-track="book_call_click">
        <span class="lang-only-en">Book a Free Call</span>
        <span class="lang-only-es">Agenda una Llamada Gratis</span>
      </a>
      <a href="tel:+17542623659" class="btn is-call">(754) 262-3659</a>
    </div>
  </section>

</main>
</BaseLayout>
